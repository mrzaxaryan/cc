@inject MessageService Msg
@implements IDisposable

<div class="toast-container">
    @foreach (var toast in Msg.Messages)
    {
        var t = toast;
        <div class="toast-item toast-@t.Type.ToString().ToLower()" @key="t.Id">
            <span class="toast-text">@t.Text</span>
            <button class="toast-dismiss" @onclick="() => Msg.Dismiss(t.Id)">&times;</button>
        </div>
    }
</div>

@code {
    private readonly Dictionary<int, Timer> _timers = new();

    protected override void OnInitialized()
    {
        Msg.OnChanged += OnChanged;
    }

    private void OnChanged()
    {
        // Schedule auto-dismiss for new messages
        foreach (var toast in Msg.Messages)
        {
            if (!_timers.ContainsKey(toast.Id) && toast.DurationMs > 0)
            {
                var id = toast.Id;
                _timers[id] = new Timer(_ =>
                {
                    InvokeAsync(() =>
                    {
                        Msg.Dismiss(id);
                        _timers.Remove(id);
                        StateHasChanged();
                    });
                }, null, toast.DurationMs, Timeout.Infinite);
            }
        }

        // Cleanup timers for dismissed messages
        var activeIds = Msg.Messages.Select(m => m.Id).ToHashSet();
        foreach (var id in _timers.Keys.Where(k => !activeIds.Contains(k)).ToList())
        {
            _timers[id].Dispose();
            _timers.Remove(id);
        }

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Msg.OnChanged -= OnChanged;
        foreach (var timer in _timers.Values)
            timer.Dispose();
        _timers.Clear();
    }
}
