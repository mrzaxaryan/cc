@inject DownloadStore Downloads
@inject AgentStore AgentDb
@inject RelayStore RelayDb
@inject CacheManager Cache
@inject VfsStore Vfs
@inject MessageService Msg
@inject WindowManager Wm
@implements IDisposable

<div>
    <div class="d-flex align-items-center gap-2 mb-2">
        <span class="badge bg-primary">Downloads</span>
        <small class="text-muted">@activeRecords.Count active</small>
        <button class="btn btn-outline-secondary btn-sm py-0 px-1 ms-auto" @onclick="Refresh" title="Refresh">&#x21bb;</button>
        @if (activeRecords.Count > 0)
        {
            @if (confirmClear)
            {
                <button class="btn btn-danger btn-sm py-0 px-1" @onclick="ClearPaused">YES</button>
                <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => confirmClear = false">NO</button>
            }
            else
            {
                <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => confirmClear = true" title="Clear paused">CLEAR</button>
            }
        }
    </div>

    @if (activeRecords.Count == 0)
    {
        <div class="text-muted small text-center py-4">
            <em>No active downloads</em>
        </div>
    }
    else
    {
        <div style="max-height:60vh;overflow-y:auto;">
            @foreach (var group in groupedRecords)
            {
                <div class="card mb-2">
                    <div class="card-header py-1 d-flex align-items-center gap-1">
                        <small class="fw-bold text-truncate">@group.AgentName</small>
                        <small class="text-muted ms-auto" style="font-size:0.65rem">@group.Records.Count file(s)</small>
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var dl in group.Records)
                        {
                            var rec = dl;
                            var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                            <div class="list-group-item py-1 small">
                                <div class="d-flex align-items-center gap-1">
                                    <span class="flex-shrink-0" style="width:1.2em;text-align:center;">&#x1f4c4;</span>
                                    <span class="flex-grow-1 text-truncate font-monospace" title="@dl.RemotePath">@dl.FileName</span>
                                    @if (dl.Status == DownloadStatus.Downloading)
                                    {
                                        <span class="spinner-border spinner-border-sm flex-shrink-0" style="width:0.8rem;height:0.8rem;"></span>
                                        <span class="badge bg-info text-dark py-0 flex-shrink-0" style="font-size:0.6rem">@pct%</span>
                                        <button class="btn btn-outline-warning btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem"
                                                @onclick="() => PauseDownload(rec)" title="Pause">&#x23F8;</button>
                                    }
                                    else if (dl.Status == DownloadStatus.Paused)
                                    {
                                        <span class="badge bg-warning text-dark py-0 flex-shrink-0" style="font-size:0.6rem">PAUSED @pct%</span>
                                        <button class="btn btn-outline-success btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem"
                                                @onclick="() => ResumeDownload(rec)" disabled="@(_resuming.Contains(rec.Id))" title="Resume">&#x25B6;</button>
                                    }
                                    <button class="btn btn-outline-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem"
                                            @onclick="() => RemoveDownload(rec)" title="Remove">&#x2717;</button>
                                </div>
                                <div class="progress mt-1" style="height:4px;">
                                    <div class="progress-bar @(dl.Status == DownloadStatus.Paused ? "bg-warning" : "bg-info")"
                                         role="progressbar"
                                         style="width:@(pct)%"
                                         aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-1" style="font-size:0.6rem;">
                                    <span class="text-muted">@Formatters.FormatSize((ulong)dl.DownloadedSize) / @Formatters.FormatSize((ulong)dl.TotalSize)</span>
                                    <span class="text-muted text-truncate ms-2" title="@dl.RemotePath">@dl.RemotePath</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<DownloadRecord> activeRecords = new();
    private List<AgentGroup> groupedRecords = new();
    private bool confirmClear;
    private readonly HashSet<int> _resuming = new();

    private class AgentGroup
    {
        public string AgentUuid { get; init; } = "";
        public string AgentName { get; init; } = "";
        public List<DownloadRecord> Records { get; init; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        Downloads.OnChanged += OnDownloadsChanged;
        await Downloads.LoadAsync();
        Refresh();
    }

    private void OnDownloadsChanged()
    {
        _ = InvokeAsync(() =>
        {
            Refresh();
            StateHasChanged();
        });
    }

    private void Refresh()
    {
        activeRecords = Downloads.GetActive();
        groupedRecords = activeRecords
            .GroupBy(r => r.AgentUuid)
            .Select(g => new AgentGroup
            {
                AgentUuid = g.Key,
                AgentName = ResolveAgentName(g.Key),
                Records = g.OrderBy(r => r.Status == DownloadStatus.Downloading ? 0 : 1)
                           .ThenBy(r => r.FileName)
                           .ToList()
            })
            .OrderBy(g => g.AgentName)
            .ToList();
    }

    private string ResolveAgentName(string agentUuid)
    {
        var agent = AgentDb.Agents.Values.FirstOrDefault(a => a.Uuid == agentUuid);
        return agent?.Name ?? agentUuid;
    }

    private void PauseDownload(DownloadRecord dl)
    {
        Downloads.CancelCts(dl.Id);
    }

    private async Task ResumeDownload(DownloadRecord dl)
    {
        if (_resuming.Contains(dl.Id)) return;
        _resuming.Add(dl.Id);
        StateHasChanged();

        RelaySocket? relay = null;
        try
        {
            // Find agent info to get relay URL
            var agent = AgentDb.GetByUuid(dl.AgentUuid);
            if (agent is null) { Msg.Error("Agent not found"); return; }

            var relayEntry = !string.IsNullOrEmpty(agent.RelayStoreId) ? RelayDb.GetById(agent.RelayStoreId) : null;
            var relayUrl = relayEntry?.Url;
            if (string.IsNullOrEmpty(relayUrl)) { Msg.Error("No relay URL for agent"); return; }

            // Reuse existing relay from any open window for this agent
            var existingWin = Wm.Windows.FirstOrDefault(w => w.AgentId == agent.AgentId && w.Relay is { IsConnected: true });
            if (existingWin?.Relay is not null)
            {
                relay = existingWin.Relay;
            }
            else
            {
                relay = new RelaySocket { BaseUrl = relayUrl };
                await relay.Connect(agent.AgentId);
            }

            // Set up cancellation via shared store
            var cts = Downloads.RegisterCts(dl.Id);

            try
            {
                var success = await Cache.DownloadFromAgentAsync(
                    relay, dl.RemotePath, dl.CacheSubPath,
                    dl.DownloadedSize, cts.Token,
                    async (downloaded, _) =>
                    {
                        await Downloads.UpdateProgressAsync(dl.Id, downloaded);
                    });

                if (success)
                    await Downloads.CompleteAsync(dl.Id);
                else
                    await Downloads.FailAsync(dl.Id, "Download returned failure");
            }
            catch (OperationCanceledException)
            {
                await Downloads.PauseAsync(dl.Id);
            }
            catch (Exception ex)
            {
                if (cts.IsCancellationRequested)
                    await Downloads.PauseAsync(dl.Id);
                else
                {
                    await Downloads.FailAsync(dl.Id, ex.Message);
                    Msg.Error($"Download failed: {ex.Message}");
                }
            }
            finally
            {
                Downloads.RemoveCts(dl.Id);
            }
        }
        catch (Exception ex)
        {
            Msg.Error($"Resume failed: {ex.Message}");
        }
        finally
        {
            // Disconnect relay only if we created it (not reused from a window)
            if (relay is not null && !Wm.Windows.Any(w => w.Relay == relay))
                await relay.Disconnect();

            _resuming.Remove(dl.Id);
            StateHasChanged();
        }
    }

    private async Task RemoveDownload(DownloadRecord dl)
    {
        Downloads.CancelCts(dl.Id);
        await Downloads.RemoveAsync(dl.Id);
    }

    private async Task ClearPaused()
    {
        confirmClear = false;
        var toRemove = activeRecords.Where(r => r.Status == DownloadStatus.Paused).ToList();
        foreach (var dl in toRemove)
            await Downloads.RemoveAsync(dl.Id);
    }

    public void Dispose()
    {
        Downloads.OnChanged -= OnDownloadsChanged;
    }
}
