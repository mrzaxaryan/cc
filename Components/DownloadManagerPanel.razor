@inject DownloadStore Downloads
@inject AgentStore AgentDb
@inject RelayStore RelayDb
@inject RelayConnectionService RelaySvc
@inject CacheManager Cache
@inject VfsStore Vfs
@inject MessageService Msg
@inject WindowManager Wm
@implements IDisposable

<div>
    <div class="d-flex align-items-center gap-2 mb-2">
        <span class="badge bg-primary">Sync Manager</span>
        @if (!string.IsNullOrEmpty(AgentName))
        {
            <small class="fw-bold text-truncate">@AgentName</small>
        }
        <small class="text-muted">@activeRecords.Count active</small>
        <div class="d-flex gap-1 ms-auto">
            @if (HasActiveSyncs)
            {
                <button class="btn btn-outline-danger btn-sm btn-tiny2" @onclick="StopAllSyncs" title="Pause all syncs">STOP ALL</button>
            }
            @if (activeRecords.Count > 0)
            {
                @if (confirmClear)
                {
                    <button class="btn btn-danger btn-sm py-0 px-1" @onclick="ClearPaused">YES</button>
                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => confirmClear = false">NO</button>
                }
                else
                {
                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => confirmClear = true" title="Clear paused">CLEAR</button>
                }
            }
            <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="Refresh" title="Refresh">&#x21bb;</button>
        </div>
    </div>

    @if (activeRecords.Count == 0)
    {
        <div class="text-muted small text-center py-4">
            <em>No active syncs</em>
        </div>
    }
    else
    {
        <div class="scrollable-list-lg">
            @foreach (var dl in activeRecords)
            {
                var rec = dl;
                var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <div class="list-group-item py-1 small">
                    <div class="d-flex align-items-center gap-1">
                        <span class="entry-icon">&#x1f4c4;</span>
                        <span class="flex-grow-1 text-truncate font-monospace" title="@dl.RemotePath">@dl.FileName</span>
                        @if (dl.Status == DownloadStatus.Downloading)
                        {
                            <span class="spinner-border spinner-border-sm flex-shrink-0 dl-spinner"></span>
                            <span class="badge bg-info text-dark py-0 flex-shrink-0 text-xs">@pct%</span>
                            @if (dl.SpeedBytesPerSec > 0)
                            {
                                <span class="text-muted flex-shrink-0 text-xs">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                            }
                            <button class="btn btn-outline-warning btn-sm btn-tiny flex-shrink-0"
                                    @onclick="() => PauseDownload(rec)" title="Pause">&#x23F8;</button>
                        }
                        else if (dl.Status == DownloadStatus.Queued)
                        {
                            <span class="badge bg-secondary py-0 flex-shrink-0 text-xs">QUEUED</span>
                            <button class="btn btn-outline-warning btn-sm btn-tiny flex-shrink-0"
                                    @onclick="() => BumpPriority(rec, -1)" title="Higher priority">&#x25B2;</button>
                            <button class="btn btn-outline-secondary btn-sm btn-tiny flex-shrink-0"
                                    @onclick="() => BumpPriority(rec, 1)" title="Lower priority">&#x25BC;</button>
                        }
                        else if (dl.Status == DownloadStatus.Paused)
                        {
                            <span class="badge bg-warning text-dark py-0 flex-shrink-0 text-xs">PAUSED @pct%</span>
                            <button class="btn btn-outline-success btn-sm btn-tiny flex-shrink-0"
                                    @onclick="() => ResumeDownload(rec)" disabled="@(_resuming.Contains(rec.Id))" title="Resume">&#x25B6;</button>
                        }
                        <button class="btn btn-outline-danger btn-sm btn-tiny flex-shrink-0"
                                @onclick="() => RemoveDownload(rec)" title="Remove">&#x2717;</button>
                    </div>
                    <div class="progress mt-1 progress-thin">
                        <div class="progress-bar @(dl.Status == DownloadStatus.Paused ? "bg-warning" : dl.Status == DownloadStatus.Queued ? "bg-secondary" : "bg-info")"
                             role="progressbar"
                             style="width:@(pct)%"
                             aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-1 dl-meta">
                        <span class="text-muted">@Formatters.FormatSize((ulong)dl.DownloadedSize) / @Formatters.FormatSize((ulong)dl.TotalSize)</span>
                        <span class="text-muted text-truncate ms-2" title="@dl.RemotePath">@dl.RemotePath</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? AgentUuid { get; set; }
    [Parameter] public string? AgentName { get; set; }

    private List<DownloadRecord> activeRecords = new();
    private bool confirmClear;
    private readonly HashSet<int> _resuming = new();

    protected override async Task OnInitializedAsync()
    {
        Downloads.OnChanged += OnDownloadsChanged;
        await AgentDb.LoadAsync();
        await RelayDb.LoadAsync();
        await Downloads.LoadAsync();
        Refresh();
    }

    private void OnDownloadsChanged()
    {
        _ = InvokeAsync(() =>
        {
            Refresh();
            StateHasChanged();
        });
    }

    private bool HasActiveSyncs =>
        activeRecords.Any(r => r.Status is DownloadStatus.Downloading or DownloadStatus.Queued);

    private async Task StopAllSyncs()
    {
        var active = activeRecords.FirstOrDefault(r => r.Status == DownloadStatus.Downloading);
        if (active is not null)
            Downloads.CancelCts(active.Id);
        var queued = activeRecords.Where(r => r.Status == DownloadStatus.Queued).ToList();
        foreach (var dl in queued)
            await Downloads.PauseAsync(dl.Id);
    }

    private void Refresh()
    {
        var all = Downloads.GetActive();
        activeRecords = string.IsNullOrEmpty(AgentUuid)
            ? all
            : all.Where(r => r.AgentUuid == AgentUuid).ToList();
        activeRecords = activeRecords
            .OrderBy(r => r.Status == DownloadStatus.Downloading ? 0 : r.Status == DownloadStatus.Queued ? 1 : 2)
            .ThenBy(r => r.Priority)
            .ThenBy(r => r.CreatedAt)
            .ToList();
    }

    private async Task BumpPriority(DownloadRecord dl, int delta)
    {
        await Downloads.SetPriorityAsync(dl.Id, dl.Priority + delta);
    }

    private void PauseDownload(DownloadRecord dl)
    {
        Downloads.CancelCts(dl.Id);
    }

    private async Task ResumeDownload(DownloadRecord dl)
    {
        if (_resuming.Contains(dl.Id)) return;
        if (Downloads.HasActiveCts(dl.Id)) return;
        _resuming.Add(dl.Id);
        StateHasChanged();

        RelaySocket? relay = null;
        try
        {
            await AgentDb.LoadAsync();
            await RelayDb.LoadAsync();

            var agent = AgentDb.GetByUuid(dl.AgentUuid);
            if (agent is null) { Msg.Error("Agent not found"); return; }

            var relayEntry = !string.IsNullOrEmpty(agent.RelayStoreId) ? RelayDb.GetById(agent.RelayStoreId) : null;
            var relayUrl = relayEntry?.Url;
            if (string.IsNullOrEmpty(relayUrl)) { Msg.Error("No relay URL for agent"); return; }

            relay = await RelaySvc.CreateRelay(agent.AgentId, relayUrl);
            if (relay is null) return;

            var cts = Downloads.RegisterCts(dl.Id);

            try
            {
                var success = await Cache.DownloadFromAgentAsync(
                    relay, dl.RemotePath, dl.CacheSubPath,
                    dl.DownloadedSize, cts.Token,
                    async (downloaded, _) =>
                    {
                        await Downloads.UpdateProgressAsync(dl.Id, downloaded);
                    });

                if (success)
                    await Downloads.CompleteAsync(dl.Id);
                else
                    await Downloads.FailAsync(dl.Id, "Sync returned failure");
            }
            catch (OperationCanceledException)
            {
                await Downloads.PauseAsync(dl.Id);
            }
            catch (Exception ex)
            {
                if (cts.IsCancellationRequested)
                    await Downloads.PauseAsync(dl.Id);
                else
                {
                    await Downloads.FailAsync(dl.Id, ex.Message);
                    Msg.Error($"Sync failed: {ex.Message}");
                }
            }
            finally
            {
                Downloads.RemoveCts(dl.Id);
            }
        }
        catch (Exception ex)
        {
            Msg.Error($"Resume failed: {ex.Message}");
        }
        finally
        {
            if (relay is not null && !Wm.Windows.Any(w => w.Relay == relay))
                await relay.Disconnect();

            _resuming.Remove(dl.Id);
            StateHasChanged();
        }
    }

    private async Task RemoveDownload(DownloadRecord dl)
    {
        Downloads.CancelCts(dl.Id);
        await Downloads.RemoveAsync(dl.Id);
    }

    private async Task ClearPaused()
    {
        confirmClear = false;
        var toRemove = activeRecords.Where(r => r.Status == DownloadStatus.Paused).ToList();
        foreach (var dl in toRemove)
            await Downloads.RemoveAsync(dl.Id);
    }

    public void Dispose()
    {
        Downloads.OnChanged -= OnDownloadsChanged;
    }
}
