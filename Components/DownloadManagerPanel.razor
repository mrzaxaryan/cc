@inject DownloadStore Downloads
@inject AgentStore AgentDb
@inject MessageService Msg
@implements IDisposable

<div class="sm">
    @* Header *@
    <div class="sm-header">
        <div class="sm-header-left">
            <span class="sm-title">Sync Manager</span>
            @if (!string.IsNullOrEmpty(AgentName))
            {
                <span class="sm-agent">@AgentName</span>
            }
        </div>
        <div class="sm-header-right">
            @if (HasActiveSyncs)
            {
                <CcBtn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="StopAllSyncs" Title="Pause all">STOP ALL</CcBtn>
            }
            @if (activeRecords.Count > 0)
            {
                @if (confirmClear)
                {
                    <CcBtn Variant="BtnVariant.DangerSolid" Size="Size.Xs" OnClick="ClearPaused">YES</CcBtn>
                    <CcBtn Size="Size.Xs" OnClick="() => confirmClear = false">NO</CcBtn>
                }
                else
                {
                    <CcBtn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="() => confirmClear = true" Title="Clear paused/failed">CLEAR</CcBtn>
                }
            }
            <CcBtn Size="Size.Xs" OnClick="Refresh" Title="Refresh">&#x21bb;</CcBtn>
        </div>
    </div>

    @* Filter tabs *@
    <div class="sm-tabs">
        <button class="sm-tab @(filter == Filter.All ? "active" : "")" @onclick="() => SetFilter(Filter.All)">
            All <span class="sm-tab-count">@activeRecords.Count</span>
        </button>
        <button class="sm-tab @(filter == Filter.Active ? "active" : "")" @onclick="() => SetFilter(Filter.Active)">
            Active <span class="sm-tab-count">@CountByFilter(Filter.Active)</span>
        </button>
        <button class="sm-tab @(filter == Filter.Paused ? "active" : "")" @onclick="() => SetFilter(Filter.Paused)">
            Paused <span class="sm-tab-count">@CountByFilter(Filter.Paused)</span>
        </button>
        <button class="sm-tab @(filter == Filter.Done ? "active" : "")" @onclick="() => SetFilter(Filter.Done)">
            Done <span class="sm-tab-count">@CountByFilter(Filter.Done)</span>
        </button>
    </div>

    @* Records list *@
    @if (filteredRecords.Count == 0)
    {
        <div class="sm-empty">
            @if (activeRecords.Count == 0)
            {
                <span>No active syncs</span>
            }
            else
            {
                <span>No @filter.ToString().ToLower() items</span>
            }
        </div>
    }
    else
    {
        <div class="sm-list">
            @foreach (var dl in filteredRecords)
            {
                var rec = dl;
                var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <div class="sm-item @StatusClass(dl.Status)">
                    <div class="sm-item-row">
                        <span class="sm-item-icon">@StatusIcon(dl.Status)</span>
                        <div class="sm-item-info">
                            <span class="sm-item-name" title="@dl.RemotePath">@dl.FileName</span>
                            <span class="sm-item-meta">
                                @Formatters.FormatSize((ulong)dl.DownloadedSize) / @Formatters.FormatSize((ulong)dl.TotalSize)
                                @if (!string.IsNullOrEmpty(dl.AgentName) && string.IsNullOrEmpty(AgentUuid))
                                {
                                    <span class="sm-item-agent">@dl.AgentName</span>
                                }
                            </span>
                        </div>
                        <div class="sm-item-status">
                            @switch (dl.Status)
                            {
                                case DownloadStatus.Downloading:
                                    <span class="sm-pct">@pct%</span>
                                    @if (dl.SpeedBytesPerSec > 0)
                                    {
                                        <span class="sm-speed">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                                    }
                                    <CcBtn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseDownload(rec)" Title="Pause">&#x23F8;</CcBtn>
                                    break;

                                case DownloadStatus.Queued:
                                    <CcBadge Variant="BadgeVariant.Muted" Size="Size.Xs">QUEUED</CcBadge>
                                    <CcBtn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => BumpPriority(rec, -1)" Title="Higher priority">&#x25B2;</CcBtn>
                                    <CcBtn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => BumpPriority(rec, 1)" Title="Lower priority">&#x25BC;</CcBtn>
                                    break;

                                case DownloadStatus.Paused:
                                    <CcBadge Variant="BadgeVariant.Warning" Size="Size.Xs">PAUSED @pct%</CcBadge>
                                    <CcBtn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeDownload(rec)" Disabled="@(Downloads.HasActiveCts(rec.Id))" Title="Resume">&#x25B6;</CcBtn>
                                    break;

                                case DownloadStatus.Completed:
                                    <CcBadge Variant="BadgeVariant.Success" Size="Size.Xs">DONE</CcBadge>
                                    break;

                                case DownloadStatus.Failed:
                                    <CcBadge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@dl.Error">FAILED</CcBadge>
                                    break;
                            }
                            <CcBtn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => RemoveDownload(rec)" Title="Remove" CssClass="sm-remove-btn">&#x2715;</CcBtn>
                        </div>
                    </div>
                    @if (dl.Status is DownloadStatus.Downloading or DownloadStatus.Queued or DownloadStatus.Paused)
                    {
                        <CcProgress Size="Size.Xs" Variant="@ProgressVariant(dl.Status)" Percent="@pct" />
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? AgentUuid { get; set; }
    [Parameter] public string? AgentName { get; set; }

    private enum Filter { All, Active, Paused, Done }

    private List<DownloadRecord> activeRecords = new();
    private List<DownloadRecord> filteredRecords = new();
    private Filter filter = Filter.All;
    private bool confirmClear;

    protected override async Task OnInitializedAsync()
    {
        Downloads.OnChanged += OnDownloadsChanged;
        await AgentDb.LoadAsync();
        await Downloads.LoadAsync();
        Refresh();
    }

    private void OnDownloadsChanged()
    {
        _ = InvokeAsync(() =>
        {
            Refresh();
            StateHasChanged();
        });
    }

    private bool HasActiveSyncs =>
        activeRecords.Any(r => r.Status is DownloadStatus.Downloading or DownloadStatus.Queued);

    private void SetFilter(Filter f) { filter = f; ApplyFilter(); }

    private void ApplyFilter()
    {
        filteredRecords = filter switch
        {
            Filter.Active => activeRecords.Where(r => r.Status is DownloadStatus.Downloading or DownloadStatus.Queued).ToList(),
            Filter.Paused => activeRecords.Where(r => r.Status is DownloadStatus.Paused or DownloadStatus.Failed).ToList(),
            Filter.Done => activeRecords.Where(r => r.Status == DownloadStatus.Completed).ToList(),
            _ => activeRecords.ToList()
        };
    }

    private int CountByFilter(Filter f) => f switch
    {
        Filter.Active => activeRecords.Count(r => r.Status is DownloadStatus.Downloading or DownloadStatus.Queued),
        Filter.Paused => activeRecords.Count(r => r.Status is DownloadStatus.Paused or DownloadStatus.Failed),
        Filter.Done => activeRecords.Count(r => r.Status == DownloadStatus.Completed),
        _ => activeRecords.Count
    };

    private static string StatusIcon(string s) => s switch
    {
        DownloadStatus.Downloading => "\u25CF",
        DownloadStatus.Queued => "\u25CB",
        DownloadStatus.Paused => "\u25A0",
        DownloadStatus.Completed => "\u2713",
        DownloadStatus.Failed => "\u2717",
        _ => "\u25CB"
    };

    private static string StatusClass(string s) => s switch
    {
        DownloadStatus.Downloading => "sm-item-active",
        DownloadStatus.Completed => "sm-item-done",
        DownloadStatus.Failed => "sm-item-failed",
        _ => ""
    };

    private static ProgressVariant ProgressVariant(string s) => s switch
    {
        DownloadStatus.Downloading => cc.Components.Shared.ProgressVariant.Info,
        DownloadStatus.Paused => cc.Components.Shared.ProgressVariant.Warning,
        _ => cc.Components.Shared.ProgressVariant.Muted
    };

    private async Task StopAllSyncs()
    {
        var active = activeRecords.FirstOrDefault(r => r.Status == DownloadStatus.Downloading);
        if (active is not null) Downloads.CancelCts(active.Id);
        var queued = activeRecords.Where(r => r.Status == DownloadStatus.Queued).ToList();
        foreach (var dl in queued) await Downloads.PauseAsync(dl.Id);
    }

    private void Refresh()
    {
        var all = Downloads.GetActive();
        activeRecords = string.IsNullOrEmpty(AgentUuid) ? all : all.Where(r => r.AgentUuid == AgentUuid).ToList();
        activeRecords = activeRecords
            .OrderBy(r => r.Status == DownloadStatus.Downloading ? 0 : r.Status == DownloadStatus.Queued ? 1 : r.Status == DownloadStatus.Paused ? 2 : r.Status == DownloadStatus.Failed ? 3 : 4)
            .ThenBy(r => r.Priority)
            .ThenBy(r => r.CreatedAt)
            .ToList();
        ApplyFilter();
    }

    private async Task BumpPriority(DownloadRecord dl, int delta) => await Downloads.SetPriorityAsync(dl.Id, dl.Priority + delta);
    private void PauseDownload(DownloadRecord dl) => Downloads.CancelCts(dl.Id);

    private async Task ResumeDownload(DownloadRecord dl)
    {
        if (Downloads.HasActiveCts(dl.Id)) return;
        await Downloads.QueueAsync(dl.Id);
    }

    private async Task RemoveDownload(DownloadRecord dl) { Downloads.CancelCts(dl.Id); await Downloads.RemoveAsync(dl.Id); }

    private async Task ClearPaused()
    {
        confirmClear = false;
        var toRemove = activeRecords.Where(r => r.Status is DownloadStatus.Paused or DownloadStatus.Failed).ToList();
        foreach (var dl in toRemove) await Downloads.RemoveAsync(dl.Id);
    }

    public void Dispose() => Downloads.OnChanged -= OnDownloadsChanged;
}
