@inject CacheManager Cache
@inject VfsStore Vfs
@inject AgentStore AgentDb
@inject DownloadStore Downloads
@inject MessageService Msg
@inject IJSRuntime Js
@implements IDisposable

<div class="cm">
    @* Tabs *@
    <div class="cm-tabs">
        <button class="cm-tab @(tab == Tab.Cache ? "active" : "")" @onclick="() => tab = Tab.Cache">Cache</button>
        <button class="cm-tab @(tab == Tab.IndexedDB ? "active" : "")" @onclick="() => { tab = Tab.IndexedDB; _ = LoadDbStats(); }">IndexedDB</button>
    </div>

    @if (tab == Tab.Cache)
    {
        @* Header *@
        <div class="cm-toolbar">
            <CcBadge Variant="BadgeVariant.Info">@(Cache.DirectoryName ?? "No folder")</CcBadge>
            <div class="cm-toolbar-actions">
                <CcBtn OnClick="Refresh" Disabled="@loading" Title="Refresh">&#x21bb;</CcBtn>
                @if (confirmPrune)
                {
                    <CcBtn Variant="BtnVariant.DangerSolid" OnClick="ConfirmPrune" Disabled="@loading">YES</CcBtn>
                    <CcBtn OnClick="() => confirmPrune = false">NO</CcBtn>
                }
                else
                {
                    <CcBtn Variant="BtnVariant.Danger" OnClick="() => confirmPrune = true" Disabled="@(loading || stats.fileCount == 0)" Title="Prune">PRUNE</CcBtn>
                }
                <CcBtn Variant="BtnVariant.Warning" OnClick="ChangeFolder" Title="Change folder">&#x1f4c1;</CcBtn>
            </div>
        </div>

        @* Stats *@
        <CcCard Compact CssClass="cm-stats-card">
            <div class="cm-stats">
                <div class="cm-stat">
                    <span class="cm-stat-value">@stats.agentCount</span>
                    <span class="cm-stat-label">Agents</span>
                </div>
                <div class="cm-stat">
                    <span class="cm-stat-value">@stats.dirCount</span>
                    <span class="cm-stat-label">Dirs</span>
                </div>
                <div class="cm-stat">
                    <span class="cm-stat-value">@stats.fileCount</span>
                    <span class="cm-stat-label">Files</span>
                </div>
                <div class="cm-stat">
                    <span class="cm-stat-value">@Formatters.FormatSize((ulong)stats.totalSize)</span>
                    <span class="cm-stat-label">Metadata</span>
                </div>
                <div class="cm-stat">
                    <span class="cm-stat-value">@Formatters.FormatSize((ulong)blobSize)</span>
                    <span class="cm-stat-label">On Disk</span>
                </div>
            </div>
        </CcCard>

        @* Breadcrumb *@
        @if (breadcrumbs.Count > 0)
        {
            <div class="cm-breadcrumb">
                <a href="javascript:void(0)" class="cm-crumb" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
                @{ var lastCrumb = breadcrumbs.LastOrDefault(); }
                @foreach (var crumb in breadcrumbs)
                {
                    <span class="cm-crumb-sep">/</span>
                    @if (crumb == lastCrumb)
                    {
                        <span class="cm-crumb-active">@crumb.Name</span>
                    }
                    else
                    {
                        <a href="javascript:void(0)" class="cm-crumb" @onclick="() => NavigateToDirectory(crumb.Id)" @onclick:preventDefault>@crumb.Name</a>
                    }
                }
            </div>
        }

        @* Content *@
        <div class="cm-list">
            @if (currentDirId == VfsStore.RootParentId && currentAgentUuid is null)
            {
                @* Agent list at root *@
                @if (loading)
                {
                    <div class="cm-list-loading"><CcSpinner /></div>
                }
                else if (agentStats.Count == 0)
                {
                    <div class="cm-empty"><em>No cached data</em></div>
                }
                else
                {
                    @foreach (var agent in agentStats)
                    {
                        <div class="cm-item">
                            <a href="javascript:void(0)" class="cm-item-name" @onclick="() => NavigateToAgent(agent.uuid)" @onclick:preventDefault>@agent.name</a>
                            <span class="cm-item-meta">@agent.dirs d / @agent.files f</span>
                            <span class="cm-item-meta">@Formatters.FormatSize((ulong)agent.size)</span>
                            <CcConfirmBtn OnConfirm="() => DeleteAgentCache(agent.uuid)" Title="Delete agent cache">DEL</CcConfirmBtn>
                        </div>
                    }
                }
            }
            else
            {
                @* Directory/file listing *@
                @if (loading)
                {
                    <div class="cm-list-loading"><CcSpinner /></div>
                }
                else
                {
                    <button class="cm-item cm-item-nav" @onclick="NavigateUp">
                        <span class="cm-item-icon">&#x2191;</span>
                        <span class="cm-item-name">..</span>
                    </button>
                    @foreach (var dir in childDirs)
                    {
                        <div class="cm-item">
                            <span class="cm-item-icon">&#x1f4c1;</span>
                            <a href="javascript:void(0)" class="cm-item-name" @onclick="() => NavigateToDirectory(dir.Id)" @onclick:preventDefault>@dir.Name</a>
                            <CcConfirmBtn OnConfirm="() => DeleteDir(dir)" Title="Delete">DEL</CcConfirmBtn>
                        </div>
                    }
                    @foreach (var file in childFiles)
                    {
                        <div class="cm-item">
                            <span class="cm-item-icon">&#x1f4c4;</span>
                            <span class="cm-item-name">@file.Name</span>
                            <span class="cm-item-meta">@Formatters.FormatSize((ulong)file.Size)</span>
                            <CcConfirmBtn OnConfirm="() => DeleteFile(file)" Title="Delete">DEL</CcConfirmBtn>
                        </div>
                    }
                    @if (childDirs.Count == 0 && childFiles.Count == 0)
                    {
                        <div class="cm-empty"><em>Empty</em></div>
                    }
                }
            }
        </div>
    }
    else if (tab == Tab.IndexedDB)
    {
        <div class="cm-db-section">
            <div class="cm-toolbar">
                <CcBadge Variant="BadgeVariant.Dark">cc-agents</CcBadge>
                <span class="cm-db-version">v4</span>
                <div class="cm-toolbar-actions">
                    <CcBtn OnClick="LoadDbStats" Disabled="@dbLoading" Title="Refresh">&#x21bb;</CcBtn>
                    @if (confirmClearAll)
                    {
                        <CcBtn Variant="BtnVariant.DangerSolid" OnClick="ClearAllData" Disabled="@clearingAll" Loading="@clearingAll">YES, DELETE ALL</CcBtn>
                        <CcBtn OnClick="() => confirmClearAll = false">NO</CcBtn>
                    }
                    else
                    {
                        <CcBtn Variant="BtnVariant.Danger" OnClick="() => confirmClearAll = true" Disabled="@dbLoading">CLEAR ALL</CcBtn>
                    }
                </div>
            </div>
            @if (dbLoading)
            {
                <div class="cm-list-loading"><CcSpinner /></div>
            }
            else
            {
                <CcTable Hover>
                    <thead>
                        <tr>
                            <th>Object Store</th>
                            <th>Key</th>
                            <th style="text-align:right">Records</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in dbTables)
                        {
                            <tr>
                                <td><code>@t.Name</code></td>
                                <td><code class="cm-db-key">@GetKeyPath(t.Name)</code></td>
                                <td style="text-align:right;font-weight:600">@t.Count</td>
                            </tr>
                        }
                    </tbody>
                </CcTable>
                @if (dbTables.Count > 0)
                {
                    <div class="cm-db-total">
                        Total: @dbTables.Sum(t => t.Count) records across @dbTables.Count stores
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private enum Tab { Cache, IndexedDB }
    private Tab tab = Tab.Cache;

    private string currentDirId = VfsStore.RootParentId;
    private string? currentAgentUuid;
    private List<(string uuid, string name, int dirs, int files, long size)> agentStats = new();
    private List<VfsDirectory> childDirs = new();
    private List<VfsFile> childFiles = new();
    private List<VfsDirectory> breadcrumbs = new();
    private (int agentCount, int dirCount, int fileCount, long totalSize) stats;
    private long blobSize;
    private bool loading;
    private bool confirmPrune;
    private bool confirmClearAll;
    private bool clearingAll;

    // IndexedDB tab
    private record DbTable(string Name, int Count);
    private List<DbTable> dbTables = new();
    private bool dbLoading;

    // Debounce
    private Timer? _debounceTimer;
    private bool _refreshing;

    protected override async Task OnInitializedAsync()
    {
        Cache.OnChanged += OnCacheChanged;
        Vfs.OnChanged += OnCacheChanged;
        await Refresh();
    }

    private void OnCacheChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            if (_refreshing) return;
            await InvokeAsync(Refresh);
        }, null, 300, Timeout.Infinite);
    }

    private async Task Refresh()
    {
        if (!Cache.HasDirectory || _refreshing) return;
        _refreshing = true;
        loading = true;
        StateHasChanged();

        try
        {
            blobSize = await Cache.GetCacheSizeAsync();
            var uuids = AgentDb.Agents.Values.Select(a => a.Uuid).ToList();
            stats = await Vfs.GetGlobalStatsAsync(uuids);

            if (currentDirId == VfsStore.RootParentId && currentAgentUuid is null)
            {
                agentStats = new();
                foreach (var agent in AgentDb.Agents.Values)
                {
                    var (d, f, s) = await Vfs.GetAgentStatsAsync(agent.Uuid);
                    if (d > 0 || f > 0)
                        agentStats.Add((agent.Uuid, agent.Name, d, f, s));
                }
                childDirs = new();
                childFiles = new();
            }
            else if (currentAgentUuid is not null)
            {
                childDirs = await Vfs.GetChildDirectoriesAsync(currentAgentUuid, currentDirId);
                childFiles = await Vfs.GetFilesInDirectoryAsync(currentAgentUuid, currentDirId);
            }
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            loading = false;
            _refreshing = false;
            StateHasChanged();
        }
    }

    private async Task NavigateToRoot()
    {
        currentDirId = VfsStore.RootParentId;
        currentAgentUuid = null;
        breadcrumbs = new();
        await Refresh();
    }

    private async Task NavigateToAgent(string agentUuid)
    {
        currentAgentUuid = agentUuid;
        currentDirId = VfsStore.RootParentId;
        breadcrumbs = new() { MakeAgentCrumb() };
        await Refresh();
    }

    private async Task NavigateToDirectory(string dirId)
    {
        currentDirId = dirId;
        await RebuildBreadcrumbs();
        await Refresh();
    }

    private async Task NavigateUp()
    {
        if (breadcrumbs.Count <= 1)
        {
            await NavigateToRoot();
            return;
        }
        var parent = breadcrumbs[^2];
        breadcrumbs.RemoveAt(breadcrumbs.Count - 1);
        currentDirId = parent.Id;
        await Refresh();
    }

    private async Task RebuildBreadcrumbs()
    {
        var crumbs = new List<VfsDirectory>();
        var id = currentDirId;
        while (id != VfsStore.RootParentId)
        {
            var dir = await Vfs.GetDirectoryAsync(id);
            if (dir is null) break;
            crumbs.Insert(0, dir);
            id = dir.ParentId;
        }
        if (currentAgentUuid is not null)
            crumbs.Insert(0, MakeAgentCrumb());
        breadcrumbs = crumbs;
    }

    private async Task DeleteDir(VfsDirectory dir)
    {
        try
        {
            await Vfs.RemoveDirectoryAsync(dir.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private async Task DeleteFile(VfsFile file)
    {
        try
        {
            await Vfs.RemoveFileAsync(file.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private async Task DeleteAgentCache(string agentUuid)
    {
        try
        {
            loading = true;
            StateHasChanged();
            await Vfs.ClearAgentAsync(agentUuid);
            foreach (var dl in Downloads.GetByAgent(agentUuid))
                await Downloads.RemoveAsync(dl.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task ConfirmPrune()
    {
        confirmPrune = false;
        try
        {
            loading = true;
            StateHasChanged();
            foreach (var agent in AgentDb.Agents.Values)
                await Vfs.ClearAgentAsync(agent.Uuid);
            await Downloads.ClearAsync();
            await NavigateToRoot();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task ChangeFolder()
    {
        try
        {
            await Cache.PickDirectoryAsync();
            await NavigateToRoot();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private VfsDirectory MakeAgentCrumb()
    {
        var name = AgentDb.Agents.Values.FirstOrDefault(a => a.Uuid == currentAgentUuid)?.Name ?? currentAgentUuid!;
        return new VfsDirectory { Id = VfsStore.RootParentId, Name = name };
    }

    // IndexedDB

    private async Task ClearAllData()
    {
        clearingAll = true;
        confirmClearAll = false;
        StateHasChanged();
        try
        {
            await Cache.ClearAllDataAsync();
            dbTables = new();
            agentStats = new();
            stats = default;
            blobSize = 0;
            Msg.Success("All application data cleared.");
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { clearingAll = false; StateHasChanged(); }
    }

    private async Task LoadDbStats()
    {
        dbLoading = true;
        StateHasChanged();
        try
        {
            var results = await Js.InvokeAsync<DbTableResult[]>("ccDbInfo.getTableStats");
            dbTables = results.Select(r => new DbTable(r.Name, r.Count)).ToList();
        }
        catch (Exception ex) { Msg.Error($"Failed to read IndexedDB: {ex.Message}"); }
        finally { dbLoading = false; StateHasChanged(); }
    }

    private record DbTableResult(string Name, int Count);

    private static string GetKeyPath(string store) => store switch
    {
        "agents" => "uuid",
        "relays" => "url",
        "downloads" => "id (auto)",
        "directories" => "id",
        "files" => "id",
        _ => "—"
    };

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        Cache.OnChanged -= OnCacheChanged;
        Vfs.OnChanged -= OnCacheChanged;
    }
}
