@inject CacheManager Cache
@inject VfsStore Vfs
@inject AgentStore AgentDb
@inject DownloadStore Downloads
@inject MessageService Msg
@implements IDisposable

<div>
    @* Header *@
    <div class="d-flex align-items-center gap-2 mb-2">
        <span class="badge bg-primary">@(Cache.DirectoryName ?? "No folder")</span>
        <button class="btn btn-outline-secondary btn-sm py-0 px-1 ms-auto" @onclick="Refresh" disabled="@loading" title="Refresh">&#x21bb;</button>
        @if (confirmPrune)
        {
            <button class="btn btn-danger btn-sm py-0 px-1" @onclick="ConfirmPrune" disabled="@loading">YES</button>
            <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => confirmPrune = false">NO</button>
        }
        else
        {
            <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => confirmPrune = true" disabled="@(loading || stats.fileCount == 0)" title="Prune file system">PRUNE</button>
        }
        <button class="btn btn-outline-warning btn-sm py-0 px-1" @onclick="ChangeFolder" title="Change folder">&#x1f4c1;</button>
    </div>

    @* Global stats *@
    <div class="card mb-2">
        <div class="card-body p-2">
            <div class="row text-center small">
                <div class="col">
                    <div class="fw-bold">@stats.agentCount</div>
                    <div class="text-muted" style="font-size:0.7rem">Agents</div>
                </div>
                <div class="col">
                    <div class="fw-bold">@stats.dirCount</div>
                    <div class="text-muted" style="font-size:0.7rem">Dirs</div>
                </div>
                <div class="col">
                    <div class="fw-bold">@stats.fileCount</div>
                    <div class="text-muted" style="font-size:0.7rem">Files</div>
                </div>
                <div class="col">
                    <div class="fw-bold">@Formatters.FormatSize((ulong)stats.totalSize)</div>
                    <div class="text-muted" style="font-size:0.7rem">Metadata</div>
                </div>
                <div class="col">
                    <div class="fw-bold">@Formatters.FormatSize((ulong)blobSize)</div>
                    <div class="text-muted" style="font-size:0.7rem">On Disk</div>
                </div>
            </div>
        </div>
    </div>

    @* Breadcrumb *@
    @if (breadcrumbs.Count > 0)
    {
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a href="javascript:void(0)" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
                </li>
                @{ var lastCrumb = breadcrumbs.LastOrDefault(); }
                @foreach (var crumb in breadcrumbs)
                {
                    if (crumb == lastCrumb)
                    {
                        <li class="breadcrumb-item active">@crumb.Name</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item">
                            <a href="javascript:void(0)" @onclick="() => NavigateToDirectory(crumb.Id)" @onclick:preventDefault>@crumb.Name</a>
                        </li>
                    }
                }
            </ol>
        </nav>
    }

    @* Agent list at root *@
    @if (currentDirId == VfsStore.RootParentId && currentAgentUuid is null)
    {
        <div class="list-group list-group-flush" style="max-height:50vh;overflow-y:auto;">
            @if (loading)
            {
                <div class="list-group-item text-center py-3">
                    <span class="spinner-border spinner-border-sm"></span>
                </div>
            }
            else
            {
                @foreach (var agent in agentStats)
                {
                    <div class="list-group-item py-1 small d-flex align-items-center gap-1">
                        <a href="javascript:void(0)" class="flex-grow-1 text-truncate font-monospace" @onclick="() => NavigateToAgent(agent.uuid)" @onclick:preventDefault>@agent.name</a>
                        <small class="text-muted flex-shrink-0" style="font-size:0.65rem">@agent.dirs d / @agent.files f</small>
                        <small class="text-muted flex-shrink-0" style="font-size:0.65rem">@Formatters.FormatSize((ulong)agent.size)</small>
                        @if (confirmDeleteId == agent.uuid)
                        {
                            <button class="btn btn-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => DeleteAgentCache(agent.uuid)">YES</button>
                            <button class="btn btn-outline-secondary btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => confirmDeleteId = null">NO</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem"
                                    @onclick="() => confirmDeleteId = agent.uuid" title="Delete agent cache">DEL</button>
                        }
                    </div>
                }
                @if (agentStats.Count == 0)
                {
                    <div class="list-group-item text-muted small"><em>No cached data</em></div>
                }
            }
        </div>
    }
    else
    {
        @* Directory/file listing *@
        <div class="list-group list-group-flush" style="max-height:50vh;overflow-y:auto;">
            @if (loading)
            {
                <div class="list-group-item text-center py-3">
                    <span class="spinner-border spinner-border-sm"></span>
                </div>
            }
            else
            {
                <button class="list-group-item list-group-item-action py-1 font-monospace small"
                        @onclick="NavigateUp">..</button>
                @foreach (var dir in childDirs)
                {
                    <div class="list-group-item py-1 font-monospace small d-flex align-items-center gap-1">
                        <span class="flex-shrink-0 me-1" style="width:1.2em;text-align:center;">&#x1f4c1;</span>
                        <a href="javascript:void(0)" class="flex-grow-1 text-truncate" @onclick="() => NavigateToDirectory(dir.Id)" @onclick:preventDefault>@dir.Name</a>
                        @if (confirmDeleteId == dir.Id)
                        {
                            <button class="btn btn-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => DeleteDir(dir)">YES</button>
                            <button class="btn btn-outline-secondary btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => confirmDeleteId = null">NO</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.65rem"
                                    @onclick="() => confirmDeleteId = dir.Id" title="Delete">DEL</button>
                        }
                    </div>
                }
                @foreach (var file in childFiles)
                {
                    <div class="list-group-item py-1 font-monospace small d-flex align-items-center gap-1">
                        <span class="flex-shrink-0 me-1" style="width:1.2em;text-align:center;">&#x1f4c4;</span>
                        <span class="flex-grow-1 text-truncate">@file.Name</span>
                        <small class="text-muted flex-shrink-0">@Formatters.FormatSize((ulong)file.Size)</small>
                        @if (confirmDeleteId == file.Id)
                        {
                            <button class="btn btn-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => DeleteFile(file)">YES</button>
                            <button class="btn btn-outline-secondary btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.6rem" @onclick="() => confirmDeleteId = null">NO</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm px-1 py-0 flex-shrink-0" style="font-size:0.65rem"
                                    @onclick="() => confirmDeleteId = file.Id" title="Delete">DEL</button>
                        }
                    </div>
                }
                @if (childDirs.Count == 0 && childFiles.Count == 0)
                {
                    <div class="list-group-item text-muted small"><em>Empty</em></div>
                }
            }
        </div>
    }
</div>

@code {
    private string currentDirId = VfsStore.RootParentId;
    private string? currentAgentUuid;
    private List<(string uuid, string name, int dirs, int files, long size)> agentStats = new();
    private List<VfsDirectory> childDirs = new();
    private List<VfsFile> childFiles = new();
    private List<VfsDirectory> breadcrumbs = new();
    private (int agentCount, int dirCount, int fileCount, long totalSize) stats;
    private long blobSize;
    private bool loading;
    private bool confirmPrune;
    private string? confirmDeleteId;

    protected override async Task OnInitializedAsync()
    {
        Cache.OnChanged += OnCacheChanged;
        Vfs.OnChanged += OnCacheChanged;
        await Refresh();
    }

    private async void OnCacheChanged()
    {
        await InvokeAsync(async () =>
        {
            await Refresh();
            StateHasChanged();
        });
    }

    private async Task Refresh()
    {
        if (!Cache.HasDirectory) return;
        loading = true;
        StateHasChanged();

        try
        {
            blobSize = await Cache.GetCacheSizeAsync();
            var uuids = AgentDb.Agents.Values.Select(a => a.Uuid).ToList();
            stats = await Vfs.GetGlobalStatsAsync(uuids);

            if (currentDirId == VfsStore.RootParentId && currentAgentUuid is null)
            {
                agentStats = new();
                foreach (var agent in AgentDb.Agents.Values)
                {
                    var (d, f, s) = await Vfs.GetAgentStatsAsync(agent.Uuid);
                    if (d > 0 || f > 0)
                        agentStats.Add((agent.Uuid, agent.Name, d, f, s));
                }
                childDirs = new();
                childFiles = new();
            }
            else if (currentAgentUuid is not null)
            {
                childDirs = await Vfs.GetChildDirectoriesAsync(currentAgentUuid, currentDirId);
                childFiles = await Vfs.GetFilesInDirectoryAsync(currentAgentUuid, currentDirId);
            }
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task NavigateToRoot()
    {
        currentDirId = VfsStore.RootParentId;
        currentAgentUuid = null;
        breadcrumbs = new();
        await Refresh();
    }

    private async Task NavigateToAgent(string agentUuid)
    {
        currentAgentUuid = agentUuid;
        currentDirId = VfsStore.RootParentId;
        breadcrumbs = new() { MakeAgentCrumb() };
        await Refresh();
    }

    private async Task NavigateToDirectory(string dirId)
    {
        currentDirId = dirId;
        await RebuildBreadcrumbs();
        await Refresh();
    }

    private async Task NavigateUp()
    {
        if (breadcrumbs.Count <= 1)
        {
            await NavigateToRoot();
            return;
        }
        var parent = breadcrumbs[^2];
        breadcrumbs.RemoveAt(breadcrumbs.Count - 1);
        currentDirId = parent.Id;
        await Refresh();
    }

    private async Task RebuildBreadcrumbs()
    {
        var crumbs = new List<VfsDirectory>();
        var id = currentDirId;
        while (id != VfsStore.RootParentId)
        {
            var dir = await Vfs.GetDirectoryAsync(id);
            if (dir is null) break;
            crumbs.Insert(0, dir);
            id = dir.ParentId;
        }
        if (currentAgentUuid is not null)
            crumbs.Insert(0, MakeAgentCrumb());
        breadcrumbs = crumbs;
    }

    private async Task DeleteDir(VfsDirectory dir)
    {
        confirmDeleteId = null;
        try
        {
            await Vfs.RemoveDirectoryAsync(dir.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private async Task DeleteFile(VfsFile file)
    {
        confirmDeleteId = null;
        try
        {
            await Vfs.RemoveFileAsync(file.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private async Task DeleteAgentCache(string agentUuid)
    {
        confirmDeleteId = null;
        try
        {
            loading = true;
            StateHasChanged();
            await Vfs.ClearAgentAsync(agentUuid);
            // Clear download records for this agent
            foreach (var dl in Downloads.GetByAgent(agentUuid))
                await Downloads.RemoveAsync(dl.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task ConfirmPrune()
    {
        confirmPrune = false;
        try
        {
            loading = true;
            StateHasChanged();
            foreach (var agent in AgentDb.Agents.Values)
                await Vfs.ClearAgentAsync(agent.Uuid);
            await Downloads.ClearAsync();
            await NavigateToRoot();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task ChangeFolder()
    {
        try
        {
            await Cache.PickDirectoryAsync();
            await NavigateToRoot();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
    }

    private VfsDirectory MakeAgentCrumb()
    {
        var name = AgentDb.Agents.Values.FirstOrDefault(a => a.Uuid == currentAgentUuid)?.Name ?? currentAgentUuid!;
        return new VfsDirectory { Id = VfsStore.RootParentId, Name = name };
    }

    public void Dispose()
    {
        Cache.OnChanged -= OnCacheChanged;
        Vfs.OnChanged -= OnCacheChanged;
    }
}
