@using cc.Components
@inject WindowManager Wm
@implements IDisposable

@* Drag overlay — captures pointer events globally during drag *@
@if (_dragging is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="z-index:9999;cursor:grabbing;touch-action:none;"
         @onpointermove="OnDragMove"
         @onpointerup="OnDragEnd"
         @onpointercancel="OnDragEnd"
         @onpointermove:preventDefault="true"></div>
}

@* Resize overlay — captures pointer events globally during resize *@
@if (_resizing is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="z-index:9999;cursor:nwse-resize;touch-action:none;"
         @onpointermove="OnResizeMove"
         @onpointerup="OnResizeEnd"
         @onpointercancel="OnResizeEnd"
         @onpointermove:preventDefault="true"></div>
}

@* Floating windows *@
@foreach (var win in Wm.Windows)
{
    if (win.Minimized) continue;
    var w = win;
    <div @key="win.Id" class="app-window @(win.Maximized ? "maximized" : "")"
         style="@(win.Maximized ? "" : $"left:{win.X}px;top:{win.Y}px;width:{win.Width}px;height:{win.Height}px;z-index:{win.ZIndex};")"
         @onpointerdown="() => Wm.BringToFront(w)">
        <div class="app-window-titlebar"
             style="touch-action:none;"
             @onpointerdown="(e) => OnDragStart(e, win)"
             @ondblclick="() => Wm.ToggleMaximize(win)">
            <span class="app-window-title">@win.Title</span>
            <button class="app-window-btn" @onclick="() => Wm.ToggleMinimize(win)" @onpointerdown:stopPropagation="true" title="Minimize">&minus;</button>
            <button class="app-window-btn" @onclick="() => Wm.ToggleMaximize(win)" @onpointerdown:stopPropagation="true" title="@(win.Maximized ? "Restore" : "Maximize")">@(win.Maximized ? "\u25a1" : "\u29c9")</button>
            <button class="app-window-btn close-btn" @onclick="async () => await Wm.CloseWindow(win)" @onpointerdown:stopPropagation="true" title="Close">&times;</button>
        </div>
        <div class="app-window-body">
            @if (win.Panel == "File Manager")
            {
                <FileManager Relay="win.Relay" AgentId="@win.AgentId" AgentName="@win.AgentName" AgentUuid="@win.AgentUuid" />
            }
            else if (win.Panel == "Cache Manager")
            {
                <CacheManagerPanel />
            }
            else if (win.Panel == "Relay")
            {
                <RelayPanel />
            }
            else if (win.Panel == "Agents")
            {
                <AgentsPanel />
            }
            else if (win.Panel == "Sync Manager")
            {
                <DownloadManagerPanel AgentUuid="@win.AgentUuid" AgentName="@win.AgentName" />
            }
        </div>
        @if (!win.Maximized)
        {
            <div class="app-window-resize"
                 style="touch-action:none;"
                 @onpointerdown="(e) => OnResizeStart(e, win)"
                 @onpointerdown:stopPropagation="true"></div>
        }
    </div>
}

@* Taskbar — always visible when windows exist *@
@if (Wm.Windows.Count > 0)
{
    <div class="mdi-taskbar">
        @foreach (var win in Wm.Windows)
        {
            var w = win;
            <button @key="win.Id"
                    class="mdi-taskbar-item @(IsTopWindow(w) ? "active" : "") @(w.Minimized ? "minimized" : "")"
                    @onclick="() => OnTaskbarClick(w)">
                @win.Title
            </button>
        }
    </div>
}

@code {
    private DragState? _dragging;
    private ResizeState? _resizing;

    private class DragState
    {
        public WindowState Window { get; init; } = null!;
        public double StartMouseX { get; init; }
        public double StartMouseY { get; init; }
        public double StartWinX { get; init; }
        public double StartWinY { get; init; }
    }

    private class ResizeState
    {
        public WindowState Window { get; init; } = null!;
        public double StartMouseX { get; init; }
        public double StartMouseY { get; init; }
        public double StartWidth { get; init; }
        public double StartHeight { get; init; }
    }

    protected override void OnInitialized()
    {
        Wm.OnChanged += OnWmChanged;
    }

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    private bool IsTopWindow(WindowState win)
    {
        if (win.Minimized) return false;
        var visible = Wm.Windows.Where(w => !w.Minimized).ToList();
        return visible.Count > 0 && visible.MaxBy(w => w.ZIndex) == win;
    }

    private void OnTaskbarClick(WindowState win)
    {
        if (win.Minimized)
        {
            win.Minimized = false;
            Wm.BringToFront(win);
        }
        else if (IsTopWindow(win))
        {
            Wm.ToggleMinimize(win);
        }
        else
        {
            Wm.BringToFront(win);
        }
    }

    // --- Drag ---

    private void OnDragStart(PointerEventArgs e, WindowState win)
    {
        if (win.Maximized) return;
        Wm.BringToFront(win);
        _dragging = new DragState
        {
            Window = win,
            StartMouseX = e.ClientX,
            StartMouseY = e.ClientY,
            StartWinX = win.X,
            StartWinY = win.Y
        };
    }

    private void OnDragMove(PointerEventArgs e)
    {
        if (_dragging is null) return;
        _dragging.Window.X = Math.Max(0, _dragging.StartWinX + (e.ClientX - _dragging.StartMouseX));
        _dragging.Window.Y = Math.Max(36, _dragging.StartWinY + (e.ClientY - _dragging.StartMouseY));
    }

    private void OnDragEnd(PointerEventArgs e) => _dragging = null;

    // --- Resize ---

    private void OnResizeStart(PointerEventArgs e, WindowState win)
    {
        if (win.Maximized) return;
        Wm.BringToFront(win);
        _resizing = new ResizeState
        {
            Window = win,
            StartMouseX = e.ClientX,
            StartMouseY = e.ClientY,
            StartWidth = win.Width,
            StartHeight = win.Height
        };
    }

    private void OnResizeMove(PointerEventArgs e)
    {
        if (_resizing is null) return;
        _resizing.Window.Width = Math.Max(320, _resizing.StartWidth + (e.ClientX - _resizing.StartMouseX));
        _resizing.Window.Height = Math.Max(120, _resizing.StartHeight + (e.ClientY - _resizing.StartMouseY));
    }

    private void OnResizeEnd(PointerEventArgs e) => _resizing = null;

    public void Dispose()
    {
        Wm.OnChanged -= OnWmChanged;
    }
}
