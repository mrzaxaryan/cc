@inject CacheManager Cache
@inject RelayStore Relay
@inject MessageService Msg

<div class="welcome-overlay">
    <div class="welcome-card">
        <h2 class="mb-3">Welcome to CC</h2>

        @if (step == Step.Cache)
        {
            @if (!Cache.IsSupported)
            {
                <p class="text-muted">Your browser does not support the File System Access API. Please use a Chromium-based browser (Chrome, Edge, Brave) for local file caching.</p>
                <button class="btn btn-secondary" @onclick="SkipCache">Continue without cache</button>
            }
            else if (Cache.NeedsPermission)
            {
                <p class="text-muted">Your previously selected cache folder needs permission to be re-granted. Click below to allow access.</p>

                <button class="btn btn-primary btn-lg me-2" @onclick="ReGrantPermission" disabled="@picking">
                    @if (picking)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Grant Access
                </button>
                <button class="btn btn-outline-secondary" @onclick="PickFolder" disabled="@picking">Pick Different Folder</button>
            }
            else
            {
                <p class="text-muted">Select a folder on your device to use as the local file cache. Files downloaded from agents will be stored here.</p>

                <button class="btn btn-primary btn-lg" @onclick="PickFolder" disabled="@picking">
                    @if (picking)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Select Cache Folder
                </button>

                <p class="text-muted small mt-3 mb-0">You can change this later in the Cache Manager.</p>
            }
        }
        else if (step == Step.Relay)
        {
            <p class="text-muted">Configure the default relay server for agent connections.</p>

            <div class="mb-3 text-start">
                <label class="form-label fw-semibold">Relay Name</label>
                <input type="text" class="form-control" @bind="relayName" placeholder="My Relay" />
            </div>
            <div class="mb-3 text-start">
                <label class="form-label fw-semibold">Relay URL</label>
                <input type="text" class="form-control" @bind="relayUrl" placeholder="wss://relay.example.com" />
            </div>

            <div class="d-flex justify-content-center gap-2">
                <button class="btn btn-primary btn-lg" @onclick="SaveRelay" disabled="@saving">
                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Save & Continue
                </button>
                <button class="btn btn-outline-secondary" @onclick="SkipRelay">Use Default</button>
            </div>

            <p class="text-muted small mt-3 mb-0">You can add more relays later on the Relay page.</p>
        }

        @if (totalSteps > 1)
        {
            <div class="mt-3">
                <small class="text-muted">Step @currentStepNumber of @totalSteps</small>
            </div>
        }
    </div>
</div>

<style>
    .welcome-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .welcome-card {
        background: #1e1e2e;
        color: #cdd6f4;
        border: 1px solid #313244;
        border-radius: 12px;
        padding: 2.5rem;
        max-width: 480px;
        width: 90%;
        text-align: center;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    }
</style>

@code {
    [Parameter] public EventCallback OnComplete { get; set; }

    private enum Step { Cache, Relay }

    private Step step;
    private bool picking;
    private bool saving;
    private string relayName = "";
    private string relayUrl = "";

    private bool needsCache;
    private bool needsRelay;
    private int totalSteps;
    private int currentStepNumber => step == Step.Cache ? 1 : (needsCache ? 2 : 1);

    protected override void OnInitialized()
    {
        needsCache = Cache.SetupRequired || Cache.NeedsPermission;
        needsRelay = Relay.SetupRequired;
        totalSteps = (needsCache ? 1 : 0) + (needsRelay ? 1 : 0);

        step = needsCache ? Step.Cache : Step.Relay;

        // Pre-fill with current relay values
        var active = Relay.Relays.FirstOrDefault(r => r.Url == Relay.ActiveUrl);
        relayName = active?.Name ?? "";
        relayUrl = active?.Url ?? "";
    }

    private void AdvanceFromCache()
    {
        if (needsRelay)
        {
            step = Step.Relay;
            StateHasChanged();
        }
        else
        {
            OnComplete.InvokeAsync();
        }
    }

    private async Task ReGrantPermission()
    {
        picking = true;
        StateHasChanged();

        try
        {
            var success = await Cache.ReRequestPermissionAsync();
            if (success)
                AdvanceFromCache();
            else
                Msg.Error("Permission denied. Try again or pick a different folder.");
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            picking = false;
        }
    }

    private async Task PickFolder()
    {
        picking = true;
        StateHasChanged();

        try
        {
            var success = await Cache.PickDirectoryAsync();
            if (success)
            {
                AdvanceFromCache();
            }
            else
            {
                Msg.Warn("No folder selected. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            picking = false;
        }
    }

    private void SkipCache()
    {
        AdvanceFromCache();
    }

    private async Task SaveRelay()
    {
        var name = relayName.Trim();
        var url = relayUrl.Trim().TrimEnd('/');

        if (string.IsNullOrEmpty(url))
        {
            Msg.Error("Relay URL is required.");
            return;
        }

        if (!url.StartsWith("wss://") && !url.StartsWith("ws://"))
        {
            Msg.Error("URL must start with wss:// or ws://");
            return;
        }

        if (string.IsNullOrEmpty(name))
            name = "Default";

        saving = true;
        StateHasChanged();

        try
        {
            // Update the default relay entry with user values
            var existing = Relay.Relays.FirstOrDefault(r => r.Url == Relay.ActiveUrl);
            if (existing != null && existing.Url == url)
            {
                // Same URL, just update the name and persist
                await Relay.UpdateRelayName(url, name);
            }
            else
            {
                // Different URL - add new and set active
                await Relay.AddRelay(name, url);
                await Relay.SetActive(url);
            }

            await OnComplete.InvokeAsync();
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SkipRelay()
    {
        await OnComplete.InvokeAsync();
    }
}
