@inject CacheManager Cache
@inject RelayStore Relay
@inject MessageService Msg

<div class="wc-overlay">
    <div class="wc-card">
        <h2 class="wc-title">Welcome to CC</h2>

        @if (step == Step.Cache)
        {
            @if (!Cache.IsSupported)
            {
                <p class="wc-desc">Your browser does not support the File System Access API. Please use a Chromium-based browser (Chrome, Edge, Brave) for local file caching.</p>
                <CcBtn Size="Size.Md" OnClick="SkipCache">Continue without cache</CcBtn>
            }
            else if (Cache.NeedsPermission)
            {
                <p class="wc-desc">Your previously selected cache folder needs permission to be re-granted.</p>
                <div class="wc-actions">
                    <CcBtn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="ReGrantPermission" Disabled="@picking" Loading="@picking">Grant Access</CcBtn>
                    <CcBtn Size="Size.Md" OnClick="PickFolder" Disabled="@picking">Pick Different Folder</CcBtn>
                </div>
            }
            else
            {
                <p class="wc-desc">Select a folder on your device to use as the local file cache. Files downloaded from agents will be stored here.</p>
                <CcBtn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="PickFolder" Disabled="@picking" Loading="@picking">Select Cache Folder</CcBtn>
                <p class="wc-hint">You can change this later in Settings.</p>
            }
        }
        else if (step == Step.Relay)
        {
            <p class="wc-desc">Configure the default relay server for agent connections.</p>

            <div class="wc-form">
                <div class="wc-field">
                    <label class="wc-label">Relay Name</label>
                    <CcInput @bind-Value="relayName" Size="Size.Md" Placeholder="My Relay" />
                </div>
                <div class="wc-field">
                    <label class="wc-label">Relay URL</label>
                    <CcInput @bind-Value="relayUrl" Size="Size.Md" Placeholder="wss://relay.example.com" Monospace />
                </div>
            </div>

            <div class="wc-actions">
                <CcBtn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="SaveRelay" Disabled="@saving" Loading="@saving">Save & Continue</CcBtn>
                <CcBtn Size="Size.Md" OnClick="SkipRelay">Use Default</CcBtn>
            </div>

            <p class="wc-hint">You can add more relays later on the Relay page.</p>
        }

        @if (totalSteps > 1)
        {
            <div class="wc-step-indicator">
                Step @currentStepNumber of @totalSteps
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnComplete { get; set; }

    private enum Step { Cache, Relay }

    private Step step;
    private bool picking;
    private bool saving;
    private string relayName = "";
    private string relayUrl = "";

    private bool needsCache;
    private bool needsRelay;
    private int totalSteps;
    private int currentStepNumber => step == Step.Cache ? 1 : (needsCache ? 2 : 1);

    protected override void OnInitialized()
    {
        needsCache = Cache.SetupRequired || Cache.NeedsPermission;
        needsRelay = Relay.SetupRequired;
        totalSteps = (needsCache ? 1 : 0) + (needsRelay ? 1 : 0);

        step = needsCache ? Step.Cache : Step.Relay;

        var enabled = Relay.EnabledRelays.FirstOrDefault();
        relayName = enabled?.Name ?? "";
        relayUrl = enabled?.Url ?? "";
    }

    private void AdvanceFromCache()
    {
        if (needsRelay)
        {
            step = Step.Relay;
            StateHasChanged();
        }
        else
        {
            OnComplete.InvokeAsync();
        }
    }

    private async Task ReGrantPermission()
    {
        picking = true;
        StateHasChanged();

        try
        {
            var success = await Cache.ReRequestPermissionAsync();
            if (success)
                AdvanceFromCache();
            else
                Msg.Error("Permission denied. Try again or pick a different folder.");
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            picking = false;
        }
    }

    private async Task PickFolder()
    {
        picking = true;
        StateHasChanged();

        try
        {
            var success = await Cache.PickDirectoryAsync();
            if (success)
                AdvanceFromCache();
            else
                Msg.Warn("No folder selected. Please try again.");
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            picking = false;
        }
    }

    private void SkipCache()
    {
        AdvanceFromCache();
    }

    private async Task SaveRelay()
    {
        var name = relayName.Trim();
        var url = relayUrl.Trim().TrimEnd('/');

        if (string.IsNullOrEmpty(url))
        {
            Msg.Error("Relay URL is required.");
            return;
        }

        if (!url.StartsWith("wss://") && !url.StartsWith("ws://"))
        {
            Msg.Error("URL must start with wss:// or ws://");
            return;
        }

        if (string.IsNullOrEmpty(name))
            name = "Default";

        saving = true;
        StateHasChanged();

        try
        {
            var existing = Relay.EnabledRelays.FirstOrDefault();
            if (existing != null && existing.Url == url)
            {
                await Relay.UpdateRelayName(url, name);
            }
            else
            {
                await Relay.AddRelay(name, url);
                await Relay.SetEnabled(url, true);
            }

            await OnComplete.InvokeAsync();
        }
        catch (Exception ex)
        {
            Msg.Error(ex.Message);
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SkipRelay()
    {
        await OnComplete.InvokeAsync();
    }
}
