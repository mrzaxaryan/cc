@using System.Text
@inject MessageService Msg

<div>
    <div class="mb-3">
        <button class="btn btn-outline-primary btn-sm me-2" @onclick="SendGetUUID" disabled="@sending">GetUUID</button>
    </div>

    <div class="mb-3">
        <label class="form-label">Path</label>
        <input class="form-control form-control-sm" @bind="commandPath" />
    </div>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <button class="btn btn-outline-primary btn-sm" @onclick="SendGetDirectoryContent" disabled="@sending">GetDirectoryContent</button>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="SendGetFileContent" disabled="@sending">GetFileContent</button>
            <input class="form-control form-control-sm cmd-input" @bind="readCount" placeholder="Size" type="number" />
            <input class="form-control form-control-sm cmd-input" @bind="fileOffset" placeholder="Offset" type="number" />
        </div>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="SendGetFileChunkHash" disabled="@sending">GetFileChunkHash</button>
            <input class="form-control form-control-sm cmd-input" @bind="chunkSize" placeholder="Chunk" type="number" />
            <input class="form-control form-control-sm cmd-input" @bind="hashOffset" placeholder="Offset" type="number" />
        </div>
    </div>

    <pre class="p-3 rounded output-pre">@output</pre>
</div>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }

    private string commandPath = "";
    private long readCount = 4096;
    private long fileOffset;
    private long chunkSize = 4096;
    private long hashOffset;
    private string output = "";
    private bool sending;

    private async Task SendGetUUID()
    {
        var response = await SendCommand(new byte[] { 0x00 });
        if (response is null) return;

        if (response.Length >= 4)
        {
            var status = RelaySocket.ReadStatus(response);
            if (status == 0 && response.Length >= 20)
                output += $"UUID: {RelaySocket.ReadUuid(response)}\n";
            else
                output += $"Error: status={status}\n";
        }
    }

    private async Task SendGetDirectoryContent()
    {
        var payload = RelaySocket.BuildPathCommand(0x01, commandPath);
        var response = await SendCommand(payload);
        if (response is null) return;

        var (entries, parseError) = DirEntry.ParseDirectoryResponse(response);
        if (parseError is not null) { output += $"{parseError}\n"; return; }

        output += $"Directory: {commandPath} ({entries.Count} entries)\n";
        foreach (var e in entries)
        {
            var prefix = e.IsDirectory ? "[DIR] " : e.IsDrive ? "[DRV] " : "";
            var sizeStr = (!e.IsDirectory && !e.IsDrive) ? $" ({e.Size} bytes)" : "";
            output += $"  {prefix}{e.Name}{sizeStr}\n";
        }
    }

    private async Task SendGetFileContent()
    {
        var payload = RelaySocket.BuildFileCommand(0x02, commandPath, readCount, fileOffset);
        var response = await SendCommand(payload);
        if (response is null) return;

        if (response.Length < 4) return;
        var status = RelaySocket.ReadStatus(response);
        if (status != 0) { output += $"Error: status={status}\n"; return; }
        if (response.Length < 12) return;

        var (bytesRead, data) = RelaySocket.ReadFileContent(response);
        try
        {
            output += $"File: {commandPath} ({bytesRead} bytes)\n{Encoding.UTF8.GetString(data)}\n";
        }
        catch
        {
            output += $"File: {commandPath} ({bytesRead} bytes)\n{Convert.ToHexString(data)}\n";
        }
    }

    private async Task SendGetFileChunkHash()
    {
        var payload = RelaySocket.BuildFileCommand(0x03, commandPath, chunkSize, hashOffset);
        var response = await SendCommand(payload);
        if (response is null) return;

        if (response.Length < 4) return;
        var status = RelaySocket.ReadStatus(response);
        if (status != 0) { output += $"Error: status={status}\n"; return; }
        if (response.Length < 36) return;

        output += $"SHA-256: {RelaySocket.ReadHash(response)}\n";
    }

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected) return null;

        sending = true;
        StateHasChanged();

        try
        {
            return await Relay.SendAndReceive(payload);
        }
        catch (Exception ex)
        {
            Msg.Error($"Command failed: {ex.Message}");
            return null;
        }
        finally
        {
            sending = false;
            StateHasChanged();
        }
    }
}
