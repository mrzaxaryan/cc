@using System.Net.WebSockets
@using System.Text
@inject CacheManager Cache
@inject MessageService Msg
@inject AgentStore AgentDb

<div>
    @if (!IsConnected)
    {
        <div class="alert alert-warning py-1 px-2 mb-2 small d-flex align-items-center gap-1">
            <span class="badge bg-danger">Offline</span>
            <span>Agent disconnected — browsing cached data only.</span>
        </div>
    }
    @* Breadcrumb *@
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
                <a href="javascript:void(0)" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
            </li>
            @for (int i = 0; i < pathSegments.Length; i++)
            {
                var idx = i;
                var segment = pathSegments[idx];
                if (idx == pathSegments.Length - 1)
                {
                    <li class="breadcrumb-item active">@segment</li>
                }
                else
                {
                    <li class="breadcrumb-item">
                        <a href="javascript:void(0)" @onclick="() => NavigateToBreadcrumb(idx)" @onclick:preventDefault>@segment</a>
                    </li>
                }
            }
        </ol>
    </nav>

    @* Path bar *@
    <div class="input-group input-group-sm mb-3">
        <input class="form-control font-monospace" @bind="currentPath" @onkeydown="OnPathKeyDown" />
        <button class="btn btn-outline-primary" @onclick="() => NavigateTo(currentPath)" disabled="@(loading || !IsConnected)">Go</button>
        <button class="btn btn-outline-secondary" @onclick="NavigateUp" disabled="@(loading || !IsConnected)">Up</button>
    </div>

    <div class="row g-3">
        @* Directory listing *@
        <div class="@(viewingFile ? "col-md-5" : "col-12")">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between py-1">
                    <small>
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @currentPath
                        @if (entries is not null)
                        {
                            <span class="text-muted ms-1">(@entries.Count)</span>
                        }
                    </small>
                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => NavigateTo(currentPath)" disabled="@(loading || !IsConnected)">&#x21bb;</button>
                </div>
                <div class="list-group list-group-flush" style="max-height:50vh;overflow-y:auto;">
                    @if (entries is not null)
                    {
                        @if (pathSegments.Length > 0)
                        {
                            <button class="list-group-item list-group-item-action py-1 font-monospace small"
                                    @onclick="NavigateUp" disabled="@(!IsConnected)">..</button>
                        }
                        @foreach (var entry in entries)
                        {
                            var e = entry;
                            <button class="list-group-item list-group-item-action py-1 font-monospace small d-flex align-items-center gap-1 @(selectedEntry == e ? "active" : "")"
                                    @onclick="() => selectedEntry = e"
                                    @ondblclick="() => OnEntryDoubleClick(e)">
                                <span class="flex-shrink-0 me-1" style="width:1.2em;text-align:center;">@(e.IsDirectory || e.IsDrive ? "\ud83d\udcc1" : "\ud83d\udcc4")</span>
                                <span class="flex-grow-1 text-truncate">@e.Name</span>
                                @if (!e.IsDirectory && !e.IsDrive)
                                {
                                    <small class="text-muted flex-shrink-0">@Formatters.FormatSize(e.Size)</small>
                                }
                                <span class="d-flex gap-1 flex-shrink-0">
                                    @if (e.IsDirectory || e.IsDrive)
                                    {
                                        <button class="btn btn-outline-primary btn-sm px-1 py-0" style="font-size:0.7rem"
                                                @onclick:stopPropagation="true" @onclick="() => OpenAsDirectory(e.Name)" title="Open folder" disabled="@(!IsConnected)">OPEN</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary btn-sm px-1 py-0" style="font-size:0.7rem"
                                                @onclick:stopPropagation="true" @onclick="() => ViewFile(e.Name)" title="View file" disabled="@(!IsConnected)">VIEW</button>
                                        @if (Cache.HasDirectory)
                                        {
                                            @if (IsDownloading(e.Name))
                                            {
                                                <span class="spinner-border spinner-border-sm" style="width:0.8rem;height:0.8rem;"></span>
                                            }
                                            else if (cachedFiles.Contains(e.Name))
                                            {
                                                <span class="badge bg-success py-0" style="font-size:0.6rem" title="Cached">&#x2713;</span>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-success btn-sm px-1 py-0" style="font-size:0.7rem"
                                                        @onclick:stopPropagation="true" @onclick="() => DownloadToCache(e)" title="Download to cache" disabled="@(!IsConnected)">DL</button>
                                            }
                                        }
                                    }
                                </span>
                            </button>
                        }
                    }
                    else if (!loading)
                    {
                        <div class="list-group-item text-muted small"><em>Enter a path and press Go.</em></div>
                    }
                </div>
            </div>
        </div>

        @* File viewer *@
        @if (viewingFile)
        {
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header d-flex align-items-center justify-content-between py-1">
                        <small class="text-truncate font-monospace">@viewingFileName</small>
                        <div class="d-flex gap-1">
                            @if (!fileLoading)
                            {
                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="HashFile" title="SHA-256" disabled="@(!IsConnected)">#</button>
                            }
                            <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="CloseFileViewer">X</button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (fileLoading)
                        {
                            <div class="p-3"><span class="spinner-border spinner-border-sm me-1"></span> Loading...</div>
                        }
                        else
                        {
                            @if (fileHash is not null)
                            {
                                <div class="px-3 pt-2">
                                    <small class="text-muted">SHA-256:</small>
                                    <code class="user-select-all small">@fileHash</code>
                                </div>
                            }
                            <div class="d-flex align-items-center gap-2 px-3 pt-2">
                                <small class="text-muted">@fileBytesRead bytes (offset @fileViewOffset)</small>
                                <div class="ms-auto d-flex gap-1">
                                    @if (fileViewOffset > 0)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm py-0" @onclick="PrevPage" disabled="@(!IsConnected)">Prev</button>
                                    }
                                    @if (fileBytesRead >= PageSize)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm py-0" @onclick="NextPage" disabled="@(!IsConnected)">Next</button>
                                    }
                                </div>
                            </div>
                            <pre class="bg-dark text-light p-3 m-0 rounded-0" style="max-height:45vh;overflow:auto;white-space:pre-wrap;word-break:break-all;font-size:0.8rem;">@fileContent</pre>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private const long PageSize = 8192;

    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }

    private bool IsConnected => Relay is not null && Relay.IsConnected;

    private string currentPath = "";
    private string[] pathSegments = [];
    private List<DirEntry>? entries;
    private DirEntry? selectedEntry;
    private bool loading;

    // Cache tracking
    private HashSet<string> cachedFiles = new();
    private HashSet<string> downloading = new();

    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";
    private string fileContent = "";
    private long fileBytesRead;
    private long fileViewOffset;
    private bool fileLoading;
    private string? fileHash;

    protected override async Task OnParametersSetAsync()
    {
        if (Relay is not null && Relay.IsConnected && entries is null)
        {
            await NavigateTo(currentPath);
        }
    }

    public void Reset()
    {
        currentPath = "";
        pathSegments = [];
        entries = null;
        selectedEntry = null;
        viewingFile = false;
        fileContent = "";
        fileHash = null;
    }

    // --- Navigation ---

    private void UpdatePathSegments()
    {
        pathSegments = currentPath
            .Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries)
            .ToArray();
    }

    private async Task NavigateTo(string path)
    {
        currentPath = path.TrimEnd('\\', '/');
        if (!string.IsNullOrEmpty(currentPath) && !currentPath.EndsWith(@"\"))
            currentPath += @"\";

        UpdatePathSegments();
        loading = true;
        entries = null;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildPathCommand(0x01, currentPath);
            var response = await SendCommand(payload);
            if (response is null) return;

            var (parsed, parseError) = DirEntry.ParseDirectoryResponse(response);
            if (parseError is not null) { Msg.Error(parseError); return; }
            entries = parsed;
            await MirrorEntriesToCache();
            await CheckCachedFiles();
        }
        catch (Exception ex)
        {
            Msg.Error($"Failed: {ex.Message}");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task NavigateUp()
    {
        if (pathSegments.Length <= 1)
        {
            await NavigateTo("");
            return;
        }
        var parent = string.Join(@"\", pathSegments.Take(pathSegments.Length - 1));
        await NavigateTo(parent);
    }

    private async Task NavigateToRoot() => await NavigateTo("");

    private async Task NavigateToBreadcrumb(int index)
    {
        var path = string.Join(@"\", pathSegments.Take(index + 1));
        await NavigateTo(path);
    }

    private async Task OnPathKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await NavigateTo(currentPath);
    }

    private async Task OpenAsDirectory(string name) => await NavigateTo(currentPath + name);

    // --- File viewer ---

    private async Task ViewFile(string name)
    {
        viewingFileName = name;
        viewingFilePath = currentPath + name;
        fileViewOffset = 0;
        fileHash = null;
        await LoadFilePage();
        viewingFile = true;
    }

    private async Task LoadFilePage()
    {
        fileLoading = true;
        fileContent = "";
        fileBytesRead = 0;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildFileCommand(0x02, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;

            if (response.Length < 4) { Msg.Error("Invalid response"); return; }
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error($"Error reading file (status={status})"); return; }
            if (response.Length < 12) { Msg.Error("Invalid response"); return; }

            var (bytesRead, data) = RelaySocket.ReadFileContent(response);
            fileBytesRead = (long)bytesRead;

            try { fileContent = Encoding.UTF8.GetString(data); }
            catch { fileContent = Formatters.FormatHexDump(data.ToArray()); }
        }
        catch (Exception ex)
        {
            Msg.Error($"Failed to read file: {ex.Message}");
        }
        finally
        {
            fileLoading = false;
            StateHasChanged();
        }
    }

    private async Task NextPage() { fileViewOffset += PageSize; await LoadFilePage(); }
    private async Task PrevPage() { fileViewOffset = Math.Max(0, fileViewOffset - PageSize); await LoadFilePage(); }

    private void CloseFileViewer()
    {
        viewingFile = false;
        fileContent = "";
        fileHash = null;
    }

    private async Task HashFile()
    {
        fileLoading = true;
        fileHash = null;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildFileCommand(0x03, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;

            if (response.Length < 4) return;
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error($"Hash error (status={status})"); return; }
            if (response.Length < 36) return;

            fileHash = RelaySocket.ReadHash(response);
        }
        catch (Exception ex)
        {
            Msg.Error($"Hash failed: {ex.Message}");
        }
        finally
        {
            fileLoading = false;
            StateHasChanged();
        }
    }

    // --- Cache sync ---

    private string AgentCacheRoot
    {
        get
        {
            if (string.IsNullOrEmpty(AgentId)) return "";
            return AgentDb.GetUuidByAgentId(AgentId) ?? "";
        }
    }
    private string CacheSubPath
    {
        get
        {
            var remotePath = currentPath.Replace('\\', '/').Trim('/').Replace(":", "");
            return string.IsNullOrEmpty(AgentCacheRoot) ? remotePath : $".fs/{AgentCacheRoot}/{remotePath}";
        }
    }

    private bool IsDownloading(string name) => downloading.Contains(name);

    private static string CacheName(DirEntry entry) =>
        entry.IsDrive ? entry.Name.Replace(":", "") : entry.Name;

    private async Task EnsureCachePathAsync()
    {
        await AgentDb.LoadAsync();
        if (!Cache.HasDirectory || string.IsNullOrEmpty(AgentCacheRoot)) return;

        // Ensure the current directory path exists in cache
        var sub = CacheSubPath;
        if (!string.IsNullOrEmpty(sub))
        {
            var parts = sub.Split('/', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length > 1)
            {
                var parent = string.Join("/", parts.Take(parts.Length - 1));
                await Cache.CreateDirectoryAsync(parent, parts.Last());
            }
        }
    }

    private async Task MirrorEntriesToCache()
    {
        await EnsureCachePathAsync();
        if (!Cache.HasDirectory || entries is null || string.IsNullOrEmpty(AgentCacheRoot)) return;

        foreach (var entry in entries)
        {
            try
            {
                var name = CacheName(entry);
                if (entry.IsDirectory || entry.IsDrive)
                {
                    await Cache.CreateDirectoryAsync(CacheSubPath, name);
                }
                else
                {
                    if (!await Cache.FileExistsAsync(CacheSubPath, name))
                        await Cache.WriteFileAsync(CacheSubPath, name, Array.Empty<byte>());
                }
            }
            catch { }
        }
    }

    private async Task CheckCachedFiles()
    {
        cachedFiles.Clear();
        if (!Cache.HasDirectory || entries is null) return;

        foreach (var entry in entries.Where(e => !e.IsDirectory && !e.IsDrive))
        {
            try
            {
                if (await Cache.FileExistsAsync(CacheSubPath, entry.Name))
                    cachedFiles.Add(entry.Name);
            }
            catch { }
        }
    }

    private async Task DownloadToCache(DirEntry entry)
    {
        if (Relay is null || !Relay.IsConnected || !Cache.HasDirectory) return;

        downloading.Add(entry.Name);
        StateHasChanged();

        try
        {
            var remotePath = currentPath + entry.Name;
            var success = await Cache.DownloadFromAgentAsync(
                Relay, remotePath, CacheSubPath, entry.Name,
                (downloaded, _) =>
                {
                    InvokeAsync(StateHasChanged);
                });

            if (success)
                cachedFiles.Add(entry.Name);
            else
                Msg.Error($"Failed to download {entry.Name}");
        }
        catch (Exception ex)
        {
            Msg.Error($"Download failed: {ex.Message}");
        }
        finally
        {
            downloading.Remove(entry.Name);
            StateHasChanged();
        }
    }

    // --- WebSocket ---

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected)
        {
            Msg.Error("Not connected to agent");
            return null;
        }

        try
        {
            return await Relay.SendAndReceive(payload);
        }
        catch (Exception ex)
        {
            Msg.Error($"Command failed: {ex.Message}");
            return null;
        }
    }

    private async Task OnEntryDoubleClick(DirEntry entry)
    {
        if (entry.IsDirectory || entry.IsDrive)
            await OpenAsDirectory(entry.Name);
        else
            await ViewFile(entry.Name);
    }
}
