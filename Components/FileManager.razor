@using System.Net.WebSockets
@using System.Text
@inject CacheManager Cache
@inject VfsStore Vfs
@inject DownloadStore Downloads
@inject RelayConnectionService RelaySvc
@inject AgentStore AgentDb
@inject RelayStore RelayDb
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js
@implements IDisposable

<div class="fm">
    @if (!IsConnected)
    {
        <div class="fm-offline">
            <span class="fm-offline-dot"></span>
            Agent disconnected — browsing cached data only.
        </div>
    }

    @* Toolbar *@
    <div class="fm-toolbar">
        <button class="fm-toolbar-btn" @onclick="NavigateUp" disabled="@(loading || (!IsConnected && !HasCache))" title="Up">
            <span class="fm-icon">&#x2191;</span>
        </button>
        <button class="fm-toolbar-btn" @onclick="() => NavigateTo(currentPath)" disabled="@(loading || (!IsConnected && !HasCache))" title="Refresh">&#x21bb;</button>
        <div class="fm-path-bar">
            <input class="fm-path-input" @bind="currentPath" @onkeydown="OnPathKeyDown" spellcheck="false" />
        </div>
        <button class="fm-toolbar-btn fm-toolbar-accent" @onclick="OpenSyncManagerWindow" title="Sync Manager">
            <span class="fm-icon">&#x21C5;</span> SYNC
        </button>
    </div>

    @* Breadcrumb *@
    @if (pathSegments.Length > 0)
    {
        <div class="fm-breadcrumb">
            <a href="javascript:void(0)" class="fm-crumb" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
            @for (int i = 0; i < pathSegments.Length; i++)
            {
                var idx = i;
                <span class="fm-crumb-sep">/</span>
                @if (idx == pathSegments.Length - 1)
                {
                    <span class="fm-crumb-active">@pathSegments[idx]</span>
                }
                else
                {
                    <a href="javascript:void(0)" class="fm-crumb" @onclick="() => NavigateToBreadcrumb(idx)" @onclick:preventDefault>@pathSegments[idx]</a>
                }
            }
        </div>
    }

    <div class="fm-content @(viewingFile ? "fm-split" : "")">
        @* Directory listing *@
        <div class="fm-listing">
            <div class="fm-listing-header">
                @if (loading)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <span class="fm-listing-title">@(string.IsNullOrEmpty(currentPath) ? "Drives" : currentPath)</span>
                @if (entries is not null)
                {
                    <span class="fm-count">@entries.Count items</span>
                }
            </div>
            <div class="fm-entries">
                @if (entries is not null)
                {
                    @if (pathSegments.Length > 0)
                    {
                        <button class="fm-entry" @onclick="NavigateUp" disabled="@(!IsConnected && !HasCache)">
                            <span class="fm-entry-icon">&#x2191;</span>
                            <span class="fm-entry-name">..</span>
                        </button>
                    }
                    @foreach (var entry in entries)
                    {
                        var e = entry;
                        var isDir = e.IsDirectory || e.IsDrive;
                        <button class="fm-entry @(selectedEntry == e ? "selected" : "") @(isDir ? "fm-entry-dir" : "")"
                                @onclick="() => selectedEntry = e"
                                @ondblclick="() => OnEntryDoubleClick(e)">
                            <span class="fm-entry-icon">@(isDir ? "\ud83d\udcc1" : "\ud83d\udcc4")</span>
                            <span class="fm-entry-name">@e.Name</span>
                            @if (!isDir)
                            {
                                <span class="fm-entry-size">@Formatters.FormatSize(e.Size)</span>
                            }
                            <span class="fm-entry-actions" @onclick:stopPropagation="true">
                                @if (isDir)
                                {
                                    <button class="fm-action-btn" @onclick="() => OpenAsDirectory(e.Name)" title="Open" disabled="@(!IsConnected && !HasCache)">OPEN</button>
                                }
                                else if (Cache.HasDirectory)
                                {
                                    @RenderFileActions(e)
                                }
                            </span>
                        </button>
                    }
                }
                else if (!loading)
                {
                    <div class="fm-empty">Enter a path and press Enter or click a drive.</div>
                }
            </div>
        </div>

        @* File viewer *@
        @if (viewingFile)
        {
            <div class="fm-viewer">
                <div class="fm-viewer-header">
                    <span class="fm-viewer-title" title="@viewingFilePath">@viewingFileName</span>
                    <div class="fm-viewer-actions">
                        @if (!fileLoading)
                        {
                            <button class="fm-toolbar-btn" @onclick="HashFile" title="SHA-256" disabled="@(!IsConnected)">SHA</button>
                        }
                        <button class="fm-toolbar-btn fm-close-btn" @onclick="CloseFileViewer">&#x2715;</button>
                    </div>
                </div>
                @if (fileLoading)
                {
                    <div class="fm-viewer-loading">
                        <span class="spinner-border spinner-border-sm"></span> Loading...
                    </div>
                }
                else
                {
                    @if (fileHash is not null)
                    {
                        <div class="fm-hash">
                            <span class="fm-hash-label">SHA-256</span>
                            <code class="fm-hash-value">@fileHash</code>
                        </div>
                    }
                    <div class="fm-viewer-meta">
                        <span>@fileBytesRead bytes (offset @fileViewOffset)</span>
                        <div class="fm-viewer-pager">
                            @if (fileViewOffset > 0)
                            {
                                <button class="fm-toolbar-btn" @onclick="PrevPage" disabled="@(!IsConnected)">&#x25C0; Prev</button>
                            }
                            @if (fileBytesRead >= PageSize)
                            {
                                <button class="fm-toolbar-btn" @onclick="NextPage" disabled="@(!IsConnected)">Next &#x25B6;</button>
                            }
                        </div>
                    </div>
                    <pre class="fm-code">@fileContent</pre>
                }
            </div>
        }
    </div>
</div>

@code {
    private const long PageSize = 8192;

    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private bool IsConnected => Relay is not null && Relay.IsConnected;
    private bool IsAgentOnline => AgentId is not null && RelaySvc.GetAllAgents().Any(a => a.Agent.Id == AgentId);
    private bool HasCache => Cache.HasDirectory && !string.IsNullOrEmpty(AgentUuid);

    private string currentPath = "";
    private string[] pathSegments = [];
    private List<DirEntry>? entries;
    private DirEntry? selectedEntry;
    private bool loading;

    private bool _syncing;
    private readonly HashSet<int> _ownedDownloads = new();

    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";
    private string fileContent = "";
    private long fileBytesRead;
    private long fileViewOffset;
    private bool fileLoading;
    private string? fileHash;

    protected override async Task OnParametersSetAsync()
    {
        if (entries is not null) return;
        await Downloads.LoadAsync();

        if (IsConnected)
            await NavigateTo(currentPath);
        else if (HasCache)
            await NavigateFromCache(currentPath);
    }

    protected override void OnInitialized()
    {
        Cache.OnChanged += OnCacheChanged;
        Downloads.OnChanged += OnDownloadsChanged;
    }

    private void OnCacheChanged()
    {
        if (!_syncing && Cache.HasDirectory && entries is not null)
            _ = SyncCacheAsync();
    }

    private void OnDownloadsChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        foreach (var id in _ownedDownloads)
            Downloads.CancelCts(id);
        _ownedDownloads.Clear();
        Cache.OnChanged -= OnCacheChanged;
        Downloads.OnChanged -= OnDownloadsChanged;
    }

    public void Reset()
    {
        currentPath = "";
        pathSegments = [];
        entries = null;
        selectedEntry = null;
        viewingFile = false;
        fileContent = "";
        fileHash = null;
    }

    // --- Render helpers ---

    private RenderFragment RenderFileActions(DirEntry e) => __builder =>
    {
        var dl = GetDownloadRecord(e.Name);
        if (dl is null || (dl.Status != DownloadStatus.Downloading && dl.Status != DownloadStatus.Paused
            && dl.Status != DownloadStatus.Queued && dl.Status != DownloadStatus.Completed && dl.Status != DownloadStatus.Failed))
        {
            <button class="fm-action-btn fm-action-sync" @onclick="() => EnqueueSync(e)" title="Sync to cache" disabled="@(!IsConnected)">SYNC</button>
            return;
        }

        switch (dl.Status)
        {
            case DownloadStatus.Downloading:
                var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <span class="fm-dl-status">
                    <span class="spinner-border spinner-border-sm fm-dl-spinner"></span>
                    <span class="fm-dl-pct">@pct%</span>
                    @if (dl.SpeedBytesPerSec > 0)
                    {
                        <span class="fm-dl-speed">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                    }
                    <button class="fm-action-btn fm-action-warn" @onclick="() => PauseDownload(e)" title="Pause">&#x23F8;</button>
                </span>
                break;

            case DownloadStatus.Paused:
                var pctP = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <span class="fm-dl-status">
                    <span class="fm-badge fm-badge-warn">@pctP%</span>
                    <button class="fm-action-btn fm-action-ok" @onclick="() => ResumeDownload(e)" title="Resume" disabled="@(!IsConnected && !IsAgentOnline)">&#x25B6;</button>
                </span>
                break;

            case DownloadStatus.Queued:
                <span class="fm-badge fm-badge-muted">QUEUED</span>
                break;

            case DownloadStatus.Completed:
                <span class="fm-dl-status">
                    <button class="fm-action-btn" @onclick="() => ViewFile(e.Name)" title="View">VIEW</button>
                    <button class="fm-action-btn fm-action-sync" @onclick="() => SaveToBrowser(dl)" title="Save">SAVE</button>
                </span>
                break;

            case DownloadStatus.Failed:
                <span class="fm-dl-status">
                    <span class="fm-badge fm-badge-err" title="@dl.Error">&#x2717;</span>
                    <button class="fm-action-btn fm-action-warn" @onclick="() => RetryDownload(e)" title="Retry" disabled="@(!IsConnected)">&#x21bb;</button>
                </span>
                break;
        }
    };

    // --- Navigation ---

    private void UpdatePathSegments()
    {
        pathSegments = currentPath
            .Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries)
            .ToArray();
    }

    private async Task NavigateTo(string path)
    {
        if (!IsConnected)
        {
            if (HasCache) await NavigateFromCache(path);
            return;
        }

        currentPath = path.TrimEnd('\\', '/');
        if (!string.IsNullOrEmpty(currentPath) && !currentPath.EndsWith(@"\"))
            currentPath += @"\";

        UpdatePathSegments();
        loading = true;
        entries = null;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildPathCommand(0x01, currentPath);
            var response = await SendCommand(payload);
            if (response is null) return;

            var (parsed, parseError) = DirEntry.ParseDirectoryResponse(response);
            if (parseError is not null) { Msg.Error(parseError); return; }
            entries = parsed;
            _ = SyncCacheAsync();
        }
        catch (Exception ex)
        {
            Msg.Error($"Failed: {ex.Message}");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task NavigateFromCache(string path)
    {
        currentPath = path.TrimEnd('\\', '/');
        if (!string.IsNullOrEmpty(currentPath) && !currentPath.EndsWith(@"\"))
            currentPath += @"\";

        UpdatePathSegments();
        loading = true;
        entries = null;
        StateHasChanged();

        try
        {
            var remotePath = currentPath.TrimEnd('\\', '/');
            var parentId = await ResolveDirectoryId(remotePath);

            var dirs = await Vfs.GetChildDirectoriesAsync(AgentUuid!, parentId);
            var files = await Vfs.GetFilesInDirectoryAsync(AgentUuid!, parentId);

            entries = new List<DirEntry>();
            foreach (var d in dirs)
            {
                entries.Add(new DirEntry(
                    Name: d.Name, CreationTime: 0, LastModifiedTime: 0,
                    Size: 0, Type: 0, IsDirectory: true, IsDrive: d.IsDrive,
                    IsHidden: false, IsSystem: false, IsReadOnly: false));
            }
            foreach (var f in files)
            {
                entries.Add(new DirEntry(
                    Name: f.Name, CreationTime: 0, LastModifiedTime: 0,
                    Size: (ulong)f.Size, Type: 0, IsDirectory: false, IsDrive: false,
                    IsHidden: false, IsSystem: false, IsReadOnly: false));
            }
        }
        catch (Exception ex)
        {
            Msg.Error($"Failed to read cache: {ex.Message}");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task<string> ResolveDirectoryId(string remotePath)
    {
        if (string.IsNullOrEmpty(remotePath)) return VfsStore.RootParentId;
        return await Vfs.ResolveOrCreatePathAsync(AgentUuid!, remotePath);
    }

    private async Task NavigateUp()
    {
        if (pathSegments.Length <= 1)
        {
            await NavigateTo("");
            return;
        }
        var parent = string.Join(@"\", pathSegments.Take(pathSegments.Length - 1));
        await NavigateTo(parent);
    }

    private async Task NavigateToRoot() => await NavigateTo("");

    private async Task NavigateToBreadcrumb(int index)
    {
        var path = string.Join(@"\", pathSegments.Take(index + 1));
        await NavigateTo(path);
    }

    private async Task OnPathKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await NavigateTo(currentPath);
    }

    private async Task OpenAsDirectory(string name) => await NavigateTo(currentPath + name);

    // --- File viewer ---

    private async Task ViewFile(string name)
    {
        viewingFileName = name;
        viewingFilePath = currentPath + name;
        fileViewOffset = 0;
        fileHash = null;
        await LoadFilePage();
        viewingFile = true;
    }

    private async Task LoadFilePage()
    {
        fileLoading = true;
        fileContent = "";
        fileBytesRead = 0;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildFileCommand(0x02, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;

            if (response.Length < 4) { Msg.Error("Invalid response"); return; }
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error($"Error reading file (status={status})"); return; }
            if (response.Length < 12) { Msg.Error("Invalid response"); return; }

            var (bytesRead, data) = RelaySocket.ReadFileContent(response);
            fileBytesRead = (long)bytesRead;

            try { fileContent = Encoding.UTF8.GetString(data); }
            catch { fileContent = Formatters.FormatHexDump(data.ToArray()); }
        }
        catch (Exception ex)
        {
            Msg.Error($"Failed to read file: {ex.Message}");
        }
        finally
        {
            fileLoading = false;
            StateHasChanged();
        }
    }

    private async Task NextPage() { fileViewOffset += PageSize; await LoadFilePage(); }
    private async Task PrevPage() { fileViewOffset = Math.Max(0, fileViewOffset - PageSize); await LoadFilePage(); }

    private void CloseFileViewer()
    {
        viewingFile = false;
        fileContent = "";
        fileHash = null;
    }

    private async Task HashFile()
    {
        fileLoading = true;
        fileHash = null;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildFileCommand(0x03, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;

            if (response.Length < 4) return;
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error($"Hash error (status={status})"); return; }
            if (response.Length < 36) return;

            fileHash = RelaySocket.ReadHash(response);
        }
        catch (Exception ex)
        {
            Msg.Error($"Hash failed: {ex.Message}");
        }
        finally
        {
            fileLoading = false;
            StateHasChanged();
        }
    }

    // --- Cache sync (VFS) ---

    private async Task SyncCacheAsync()
    {
        if (_syncing) return;
        if (!Cache.HasDirectory || entries is null || string.IsNullOrEmpty(AgentUuid)) return;
        var snapshot = entries.ToList();
        var remotePath = currentPath.TrimEnd('\\', '/');

        _syncing = true;
        try
        {
            var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, remotePath);
            foreach (var entry in snapshot)
            {
                try
                {
                    var entryRemotePath = string.IsNullOrEmpty(remotePath)
                        ? entry.Name : $"{remotePath}/{entry.Name}";

                    if (entry.IsDirectory || entry.IsDrive)
                        await Vfs.PutDirectoryAsync(AgentUuid, parentId, entry.Name, entryRemotePath, entry.IsDrive);
                    else
                        await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, entryRemotePath, (long)entry.Size);
                }
                catch { }
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { }
        finally
        {
            _syncing = false;
        }
    }

    private DownloadRecord? GetDownloadRecord(string fileName)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return null;
        return Downloads.Find(AgentUuid, currentPath + fileName);
    }

    private async Task EnqueueSync(DirEntry entry)
    {
        if (!Cache.HasDirectory || string.IsNullOrEmpty(AgentUuid)) return;

        var remotePath = currentPath + entry.Name;
        var parentRemotePath = currentPath.TrimEnd('\\', '/');
        var totalSize = (long)entry.Size;

        var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, parentRemotePath);
        var vfsFile = await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, remotePath.Replace('\\', '/'), totalSize);

        var record = Downloads.Find(AgentUuid, remotePath);
        if (record is null || record.Status == DownloadStatus.Completed || record.Status == DownloadStatus.Failed)
        {
            record = await Downloads.AddAsync(
                AgentUuid, AgentName ?? "", remotePath, entry.Name, vfsFile.Id, totalSize);
        }
        else if (record.Status == DownloadStatus.Paused)
        {
            await Downloads.QueueAsync(record.Id);
        }

        StateHasChanged();
        _ = ProcessQueue();
    }

    private bool _processingQueue;

    private async Task ProcessQueue()
    {
        if (_processingQueue) return;
        if (string.IsNullOrEmpty(AgentUuid)) return;
        if (Relay is null || !Relay.IsConnected) return;
        if (Downloads.HasActiveDownload(AgentUuid)) return;

        var next = Downloads.GetNextQueued(AgentUuid);
        if (next is null) return;

        _processingQueue = true;
        try
        {
            await SyncRecord(next);
        }
        finally
        {
            _processingQueue = false;
            if (!Downloads.HasActiveDownload(AgentUuid))
                _ = ProcessQueue();
        }
    }

    private async Task SyncRecord(DownloadRecord record)
    {
        if (Relay is null || !Relay.IsConnected) return;

        var cts = Downloads.RegisterCts(record.Id);
        _ownedDownloads.Add(record.Id);
        StateHasChanged();

        try
        {
            var success = await Cache.DownloadFromAgentAsync(
                Relay, record.RemotePath, record.CacheSubPath,
                record.DownloadedSize, cts.Token,
                async (downloaded, _) =>
                {
                    await Downloads.UpdateProgressAsync(record.Id, downloaded);
                });

            if (success)
                await Downloads.CompleteAsync(record.Id);
            else
                await Downloads.FailAsync(record.Id, "Sync returned failure");
        }
        catch (OperationCanceledException)
        {
            await Downloads.PauseAsync(record.Id);
        }
        catch (Exception ex)
        {
            if (cts.IsCancellationRequested)
                await Downloads.PauseAsync(record.Id);
            else
            {
                await Downloads.FailAsync(record.Id, ex.Message);
                Msg.Error($"Sync failed: {ex.Message}");
            }
        }
        finally
        {
            _ownedDownloads.Remove(record.Id);
            Downloads.RemoveCts(record.Id);
            StateHasChanged();
        }
    }

    private void PauseDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var record = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (record is not null) Downloads.CancelCts(record.Id);
    }

    private async Task ResumeDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var record = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (record is null || Downloads.HasActiveCts(record.Id)) return;

        await Downloads.QueueAsync(record.Id);
        _ = ProcessQueue();
    }

    private async Task RetryDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var existing = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (existing is not null) await Downloads.RemoveAsync(existing.Id);
        await EnqueueSync(entry);
    }

    private void OpenSyncManagerWindow()
    {
        if (!string.IsNullOrEmpty(AgentId))
            Wm.OpenAgentWindow("Sync Manager", AgentId, agentName: AgentName, agentUuid: AgentUuid);
        else
            Wm.OpenWindow("Sync Manager");
    }

    private async Task SaveToBrowser(DownloadRecord dl)
    {
        try
        {
            if (!await Cache.BlobExistsAsync(dl.CacheSubPath)) { Msg.Error("File not found in cache"); return; }
            await Js.InvokeVoidAsync("ccSaveFile", dl.FileName, dl.CacheSubPath);
        }
        catch (Exception ex)
        {
            Msg.Error($"Save failed: {ex.Message}");
        }
    }

    // --- WebSocket ---

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected)
        {
            Msg.Error("Not connected to agent");
            return null;
        }

        try
        {
            return await Relay.SendAndReceive(payload);
        }
        catch (Exception ex)
        {
            Msg.Error($"Command failed: {ex.Message}");
            return null;
        }
    }

    private async Task OnEntryDoubleClick(DirEntry entry)
    {
        if (entry.IsDirectory || entry.IsDrive)
            await OpenAsDirectory(entry.Name);
        else if (IsFileSynced(entry.Name))
            await ViewFile(entry.Name);
    }

    private bool IsFileSynced(string fileName)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return false;
        var dl = Downloads.Find(AgentUuid, currentPath + fileName);
        return dl?.Status == DownloadStatus.Completed;
    }
}