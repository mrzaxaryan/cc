@inherits Microsoft.AspNetCore.Components.ComponentBase

<input class="cc-input @SizeClass @CssClass @(Monospace ? "cc-input-mono" : "")"
       type="@Type"
       value="@Value"
       @onchange="OnValueChanged"
       @oninput="OnInputEvent"
       @onkeydown="OnKeyDown"
       @onfocus="OnFocus"
       @onblur="OnBlur"
       placeholder="@Placeholder"
       disabled="@Disabled"
       spellcheck="@Spellcheck" />

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback OnFocus { get; set; }
    [Parameter] public EventCallback OnBlur { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Monospace { get; set; }
    [Parameter] public string? Spellcheck { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool BindOnInput { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Sm;

    private string SizeClass => Size switch
    {
        Size.Xs => "cc-input-xs",
        Size.Md => "cc-input-md",
        Size.Lg => "cc-input-lg",
        _ => ""
    };

    private async Task OnValueChanged(ChangeEventArgs e)
    {
        if (!BindOnInput)
            await ValueChanged.InvokeAsync(e.Value?.ToString());
    }

    private async Task OnInputEvent(ChangeEventArgs e)
    {
        if (BindOnInput)
            await ValueChanged.InvokeAsync(e.Value?.ToString());
    }
}
