@inherits Microsoft.AspNetCore.Components.ComponentBase

<div class="cc-progress @SizeClass @CssClass">
    <div class="cc-progress-fill @VariantClass" style="width:@Percent%"></div>
</div>

@code {
    [Parameter] public int Percent { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public ProgressVariant Variant { get; set; } = ProgressVariant.Info;
    [Parameter] public Size Size { get; set; } = Size.Sm;

    private string VariantClass => Variant switch
    {
        ProgressVariant.Success => "cc-progress-success",
        ProgressVariant.Warning => "cc-progress-warning",
        ProgressVariant.Danger => "cc-progress-danger",
        ProgressVariant.Muted => "cc-progress-muted",
        _ => "cc-progress-info"
    };

    private string SizeClass => Size switch
    {
        Size.Xs => "cc-progress-xs",
        _ => ""
    };
}
