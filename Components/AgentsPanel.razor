@inject HttpClient Http
@inject WindowManager Wm
@inject RelayStore Store
@inject MessageService Msg
@using System.Net.WebSockets
@using System.Text
@using System.Text.Json
@implements IAsyncDisposable

@if (agents is null)
{
    <p><em>Connecting to events...</em></p>
}
else
{
    <div class="card mb-3">
        <div class="card-body d-flex align-items-center gap-3">
            <div>
                <h6 class="card-title mb-0">Connected</h6>
                <p class="card-text display-6 mb-0">@agents.Count</p>
            </div>
            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="badge @(eventsConnected ? "bg-success" : "bg-danger")">
                    @(eventsConnected ? "Live" : "Disconnected")
                </span>
                @if (eventsConnected)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="DisconnectEvents">Disconnect</button>
                }
                else
                {
                    <button class="btn btn-outline-success btn-sm" @onclick="ReconnectEvents">Connect</button>
                }
            </div>
        </div>
    </div>

    @if (agents.Connections.Length == 0)
    {
        <p><em>No agents connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Network</th>
                        <th>Connected At</th>
                        <th>Messages</th>
                        <th>Relayed</th>
                        <th>Relay ID</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in agents.Connections)
                    {
                        <tr class="@(Wm.ConnectedAgentIds.Contains(agent.Id) ? "table-active" : "")"
                            style="cursor:context-menu"
                            @oncontextmenu="(e) => ShowContextMenu(e, agent.Id)"
                            @oncontextmenu:preventDefault="true">
                            <td><code>@agent.Id</code></td>
                            <td><code>@agent.Ip</code></td>
                            <td>@Formatters.FormatLocation(agent)</td>
                            <td>@Formatters.FormatNetwork(agent)</td>
                            <td>@Formatters.FormatTimestamp(agent.ConnectedAt)</td>
                            <td>@agent.MessageCount</td>
                            <td>
                                @if (agent.Relayed || Wm.ConnectedAgentIds.Contains(agent.Id))
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td><code>@(agent.RelayId ?? (Wm.ConnectedAgentIds.Contains(agent.Id) ? "local" : "—"))</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* Context menu *@
@if (ctxVisible)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index:1050;" @onclick="HideContextMenu" @oncontextmenu="HideContextMenu" @oncontextmenu:preventDefault="true"></div>
    <div class="dropdown-menu show shadow" style="position:fixed;left:@(ctxX)px;top:@(ctxY)px;z-index:1051;">
        <button class="dropdown-item" @onclick="CtxOpenFiles">File Manager</button>
        @if (Wm.ConnectedAgentIds.Contains(ctxAgentId!))
        {
            <button class="dropdown-item text-danger" @onclick="CtxDisconnect">Disconnect</button>
        }
    </div>
}

@code {
    private static readonly JsonSerializerOptions JsonOptions = new() { PropertyNameCaseInsensitive = true };

    private GroupInfo<AgentConnection>? agents;
    private bool eventsConnected;

    // Events WebSocket
    private ClientWebSocket? eventsWs;
    private CancellationTokenSource? eventsCts;

    private bool _disposing;

    // Context menu
    private bool ctxVisible;
    private double ctxX;
    private double ctxY;
    private string? ctxAgentId;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        _ = ConnectToEvents();
    }

    // --- Context menu ---

    private void ShowContextMenu(MouseEventArgs e, string agentId)
    {
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxAgentId = agentId;
        ctxVisible = true;
    }

    private void HideContextMenu() => ctxVisible = false;

    private async Task CtxOpenFiles()
    {
        HideContextMenu();
        if (ctxAgentId is not null)
            await OpenAgentWindow("File Manager", ctxAgentId);
    }

    private async Task CtxDisconnect()
    {
        HideContextMenu();
        if (ctxAgentId is not null)
            await Wm.DisconnectAgent(ctxAgentId);
    }

    private async Task OpenAgentWindow(string panel, string agentId)
    {
        var relay = await CreateRelay(agentId);
        if (relay is not null)
            Wm.OpenAgentWindow(panel, agentId, relay);
    }

    // --- Events WebSocket ---

    private async Task DisconnectEvents()
    {
        eventsCts?.Cancel();
        agents = null;
        await Wm.CloseAllWindows();
    }

    private void ReconnectEvents()
    {
        eventsCts?.Cancel();
        _ = ConnectToEvents();
    }

    private async Task ConnectToEvents()
    {
        eventsCts = new CancellationTokenSource();
        var token = eventsCts.Token;

        while (!token.IsCancellationRequested)
        {
            try
            {
                eventsWs = new ClientWebSocket();
                await eventsWs.ConnectAsync(new Uri($"{Store.WsBaseUrl}/events"), token);
                eventsConnected = true;
                await InvokeAsync(StateHasChanged);

                var buffer = new byte[65536];
                while (eventsWs.State == WebSocketState.Open && !token.IsCancellationRequested)
                {
                    using var ms = new MemoryStream();
                    WebSocketReceiveResult result;
                    do
                    {
                        result = await eventsWs.ReceiveAsync(buffer, token);
                        ms.Write(buffer, 0, result.Count);
                    } while (!result.EndOfMessage);

                    if (result.MessageType == WebSocketMessageType.Close) break;

                    var json = Encoding.UTF8.GetString(ms.ToArray());
                    HandleEventMessage(json);
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception) when (!token.IsCancellationRequested)
            {
                // Connection error — cleanup happens in finally
            }
            finally
            {
                eventsWs?.Dispose();
                eventsWs = null;
                eventsConnected = false;
                agents = null;
                if (!_disposing)
                    await InvokeAsync(StateHasChanged);
            }

            if (!token.IsCancellationRequested)
                await Task.Delay(3000, token).ContinueWith(_ => { });
        }
    }

    private void HandleEventMessage(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.ValueKind != JsonValueKind.Object || !root.TryGetProperty("type", out var typeProp))
            {
                Msg.Warn($"Unknown event: {json[..Math.Min(json.Length, 200)]}");
                return;
            }

            var type = typeProp.GetString();

            if (type == "agents" && root.TryGetProperty("agents", out var agentsProp))
            {
                var agentArray = JsonSerializer.Deserialize<AgentConnection[]>(agentsProp.GetRawText(), JsonOptions) ?? [];
                agents = new GroupInfo<AgentConnection>
                {
                    Count = agentArray.Length,
                    Connections = agentArray
                };

                // Disconnect windows for agents no longer in the list
                foreach (var id in Wm.ConnectedAgentIds.ToList())
                {
                    if (!agentArray.Any(a => a.Id == id))
                        _ = Wm.DisconnectAgent(id);
                }

            }
            else
            {
                var agent = root.TryGetProperty("agent", out var agentProp)
                    ? JsonSerializer.Deserialize<AgentConnection>(agentProp.GetRawText(), JsonOptions)
                    : null;

                if (agents is null) return;

                if (type == "agent_connected" && agent is not null)
                {
                    var list = agents.Connections.ToList();
                    list.Add(agent);
                    agents = new GroupInfo<AgentConnection>
                    {
                        Count = list.Count,
                        Connections = list.ToArray()
                    };
                }
                else if (type == "agent_disconnected" && agent is not null)
                {
                    var list = agents.Connections.Where(a => a.Id != agent.Id).ToList();
                    agents = new GroupInfo<AgentConnection>
                    {
                        Count = list.Count,
                        Connections = list.ToArray()
                    };

                    if (Wm.ConnectedAgentIds.Contains(agent.Id))
                    {
                        _ = Wm.DisconnectAgent(agent.Id);
                        Msg.Warn("Agent disconnected.");
                    }
                }
                else if (type == "agent_relayed" && agent is not null)
                {
                    var existing = agents.Connections.FirstOrDefault(a => a.Id == agent.Id);
                    if (existing is not null)
                    {
                        existing.Relayed = true;
                        existing.RelayId = agent.RelayId;
                        agents = new GroupInfo<AgentConnection>
                        {
                            Count = agents.Count,
                            Connections = agents.Connections.ToArray()
                        };
                    }
                }
                else if (type == "agent_unrelayed" && agent is not null)
                {
                    var existing = agents.Connections.FirstOrDefault(a => a.Id == agent.Id);
                    if (existing is not null)
                    {
                        existing.Relayed = false;
                        existing.RelayId = null;
                        agents = new GroupInfo<AgentConnection>
                        {
                            Count = agents.Count,
                            Connections = agents.Connections.ToArray()
                        };
                    }

                    if (Wm.ConnectedAgentIds.Contains(agent.Id))
                    {
                        _ = Wm.DisconnectAgent(agent.Id);
                        Msg.Warn("Agent relay disconnected.");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Msg.Error($"Event parse error: {ex.Message}");
        }
    }

    // --- Relay connection ---

    private async Task<RelaySocket?> CreateRelay(string agentId)
    {
        // Reuse existing relay for this agent if one exists
        var existingWin = Wm.Windows.FirstOrDefault(w => w.AgentId == agentId && w.Relay is { IsConnected: true });
        if (existingWin?.Relay is not null)
            return existingWin.Relay;

        var relay = new RelaySocket { BaseUrl = Store.WsBaseUrl };
        try
        {
            await relay.Connect(agentId);
            return relay;
        }
        catch (Exception ex)
        {
            Msg.Error($"Connection failed: {ex.Message}");
            await relay.Disconnect();
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposing = true;
        eventsCts?.Cancel();
        if (eventsWs is not null)
        {
            eventsWs.Dispose();
            eventsWs = null;
        }
        eventsCts?.Dispose();
    }
}
