@inject WindowManager Wm
@inject RelayStore Store
@inject AgentStore AgentDb
@inject RelayConnectionService Relay
@implements IDisposable

@if (Relay.RelayStates.Count == 0)
{
    <p><em>Connecting to events...</em></p>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-3">
        @foreach (var rs in Relay.RelayStates.Values)
        {
            <div class="card flex-fill" style="min-width:200px">
                <div class="card-body py-2 px-3 d-flex align-items-center gap-2">
                    <div class="d-flex flex-column lh-sm" style="min-width:0">
                        <div class="d-flex align-items-center gap-1 flex-wrap">
                            <span class="fw-semibold text-truncate">@rs.Name</span>
                            <span class="badge @(rs.Connected ? "bg-success" : "bg-danger") badge-sm">@(rs.Connected ? "Live" : "Off")</span>
                            <span class="badge bg-dark badge-sm">@GetProtocolShort(rs.Url)</span>
                        </div>
                        <code class="small text-muted text-truncate" title="@rs.Url" style="font-size:.7rem">@GetHostFromUrl(rs.Url)</code>
                        @if (rs.Connected)
                        {
                            <small class="text-muted" style="font-size:.65rem">
                                @(rs.Agents?.Count ?? 0) agent@(rs.Agents?.Count != 1 ? "s" : "") connected
                            </small>
                        }
                        else if (rs.ReconnectAt is not null)
                        {
                            var secs = Math.Max(0, (int)Math.Ceiling((rs.ReconnectAt.Value - DateTime.UtcNow).TotalSeconds));
                            <small class="text-warning" style="font-size:.65rem">
                                Reconnecting in @(secs)s...
                                <button class="btn btn-link btn-sm p-0 text-success" style="font-size:.65rem;vertical-align:baseline" @onclick="() => Relay.ForceReconnect(rs.Url)">Connect now</button>
                            </small>
                        }
                        else
                        {
                            <small class="text-danger" style="font-size:.65rem">Disconnected</small>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    var rows = BuildAgentRows(Relay.GetAllAgents());
    if (rows.Count == 0)
    {
        <p><em>No agents known.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped mb-0" style="table-layout:fixed">
                <colgroup>
                    <col style="width:80px" />
                    <col style="width:14%" />
                    <col style="width:90px" />
                    <col style="width:80px" />
                    <col style="width:120px" />
                    <col style="width:18%" />
                    <col />
                    <col style="width:110px" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>UUID</th>
                        <th>Relay Use</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Network</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="@(row.IsOnline && Wm.ConnectedAgentIds.Contains(row.AgentId) ? "table-active" : "") @(!row.IsOnline ? "opacity-50" : "")"
                            style="cursor:context-menu"
                            @oncontextmenu="(e) => ShowContextMenu(e, row.AgentId, row.RelayUrl, row.IsOnline)"
                            @oncontextmenu:preventDefault="true">
                            <td>
                                @if (row.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </td>
                            <td>
                                @if (renamingUuid == row.Uuid)
                                {
                                    <input class="form-control form-control-sm py-0" style="font-size:.8rem" @bind="renameValue"
                                           @onkeydown="OnRenameKeyDown" @onblur="CancelRename" />
                                }
                                else
                                {
                                    @row.Name
                                }
                            </td>
                            <td><code title="@row.Uuid">@(row.Uuid is not null ? row.Uuid[..Math.Min(8, row.Uuid.Length)] : "...")</code></td>
                            <td>
                                @if (row.IsOnline && row.RelayUsed)
                                {
                                    <span class="badge bg-success" style="font-size:0.65rem">Used</span>
                                }
                                else if (row.IsOnline)
                                {
                                    <span class="badge bg-secondary" style="font-size:0.65rem">Unused</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td><code>@row.Ip</code></td>
                            <td>@row.Location</td>
                            <td>@row.Network</td>
                            <td>@row.LastSeen</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* Context menu *@
@if (ctxVisible)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index:1050;" @onclick="HideContextMenu" @oncontextmenu="HideContextMenu" @oncontextmenu:preventDefault="true"></div>
    <div class="dropdown-menu show shadow" style="position:fixed;left:@(ctxX)px;top:@(ctxY)px;z-index:1051;">
        <button class="dropdown-item" @onclick="CtxOpenFiles">File Manager</button>
        <button class="dropdown-item" @onclick="CtxStartRename">Rename</button>
    </div>
}

@code {
    private Timer? _countdownTimer;

    // Context menu
    private bool ctxVisible;
    private double ctxX;
    private double ctxY;
    private string? ctxAgentId;
    private string? ctxRelayUrl;
    private bool ctxIsOnline;

    // Rename
    private string? renamingUuid;
    private string renameValue = "";
    private bool _renameCommitting;

    protected override void OnInitialized()
    {
        Relay.OnChanged += OnServiceChanged;
        Wm.OnChanged += OnServiceChanged;
        _countdownTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 1000, 1000);
    }

    private void OnServiceChanged() => InvokeAsync(StateHasChanged);

    // --- View model ---

    private class AgentRow
    {
        public bool IsOnline { get; set; }
        public string Name { get; set; } = "";
        public string? Uuid { get; set; }
        public string AgentId { get; set; } = "";
        public string RelayUrl { get; set; } = "";
        public string RelayName { get; set; } = "";
        public bool RelayUsed { get; set; }
        public string Ip { get; set; } = "";
        public string Location { get; set; } = "";
        public string Network { get; set; } = "";
        public string LastSeen { get; set; } = "";
    }

    private List<AgentRow> BuildAgentRows(List<(AgentConnection Agent, string RelayUrl)> liveAgents)
    {
        var rows = new List<AgentRow>();
        var seenUuids = new HashSet<string>();

        foreach (var (agent, relayUrl) in liveAgents)
        {
            var uuid = AgentDb.GetUuidByAgentId(agent.Id);
            if (uuid is not null) seenUuids.Add(uuid);

            var record = uuid is not null ? AgentDb.GetByUuid(uuid) : null;
            var relayName = Relay.RelayStates.TryGetValue(relayUrl, out var s) ? s.Name : relayUrl;

            rows.Add(new AgentRow
            {
                IsOnline = true,
                Name = record?.Name ?? "—",
                Uuid = uuid,
                AgentId = agent.Id,
                RelayUrl = relayUrl,
                RelayName = relayName,
                RelayUsed = Wm.ConnectedAgentIds.Contains(agent.Id),
                Ip = agent.Ip,
                Location = Formatters.FormatLocation(agent),
                Network = Formatters.FormatNetwork(agent),
                LastSeen = "Now"
            });
        }

        foreach (var record in AgentDb.Agents.Values)
        {
            if (seenUuids.Contains(record.Uuid)) continue;

            var relayEntry = !string.IsNullOrEmpty(record.RelayStoreId) ? Store.GetById(record.RelayStoreId) : null;
            var relayName = relayEntry?.Name ?? "—";

            rows.Add(new AgentRow
            {
                IsOnline = false,
                Name = record.Name,
                Uuid = record.Uuid,
                AgentId = record.AgentId,
                RelayUrl = relayEntry?.Url ?? "",
                RelayName = relayName,
                Ip = record.Ip,
                Location = FormatStoredLocation(record),
                Network = FormatStoredNetwork(record),
                LastSeen = Formatters.FormatTimestamp(record.LastSeen)
            });
        }

        return rows;
    }

    private static string GetProtocolShort(string url)
    {
        if (url.StartsWith("wss://")) return "WSS";
        if (url.StartsWith("ws://")) return "WS";
        if (url.StartsWith("https://")) return "HTTPS";
        if (url.StartsWith("http://")) return "HTTP";
        return "?";
    }

    private static string GetHostFromUrl(string url)
    {
        try { return new Uri(url).Host; }
        catch { return url; }
    }

    private static string FormatStoredLocation(AgentRecord r)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(r.City)) parts.Add(r.City);
        if (!string.IsNullOrEmpty(r.Region)) parts.Add(r.Region);
        if (!string.IsNullOrEmpty(r.Country)) parts.Add(r.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "—";
    }

    private static string FormatStoredNetwork(AgentRecord r)
    {
        if (r.Asn > 0 && !string.IsNullOrEmpty(r.AsOrganization))
            return $"AS{r.Asn} {r.AsOrganization}";
        return "—";
    }

    // --- Context menu ---

    private void ShowContextMenu(MouseEventArgs e, string agentId, string relayUrl, bool isOnline)
    {
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxAgentId = agentId;
        ctxRelayUrl = relayUrl;
        ctxIsOnline = isOnline;
        ctxVisible = true;
    }

    private void HideContextMenu() => ctxVisible = false;

    private async Task CtxOpenFiles()
    {
        HideContextMenu();
        if (ctxAgentId is not null && ctxRelayUrl is not null)
            await OpenAgentWindow("File Manager", ctxAgentId, ctxRelayUrl);
    }

    private async Task OpenAgentWindow(string panel, string agentId, string relayUrl)
    {
        var relay = await Relay.CreateRelay(agentId, relayUrl);
        var uuid = AgentDb.GetUuidByAgentId(agentId);
        var name = uuid is not null ? AgentDb.GetByUuid(uuid)?.Name : null;
        Wm.OpenAgentWindow(panel, agentId, relay, name, uuid);
    }

    // --- Rename ---

    private void CtxStartRename()
    {
        HideContextMenu();
        if (ctxAgentId is null) return;
        var uuid = AgentDb.GetUuidByAgentId(ctxAgentId);
        if (uuid is null) return;
        var record = AgentDb.GetByUuid(uuid);
        if (record is null) return;
        renamingUuid = uuid;
        renameValue = record.Name;
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitRename();
        else if (e.Key == "Escape") CancelRename();
    }

    private void CancelRename()
    {
        if (!_renameCommitting) renamingUuid = null;
    }

    private async Task CommitRename()
    {
        if (renamingUuid is null) return;
        _renameCommitting = true;
        try
        {
            var newName = renameValue.Trim();
            if (string.IsNullOrEmpty(newName)) { renamingUuid = null; return; }

            var record = AgentDb.GetByUuid(renamingUuid);
            if (record is not null && record.Name != newName)
            {
                await AgentDb.RenameAsync(renamingUuid, newName);
            }
            renamingUuid = null;
        }
        finally
        {
            _renameCommitting = false;
        }
    }

    public void Dispose()
    {
        _countdownTimer?.Dispose();
        Relay.OnChanged -= OnServiceChanged;
        Wm.OnChanged -= OnServiceChanged;
    }
}
