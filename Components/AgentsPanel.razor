@inject HttpClient Http
@inject WindowManager Wm
@inject RelayStore Store
@inject MessageService Msg
@inject AgentStore AgentDb
@using System.Net.WebSockets
@using System.Text
@using System.Text.Json
@implements IAsyncDisposable

@if (relayStates.Count == 0)
{
    <p><em>Connecting to events...</em></p>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-3">
        @foreach (var rs in relayStates.Values)
        {
            <div class="card flex-fill" style="min-width:220px">
                <div class="card-body d-flex align-items-center gap-3">
                    <div>
                        <h6 class="card-title mb-0">@rs.Name</h6>
                        <p class="card-text display-6 mb-0">@(rs.Agents?.Count ?? 0)</p>
                    </div>
                    <div class="ms-auto d-flex align-items-center gap-2">
                        <span class="badge @(rs.Connected ? "bg-success" : "bg-danger")">
                            @(rs.Connected ? "Live" : "Disconnected")
                        </span>
                        @if (rs.Connected)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DisconnectRelay(rs.Url)">Disconnect</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm" @onclick="() => ReconnectRelay(rs.Url)">Connect</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    var rows = BuildAgentRows(GetAllAgents());
    if (rows.Count == 0)
    {
        <p><em>No agents known.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>UUID</th>
                        <th>Source</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Network</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="@(row.IsOnline && Wm.ConnectedAgentIds.Contains(row.AgentId) ? "table-active" : "") @(!row.IsOnline ? "opacity-50" : "")"
                            style="cursor:context-menu"
                            @oncontextmenu="(e) => ShowContextMenu(e, row.AgentId, row.RelayUrl)"
                            @oncontextmenu:preventDefault="true">
                            <td>
                                @if (row.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </td>
                            <td>@row.Name</td>
                            <td><code title="@row.Uuid">@(row.Uuid is not null ? row.Uuid[..Math.Min(8, row.Uuid.Length)] : "...")</code></td>
                            <td><span class="badge bg-info">@row.RelayName</span></td>
                            <td><code>@row.Ip</code></td>
                            <td>@row.Location</td>
                            <td>@row.Network</td>
                            <td>@row.LastSeen</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* Context menu *@
@if (ctxVisible)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index:1050;" @onclick="HideContextMenu" @oncontextmenu="HideContextMenu" @oncontextmenu:preventDefault="true"></div>
    <div class="dropdown-menu show shadow" style="position:fixed;left:@(ctxX)px;top:@(ctxY)px;z-index:1051;">
        <button class="dropdown-item" @onclick="CtxOpenFiles">File Manager</button>
        @if (Wm.ConnectedAgentIds.Contains(ctxAgentId!))
        {
            <button class="dropdown-item text-danger" @onclick="CtxDisconnect">Disconnect</button>
        }
    </div>
}

@code {
    private static readonly JsonSerializerOptions JsonOptions = new() { PropertyNameCaseInsensitive = true };

    // Per-relay state
    private class RelayState
    {
        public string Url { get; set; } = "";
        public string Name { get; set; } = "";
        public bool Connected { get; set; }
        public GroupInfo<AgentConnection>? Agents { get; set; }
        public ClientWebSocket? Ws { get; set; }
        public CancellationTokenSource? Cts { get; set; }
    }

    private readonly Dictionary<string, RelayState> relayStates = new();

    private bool _disposing;

    // Context menu
    private bool ctxVisible;
    private double ctxX;
    private double ctxY;
    private string? ctxAgentId;
    private string? ctxRelayUrl;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        await AgentDb.LoadAsync();
        ConnectAllRelays();
    }

    private void ConnectAllRelays()
    {
        foreach (var relay in Store.Relays)
        {
            if (!relayStates.ContainsKey(relay.Url))
            {
                relayStates[relay.Url] = new RelayState { Url = relay.Url, Name = relay.Name };
                _ = ConnectToEvents(relay.Url);
            }
        }
    }

    private List<(AgentConnection Agent, string RelayUrl)> GetAllAgents()
    {
        var result = new List<(AgentConnection, string)>();
        foreach (var rs in relayStates.Values)
        {
            if (rs.Agents?.Connections is not null)
            {
                foreach (var agent in rs.Agents.Connections)
                    result.Add((agent, rs.Url));
            }
        }
        return result;
    }

    // --- View model ---

    private class AgentRow
    {
        public bool IsOnline { get; set; }
        public string Name { get; set; } = "";
        public string? Uuid { get; set; }
        public string AgentId { get; set; } = "";
        public string RelayUrl { get; set; } = "";
        public string RelayName { get; set; } = "";
        public string Ip { get; set; } = "";
        public string Location { get; set; } = "";
        public string Network { get; set; } = "";
        public string LastSeen { get; set; } = "";
    }

    private List<AgentRow> BuildAgentRows(List<(AgentConnection Agent, string RelayUrl)> liveAgents)
    {
        var rows = new List<AgentRow>();
        var seenUuids = new HashSet<string>();

        // Online agents first
        foreach (var (agent, relayUrl) in liveAgents)
        {
            var uuid = AgentDb.GetUuidByAgentId(agent.Id);
            if (uuid is not null) seenUuids.Add(uuid);

            var record = uuid is not null ? AgentDb.GetByUuid(uuid) : null;
            var relayName = relayStates.TryGetValue(relayUrl, out var s) ? s.Name : relayUrl;

            rows.Add(new AgentRow
            {
                IsOnline = true,
                Name = record?.Name ?? "—",
                Uuid = uuid,
                AgentId = agent.Id,
                RelayUrl = relayUrl,
                RelayName = relayName,
                Ip = agent.Ip,
                Location = Formatters.FormatLocation(agent),
                Network = Formatters.FormatNetwork(agent),
                LastSeen = "Now"
            });
        }

        // Offline agents from store
        foreach (var record in AgentDb.Agents.Values)
        {
            if (seenUuids.Contains(record.Uuid)) continue;

            var relayName = relayStates.TryGetValue(record.RelayUrl, out var s) ? s.Name : record.RelayUrl;

            rows.Add(new AgentRow
            {
                IsOnline = false,
                Name = record.Name,
                Uuid = record.Uuid,
                AgentId = record.AgentId,
                RelayUrl = record.RelayUrl,
                RelayName = relayName,
                Ip = record.Ip,
                Location = FormatStoredLocation(record),
                Network = FormatStoredNetwork(record),
                LastSeen = Formatters.FormatTimestamp(record.LastSeen)
            });
        }

        return rows;
    }

    private static string FormatStoredLocation(AgentRecord r)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(r.City)) parts.Add(r.City);
        if (!string.IsNullOrEmpty(r.Region)) parts.Add(r.Region);
        if (!string.IsNullOrEmpty(r.Country)) parts.Add(r.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "—";
    }

    private static string FormatStoredNetwork(AgentRecord r)
    {
        if (r.Asn > 0 && !string.IsNullOrEmpty(r.AsOrganization))
            return $"AS{r.Asn} {r.AsOrganization}";
        return "—";
    }

    // --- Context menu ---

    private void ShowContextMenu(MouseEventArgs e, string agentId, string relayUrl)
    {
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxAgentId = agentId;
        ctxRelayUrl = relayUrl;
        ctxVisible = true;
    }

    private void HideContextMenu() => ctxVisible = false;

    private async Task CtxOpenFiles()
    {
        HideContextMenu();
        if (ctxAgentId is not null && ctxRelayUrl is not null)
            await OpenAgentWindow("File Manager", ctxAgentId, ctxRelayUrl);
    }

    private async Task CtxDisconnect()
    {
        HideContextMenu();
        if (ctxAgentId is not null)
            await Wm.DisconnectAgent(ctxAgentId);
    }

    private async Task OpenAgentWindow(string panel, string agentId, string relayUrl)
    {
        var relay = await CreateRelay(agentId, relayUrl);
        if (relay is not null)
            Wm.OpenAgentWindow(panel, agentId, relay);
    }

    // --- UUID fetching ---

    private async Task FetchUuid(AgentConnection agent, string relayUrl)
    {
        var relay = new RelaySocket { BaseUrl = relayUrl };
        try
        {
            await relay.Connect(agent.Id);
            var response = await relay.SendAndReceive(new byte[] { 0x00 });
            if (response is not null && response.Length >= 20)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status == 0)
                {
                    var uuid = RelaySocket.ReadUuid(response).ToString();
                    await AgentDb.UpsertAsync(uuid, agent, relayUrl);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch { }
        finally
        {
            await relay.Disconnect();
        }
    }

    private void FetchUuidsForAgents(AgentConnection[] agents, string relayUrl)
    {
        foreach (var agent in agents)
        {
            if (AgentDb.GetUuidByAgentId(agent.Id) is null)
                _ = FetchUuid(agent, relayUrl);
        }
    }

    // --- Events WebSocket (per relay) ---

    private async Task DisconnectRelay(string url)
    {
        if (relayStates.TryGetValue(url, out var rs))
        {
            rs.Cts?.Cancel();

            // Disconnect all agents from this relay
            if (rs.Agents?.Connections is not null)
            {
                foreach (var agent in rs.Agents.Connections)
                {
                    if (Wm.ConnectedAgentIds.Contains(agent.Id))
                        await Wm.DisconnectAgent(agent.Id);
                }
            }
            rs.Agents = null;
        }
    }

    private void ReconnectRelay(string url)
    {
        if (relayStates.TryGetValue(url, out var rs))
        {
            rs.Cts?.Cancel();
            _ = ConnectToEvents(url);
        }
    }

    private async Task ConnectToEvents(string relayUrl)
    {
        if (!relayStates.TryGetValue(relayUrl, out var rs)) return;

        rs.Cts = new CancellationTokenSource();
        var token = rs.Cts.Token;

        while (!token.IsCancellationRequested)
        {
            try
            {
                rs.Ws = new ClientWebSocket();
                await rs.Ws.ConnectAsync(new Uri($"{relayUrl}/events"), token);
                rs.Connected = true;
                await InvokeAsync(StateHasChanged);

                var buffer = new byte[65536];
                while (rs.Ws.State == WebSocketState.Open && !token.IsCancellationRequested)
                {
                    using var ms = new MemoryStream();
                    WebSocketReceiveResult result;
                    do
                    {
                        result = await rs.Ws.ReceiveAsync(buffer, token);
                        ms.Write(buffer, 0, result.Count);
                    } while (!result.EndOfMessage);

                    if (result.MessageType == WebSocketMessageType.Close) break;

                    var json = Encoding.UTF8.GetString(ms.ToArray());
                    HandleEventMessage(json, relayUrl);
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception) when (!token.IsCancellationRequested)
            {
                // Connection error — cleanup happens in finally
            }
            finally
            {
                rs.Ws?.Dispose();
                rs.Ws = null;
                rs.Connected = false;
                rs.Agents = null;
                if (!_disposing)
                    await InvokeAsync(StateHasChanged);
            }

            if (!token.IsCancellationRequested)
                await Task.Delay(3000, token).ContinueWith(_ => { });
        }
    }

    private void HandleEventMessage(string json, string relayUrl)
    {
        if (!relayStates.TryGetValue(relayUrl, out var rs)) return;

        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.ValueKind != JsonValueKind.Object || !root.TryGetProperty("type", out var typeProp))
            {
                Msg.Warn($"Unknown event: {json[..Math.Min(json.Length, 200)]}");
                return;
            }

            var type = typeProp.GetString();

            if (type == "agents" && root.TryGetProperty("agents", out var agentsProp))
            {
                var agentArray = JsonSerializer.Deserialize<AgentConnection[]>(agentsProp.GetRawText(), JsonOptions) ?? [];
                rs.Agents = new GroupInfo<AgentConnection>
                {
                    Count = agentArray.Length,
                    Connections = agentArray
                };

                FetchUuidsForAgents(agentArray, relayUrl);

                // Disconnect windows for agents no longer in any relay
                foreach (var id in Wm.ConnectedAgentIds.ToList())
                {
                    if (!GetAllAgents().Any(a => a.Agent.Id == id))
                        _ = Wm.DisconnectAgent(id);
                }
            }
            else
            {
                var agent = root.TryGetProperty("agent", out var agentProp)
                    ? JsonSerializer.Deserialize<AgentConnection>(agentProp.GetRawText(), JsonOptions)
                    : null;

                if (rs.Agents is null) return;

                if (type == "agent_connected" && agent is not null)
                {
                    var list = rs.Agents.Connections.ToList();
                    list.Add(agent);
                    rs.Agents = new GroupInfo<AgentConnection>
                    {
                        Count = list.Count,
                        Connections = list.ToArray()
                    };

                    _ = FetchUuid(agent, relayUrl);
                }
                else if (type == "agent_disconnected" && agent is not null)
                {
                    var list = rs.Agents.Connections.Where(a => a.Id != agent.Id).ToList();
                    rs.Agents = new GroupInfo<AgentConnection>
                    {
                        Count = list.Count,
                        Connections = list.ToArray()
                    };

                    if (Wm.ConnectedAgentIds.Contains(agent.Id))
                    {
                        _ = Wm.DisconnectAgent(agent.Id);
                        Msg.Warn("Agent disconnected.");
                    }
                }
                else if (type == "agent_relayed" && agent is not null)
                {
                    var existing = rs.Agents.Connections.FirstOrDefault(a => a.Id == agent.Id);
                    if (existing is not null)
                    {
                        existing.Relayed = true;
                        existing.RelayId = agent.RelayId;
                        rs.Agents = new GroupInfo<AgentConnection>
                        {
                            Count = rs.Agents.Count,
                            Connections = rs.Agents.Connections.ToArray()
                        };
                    }
                }
                else if (type == "agent_unrelayed" && agent is not null)
                {
                    var existing = rs.Agents.Connections.FirstOrDefault(a => a.Id == agent.Id);
                    if (existing is not null)
                    {
                        existing.Relayed = false;
                        existing.RelayId = null;
                        rs.Agents = new GroupInfo<AgentConnection>
                        {
                            Count = rs.Agents.Count,
                            Connections = rs.Agents.Connections.ToArray()
                        };
                    }

                    if (Wm.ConnectedAgentIds.Contains(agent.Id))
                    {
                        _ = Wm.DisconnectAgent(agent.Id);
                        Msg.Warn("Agent relay disconnected.");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Msg.Error($"Event parse error: {ex.Message}");
        }
    }

    // --- Relay connection ---

    private async Task<RelaySocket?> CreateRelay(string agentId, string relayUrl)
    {
        // Reuse existing relay for this agent if one exists
        var existingWin = Wm.Windows.FirstOrDefault(w => w.AgentId == agentId && w.Relay is { IsConnected: true });
        if (existingWin?.Relay is not null)
            return existingWin.Relay;

        var relay = new RelaySocket { BaseUrl = relayUrl };
        try
        {
            await relay.Connect(agentId);
            return relay;
        }
        catch (Exception ex)
        {
            Msg.Error($"Connection failed: {ex.Message}");
            await relay.Disconnect();
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposing = true;
        foreach (var rs in relayStates.Values)
        {
            rs.Cts?.Cancel();
            if (rs.Ws is not null)
            {
                rs.Ws.Dispose();
                rs.Ws = null;
            }
            rs.Cts?.Dispose();
        }
        relayStates.Clear();
    }
}
