@using cc.Components
@inject CacheManager Cache
@inject RelayStore Relay
@inject RelayConnectionService RelaySvc
@inject WindowManager Wm
@inject ThemeService Theme
@implements IDisposable

<div class="mdi-menubar">
    <span class="mdi-brand">cc</span>
    <span class="mdi-sep"></span>
    <button class="mdi-menu-item" @onclick='() => Wm.OpenWindow("Relay")'>Relay</button>
    <button class="mdi-menu-item" @onclick='() => Wm.OpenWindow("Agents")'>Agents</button>
    <button class="mdi-menu-item" @onclick='() => Wm.OpenWindow("Cache Manager")'>Cache</button>
    <button class="mdi-menu-item" @onclick='() => Wm.OpenWindow("Downloads")'>Downloads</button>
    <div class="mdi-spacer"></div>
    @foreach (var agentId in Wm.ConnectedAgentIds)
    {
        <span class="mdi-status connected" title="Connected agent">@agentId</span>
    }
    <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle theme">
        @if (Theme.Current == cc.Services.Theme.Dark)
        {
            <span>&#9788;</span>
        }
        else
        {
            <span>&#9790;</span>
        }
    </button>
</div>

<div class="mdi-workspace"></div>

<FloatingWindows />
<ToastContainer />

@if (showWelcome)
{
    <Welcome OnComplete="OnWelcomeComplete" />
}

@code {
    private bool showWelcome;
    private bool initialized;

    protected override void OnInitialized()
    {
        Wm.OnChanged += OnWmChanged;
        Theme.OnChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            initialized = true;
            await Theme.InitializeAsync();
            await Cache.InitializeAsync();
            await Relay.LoadAsync();
            await RelaySvc.StartAsync();
            if (Cache.SetupRequired || Cache.NeedsPermission || Relay.SetupRequired)
            {
                showWelcome = true;
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme() => await Theme.Toggle();

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    private void OnWelcomeComplete()
    {
        showWelcome = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        Wm.OnChanged -= OnWmChanged;
        Theme.OnChanged -= OnThemeChanged;
    }
}
