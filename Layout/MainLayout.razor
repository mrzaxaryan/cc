@inherits LayoutComponentBase
@using cc.Components
@inject CacheManager Cache
@inject RelayStore Relay

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<FloatingWindows />

@if (showWelcome)
{
    <Welcome OnComplete="OnWelcomeComplete" />
}

@code {
    private bool showWelcome;
    private bool initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            initialized = true;
            await Cache.InitializeAsync();
            await Relay.LoadAsync();
            if (Cache.SetupRequired || Cache.NeedsPermission || Relay.SetupRequired)
            {
                showWelcome = true;
                StateHasChanged();
            }
        }
    }

    private void OnWelcomeComplete()
    {
        showWelcome = false;
        StateHasChanged();
    }
}
