@inherits Microsoft.AspNetCore.Components.ComponentBase

<button class="cc-btn @VariantClass @SizeClass @CssClass"
        @onclick="OnClick"
        @onclick:stopPropagation="StopPropagation"
        disabled="@Disabled"
        title="@Title"
        type="button">
    @if (Loading)
    {
        <span class="cc-spinner cc-spinner-inline"></span>
    }
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool StopPropagation { get; set; }
    [Parameter] public BtnVariant Variant { get; set; } = BtnVariant.Default;
    [Parameter] public Size Size { get; set; } = Size.Sm;

    private string VariantClass => Variant switch
    {
        BtnVariant.Primary => "cc-btn-primary",
        BtnVariant.Success => "cc-btn-success",
        BtnVariant.Danger => "cc-btn-danger",
        BtnVariant.DangerSolid => "cc-btn-danger-solid",
        BtnVariant.Warning => "cc-btn-warning",
        BtnVariant.Ghost => "cc-btn-ghost",
        BtnVariant.Link => "cc-btn-link",
        _ => ""
    };

    private string SizeClass => Size switch
    {
        Size.Xs => "cc-btn-xs",
        Size.Md => "cc-btn-md",
        Size.Lg => "cc-btn-lg",
        Size.Icon => "cc-btn-icon",
        _ => ""
    };
}
