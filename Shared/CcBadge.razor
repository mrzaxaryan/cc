@inherits Microsoft.AspNetCore.Components.ComponentBase

<span class="cc-badge @VariantClass @SizeClass @CssClass" title="@Title">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public BadgeVariant Variant { get; set; } = BadgeVariant.Muted;
    [Parameter] public Size Size { get; set; } = Size.Sm;

    private string VariantClass => Variant switch
    {
        BadgeVariant.Success => "cc-badge-success",
        BadgeVariant.Danger => "cc-badge-danger",
        BadgeVariant.Warning => "cc-badge-warning",
        BadgeVariant.Info => "cc-badge-info",
        BadgeVariant.Dark => "cc-badge-dark",
        _ => "cc-badge-muted"
    };

    private string SizeClass => Size switch
    {
        Size.Xs => "cc-badge-xs",
        _ => ""
    };
}
