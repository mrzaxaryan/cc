@inherits Microsoft.AspNetCore.Components.ComponentBase

@if (Visible)
{
    <div class="c2-dialog-backdrop" @onclick="Cancel"></div>
    <div class="c2-dialog">
        <div class="c2-dialog-header">
            <span class="c2-dialog-title">@Title</span>
            <button class="c2-dialog-close" @onclick="Cancel">&times;</button>
        </div>
        <div class="c2-dialog-body">
            @ChildContent
        </div>
        <div class="c2-dialog-footer">
            <C2Btn OnClick="Cancel">Cancel</C2Btn>
            <C2Btn Variant="BtnVariant.Primary" OnClick="Confirm">@ConfirmText</C2Btn>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string ConfirmText { get; set; } = "OK";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
