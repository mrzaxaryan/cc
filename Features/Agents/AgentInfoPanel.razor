@inherits EventSubscriber
@inject RelayConnectionService Relay
@inject AgentStore AgentDb

@{
    var data = BuildInfo();
}

<PanelLayout Title="Agent Information">
    <HeaderLeft>
        @if (data.IsOnline)
        {
            <CcBadge Variant="BadgeVariant.Success" Size="Size.Xs">Online</CcBadge>
        }
        else
        {
            <CcBadge Variant="BadgeVariant.Muted" Size="Size.Xs">Offline</CcBadge>
        }
    </HeaderLeft>
    <Body>
        <div class="ai-body">
            <table class="ai-table">
                <tbody>
                    @foreach (var row in data.Rows)
                    {
                        <tr>
                            <th>@row.Label</th>
                            <td class="@row.CssClass">@((MarkupString)row.Value)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </Body>
</PanelLayout>

@code {
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private Timer? _refreshTimer;

    protected override void OnInitialized()
    {
        On<RelayAgentsChangedEvent>();
        On<RelayConnectionChangedEvent>();
        _refreshTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 1000, 1000);
    }

    private record InfoRow(string Label, string Value, string? CssClass = null);

    private record InfoData(bool IsOnline, List<InfoRow> Rows);

    private InfoData BuildInfo()
    {
        var rows = new List<InfoRow>();
        AgentConnection? live = null;
        AgentRecord? stored = null;

        // Try to find live connection
        if (!string.IsNullOrEmpty(AgentId))
        {
            live = Relay.GetAllAgents()
                .Select(a => a.Agent)
                .FirstOrDefault(a => a.Id == AgentId);
        }

        // Resolve UUID
        var uuid = AgentUuid;
        if (uuid is null && !string.IsNullOrEmpty(AgentId))
            uuid = AgentDb.GetUuidByAgentId(AgentId);

        if (uuid is not null)
            stored = AgentDb.GetByUuid(uuid);

        var isOnline = live is not null;

        // Status
        var statusDot = isOnline ? "dot-on" : "dot-off";
        rows.Add(new("Status", $"<span class=\"status-dot {statusDot}\"></span> {(isOnline ? "Online" : "Offline")}"));

        // Identity
        Add(rows, "Name", stored?.Name);
        if (uuid is not null)
            rows.Add(new("UUID", $"<code>{uuid}</code>"));
        else if (isOnline)
            rows.Add(new("UUID", "Not yet received", "ai-note"));
        if (!string.IsNullOrEmpty(AgentId))
            rows.Add(new("Agent ID", $"<code>{AgentId}</code>"));

        // Network
        var ip = live?.Ip ?? stored?.Ip;
        if (HasValue(ip)) rows.Add(new("IP Address", $"<code>{ip}</code>"));

        // System
        var os = Pick(live?.Os, stored?.Os);
        if (HasValue(os)) rows.Add(new("Operating System", os!));
        var arch = Pick(live?.Arch, stored?.Arch);
        if (HasValue(arch)) rows.Add(new("Architecture", arch!));

        // Geo
        var country = Pick(live?.Country, stored?.Country);
        var city = Pick(live?.City, stored?.City);
        var region = Pick(live?.Region, stored?.Region);
        var continent = Pick(live?.Continent, stored?.Continent);
        var timezone = Pick(live?.Timezone, stored?.Timezone);

        if (HasValue(country)) rows.Add(new("Country", country!));
        if (HasValue(city)) rows.Add(new("City", city!));
        if (HasValue(region)) rows.Add(new("Region", region!));
        if (HasValue(continent)) rows.Add(new("Continent", continent!));
        if (HasValue(timezone)) rows.Add(new("Timezone", timezone!));

        if (live is not null && HasValue(live.PostalCode))
            rows.Add(new("Postal Code", live.PostalCode));
        if (live is not null && HasValue(live.Latitude) && HasValue(live.Longitude))
            rows.Add(new("Coordinates", $"<code>{live.Latitude}, {live.Longitude}</code>"));

        // ASN
        var asn = live?.Asn ?? 0;
        var asOrg = live?.AsOrganization;
        if (asn > 0) rows.Add(new("Autonomous System Number", asn.ToString()));
        if (HasValue(asOrg)) rows.Add(new("AS Organization", asOrg!));

        // Connection details
        var ua = live?.UserAgent;
        rows.Add(new("User Agent", HasValue(ua) ? ua! : "\u2014", "ai-ua"));

        var tls = live?.TlsVersion;
        if (HasValue(tls)) rows.Add(new("TLS Version", tls!));

        if (live is not null && HasValue(live.HttpVersion))
            rows.Add(new("HTTP Version", live.HttpVersion));

        var reqPri = live?.RequestPriority;
        if (HasValue(reqPri)) rows.Add(new("Request Priority", reqPri!));

        // State
        if (live is not null && live.Paired)
            rows.Add(new("Paired", "Yes"));
        if (live is not null && live.MessagesForwarded > 0)
            rows.Add(new("Messages Forwarded", live.MessagesForwarded.ToString()));

        // Timestamps
        if (live is not null && live.ConnectedAt > 0)
            rows.Add(new("Connected At", Formatters.FormatTimestamp(live.ConnectedAt)));
        if (stored is not null && stored.FirstSeen > 0)
            rows.Add(new("First Seen", Formatters.FormatTimestamp(stored.FirstSeen)));
        if (stored is not null && stored.LastSeen > 0 && !isOnline)
            rows.Add(new("Last Seen", Formatters.FormatTimestamp(stored.LastSeen)));

        return new InfoData(isOnline, rows);
    }

    private static string? Pick(string? a, string? b) =>
        HasValue(a) ? a : HasValue(b) ? b : null;

    private static bool HasValue(string? v) =>
        !string.IsNullOrWhiteSpace(v) && v != "\u2014";

    private static void Add(List<InfoRow> rows, string label, string? value)
    {
        if (HasValue(value)) rows.Add(new(label, value!));
    }

    public override void Dispose()
    {
        _refreshTimer?.Dispose();
        base.Dispose();
    }
}
