@inherits EventSubscriber
@inject WindowManager Wm
@inject RelayStore Store
@inject AgentStore AgentDb
@inject RelayConnectionService Relay
@inject IJSRuntime Js

@{
    var relays = BuildRelayTabs();
    var rows = BuildAgentRows(Relay.GetAllAgents());
    var filtered = selectedRelay is null ? rows : rows.Where(r => r.RelayUrl == selectedRelay && r.IsOnline).ToList();
    var onlineCount = rows.Count(r => r.IsOnline);
    var offlineCount = rows.Count - onlineCount;
}

<PanelLayout Title="Agents">
    <HeaderLeft>
        @if (onlineCount > 0)
        {
            <CcBadge Variant="BadgeVariant.Success" Size="Size.Xs">@onlineCount Online</CcBadge>
        }
        else
        {
            <CcBadge Variant="BadgeVariant.Muted" Size="Size.Xs">None Online</CcBadge>
        }
    </HeaderLeft>
    <Toolbar>
        <div class="panel-stats">
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-active">@onlineCount</span>
                <span class="panel-stat-label">Online</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@offlineCount</span>
                <span class="panel-stat-label">Offline</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@rows.Count</span>
                <span class="panel-stat-label">Total</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-done">@rows.Count(r => r.Paired)</span>
                <span class="panel-stat-label">Paired</span>
            </div>
        </div>
    </Toolbar>
    <Body>
        <div class="ap-relay-bar">
            <button class="ap-relay-tab @(selectedRelay is null ? "ap-relay-tab--active" : "")"
                    @onclick="() => selectedRelay = null">
                All <span class="ap-relay-count">@rows.Count</span>
            </button>
            @foreach (var relay in relays)
            {
                var url = relay.Url;
                <button class="ap-relay-tab @(selectedRelay == url ? "ap-relay-tab--active" : "")"
                        @onclick="() => selectedRelay = url">
                    <span class="status-dot @(relay.Connected ? "dot-on" : "dot-off")"></span>
                    @relay.Name
                    <span class="ap-relay-count">@relay.AgentCount</span>
                </button>
            }
        </div>
        @if (filtered.Count == 0)
        {
            <div class="panel-empty">No agents known.</div>
        }
        else
        {
            @* Desktop/Tablet: table view *@
            <div class="ap-table-view">
                <CcTable Striped Hover>
                    <thead>
                        <tr>
                            <th class="ap-col-status"></th>
                            <th>Name</th>
                            <th class="ap-col-ip">IP</th>
                            <th class="ap-col-sys">System</th>
                            <th class="ap-col-loc">Location</th>
                            <th class="ap-col-net">Network</th>
                            <th class="ap-col-paired">Paired</th>
                            <th class="ap-col-seen">Last Seen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in filtered)
                        {
                            <CcTr Active="@(row.IsOnline && Wm.ConnectedAgentIds.Contains(row.AgentId))"
                                  Dim="@(!row.IsOnline)"
                                  CssClass="ap-row"
                                  OnContextMenu="(e) => ShowContextMenu(e, row)"
                                  PreventDefault>
                                <td class="ap-col-status">
                                    <span class="status-dot @(row.IsOnline ? "dot-on" : "dot-off")"></span>
                                </td>
                                <td>
                                    <div class="ap-name-cell">
                                        <span class="ap-name">@row.Name</span>
                                        <code class="ap-uuid" title="@row.Uuid">@(row.Uuid is not null ? row.Uuid[..Math.Min(8, row.Uuid.Length)] : "...")</code>
                                    </div>
                                </td>
                                <td class="ap-col-ip"><code>@row.Ip</code></td>
                                <td class="ap-col-sys">
                                    <span class="ap-sys">@row.Os</span>
                                    @if (row.Arch != "\u2014")
                                    {
                                        <span class="ap-arch">@row.Arch</span>
                                    }
                                </td>
                                <td class="ap-col-loc">@row.Location</td>
                                <td class="ap-col-net ap-net-cell">@row.Network</td>
                                <td class="ap-col-paired">
                                    @if (row.Paired)
                                    {
                                        <span class="status-dot dot-on"></span>
                                    }
                                </td>
                                <td class="ap-col-seen ap-seen-cell">@row.LastSeen</td>
                            </CcTr>
                        }
                    </tbody>
                </CcTable>
            </div>

            @* Mobile: card view *@
            <div class="ap-card-view">
                @foreach (var row in filtered)
                {
                    <div class="ap-card @(!row.IsOnline ? "ap-card--dim" : "") @(row.IsOnline && Wm.ConnectedAgentIds.Contains(row.AgentId) ? "ap-card--active" : "")"
                         @oncontextmenu="(e) => ShowContextMenu(e, row)"
                         @oncontextmenu:preventDefault>
                        <div class="ap-card-top">
                            <span class="status-dot @(row.IsOnline ? "dot-on" : "dot-off")"></span>
                            <span class="ap-card-name">@row.Name</span>
                            @if (row.Paired)
                            {
                                <span class="status-dot dot-on ap-card-paired"></span>
                            }
                            <span class="ap-card-seen">@row.LastSeen</span>
                        </div>
                        <div class="ap-card-details">
                            <span class="ap-card-detail"><code>@row.Ip</code></span>
                            <span class="ap-card-detail">@row.Os @(row.Arch != "\u2014" ? row.Arch : "")</span>
                            @if (!string.IsNullOrEmpty(row.Location) && row.Location != "\u2014")
                            {
                                <span class="ap-card-detail">@row.Location</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </Body>
</PanelLayout>

<CcDropdown Visible="@ctxVisible" X="@ctxX" Y="@ctxY" OnClose="HideContextMenu">
    <CcDropdownItem OnClick="CtxShowInfo">Information</CcDropdownItem>
    @if (ctxRow is not null)
    {
        <div class="ap-ctx-submenu-wrap">
            <button class="ap-ctx-sub-trigger" type="button">
                Copy <span class="ap-ctx-arrow">&#9656;</span>
            </button>
            <div class="ap-ctx-submenu">
                @foreach (var item in GetCopyItems(ctxRow))
                {
                    var val = item.Value;
                    <CcDropdownItem OnClick="() => CtxCopy(val)" CssClass="ap-ctx-copy-item">@item.Label</CcDropdownItem>
                }
            </div>
        </div>
    }
    <CcDropdownItem OnClick="CtxOpenFiles" Disabled="@(!ctxIsOnline)">File Manager</CcDropdownItem>
    <CcDropdownItem OnClick="CtxOpenShell" Disabled="@(!ctxIsOnline)">Shell</CcDropdownItem>
    <CcDropdownItem OnClick="CtxStartRename" Disabled="@(!ctxIsOnline)">Rename</CcDropdownItem>
</CcDropdown>

<CcDialog Visible="@renameVisible" Title="Rename Agent" ConfirmText="Rename"
          OnConfirm="CommitRename" OnCancel="CancelRename">
    <CcInput @bind-Value="renameValue" BindOnInput Placeholder="Agent name"
             OnKeyDown="OnRenameKeyDown" />
</CcDialog>

@code {
    private Timer? _countdownTimer;
    private string? selectedRelay;

    private bool ctxVisible;
    private double ctxX;
    private double ctxY;
    private string? ctxAgentId;
    private string? ctxRelayUrl;
    private bool ctxIsOnline;
    private AgentRow? ctxRow;

    private bool renameVisible;
    private string? renamingUuid;
    private string renameValue = "";

    protected override void OnInitialized()
    {
        On<RelayAgentsChangedEvent>();
        On<RelayConnectionChangedEvent>();
        On<WindowChangedEvent>();
        On<AgentConnectedEvent>();
        On<AgentDisconnectedEvent>();
        On<AgentPairingChangedEvent>();
        _countdownTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 1000, 1000);
    }

    private class RelayTab
    {
        public string Url { get; set; } = "";
        public string Name { get; set; } = "";
        public bool Connected { get; set; }
        public int AgentCount { get; set; }
    }

    private class AgentRow
    {
        public bool IsOnline { get; set; }
        public string Name { get; set; } = "";
        public string? Uuid { get; set; }
        public string AgentId { get; set; } = "";
        public string RelayUrl { get; set; } = "";
        public string Ip { get; set; } = "";
        public string Os { get; set; } = "";
        public string Arch { get; set; } = "";
        public string Location { get; set; } = "";
        public string Network { get; set; } = "";
        public bool Paired { get; set; }
        public string LastSeen { get; set; } = "";
        public string Country { get; set; } = "";
        public string City { get; set; } = "";
        public string Region { get; set; } = "";
        public string Continent { get; set; } = "";
        public string Timezone { get; set; } = "";
        public string PostalCode { get; set; } = "";
        public string Latitude { get; set; } = "";
        public string Longitude { get; set; } = "";
        public int Asn { get; set; }
        public string AsOrganization { get; set; } = "";
        public string UserAgent { get; set; } = "";
        public string RequestPriority { get; set; } = "";
        public string TlsVersion { get; set; } = "";
        public string HttpVersion { get; set; } = "";
        public string ConnectedAt { get; set; } = "";
        public string FirstSeen { get; set; } = "";
        public int MessagesForwarded { get; set; }
    }

    private List<RelayTab> BuildRelayTabs()
    {
        var tabs = new List<RelayTab>();
        foreach (var (url, rs) in Relay.RelayStates)
        {
            tabs.Add(new RelayTab
            {
                Url = url,
                Name = rs.Name,
                Connected = rs.Connected,
                AgentCount = rs.Agents?.Connections?.Length ?? 0
            });
        }
        return tabs;
    }

    private List<AgentRow> BuildAgentRows(List<(AgentConnection Agent, string RelayUrl)> liveAgents)
    {
        var rows = new List<AgentRow>();
        var seenUuids = new HashSet<string>();

        foreach (var (agent, relayUrl) in liveAgents)
        {
            var uuid = AgentDb.GetUuidByAgentId(agent.Id);
            if (uuid is not null) seenUuids.Add(uuid);

            var record = uuid is not null ? AgentDb.GetByUuid(uuid) : null;

            rows.Add(new AgentRow
            {
                IsOnline = true,
                Name = record?.Name ?? "\u2014",
                Uuid = uuid,
                AgentId = agent.Id,
                RelayUrl = relayUrl,
                Ip = agent.Ip,
                Os = !string.IsNullOrEmpty(agent.Os) ? agent.Os
                    : !string.IsNullOrEmpty(record?.Os) ? record.Os : "\u2014",
                Arch = !string.IsNullOrEmpty(agent.Arch) ? agent.Arch
                    : !string.IsNullOrEmpty(record?.Arch) ? record.Arch : "\u2014",
                Location = Formatters.FormatLocation(agent),
                Network = Formatters.FormatNetwork(agent),
                Paired = agent.Paired,
                LastSeen = "Now",
                Country = agent.Country,
                City = agent.City,
                Region = agent.Region,
                Continent = agent.Continent,
                Timezone = agent.Timezone,
                PostalCode = agent.PostalCode,
                Latitude = agent.Latitude,
                Longitude = agent.Longitude,
                Asn = agent.Asn,
                AsOrganization = agent.AsOrganization,
                UserAgent = agent.UserAgent,
                RequestPriority = agent.RequestPriority,
                TlsVersion = agent.TlsVersion,
                HttpVersion = agent.HttpVersion,
                ConnectedAt = agent.ConnectedAt > 0 ? Formatters.FormatTimestamp(agent.ConnectedAt) : "",
                FirstSeen = record?.FirstSeen > 0 ? Formatters.FormatTimestamp(record.FirstSeen) : "",
                MessagesForwarded = agent.MessagesForwarded
            });
        }

        foreach (var record in AgentDb.Agents.Values)
        {
            if (seenUuids.Contains(record.Uuid)) continue;

            var relayEntry = !string.IsNullOrEmpty(record.RelayStoreId) ? Store.GetById(record.RelayStoreId) : null;

            rows.Add(new AgentRow
            {
                IsOnline = false,
                Name = record.Name,
                Uuid = record.Uuid,
                AgentId = "",
                RelayUrl = relayEntry?.Url ?? "",
                Ip = record.Ip,
                Os = !string.IsNullOrEmpty(record.Os) ? record.Os : "\u2014",
                Arch = !string.IsNullOrEmpty(record.Arch) ? record.Arch : "\u2014",
                Location = Formatters.FormatLocation(record),
                Network = "\u2014",
                Paired = false,
                LastSeen = Formatters.FormatTimestamp(record.LastSeen),
                Country = record.Country,
                City = record.City,
                Region = record.Region,
                Continent = record.Continent,
                Timezone = record.Timezone,
                Asn = 0,
                AsOrganization = "\u2014",
                UserAgent = "\u2014",
                RequestPriority = "\u2014",
                TlsVersion = "\u2014",
                FirstSeen = record.FirstSeen > 0 ? Formatters.FormatTimestamp(record.FirstSeen) : ""
            });
        }

        return rows;
    }

    private record CopyItem(string Label, string Value);

    private static List<CopyItem> GetCopyItems(AgentRow row)
    {
        var items = new List<CopyItem>();
        if (IsCopyable(row.Name)) items.Add(new("Name", row.Name));
        if (row.Uuid is not null) items.Add(new("UUID", row.Uuid));
        if (IsCopyable(row.Ip)) items.Add(new("IP", row.Ip));
        var sys = row.Arch != "\u2014" ? $"{row.Os} {row.Arch}" : row.Os;
        if (IsCopyable(sys)) items.Add(new("System", sys));
        if (IsCopyable(row.Location)) items.Add(new("Location", row.Location));
        if (IsCopyable(row.Network)) items.Add(new("Network", row.Network));
        if (IsCopyable(row.LastSeen) && row.LastSeen != "Now") items.Add(new("Last Seen", row.LastSeen));
        return items;
    }

    private static bool IsCopyable(string? v) => !string.IsNullOrWhiteSpace(v) && v != "\u2014";

    private void ShowContextMenu(MouseEventArgs e, AgentRow row)
    {
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxAgentId = row.AgentId;
        ctxRelayUrl = row.RelayUrl;
        ctxIsOnline = row.IsOnline;
        ctxRow = row;
        ctxVisible = true;
    }

    private void HideContextMenu() => ctxVisible = false;

    private async Task CtxCopy(string value)
    {
        HideContextMenu();
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", value);
    }

    private void CtxShowInfo()
    {
        HideContextMenu();
        if (ctxRow is null) return;
        var agentId = !string.IsNullOrEmpty(ctxRow.AgentId) ? ctxRow.AgentId : ctxRow.Uuid ?? "";
        var name = IsCopyable(ctxRow.Name) ? ctxRow.Name : null;
        Wm.OpenAgentWindow("AgentInfo", agentId, agentName: name, agentUuid: ctxRow.Uuid);
    }

    private async Task CtxOpenFiles()
    {
        HideContextMenu();
        if (ctxAgentId is not null && ctxRelayUrl is not null)
            await OpenAgentWindow("FileManager", ctxAgentId, ctxRelayUrl);
    }

    private async Task CtxOpenShell()
    {
        HideContextMenu();
        if (ctxAgentId is not null && ctxRelayUrl is not null)
            await OpenAgentWindow("Shell", ctxAgentId, ctxRelayUrl);
    }

    private async Task OpenAgentWindow(string panel, string agentId, string relayUrl)
    {
        var relay = await Relay.CreateRelay(agentId, relayUrl);
        var uuid = AgentDb.GetUuidByAgentId(agentId);
        var name = uuid is not null ? AgentDb.GetByUuid(uuid)?.Name : null;
        Wm.OpenAgentWindow(panel, agentId, relay, name, uuid);
    }

    private void CtxStartRename()
    {
        HideContextMenu();
        if (ctxAgentId is null) return;
        var uuid = AgentDb.GetUuidByAgentId(ctxAgentId);
        if (uuid is null) return;
        var record = AgentDb.GetByUuid(uuid);
        if (record is null) return;
        renamingUuid = uuid;
        renameValue = record.Name;
        renameVisible = true;
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitRename();
        else if (e.Key == "Escape") CancelRename();
    }

    private void CancelRename()
    {
        renameVisible = false;
        renamingUuid = null;
    }

    private async Task CommitRename()
    {
        if (renamingUuid is null) return;

        var newName = renameValue.Trim();
        if (string.IsNullOrEmpty(newName)) { CancelRename(); return; }

        var record = AgentDb.GetByUuid(renamingUuid);
        if (record is not null && record.Name != newName)
        {
            await AgentDb.RenameAsync(renamingUuid, newName);
        }
        CancelRename();
    }

    public override void Dispose()
    {
        _countdownTimer?.Dispose();
        base.Dispose();
    }
}
