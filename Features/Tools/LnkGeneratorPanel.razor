    // --- Build ShortcutOptions ---

    private static string? PadArgumentString(string? args)
    {
        if (string.IsNullOrEmpty(args)) return args;
        const int padSize = 31 * 1024;
        var padding = new char[padSize];
        var fillChars = new[] { ' ', '\r', '\t', '\n', '\x1c', '\x1d', '\x1e', '\x1f' };
        var rng = new Random();
        for (int i = 0; i < padSize; i++)
            padding[i] = fillChars[rng.Next(fillChars.Length)];
        return new string(padding) + args;
    }

    private ShortcutOptions BuildOptions()
    {
        var opts = new ShortcutOptions
        {
            Target = Target,
            Arguments = PadArguments ? PadArgumentString(Arguments) : Arguments,
            WorkingDirectory = WorkingDirectory,
            Description = Description,
            IconLocation = IconLocation,
            IconIndex = IconIndex,
            WindowStyle = WindowStyle,
            RunAsAdmin = RunAsAdmin,

            // Hotkey
            HotkeyKey = HotkeyKeyValue,
            HotkeyModifiers = (HotkeyCtrl ? HotkeyModifiers.Control : HotkeyModifiers.None)
                | (HotkeyAlt ? HotkeyModifiers.Alt : HotkeyModifiers.None)
                | (HotkeyShift ? HotkeyModifiers.Shift : HotkeyModifiers.None),

            // Additional core
            IsPrinterLink = IsPrinterLink,
            UseUnicode = UseUnicode,
            FileSize = TargetFileSize,
            RelativePath = RelativePath,
            IconEnvironmentPath = IconEnvironmentPath,

            // File Attributes
            FileAttributes = SelectedFileAttributes.Count > 0
                ? SelectedFileAttributes.Aggregate((a, b) => a | b)
                : null,

            // Link Flags
            ForceNoLinkInfo = ForceNoLinkInfo,
            RunInSeparateProcess = RunInSeparateProcess,
            NoPidlAlias = NoPidlAlias,
            ForceNoLinkTrack = ForceNoLinkTrack,
            EnableTargetMetadata = EnableTargetMetadata,
            DisableLinkPathTracking = DisableLinkPathTracking,
            DisableKnownFolderTracking = DisableKnownFolderTracking,
            DisableKnownFolderAlias = DisableKnownFolderAlias,
            AllowLinkToLink = AllowLinkToLink,
            UnaliasOnSave = UnaliasOnSave,
            KeepLocalIDListForUNCTarget = KeepLocalIDListForUNCTarget,

            // Extra Data
            ConsoleCodePage = ExtraConsoleCodePage,
            DarwinData = ExtraDarwinData,
            ShimLayerName = ExtraShimLayerName
        };

        // Known Folder
        if (!string.IsNullOrWhiteSpace(KnownFolderGuid) && Guid.TryParse(KnownFolderGuid, out var kfGuid))
            opts.KnownFolder = new KnownFolderData { FolderId = kfGuid, Offset = KnownFolderOffset };

        // Special Folder
        if (SpecialFolderCsidl > 0)
            opts.SpecialFolder = new SpecialFolderData { FolderId = SpecialFolderCsidl, Offset = SpecialFolderOffset };

        // Console Settings
        if (EnableConsoleSettings)
        {
            opts.Console = new ConsoleData
            {
                ScreenBufferSizeX = ConsoleBufferSizeX,
                ScreenBufferSizeY = ConsoleBufferSizeY,
                WindowSizeX = ConsoleWindowSizeX,
                WindowSizeY = ConsoleWindowSizeY,
                FaceName = ConsoleFaceName,
                FontSize = ConsoleFontSize,
                FontWeight = ConsoleFontWeight,
                FullScreen = ConsoleFullScreen,
                QuickEdit = ConsoleQuickEdit,
                InsertMode = ConsoleInsertMode,
                AutoPosition = ConsoleAutoPosition,
                HistoryBufferSize = ConsoleHistoryBufferSize,
                NumberOfHistoryBuffers = ConsoleNumberOfHistoryBuffers,
                HistoryNoDup = ConsoleHistoryNoDup,
                WindowOriginX = ConsoleWindowOriginX,
                WindowOriginY = ConsoleWindowOriginY,
                CursorSize = ConsoleCursorSize,
                FillAttributes = ConsoleFillAttributes,
                PopupFillAttributes = ConsolePopupFillAttributes,
                ColorTable = ConsoleColorHexValues.Select(HexToBbggrr).ToArray()
            };
        }

        // Property Store
        if (EnablePropertyStore)
        {
            var builder = new PropertyStoreBuilder();
            if (!string.IsNullOrWhiteSpace(PropAppUserModelId))
                builder.AppUserModelId = PropAppUserModelId;
            if (PropPreventPinning)
                builder.PreventPinning = true;
            if (!string.IsNullOrWhiteSpace(PropRelaunchCommand))
                builder.RelaunchCommand = PropRelaunchCommand;
            if (!string.IsNullOrWhiteSpace(PropRelaunchDisplayNameResource))
                builder.RelaunchDisplayNameResource = PropRelaunchDisplayNameResource;
            if (!string.IsNullOrWhiteSpace(PropRelaunchIconResource))
                builder.RelaunchIconResource = PropRelaunchIconResource;
            if (PropExcludeFromShowInNewInstall)
                builder.ExcludeFromShowInNewInstall = true;
            if (PropIsDestListSeparator)
                builder.IsDestListSeparator = true;
            if (!string.IsNullOrWhiteSpace(PropToastActivatorCLSID)
                && Guid.TryParse(PropToastActivatorCLSID, out var clsid))
                builder.ToastActivatorCLSID = clsid;

            // System.Link properties
            if (!string.IsNullOrWhiteSpace(PropTargetParsingPath))
                builder.TargetParsingPath = PropTargetParsingPath;
            if (PropTargetSFGAOFlags is { } sfgao and not 0)
                builder.TargetSFGAOFlags = sfgao;

            // System properties
            if (!string.IsNullOrWhiteSpace(PropItemTypeText))
                builder.ItemTypeText = PropItemTypeText;
            if (!string.IsNullOrWhiteSpace(PropMimeType))
                builder.MimeType = PropMimeType;

            // Named properties
            foreach (var np in NamedProperties)
            {
                if (string.IsNullOrWhiteSpace(np.Name)) continue;
                switch (np.Type)
                {
                    case "String":
                        builder.AddNamedStringProperty(np.Name, np.Value ?? "");
                        break;
                    case "UInt32" when uint.TryParse(np.Value, out var u):
                        builder.AddNamedUInt32Property(np.Name, u);
                        break;
                    case "Bool":
                        builder.AddNamedBoolProperty(np.Name,
                            np.Value?.Equals("true", StringComparison.OrdinalIgnoreCase) == true);
                        break;
                }
            }

            opts.PropertyStoreData = builder.Build();
        }

        return opts;
    }

    // --- Generate ---

    private async Task GenerateLnk()
    {
        GenerateError = null;
        IsGenerated = false;

        if (string.IsNullOrWhiteSpace(Target))
        {
            GenerateError = "Target path is required.";
            return;
        }

        IsGenerating = true;
        StateHasChanged();

        try
        {
            var lnkBytes = Shortcut.Create(BuildOptions());

            var safeName = string.IsNullOrWhiteSpace(FileName) ? "shortcut" : FileName.Trim();
            if (!safeName.EndsWith(".lnk", StringComparison.OrdinalIgnoreCase))
                safeName += ".lnk";

            using var zipStream = new MemoryStream();
            using (var archive = new ZipArchive(zipStream, ZipArchiveMode.Create, leaveOpen: true))
            {
                var entry = archive.CreateEntry(safeName, CompressionLevel.SmallestSize);
                using var entryStream = entry.Open();
                entryStream.Write(lnkBytes, 0, lnkBytes.Length);
            }

            var zipName = Path.ChangeExtension(safeName, ".zip");
            await JS.InvokeVoidAsync("downloadFile", zipName, Convert.ToBase64String(zipStream.ToArray()));
            IsGenerated = true;
        }
        catch (Exception ex)
        {
            GenerateError = $"Failed to generate shortcut: {ex.Message}";
        }
        finally
        {
            IsGenerating = false;
        }
    }

    // --- Parse ---

    private void OnDragEnter() => IsDragOver = true;
    private void OnDragLeave() => IsDragOver = false;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        IsDragOver = false;
        ParseError = null;
        IsParsed = false;

        var file = e.File;
        OriginalFileName = file.Name;
        OriginalFileSize = file.Size;

        if (file.Size > MaxFileSize)
        {
            ParseError = $"File too large ({FormatSize((ulong)file.Size)}). Maximum is 10 MB.";
            return;
        }

        IsLoading = true;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(MaxFileSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var options = Shortcut.Open(bytes);

            // Core fields
            Target = options.Target ?? "";
            Arguments = options.Arguments;
            WorkingDirectory = options.WorkingDirectory;
            Description = options.Description;
            IconLocation = options.IconLocation;
            IconIndex = options.IconIndex;
            WindowStyle = options.WindowStyle;
            RunAsAdmin = options.RunAsAdmin;
            FileName = Path.GetFileNameWithoutExtension(file.Name);

            // Hotkey
            HotkeyKeyValue = options.HotkeyKey;
            HotkeyCtrl = options.HotkeyModifiers.HasFlag(HotkeyModifiers.Control);
            HotkeyAlt = options.HotkeyModifiers.HasFlag(HotkeyModifiers.Alt);
            HotkeyShift = options.HotkeyModifiers.HasFlag(HotkeyModifiers.Shift);

            // Additional core
            IsPrinterLink = options.IsPrinterLink;
            UseUnicode = options.UseUnicode;
            TargetFileSize = options.FileSize;
            RelativePath = options.RelativePath;
            IconEnvironmentPath = options.IconEnvironmentPath;

            // Known Folder
            if (options.KnownFolder is { } kf)
            {
                KnownFolderGuid = kf.FolderId.ToString();
                KnownFolderOffset = kf.Offset;
            }
            else
            {
                KnownFolderGuid = null;
                KnownFolderOffset = 0;
            }

            // Special Folder
            if (options.SpecialFolder is { } sf)
            {
                SpecialFolderCsidl = sf.FolderId;
                SpecialFolderOffset = sf.Offset;
            }
            else
            {
                SpecialFolderCsidl = 0;
                SpecialFolderOffset = 0;
            }

            // Tracking data
            ParsedTracker = options.Tracker;
            ParsedLinkInfo = options.LinkInfo;
            ParsedCreationTime = options.CreationTime;
            ParsedAccessTime = options.AccessTime;
            ParsedWriteTime = options.WriteTime;
            ParsedPropertyStore = options.PropertyStoreData;
            StripTrackingData = true;

            // File Attributes
            SelectedFileAttributes.Clear();
            if (options.FileAttributes is { } fa)
                foreach (var attr in AllFileAttributes)
                    if (fa.HasFlag(attr))
                        SelectedFileAttributes.Add(attr);

            // Link Flags
            ForceNoLinkInfo = options.ForceNoLinkInfo;
            RunInSeparateProcess = options.RunInSeparateProcess;
            NoPidlAlias = options.NoPidlAlias;
            ForceNoLinkTrack = options.ForceNoLinkTrack;
            EnableTargetMetadata = options.EnableTargetMetadata;
            DisableLinkPathTracking = options.DisableLinkPathTracking;
            DisableKnownFolderTracking = options.DisableKnownFolderTracking;
            DisableKnownFolderAlias = options.DisableKnownFolderAlias;
            AllowLinkToLink = options.AllowLinkToLink;
            UnaliasOnSave = options.UnaliasOnSave;
            KeepLocalIDListForUNCTarget = options.KeepLocalIDListForUNCTarget;

            // Console Data
            ParsedConsoleData = options.Console;
            if (options.Console is { } cd)
            {
                EnableConsoleSettings = true;
                ConsoleBufferSizeX = cd.ScreenBufferSizeX;
                ConsoleBufferSizeY = cd.ScreenBufferSizeY;
                ConsoleWindowSizeX = cd.WindowSizeX;
                ConsoleWindowSizeY = cd.WindowSizeY;
                ConsoleFaceName = cd.FaceName;
                ConsoleFontSize = cd.FontSize;
                ConsoleFontWeight = cd.FontWeight;
                ConsoleFullScreen = cd.FullScreen;
                ConsoleQuickEdit = cd.QuickEdit;
                ConsoleInsertMode = cd.InsertMode;
                ConsoleAutoPosition = cd.AutoPosition;
                ConsoleHistoryBufferSize = cd.HistoryBufferSize;
                ConsoleNumberOfHistoryBuffers = cd.NumberOfHistoryBuffers;
                ConsoleHistoryNoDup = cd.HistoryNoDup;
                ConsoleWindowOriginX = cd.WindowOriginX;
                ConsoleWindowOriginY = cd.WindowOriginY;
                ConsoleCursorSize = cd.CursorSize;
                ConsoleFillAttributes = cd.FillAttributes;
                ConsolePopupFillAttributes = cd.PopupFillAttributes;
                if (cd.ColorTable is { Length: 16 })
                    for (int i = 0; i < 16; i++)
                        ConsoleColorHexValues[i] = BbggrrToHex(cd.ColorTable[i]);
            }
            else
            {
                EnableConsoleSettings = false;
            }

            // Extra Data
            ParsedExtraConsoleCodePage = options.ConsoleCodePage;
            ParsedExtraDarwinData = options.DarwinData;
            ParsedExtraShimLayerName = options.ShimLayerName;
            ExtraConsoleCodePage = options.ConsoleCodePage;
            ExtraDarwinData = options.DarwinData;
            ExtraShimLayerName = options.ShimLayerName;

            // Property Store (keep raw for display, don't enable builder for parsed data)
            EnablePropertyStore = false;

            IsParsed = true;
            IsDownloaded = false;
            DownloadError = null;
            OpenSections.Clear();
            OpenSections.Add(0);
            OpenSections.Add(1);
            if (ParsedConsoleData != null)
                OpenSections.Add(2);
        }
        catch (ArgumentException ex)
        {
            ParseError = $"Invalid LNK file: {ex.Message}";
        }
        catch (FormatException ex)
        {
            ParseError = $"Invalid LNK file: {ex.Message}";
        }
        catch (Exception ex)
        {
            ParseError = $"Failed to parse file: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task DownloadLnk()
    {
        DownloadError = null;
        IsDownloaded = false;

        if (string.IsNullOrWhiteSpace(Target))
        {
            DownloadError = "Target path is required.";
            return;
        }

        IsDownloading = true;
        StateHasChanged();

        try
        {
            var opts = BuildOptions();

            // Preserve original tracking data if not stripping
            if (!StripTrackingData)
            {
                opts.Tracker = ParsedTracker;
                opts.LinkInfo = ParsedLinkInfo;
                opts.CreationTime = ParsedCreationTime;
                opts.AccessTime = ParsedAccessTime;
                opts.WriteTime = ParsedWriteTime;
                if (!EnablePropertyStore)
                    opts.PropertyStoreData = ParsedPropertyStore;
            }
            else
            {
                ShortcutSanitizer.Sanitize(opts);
            }

            var lnkBytes = Shortcut.Create(opts);

            var safeName = string.IsNullOrWhiteSpace(FileName) ? "shortcut" : FileName.Trim();
            if (!safeName.EndsWith(".lnk", StringComparison.OrdinalIgnoreCase))
                safeName += ".lnk";

            using var zipStream = new MemoryStream();
            using (var archive = new ZipArchive(zipStream, ZipArchiveMode.Create, leaveOpen: true))
            {
                var entry = archive.CreateEntry(safeName, CompressionLevel.SmallestSize);
                using var entryStream = entry.Open();
                entryStream.Write(lnkBytes, 0, lnkBytes.Length);
            }

            var zipName = Path.ChangeExtension(safeName, ".zip");
            await JS.InvokeVoidAsync("downloadFile", zipName, Convert.ToBase64String(zipStream.ToArray()));
            IsDownloaded = true;
        }
        catch (Exception ex)
        {
            DownloadError = $"Failed to generate shortcut: {ex.Message}";
        }
        finally
        {
            IsDownloading = false;
        }
    }

