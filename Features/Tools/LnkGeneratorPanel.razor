@inject IJSRuntime JS
@using ShortcutLib
@using System.IO.Compression

<section class="tool-panel">
    <div class="tool-content">
        <div class="tool-header">
            <h1 class="mono">LNK <span class="accent">Generator</span></h1>
            <p class="tool-subtitle">Generate and edit Windows shortcut (.lnk) files directly in your browser.</p>
        </div>

        @if (!IsParsed)
        {
            <div class="upload-strip @(IsDragOver ? "drag-over" : "")"
                 @ondragenter="OnDragEnter" @ondragleave="OnDragLeave" @ondragover:preventDefault>
                <span class="mono upload-strip-label">Drop .lnk to edit</span>
                <span class="upload-strip-sep mono">|</span>
                <span class="upload-strip-hint">or click to browse</span>
                <InputFile OnChange="OnFileSelected" accept=".lnk" class="upload-input" />
            </div>

            @if (IsLoading)
            {
                <div class="loading-banner mono">Parsing...</div>
            }

            @if (!string.IsNullOrWhiteSpace(ParseError))
            {
                <div class="parse-error-wrapper">
                    <div class="error-banner">
                        <span>@ParseError</span>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Overview -->
            <div class="lnk-results">
                <div class="tool-section">
                    <button class="tool-section-header" @onclick="() => ToggleSection(0)">
                        <span class="mono">Overview</span>
                        <span class="section-arrow @(IsSectionOpen(0) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                    </button>
                    @if (IsSectionOpen(0))
                    {
                        <div class="tool-section-body">
                            <div class="tool-info-grid tool-info-grid--single-col">
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">File</span>
                                    <span class="tool-info-value">@OriginalFileName</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Size</span>
                                    <span class="tool-info-value">@FormatSize((ulong)OriginalFileSize)</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Target</span>
                                    <span class="tool-info-value mono">@(Target ?? "—")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(Arguments))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Arguments</span>
                                        <span class="tool-info-value mono">@Arguments</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(WorkingDirectory))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Working Dir</span>
                                        <span class="tool-info-value mono">@WorkingDirectory</span>
                                    </div>
                                }
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Window Style</span>
                                    <span class="tool-info-value">@WindowStyle</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Run as Admin</span>
                                    <span class="tool-info-value">@(RunAsAdmin ? "Yes" : "No")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(IconLocation))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Icon</span>
                                        <span class="tool-info-value mono">@IconLocation, @IconIndex</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Description))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Description</span>
                                        <span class="tool-info-value">@Description</span>
                                    </div>
                                }
                                @if (HotkeyKeyValue != 0)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Hotkey</span>
                                        <span class="tool-info-value mono">@FormatHotkey()</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(RelativePath))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Relative Path</span>
                                        <span class="tool-info-value mono">@RelativePath</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(IconEnvironmentPath))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Icon Env Path</span>
                                        <span class="tool-info-value mono">@IconEnvironmentPath</span>
                                    </div>
                                }
                                @if (TargetFileSize > 0)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Target File Size</span>
                                        <span class="tool-info-value mono">@FormatSize(TargetFileSize)</span>
                                    </div>
                                }
                                @if (UseUnicode)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Unicode</span>
                                        <span class="tool-info-value">Yes</span>
                                    </div>
                                }
                                @if (IsPrinterLink)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Printer Link</span>
                                        <span class="tool-info-value">Yes</span>
                                    </div>
                                }
                            </div>

                            @{ var parsedFileAttrFlags = GetParsedFileAttributeNames(); }
                            @if (parsedFileAttrFlags.Length > 0)
                            {
                                <div class="lnk-flags">
                                    <span class="lnk-flags-label mono">File Attributes:</span>
                                    @foreach (var flag in parsedFileAttrFlags)
                                    {
                                        <span class="lnk-flag">@flag</span>
                                    }
                                </div>
                            }

                            @{ var activeLinkFlags = GetActiveLinkFlagNames(); }
                            @if (activeLinkFlags.Length > 0)
                            {
                                <div class="lnk-flags">
                                    <span class="lnk-flags-label mono">Link Flags:</span>
                                    @foreach (var flag in activeLinkFlags)
                                    {
                                        <span class="lnk-flag">@flag</span>
                                    }
                                </div>
                            }

                            @if (ParsedExtraConsoleCodePage != null || !string.IsNullOrWhiteSpace(ParsedExtraDarwinData) || !string.IsNullOrWhiteSpace(ParsedExtraShimLayerName)
                                || !string.IsNullOrWhiteSpace(KnownFolderGuid) || SpecialFolderCsidl > 0)
                            {
                                <div class="tool-info-grid tool-info-grid--single-col" style="margin-top: 0.75rem;">
                                    @if (ParsedExtraConsoleCodePage != null)
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Console Code Page</span>
                                            <span class="tool-info-value mono">@ParsedExtraConsoleCodePage</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ParsedExtraDarwinData))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Darwin Data</span>
                                            <span class="tool-info-value mono">@ParsedExtraDarwinData</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ParsedExtraShimLayerName))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Shim Layer</span>
                                            <span class="tool-info-value mono">@ParsedExtraShimLayerName</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(KnownFolderGuid))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Known Folder</span>
                                            <span class="tool-info-value mono">@KnownFolderGuid (offset: @KnownFolderOffset)</span>
                                        </div>
                                    }
                                    @if (SpecialFolderCsidl > 0)
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Special Folder</span>
                                            <span class="tool-info-value mono">CSIDL @SpecialFolderCsidl (offset: @SpecialFolderOffset)</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Tracking Info -->
                @if (HasTrackingData)
                {
                    <div class="tool-section tracking-section">
                        <button class="tool-section-header" @onclick="() => ToggleSection(1)">
                            <span class="mono">Tracking Info</span>
                            <span class="section-arrow @(IsSectionOpen(1) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                        </button>
                        @if (IsSectionOpen(1))
                        {
                            <div class="tool-section-body">
                                <div class="warning-banner">
                                    <span>This file contains embedded tracking data that can identify the machine it was created on.</span>
                                </div>

                                <div class="tool-info-grid tool-info-grid--single-col">
                                    @if (ParsedTracker != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Machine ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.MachineId</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Volume ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.VolumeId</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Object ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.ObjectId</span>
                                        </div>
                                        @if (ParsedTracker.BirthVolumeId != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Birth Volume ID</span>
                                                <span class="tool-info-value mono">@ParsedTracker.BirthVolumeId</span>
                                            </div>
                                        }
                                        @if (ParsedTracker.BirthObjectId != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Birth Object ID</span>
                                                <span class="tool-info-value mono">@ParsedTracker.BirthObjectId</span>
                                            </div>
                                        }
                                    }

                                    @if (ParsedLinkInfo?.Local != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Local Path</span>
                                            <span class="tool-info-value mono">@ParsedLinkInfo.Local.BasePath</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Drive Serial</span>
                                            <span class="tool-info-value mono">@($"0x{ParsedLinkInfo.Local.DriveSerialNumber:X8}")</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(ParsedLinkInfo.Local.VolumeLabel))
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Volume Label</span>
                                                <span class="tool-info-value mono">@ParsedLinkInfo.Local.VolumeLabel</span>
                                            </div>
                                        }
                                    }
                                    @if (ParsedLinkInfo?.Network != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Network Share</span>
                                            <span class="tool-info-value mono">@ParsedLinkInfo.Network.ShareName</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(ParsedLinkInfo.Network.DeviceName))
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Device Name</span>
                                                <span class="tool-info-value mono">@ParsedLinkInfo.Network.DeviceName</span>
                                            </div>
                                        }
                                        @if (ParsedLinkInfo.Network.NetworkProviderType != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Network Provider</span>
                                                <span class="tool-info-value mono">@($"0x{ParsedLinkInfo.Network.NetworkProviderType.Value:X8}")</span>
                                            </div>
                                        }
                                    }

                                    @if (ParsedCreationTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Created</span>
                                            <span class="tool-info-value mono">@ParsedCreationTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }
                                    @if (ParsedAccessTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Accessed</span>
                                            <span class="tool-info-value mono">@ParsedAccessTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }
                                    @if (ParsedWriteTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Modified</span>
                                            <span class="tool-info-value mono">@ParsedWriteTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }

                                    @if (ParsedPropertyStore != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Property Store</span>
                                            <span class="tool-info-value mono">@FormatSize((ulong)ParsedPropertyStore.Length)</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Console Data (parsed) -->
                @if (ParsedConsoleData != null)
                {
                    <div class="tool-section">
                        <button class="tool-section-header" @onclick="() => ToggleSection(2)">
                            <span class="mono">Console Data</span>
                            <span class="section-arrow @(IsSectionOpen(2) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                        </button>
                        @if (IsSectionOpen(2))
                        {
                            <div class="tool-section-body">
                                <div class="tool-info-grid">
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Buffer Size</span>
                                        <span class="tool-info-value mono">@(ParsedConsoleData.ScreenBufferSizeX)x@(ParsedConsoleData.ScreenBufferSizeY)</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Window Size</span>
                                        <span class="tool-info-value mono">@(ParsedConsoleData.WindowSizeX)x@(ParsedConsoleData.WindowSizeY)</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Font</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.FaceName</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Font Weight</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.FontWeight</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Cursor Size</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.CursorSize%</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">History Buffer</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.HistoryBufferSize</span>
                                    </div>
                                </div>

                                @{ var consoleFlags = GetParsedConsoleFlagNames(); }
                                @if (consoleFlags.Length > 0)
                                {
                                    <div class="lnk-flags">
                                        <span class="lnk-flags-label mono">Options:</span>
                                        @foreach (var flag in consoleFlags)
                                        {
                                            <span class="lnk-flag">@flag</span>
                                        }
                                    </div>
                                }

                                @if (ParsedConsoleData.ColorTable is { Length: 16 })
                                {
                                    <div class="color-preview-row">
                                        @for (int i = 0; i < 16; i++)
                                        {
                                            <div class="color-preview-swatch"
                                                 style="background: @BbggrrToHex(ParsedConsoleData.ColorTable[i])" title="Color @i">
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Shared Form -->
        <div class="tool-form-wrapper">
            @if (!IsParsed)
            {
                <div class="form-group template-selector">
                    <label class="mono" for="template">Template</label>
                    <select id="template" class="form-input" value="@SelectedTemplateName" @onchange="OnTemplateSelected">
                        <option value="">Custom</option>
                        @foreach (var tpl in LnkTemplates)
                        {
                            <option value="@tpl.Name">@tpl.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group">
                <label class="mono" for="target">Target Path <span class="required">*</span></label>
                <input id="target" type="text" @bind="Target" placeholder="C:\Windows\notepad.exe" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="arguments">Arguments</label>
                <input id="arguments" type="text" @bind="Arguments" placeholder="--flag value" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="workingDir">Working Directory</label>
                <input id="workingDir" type="text" @bind="WorkingDirectory" placeholder="C:\MyApp" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="description">Description</label>
                <input id="description" type="text" @bind="Description" placeholder="My Shortcut" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="iconTemplate">Icon Template</label>
                <select id="iconTemplate" class="form-input" value="@SelectedIconTemplateName" @onchange="OnIconTemplateSelected">
                    <option value="">None</option>
                    @foreach (var tpl in IconTemplates)
                    {
                        <option value="@tpl.Label">@tpl.Symbol @tpl.Label</option>
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="mono" for="iconLocation">Icon Location</label>
                    <input id="iconLocation" type="text" @bind="IconLocation"
                           placeholder="%SystemRoot%\system32\shell32.dll" class="form-input" />
                </div>
                <div class="form-group">
                    <label class="mono" for="iconIndex">Icon Index</label>
                    <input id="iconIndex" type="number" @bind="IconIndex" class="form-input" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="mono" for="windowStyle">Window Style</label>
                    <select id="windowStyle" @bind="WindowStyle" class="form-input">
                        <option value="@ShortcutWindowStyle.Normal">Normal</option>
                        <option value="@ShortcutWindowStyle.Maximized">Maximized</option>
                        <option value="@ShortcutWindowStyle.Minimized">Minimized</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="mono" for="fileName">File Name</label>
                    <input id="fileName" type="text" @bind="FileName" placeholder="shortcut" class="form-input" />
                </div>
            </div>

            <div class="form-group">
                <label class="mono">Hotkey</label>
                <span class="form-hint">Global keyboard shortcut to launch this shortcut</span>
                <div class="hotkey-row">
                    <div class="hotkey-modifiers">
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="HotkeyCtrl" />
                            <span class="checkmark"></span>
                            <span class="mono">Ctrl</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="HotkeyAlt" />
                            <span class="checkmark"></span>
                            <span class="mono">Alt</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="HotkeyShift" />
                            <span class="checkmark"></span>
                            <span class="mono">Shift</span>
                        </label>
                    </div>
                    <select @bind="HotkeyKeyValue" class="form-input hotkey-key-select">
                        <option value="0">None</option>
                        @foreach (var kv in HotkeyKeyOptions)
                        {
                            <option value="@kv.Value">@kv.Label</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="mono" for="relativePath">Relative Path</label>
                <span class="form-hint">Relative path from the .lnk file to its target</span>
                <input id="relativePath" type="text" @bind="RelativePath" placeholder="..\..\target.exe" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="iconEnvPath">Icon Environment Path</label>
                <span class="form-hint">Icon path using environment variables like %ProgramFiles%</span>
                <input id="iconEnvPath" type="text" @bind="IconEnvironmentPath" placeholder="%ProgramFiles%\app\icon.ico" class="form-input" />
            </div>

            <div class="form-checkboxes">
                <label class="checkbox-label">
                    <input type="checkbox" @bind="RunAsAdmin" />
                    <span class="checkmark"></span>
                    <span class="checkbox-text">
                        <span class="mono">Run as Administrator</span>
                        <span class="form-hint">Launch the target with elevated privileges (UAC prompt)</span>
                    </span>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" @bind="UseUnicode" />
                    <span class="checkmark"></span>
                    <span class="checkbox-text">
                        <span class="mono">Use Unicode</span>
                        <span class="form-hint">Store string data as Unicode instead of ANSI</span>
                    </span>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" @bind="IsPrinterLink" />
                    <span class="checkmark"></span>
                    <span class="checkbox-text">
                        <span class="mono">Printer Link</span>
                        <span class="form-hint">Target is a network printer</span>
                    </span>
                </label>
                @if (IsParsed && HasTrackingData)
                {
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="StripTrackingData" />
                        <span class="checkmark"></span>
                        <span class="checkbox-text">
                            <span class="mono">Strip Tracking Data</span>
                            <span class="form-hint">Remove machine-identifying metadata from the file</span>
                        </span>
                    </label>
                }
            </div>

            <!-- File Attributes -->
            <div class="tool-section form-section">
                <button class="tool-section-header" @onclick="() => ToggleSection(10)">
                    <span class="mono">File Attributes</span>
                    <span class="section-arrow @(IsSectionOpen(10) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                </button>
                @if (IsSectionOpen(10))
                {
                    <div class="tool-section-body">
                        <div class="form-checkboxes checkbox-grid">
                            @foreach (var attr in AllFileAttributes)
                            {
                                <label class="checkbox-label">
                                    <input type="checkbox" checked="@SelectedFileAttributes.Contains(attr)"
                                           @onchange="() => ToggleFileAttribute(attr)" />
                                    <span class="checkmark"></span>
                                    <span class="checkbox-text">
                                        <span class="mono">@attr</span>
                                        <span class="form-hint">@GetFileAttributeHint(attr)</span>
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Link Flags -->
            <div class="tool-section form-section">
                <button class="tool-section-header" @onclick="() => ToggleSection(11)">
                    <span class="mono">Link Flags</span>
                    <span class="section-arrow @(IsSectionOpen(11) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                </button>
                @if (IsSectionOpen(11))
                {
                    <div class="tool-section-body">
                        <div class="form-checkboxes checkbox-grid">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="ForceNoLinkInfo" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Force No Link Info</span>
                                    <span class="form-hint">Ignore LinkInfo when resolving the shortcut</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="RunInSeparateProcess" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Run In Separate Process</span>
                                    <span class="form-hint">Run 16-bit target in a separate Virtual DOS Machine</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="NoPidlAlias" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">No PIDL Alias</span>
                                    <span class="form-hint">Do not use shell namespace aliasing for the IDList</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="ForceNoLinkTrack" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Force No Link Track</span>
                                    <span class="form-hint">Ignore distributed link tracking data</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="EnableTargetMetadata" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Enable Target Metadata</span>
                                    <span class="form-hint">Populate PropertyStore when target is set</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="DisableLinkPathTracking" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Disable Link Path Tracking</span>
                                    <span class="form-hint">Ignore environment variable expansion data</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="DisableKnownFolderTracking" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Disable Known Folder Tracking</span>
                                    <span class="form-hint">Ignore known folder tracking data blocks</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="DisableKnownFolderAlias" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Disable Known Folder Alias</span>
                                    <span class="form-hint">Store the full unaliased IDList form</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="AllowLinkToLink" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Allow Link To Link</span>
                                    <span class="form-hint">Allow the target to be another .lnk file</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="UnaliasOnSave" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Unalias On Save</span>
                                    <span class="form-hint">Remove alias from target IDList when saving</span>
                                </span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="KeepLocalIDListForUNCTarget" />
                                <span class="checkmark"></span>
                                <span class="checkbox-text">
                                    <span class="mono">Keep Local IDList for UNC</span>
                                    <span class="form-hint">Store local IDList for UNC network paths</span>
                                </span>
                            </label>
                        </div>
                    </div>
                }
            </div>

            <!-- Console Settings -->
            <div class="tool-section form-section">
                <button class="tool-section-header" @onclick="() => ToggleSection(12)">
                    <span class="mono">Console Settings</span>
                    <span class="section-arrow @(IsSectionOpen(12) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                </button>
                @if (IsSectionOpen(12))
                {
                    <div class="tool-section-body">
                        <label class="checkbox-label" style="margin-bottom: 1rem;">
                            <input type="checkbox" @bind="EnableConsoleSettings" />
                            <span class="checkmark"></span>
                            <span class="checkbox-text">
                                <span class="mono">Enable Console Data</span>
                                <span class="form-hint">Embed console window settings (font, colors, buffer) for console-based targets</span>
                            </span>
                        </label>

                        @if (EnableConsoleSettings)
                        {
                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Buffer & Window</span>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">Buffer Width</label>
                                        <span class="form-hint">Number of character columns in the screen buffer</span>
                                        <input type="number" @bind="ConsoleBufferSizeX" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Buffer Height</label>
                                        <span class="form-hint">Number of rows in the screen buffer (scrollback)</span>
                                        <input type="number" @bind="ConsoleBufferSizeY" class="form-input" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">Window Width</label>
                                        <span class="form-hint">Visible columns in the console window</span>
                                        <input type="number" @bind="ConsoleWindowSizeX" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Window Height</label>
                                        <span class="form-hint">Visible rows in the console window</span>
                                        <input type="number" @bind="ConsoleWindowSizeY" class="form-input" />
                                    </div>
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Font</span>
                                <div class="form-group">
                                    <label class="mono">Face Name</label>
                                    <span class="form-hint">Console font family (e.g. Consolas, Cascadia Mono, Lucida Console)</span>
                                    <input type="text" @bind="ConsoleFaceName" placeholder="Consolas" class="form-input" />
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">Font Size</label>
                                        <span class="form-hint">Font height in pixels (0 = system default)</span>
                                        <input type="number" @bind="ConsoleFontSize" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Font Weight</label>
                                        <span class="form-hint">400 = normal, 700 = bold</span>
                                        <input type="number" @bind="ConsoleFontWeight" placeholder="400" class="form-input" />
                                    </div>
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Display</span>
                                <div class="form-checkboxes checkbox-grid">
                                    <label class="checkbox-label">
                                        <input type="checkbox" @bind="ConsoleFullScreen" />
                                        <span class="checkmark"></span>
                                        <span class="checkbox-text">
                                            <span class="mono">Full Screen</span>
                                            <span class="form-hint">Launch console in full-screen mode</span>
                                        </span>
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" @bind="ConsoleQuickEdit" />
                                        <span class="checkmark"></span>
                                        <span class="checkbox-text">
                                            <span class="mono">Quick Edit</span>
                                            <span class="form-hint">Select text with mouse without entering mark mode</span>
                                        </span>
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" @bind="ConsoleInsertMode" />
                                        <span class="checkmark"></span>
                                        <span class="checkbox-text">
                                            <span class="mono">Insert Mode</span>
                                            <span class="form-hint">Insert text instead of overwriting at cursor</span>
                                        </span>
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" @bind="ConsoleAutoPosition" />
                                        <span class="checkmark"></span>
                                        <span class="checkbox-text">
                                            <span class="mono">Auto Position</span>
                                            <span class="form-hint">Let the system position the console window automatically</span>
                                        </span>
                                    </label>
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">History</span>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">History Buffer Size</label>
                                        <span class="form-hint">Number of commands stored per buffer</span>
                                        <input type="number" @bind="ConsoleHistoryBufferSize" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Number of Buffers</label>
                                        <span class="form-hint">Number of separate history buffers to maintain</span>
                                        <input type="number" @bind="ConsoleNumberOfHistoryBuffers" class="form-input" />
                                    </div>
                                </div>
                                <div class="form-checkboxes">
                                    <label class="checkbox-label">
                                        <input type="checkbox" @bind="ConsoleHistoryNoDup" />
                                        <span class="checkmark"></span>
                                        <span class="checkbox-text">
                                            <span class="mono">Discard Duplicates</span>
                                            <span class="form-hint">Remove duplicate entries from command history</span>
                                        </span>
                                    </label>
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Color Table</span>
                                <div class="color-table-grid">
                                    @for (int i = 0; i < 16; i++)
                                    {
                                        var idx = i;
                                        <input type="color" class="color-swatch"
                                               value="@ConsoleColorHexValues[idx]"
                                               @onchange="e => OnColorChanged(idx, e)"
                                               title="Color @idx" />
                                    }
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Position & Attributes</span>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">Window Origin X</label>
                                        <span class="form-hint">Horizontal screen position in pixels</span>
                                        <input type="number" @bind="ConsoleWindowOriginX" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Window Origin Y</label>
                                        <span class="form-hint">Vertical screen position in pixels</span>
                                        <input type="number" @bind="ConsoleWindowOriginY" class="form-input" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="mono">Cursor Size (%)</label>
                                        <span class="form-hint">Cursor fill percentage (25 = small, 100 = block)</span>
                                        <input type="number" @bind="ConsoleCursorSize" min="1" max="100" class="form-input" />
                                    </div>
                                    <div class="form-group">
                                        <label class="mono">Fill Attributes</label>
                                        <span class="form-hint">Foreground/background color index for main text</span>
                                        <input type="number" @bind="ConsoleFillAttributes" class="form-input" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="mono">Popup Fill Attributes</label>
                                    <span class="form-hint">Foreground/background color index for popup windows</span>
                                    <input type="number" @bind="ConsolePopupFillAttributes" class="form-input" />
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Property Store -->
            <div class="tool-section form-section">
                <button class="tool-section-header" @onclick="() => ToggleSection(13)">
                    <span class="mono">Property Store</span>
                    <span class="section-arrow @(IsSectionOpen(13) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                </button>
                @if (IsSectionOpen(13))
                {
                    <div class="tool-section-body">
                        <label class="checkbox-label" style="margin-bottom: 1rem;">
                            <input type="checkbox" @bind="EnablePropertyStore" />
                            <span class="checkmark"></span>
                            <span class="checkbox-text">
                                <span class="mono">Enable Property Store</span>
                                <span class="form-hint">Embed serialized properties for taskbar grouping, relaunch, and toast activation</span>
                            </span>
                        </label>

                        @if (EnablePropertyStore)
                        {
                            @if (IsParsed && ParsedPropertyStore != null)
                            {
                                <div class="info-banner">
                                    <span>Enabling this will replace the existing property store from the parsed file.</span>
                                </div>
                            }

                            <div class="form-group">
                                <label class="mono">App User Model ID</label>
                                <span class="form-hint">Controls taskbar grouping — windows with the same ID share a button</span>
                                <input type="text" @bind="PropAppUserModelId" placeholder="com.company.app" class="form-input" />
                            </div>

                            <div class="form-group">
                                <label class="mono">Relaunch Command</label>
                                <span class="form-hint">Command line used when re-launching the application from the taskbar</span>
                                <input type="text" @bind="PropRelaunchCommand" class="form-input" />
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="mono">Relaunch Display Name</label>
                                    <span class="form-hint">Friendly name shown in taskbar tooltip</span>
                                    <input type="text" @bind="PropRelaunchDisplayNameResource" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="mono">Relaunch Icon</label>
                                    <span class="form-hint">Icon resource path for taskbar button</span>
                                    <input type="text" @bind="PropRelaunchIconResource" class="form-input" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="mono">Toast Activator CLSID</label>
                                <span class="form-hint">COM class ID for handling Windows toast notification activations</span>
                                <input type="text" @bind="PropToastActivatorCLSID"
                                       placeholder="00000000-0000-0000-0000-000000000000" class="form-input" />
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">System.Link Properties</span>
                                <div class="form-group">
                                    <label class="mono">Target Parsing Path</label>
                                    <span class="form-hint">Canonical parsing path to the link target (System.Link.TargetParsingPath)</span>
                                    <input type="text" @bind="PropTargetParsingPath" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="mono">Target SFGAO Flags</label>
                                    <span class="form-hint">Shell attributes (SFGAO) of the target as a decimal value (System.Link.TargetSFGAOFlags)</span>
                                    <input type="number" @bind="PropTargetSFGAOFlags" class="form-input" />
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">System Properties</span>
                                <div class="form-group">
                                    <label class="mono">Item Type Text</label>
                                    <span class="form-hint">File type description e.g. "Text Document" (System.ItemTypeText)</span>
                                    <input type="text" @bind="PropItemTypeText" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="mono">MIME Type</label>
                                    <span class="form-hint">MIME type of the target e.g. "text/plain" (System.MIMEType)</span>
                                    <input type="text" @bind="PropMimeType" placeholder="application/octet-stream" class="form-input" />
                                </div>
                            </div>

                            <div class="console-subgroup">
                                <span class="console-subgroup-label mono">Named Properties</span>
                                @for (int i = 0; i < NamedProperties.Count; i++)
                                {
                                    var idx = i;
                                    <div class="form-row" style="align-items: flex-end;">
                                        <div class="form-group" style="flex: 1;">
                                            <label class="mono">Name</label>
                                            <input type="text" value="@NamedProperties[idx].Name"
                                                   @onchange="e => UpdateNamedProperty(idx, e.Value?.ToString(), null, null)"
                                                   class="form-input" />
                                        </div>
                                        <div class="form-group" style="flex: 0 0 120px;">
                                            <label class="mono">Type</label>
                                            <select value="@NamedProperties[idx].Type"
                                                    @onchange="e => UpdateNamedProperty(idx, null, e.Value?.ToString(), null)"
                                                    class="form-input">
                                                <option value="String">String</option>
                                                <option value="UInt32">UInt32</option>
                                                <option value="Bool">Bool</option>
                                            </select>
                                        </div>
                                        <div class="form-group" style="flex: 1;">
                                            <label class="mono">Value</label>
                                            <input type="text" value="@NamedProperties[idx].Value"
                                                   @onchange="e => UpdateNamedProperty(idx, null, null, e.Value?.ToString())"
                                                   class="form-input" />
                                        </div>
                                        <button class="btn btn-secondary" style="margin-bottom: 0.5rem; padding: 0.4rem 0.6rem;"
                                                @onclick="() => RemoveNamedProperty(idx)">✕</button>
                                    </div>
                                }
                                <button class="btn btn-secondary" style="margin-top: 0.25rem;" @onclick="AddNamedProperty">
                                    + Add Property
                                </button>
                            </div>

                            <div class="form-checkboxes checkbox-grid">
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="PropPreventPinning" />
                                    <span class="checkmark"></span>
                                    <span class="checkbox-text">
                                        <span class="mono">Prevent Pinning</span>
                                        <span class="form-hint">Prevent user from pinning this shortcut to taskbar or Start</span>
                                    </span>
                                </label>
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="PropExcludeFromShowInNewInstall" />
                                    <span class="checkmark"></span>
                                    <span class="checkbox-text">
                                        <span class="mono">Exclude From New Install List</span>
                                        <span class="form-hint">Hide from "newly installed programs" highlight in Start menu</span>
                                    </span>
                                </label>
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="PropIsDestListSeparator" />
                                    <span class="checkmark"></span>
                                    <span class="checkbox-text">
                                        <span class="mono">Destination List Separator</span>
                                        <span class="form-hint">Marks this item as a visual separator in jump lists</span>
                                    </span>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Extra Data -->
            <div class="tool-section form-section">
                <button class="tool-section-header" @onclick="() => ToggleSection(14)">
                    <span class="mono">Extra Data</span>
                    <span class="section-arrow @(IsSectionOpen(14) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                </button>
                @if (IsSectionOpen(14))
                {
                    <div class="tool-section-body">
                        <div class="form-group">
                            <label class="mono">Target File Size (bytes)</label>
                            <span class="form-hint">Override the file size stored in the shortcut header (0 = auto)</span>
                            <input type="number" @bind="TargetFileSize" placeholder="0" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label class="mono">Console Code Page</label>
                            <span class="form-hint">Character encoding for console targets (e.g. 65001 = UTF-8, 437 = US)</span>
                            <input type="number" @bind="ExtraConsoleCodePage" placeholder="65001" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label class="mono">Darwin Data (MSI)</label>
                            <span class="form-hint">Windows Installer (MSI) application identifier for advertised shortcuts</span>
                            <input type="text" @bind="ExtraDarwinData" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label class="mono">Shim Layer Name</label>
                            <span class="form-hint">Application compatibility layer — select a preset or type a custom value (prefix with ~ for single layer)</span>
                            <select class="form-input" value="@ExtraShimLayerName" @onchange="OnShimLayerSelected" style="margin-bottom: 0.35rem;">
                                <option value="">None</option>
                                @foreach (var shim in ShimLayerOptions)
                                {
                                    <option value="@shim.Value">@shim.Label</option>
                                }
                            </select>
                            <input type="text" @bind="ExtraShimLayerName" placeholder="~ WIN7RTM" class="form-input" />
                        </div>

                        <div class="console-subgroup">
                            <span class="console-subgroup-label mono">Known Folder</span>
                            <div class="form-group">
                                <label class="mono">Preset</label>
                                <span class="form-hint">Select a well-known folder or enter a custom GUID below</span>
                                <select class="form-input" value="@KnownFolderGuid" @onchange="OnKnownFolderSelected">
                                    <option value="">None</option>
                                    @foreach (var kf in KnownFolderOptions)
                                    {
                                        <option value="@kf.Value">@kf.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="mono">Folder GUID</label>
                                    <span class="form-hint">KNOWNFOLDERID GUID for a shell known folder</span>
                                    <input type="text" @bind="KnownFolderGuid"
                                           placeholder="00000000-0000-0000-0000-000000000000" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="mono">Offset</label>
                                    <span class="form-hint">Byte offset into the link target ID list</span>
                                    <input type="number" @bind="KnownFolderOffset" class="form-input" />
                                </div>
                            </div>
                        </div>

                        <div class="console-subgroup">
                            <span class="console-subgroup-label mono">Special Folder</span>
                            <div class="form-group">
                                <label class="mono">Preset</label>
                                <span class="form-hint">Select a CSIDL folder or enter a custom value below</span>
                                <select class="form-input" value="@SpecialFolderCsidl" @onchange="OnCsidlSelected">
                                    <option value="0">None</option>
                                    @foreach (var csidl in CsidlOptions)
                                    {
                                        <option value="@csidl.Value">@csidl.Label (0x@(csidl.Value.ToString("X4")))</option>
                                    }
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="mono">CSIDL Value</label>
                                    <span class="form-hint">CSIDL constant identifying a special folder</span>
                                    <input type="number" @bind="SpecialFolderCsidl" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="mono">Offset</label>
                                    <span class="form-hint">Byte offset into the link target ID list</span>
                                    <input type="number" @bind="SpecialFolderOffset" class="form-input" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!IsParsed)
            {
                @if (!string.IsNullOrWhiteSpace(GenerateError))
                {
                    <div class="error-banner">
                        <span>@GenerateError</span>
                    </div>
                }

                @if (IsGenerated)
                {
                    <div class="success-banner">
                        <span>Shortcut generated and downloaded as .zip successfully.</span>
                    </div>
                }

                <button class="btn btn-primary generate-btn" @onclick="GenerateLnk" disabled="@IsGenerating">
                    @if (IsGenerating)
                    {
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Generate .lnk</span>
                    }
                </button>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(DownloadError))
                {
                    <div class="error-banner">
                        <span>@DownloadError</span>
                    </div>
                }

                @if (IsDownloaded)
                {
                    <div class="success-banner">
                        <span>Shortcut downloaded as .zip successfully.</span>
                    </div>
                }

                <div class="lnk-actions">
                    <button class="btn btn-primary action-btn" @onclick="DownloadLnk" disabled="@IsDownloading">
                        @if (IsDownloading)
                        {
                            <span>Downloading...</span>
                        }
                        else
                        {
                            <span>Download .lnk</span>
                        }
                    </button>
                    <button class="btn btn-secondary action-btn" @onclick="ResetParse">
                        Back to Generator
                    </button>
                </div>
            }
        </div>

        <div class="powered-by">
            <div class="powered-by-header">
                <span class="mono powered-by-label">Powered by</span>
                <a href="https://github.com/mrzaxaryan/ShortcutLib" target="_blank" rel="noopener noreferrer"
                   class="mono powered-by-link">ShortcutLib</a>
            </div>
        </div>
    </div>
</section>

@code {
    // Shared form fields
    private string Target { get; set; } = "";
    private string? Arguments { get; set; }
    private string? WorkingDirectory { get; set; }
    private string? Description { get; set; }
    private string? IconLocation { get; set; }
    private int IconIndex { get; set; }
    private ShortcutWindowStyle WindowStyle { get; set; } = ShortcutWindowStyle.Normal;
    private bool RunAsAdmin { get; set; }
    private string FileName { get; set; } = "shortcut";

    // Hotkey
    private byte HotkeyKeyValue { get; set; }
    private bool HotkeyCtrl { get; set; }
    private bool HotkeyAlt { get; set; }
    private bool HotkeyShift { get; set; }

    // Additional core fields
    private bool IsPrinterLink { get; set; }
    private bool UseUnicode { get; set; }
    private uint TargetFileSize { get; set; }
    private string? RelativePath { get; set; }
    private string? IconEnvironmentPath { get; set; }

    // Known Folder
    private string? KnownFolderGuid { get; set; }
    private uint KnownFolderOffset { get; set; }

    // Special Folder
    private uint SpecialFolderCsidl { get; set; }
    private uint SpecialFolderOffset { get; set; }

    // File Attributes
    private HashSet<ShortcutLib.FileAttributes> SelectedFileAttributes { get; set; } = [];
