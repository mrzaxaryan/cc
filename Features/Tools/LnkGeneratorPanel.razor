@inject IJSRuntime JS
@using ShortcutLib
@using System.IO.Compression

<section class="tool-panel">
    <div class="tool-content">
        <div class="tool-header">
            <h1 class="mono">LNK <span class="accent">Generator</span></h1>
            <p class="tool-subtitle">Generate Windows shortcut (.lnk) files directly in your browser.</p>
        </div>

        @if (IsParsed)
        {
            <!-- Overview -->
            <div class="lnk-results">
                <div class="tool-section">
                    <button class="tool-section-header" @onclick="() => ToggleSection(0)">
                        <span class="mono">Overview</span>
                        <span class="section-arrow @(IsSectionOpen(0) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                    </button>
                    @if (IsSectionOpen(0))
                    {
                        <div class="tool-section-body">
                            <div class="tool-info-grid tool-info-grid--single-col">
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">File</span>
                                    <span class="tool-info-value">@OriginalFileName</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Size</span>
                                    <span class="tool-info-value">@FormatSize((ulong)OriginalFileSize)</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Target</span>
                                    <span class="tool-info-value mono">@(Target ?? "—")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(Arguments))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Arguments</span>
                                        <span class="tool-info-value mono">@Arguments</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(WorkingDirectory))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Working Dir</span>
                                        <span class="tool-info-value mono">@WorkingDirectory</span>
                                    </div>
                                }
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Window Style</span>
                                    <span class="tool-info-value">@WindowStyle</span>
                                </div>
                                <div class="tool-info-item">
                                    <span class="tool-info-label mono">Run as Admin</span>
                                    <span class="tool-info-value">@(RunAsAdmin ? "Yes" : "No")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(IconLocation))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Icon</span>
                                        <span class="tool-info-value mono">@IconLocation, @IconIndex</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Description))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Description</span>
                                        <span class="tool-info-value">@Description</span>
                                    </div>
                                }
                                @if (HotkeyKeyValue != 0)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Hotkey</span>
                                        <span class="tool-info-value mono">@FormatHotkey()</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(RelativePath))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Relative Path</span>
                                        <span class="tool-info-value mono">@RelativePath</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(IconEnvironmentPath))
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Icon Env Path</span>
                                        <span class="tool-info-value mono">@IconEnvironmentPath</span>
                                    </div>
                                }
                                @if (TargetFileSize > 0)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Target File Size</span>
                                        <span class="tool-info-value mono">@FormatSize(TargetFileSize)</span>
                                    </div>
                                }
                                @if (UseUnicode)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Unicode</span>
                                        <span class="tool-info-value">Yes</span>
                                    </div>
                                }
                                @if (IsPrinterLink)
                                {
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Printer Link</span>
                                        <span class="tool-info-value">Yes</span>
                                    </div>
                                }
                            </div>

                            @{ var parsedFileAttrFlags = GetParsedFileAttributeNames(); }
                            @if (parsedFileAttrFlags.Length > 0)
                            {
                                <div class="lnk-flags">
                                    <span class="lnk-flags-label mono">File Attributes:</span>
                                    @foreach (var flag in parsedFileAttrFlags)
                                    {
                                        <span class="lnk-flag">@flag</span>
                                    }
                                </div>
                            }

                            @{ var activeLinkFlags = GetActiveLinkFlagNames(); }
                            @if (activeLinkFlags.Length > 0)
                            {
                                <div class="lnk-flags">
                                    <span class="lnk-flags-label mono">Link Flags:</span>
                                    @foreach (var flag in activeLinkFlags)
                                    {
                                        <span class="lnk-flag">@flag</span>
                                    }
                                </div>
                            }

                            @if (ParsedExtraConsoleCodePage != null || !string.IsNullOrWhiteSpace(ParsedExtraDarwinData) || !string.IsNullOrWhiteSpace(ParsedExtraShimLayerName)
                                || !string.IsNullOrWhiteSpace(KnownFolderGuid) || SpecialFolderCsidl > 0)
                            {
                                <div class="tool-info-grid tool-info-grid--single-col" style="margin-top: 0.75rem;">
                                    @if (ParsedExtraConsoleCodePage != null)
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Console Code Page</span>
                                            <span class="tool-info-value mono">@ParsedExtraConsoleCodePage</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ParsedExtraDarwinData))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Darwin Data</span>
                                            <span class="tool-info-value mono">@ParsedExtraDarwinData</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ParsedExtraShimLayerName))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Shim Layer</span>
                                            <span class="tool-info-value mono">@ParsedExtraShimLayerName</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(KnownFolderGuid))
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Known Folder</span>
                                            <span class="tool-info-value mono">@KnownFolderGuid (offset: @KnownFolderOffset)</span>
                                        </div>
                                    }
                                    @if (SpecialFolderCsidl > 0)
                                    {
                                        <div class="tool-info-item">
                                            <span class="tool-info-label mono">Special Folder</span>
                                            <span class="tool-info-value mono">CSIDL @SpecialFolderCsidl (offset: @SpecialFolderOffset)</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Tracking Info -->
                @if (HasTrackingData)
                {
                    <div class="tool-section tracking-section">
                        <button class="tool-section-header" @onclick="() => ToggleSection(1)">
                            <span class="mono">Tracking Info</span>
                            <span class="section-arrow @(IsSectionOpen(1) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                        </button>
                        @if (IsSectionOpen(1))
                        {
                            <div class="tool-section-body">
                                <div class="warning-banner">
                                    <span>This file contains embedded tracking data that can identify the machine it was created on.</span>
                                </div>

                                <div class="tool-info-grid tool-info-grid--single-col">
                                    @if (ParsedTracker != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Machine ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.MachineId</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Volume ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.VolumeId</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Object ID</span>
                                            <span class="tool-info-value mono">@ParsedTracker.ObjectId</span>
                                        </div>
                                        @if (ParsedTracker.BirthVolumeId != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Birth Volume ID</span>
                                                <span class="tool-info-value mono">@ParsedTracker.BirthVolumeId</span>
                                            </div>
                                        }
                                        @if (ParsedTracker.BirthObjectId != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Birth Object ID</span>
                                                <span class="tool-info-value mono">@ParsedTracker.BirthObjectId</span>
                                            </div>
                                        }
                                    }

                                    @if (ParsedLinkInfo?.Local != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Local Path</span>
                                            <span class="tool-info-value mono">@ParsedLinkInfo.Local.BasePath</span>
                                        </div>
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Drive Serial</span>
                                            <span class="tool-info-value mono">@($"0x{ParsedLinkInfo.Local.DriveSerialNumber:X8}")</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(ParsedLinkInfo.Local.VolumeLabel))
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Volume Label</span>
                                                <span class="tool-info-value mono">@ParsedLinkInfo.Local.VolumeLabel</span>
                                            </div>
                                        }
                                    }
                                    @if (ParsedLinkInfo?.Network != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Network Share</span>
                                            <span class="tool-info-value mono">@ParsedLinkInfo.Network.ShareName</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(ParsedLinkInfo.Network.DeviceName))
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Device Name</span>
                                                <span class="tool-info-value mono">@ParsedLinkInfo.Network.DeviceName</span>
                                            </div>
                                        }
                                        @if (ParsedLinkInfo.Network.NetworkProviderType != null)
                                        {
                                            <div class="tool-info-item tracking-item">
                                                <span class="tool-info-label mono">Network Provider</span>
                                                <span class="tool-info-value mono">@($"0x{ParsedLinkInfo.Network.NetworkProviderType.Value:X8}")</span>
                                            </div>
                                        }
                                    }

                                    @if (ParsedCreationTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Created</span>
                                            <span class="tool-info-value mono">@ParsedCreationTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }
                                    @if (ParsedAccessTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Accessed</span>
                                            <span class="tool-info-value mono">@ParsedAccessTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }
                                    @if (ParsedWriteTime != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Modified</span>
                                            <span class="tool-info-value mono">@ParsedWriteTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                    }

                                    @if (ParsedPropertyStore != null)
                                    {
                                        <div class="tool-info-item tracking-item">
                                            <span class="tool-info-label mono">Property Store</span>
                                            <span class="tool-info-value mono">@FormatSize((ulong)ParsedPropertyStore.Length)</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Console Data (parsed) -->
                @if (ParsedConsoleData != null)
                {
                    <div class="tool-section">
                        <button class="tool-section-header" @onclick="() => ToggleSection(2)">
                            <span class="mono">Console Data</span>
                            <span class="section-arrow @(IsSectionOpen(2) ? "open" : "")"><C2Icon Name="chevron-down" Size="Size.Xs" /></span>
                        </button>
                        @if (IsSectionOpen(2))
                        {
                            <div class="tool-section-body">
                                <div class="tool-info-grid">
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Buffer Size</span>
                                        <span class="tool-info-value mono">@(ParsedConsoleData.ScreenBufferSizeX)x@(ParsedConsoleData.ScreenBufferSizeY)</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Window Size</span>
                                        <span class="tool-info-value mono">@(ParsedConsoleData.WindowSizeX)x@(ParsedConsoleData.WindowSizeY)</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Font</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.FaceName</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Font Weight</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.FontWeight</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">Cursor Size</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.CursorSize%</span>
                                    </div>
                                    <div class="tool-info-item">
                                        <span class="tool-info-label mono">History Buffer</span>
                                        <span class="tool-info-value mono">@ParsedConsoleData.HistoryBufferSize</span>
                                    </div>
                                </div>

                                @{ var consoleFlags = GetParsedConsoleFlagNames(); }
                                @if (consoleFlags.Length > 0)
                                {
                                    <div class="lnk-flags">
                                        <span class="lnk-flags-label mono">Options:</span>
                                        @foreach (var flag in consoleFlags)
                                        {
                                            <span class="lnk-flag">@flag</span>
                                        }
                                    </div>
                                }

                                @if (ParsedConsoleData.ColorTable is { Length: 16 })
                                {
                                    <div class="color-preview-row">
                                        @for (int i = 0; i < 16; i++)
                                        {
                                            <div class="color-preview-swatch"
                                                 style="background: @BbggrrToHex(ParsedConsoleData.ColorTable[i])" title="Color @i">
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Shared Form -->
        <div class="tool-form-wrapper">
            @if (!IsParsed)
            {
                <div class="form-group template-selector">
                    <label class="mono" for="template">Template</label>
                    <select id="template" class="form-input" value="@SelectedTemplateName" @onchange="OnTemplateSelected">
                        <option value="">Custom</option>
                        @foreach (var tpl in LnkTemplates)
                        {
                            <option value="@tpl.Name">@tpl.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group">
                <label class="mono" for="target">Target Path <span class="required">*</span></label>
                <input id="target" type="text" @bind="Target" placeholder="C:\Windows\notepad.exe" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="arguments">Arguments</label>
                <input id="arguments" type="text" @bind="Arguments" placeholder="--flag value" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="workingDir">Working Directory</label>
                <input id="workingDir" type="text" @bind="WorkingDirectory" placeholder="C:\MyApp" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="description">Description</label>
                <input id="description" type="text" @bind="Description" placeholder="My Shortcut" class="form-input" />
            </div>

            <div class="form-group">
                <label class="mono" for="iconTemplate">Icon Template</label>
                <select id="iconTemplate" class="form-input" value="@SelectedIconTemplateName" @onchange="OnIconTemplateSelected">
                    <option value="">None</option>
                    @foreach (var tpl in IconTemplates)
                    {
                        <option value="@tpl.Label">@tpl.Symbol @tpl.Label</option>
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="mono" for="iconLocation">Icon Location</label>
                    <input id="iconLocation" type="text" @bind="IconLocation"
                           placeholder="%SystemRoot%\system32\shell32.dll" class="form-input" />
                </div>
                <div class="form-group">
                    <label class="mono" for="iconIndex">Icon Index</label>
                    <input id="iconIndex" type="number" @bind="IconIndex" class="form-input" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="mono" for="windowStyle">Window Style</label>
                    <select id="windowStyle" @bind="WindowStyle" class="form-input">
                        <option value="@ShortcutWindowStyle.Normal">Normal</option>
                        <option value="@ShortcutWindowStyle.Maximized">Maximized</option>
                        <option value="@ShortcutWindowStyle.Minimized">Minimized</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="mono" for="fileName">File Name</label>
                    <input id="fileName" type="text" @bind="FileName" placeholder="shortcut" class="form-input" />
                </div>
            </div>

            <div class="form-checkboxes">
                <label class="checkbox-label">
                    <input type="checkbox" @bind="PadArguments" />
                    <span class="checkmark"></span>
                    <span class="checkbox-text">
                        <span class="mono">Pad Arguments</span>
                        <span class="form-hint">Hide arguments from the shortcut properties dialog with 31 KB of whitespace padding</span>
                    </span>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" @bind="RunAsAdmin" />
                    <span class="checkmark"></span>
                    <span class="checkbox-text">
                        <span class="mono">Run as Administrator</span>
                        <span class="form-hint">Launch the target with elevated privileges (UAC prompt)</span>
                    </span>
                </label>
                @if (IsParsed && HasTrackingData)
                {
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="StripTrackingData" />
                        <span class="checkmark"></span>
                        <span class="checkbox-text">
                            <span class="mono">Strip Tracking Data</span>
                            <span class="form-hint">Remove machine-identifying metadata from the file</span>
                        </span>
                    </label>
                }
            </div>


            @if (!IsParsed)
            {
                @if (!string.IsNullOrWhiteSpace(GenerateError))
                {
                    <div class="error-banner">
                        <span>@GenerateError</span>
                    </div>
                }

                @if (IsGenerated)
                {
                    <div class="success-banner">
                        <span>Shortcut generated and downloaded as .zip successfully.</span>
                    </div>
                }

                <button class="btn btn-primary generate-btn" @onclick="GenerateLnk" disabled="@IsGenerating">
                    @if (IsGenerating)
                    {
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Generate .lnk</span>
                    }
                </button>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(DownloadError))
                {
                    <div class="error-banner">
                        <span>@DownloadError</span>
                    </div>
                }

                @if (IsDownloaded)
                {
                    <div class="success-banner">
                        <span>Shortcut downloaded as .zip successfully.</span>
                    </div>
                }

                <div class="lnk-actions">
                    <button class="btn btn-primary action-btn" @onclick="DownloadLnk" disabled="@IsDownloading">
                        @if (IsDownloading)
                        {
                            <span>Downloading...</span>
                        }
                        else
                        {
                            <span>Download .lnk</span>
                        }
                    </button>
                    <button class="btn btn-secondary action-btn" @onclick="ResetParse">
                        Back to Generator
                    </button>
                </div>
            }
        </div>

        <div class="powered-by">
            <div class="powered-by-header">
                <span class="mono powered-by-label">Powered by</span>
                <a href="https://github.com/mrzaxaryan/ShortcutLib" target="_blank" rel="noopener noreferrer"
                   class="mono powered-by-link">ShortcutLib</a>
            </div>
        </div>
    </div>
</section>

@code {
    // Shared form fields
    private string Target { get; set; } = "";
    private string? Arguments { get; set; }
    private string? WorkingDirectory { get; set; }
    private string? Description { get; set; }
    private string? IconLocation { get; set; }
    private int IconIndex { get; set; }
    private ShortcutWindowStyle WindowStyle { get; set; } = ShortcutWindowStyle.Normal;
    private bool RunAsAdmin { get; set; }
    private bool PadArguments { get; set; }
    private string FileName { get; set; } = "shortcut";

    // Hotkey
    private byte HotkeyKeyValue { get; set; }
    private bool HotkeyCtrl { get; set; }
    private bool HotkeyAlt { get; set; }
    private bool HotkeyShift { get; set; }

    // Additional core fields
    private bool IsPrinterLink { get; set; }
    private bool UseUnicode { get; set; }
    private uint TargetFileSize { get; set; }
    private string? RelativePath { get; set; }
    private string? IconEnvironmentPath { get; set; }

    // Known Folder
    private string? KnownFolderGuid { get; set; }
    private uint KnownFolderOffset { get; set; }

    // Special Folder
    private uint SpecialFolderCsidl { get; set; }
    private uint SpecialFolderOffset { get; set; }

    // File Attributes
    private HashSet<ShortcutLib.FileAttributes> SelectedFileAttributes { get; set; } = [];
    private static readonly ShortcutLib.FileAttributes[] AllFileAttributes = Enum.GetValues<ShortcutLib.FileAttributes>();

    // Link Flags
    private bool ForceNoLinkInfo { get; set; }
    private bool RunInSeparateProcess { get; set; }
    private bool NoPidlAlias { get; set; }
    private bool ForceNoLinkTrack { get; set; }
    private bool EnableTargetMetadata { get; set; }
    private bool DisableLinkPathTracking { get; set; }
    private bool DisableKnownFolderTracking { get; set; }
    private bool DisableKnownFolderAlias { get; set; }
    private bool AllowLinkToLink { get; set; }
    private bool UnaliasOnSave { get; set; }
    private bool KeepLocalIDListForUNCTarget { get; set; }

    // Console Settings
    private bool EnableConsoleSettings { get; set; }
    private short ConsoleBufferSizeX { get; set; } = 120;
    private short ConsoleBufferSizeY { get; set; } = 9001;
    private short ConsoleWindowSizeX { get; set; } = 120;
    private short ConsoleWindowSizeY { get; set; } = 30;
    private string ConsoleFaceName { get; set; } = "Consolas";
    private uint ConsoleFontSize { get; set; }
    private uint ConsoleFontWeight { get; set; } = 400;
    private bool ConsoleFullScreen { get; set; }
    private bool ConsoleQuickEdit { get; set; }
    private bool ConsoleInsertMode { get; set; }
    private bool ConsoleAutoPosition { get; set; } = true;
    private uint ConsoleHistoryBufferSize { get; set; } = 50;
    private uint ConsoleNumberOfHistoryBuffers { get; set; } = 4;
    private bool ConsoleHistoryNoDup { get; set; }
    private short ConsoleWindowOriginX { get; set; }
    private short ConsoleWindowOriginY { get; set; }
    private uint ConsoleCursorSize { get; set; } = 25;
    private ushort ConsoleFillAttributes { get; set; }
    private ushort ConsolePopupFillAttributes { get; set; }
    private string[] ConsoleColorHexValues { get; set; } = DefaultConsoleColors();

    // Property Store
    private bool EnablePropertyStore { get; set; }
    private string? PropAppUserModelId { get; set; }
    private bool PropPreventPinning { get; set; }
    private string? PropRelaunchCommand { get; set; }
    private string? PropRelaunchDisplayNameResource { get; set; }
    private string? PropRelaunchIconResource { get; set; }
    private bool PropExcludeFromShowInNewInstall { get; set; }
    private bool PropIsDestListSeparator { get; set; }
    private string? PropToastActivatorCLSID { get; set; }
    private string? PropTargetParsingPath { get; set; }
    private uint? PropTargetSFGAOFlags { get; set; }
    private string? PropItemTypeText { get; set; }
    private string? PropMimeType { get; set; }

    // Named Properties
    private record NamedPropertyEntry(string Name, string Type, string Value);
    private List<NamedPropertyEntry> NamedProperties { get; set; } = [];

    private void AddNamedProperty() =>
        NamedProperties.Add(new NamedPropertyEntry("", "String", ""));

    private void RemoveNamedProperty(int index) =>
        NamedProperties.RemoveAt(index);

    private void UpdateNamedProperty(int index, string? name, string? type, string? value)
    {
        var p = NamedProperties[index];
        NamedProperties[index] = new NamedPropertyEntry(
            name ?? p.Name,
            type ?? p.Type,
            value ?? p.Value);
    }

