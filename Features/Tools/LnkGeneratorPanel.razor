    private string FormatHotkey()
    {
        var parts = new List<string>();
        if (HotkeyCtrl) parts.Add("Ctrl");
        if (HotkeyAlt) parts.Add("Alt");
        if (HotkeyShift) parts.Add("Shift");
        var key = HotkeyKeyOptions.FirstOrDefault(k => k.Value == HotkeyKeyValue);
        parts.Add(key?.Label ?? $"0x{HotkeyKeyValue:X2}");
        return string.Join(" + ", parts);
    }

