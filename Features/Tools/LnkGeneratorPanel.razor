    }

    private static string BbggrrToHex(uint bbggrr)
    {
        byte r = (byte)(bbggrr & 0xFF);
        byte g = (byte)((bbggrr >> 8) & 0xFF);
        byte b = (byte)((bbggrr >> 16) & 0xFF);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private static uint HexToBbggrr(string hex)
    {
        hex = hex.TrimStart('#');
        if (hex.Length != 6) return 0;
        var color = Convert.ToUInt32(hex, 16);
        byte r = (byte)((color >> 16) & 0xFF);
        byte g = (byte)((color >> 8) & 0xFF);
        byte b = (byte)(color & 0xFF);
        return (uint)((b << 16) | (g << 8) | r);
    }

