    private void OnTemplateSelected(ChangeEventArgs e)
    {
        SelectedTemplateName = e.Value?.ToString() ?? "";
        var template = LnkTemplates.FirstOrDefault(t => t.Name == SelectedTemplateName);
        if (template is null)
        {
            Target = "";
            Arguments = null;
            WorkingDirectory = null;
            Description = null;
            IconLocation = null;
            IconIndex = 0;
            WindowStyle = ShortcutWindowStyle.Normal;
            RunAsAdmin = false;
            FileName = "shortcut";
            RelativePath = null;
            IconEnvironmentPath = null;
            ResetAdvancedFields();
        }
        else
        {
            Target = template.Target;
            Arguments = template.Arguments;
            WorkingDirectory = template.WorkingDirectory;
            Description = template.ShortcutDescription;
            IconLocation = template.IconLocation;
            IconIndex = template.IconIndex;
            WindowStyle = template.WindowStyle;
            RunAsAdmin = template.RunAsAdmin;
            FileName = template.FileName;

            ResetAdvancedFields();

            // Apply template console settings
            if (template.Console is { } c)
            {
                EnableConsoleSettings = true;
                ConsoleBufferSizeX = c.ScreenBufferSizeX;
                ConsoleBufferSizeY = c.ScreenBufferSizeY;
                ConsoleWindowSizeX = c.WindowSizeX;
                ConsoleWindowSizeY = c.WindowSizeY;
                ConsoleFaceName = c.FaceName;
                ConsoleFontSize = c.FontSize;
                ConsoleFontWeight = c.FontWeight;
                ConsoleFullScreen = c.FullScreen;
                ConsoleQuickEdit = c.QuickEdit;
                ConsoleInsertMode = c.InsertMode;
                ConsoleAutoPosition = c.AutoPosition;
                ConsoleHistoryBufferSize = c.HistoryBufferSize;
                ConsoleNumberOfHistoryBuffers = c.NumberOfHistoryBuffers;
                ConsoleHistoryNoDup = c.HistoryNoDup;
                ConsoleWindowOriginX = c.WindowOriginX;
                ConsoleWindowOriginY = c.WindowOriginY;
                ConsoleCursorSize = c.CursorSize;
                ConsoleFillAttributes = c.FillAttributes;
                ConsolePopupFillAttributes = c.PopupFillAttributes;
                if (c.ColorTable is { Length: 16 })
                    for (int i = 0; i < 16; i++)
                        ConsoleColorHexValues[i] = BbggrrToHex(c.ColorTable[i]);
            }

            // Apply template property store
            if (!string.IsNullOrWhiteSpace(template.AppUserModelId))
            {
                EnablePropertyStore = true;
                PropAppUserModelId = template.AppUserModelId;
            }

            // Apply template link flags
            ForceNoLinkTrack = template.ForceNoLinkTrack;
            ForceNoLinkInfo = template.ForceNoLinkInfo;
        }
        GenerateError = null;
        IsGenerated = false;
    }

