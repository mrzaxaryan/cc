        ..Enumerable.Range('0', 10).Select(c => new HotkeyOption(((char)c).ToString(), (byte)c)),
        ..Enumerable.Range(0, 12).Select(i => new HotkeyOption($"F{i + 1}", (byte)(0x70 + i))),
        new("Numpad 0", 0x60), new("Numpad 1", 0x61), new("Numpad 2", 0x62),
        new("Numpad 3", 0x63), new("Numpad 4", 0x64), new("Numpad 5", 0x65),
        new("Numpad 6", 0x66), new("Numpad 7", 0x67), new("Numpad 8", 0x68),
        new("Numpad 9", 0x69),
    ];

    private string FormatHotkey()
    {
        var parts = new List<string>();
        if (HotkeyCtrl) parts.Add("Ctrl");
        if (HotkeyAlt) parts.Add("Alt");
        if (HotkeyShift) parts.Add("Shift");
        var key = HotkeyKeyOptions.FirstOrDefault(k => k.Value == HotkeyKeyValue);
        parts.Add(key?.Label ?? $"0x{HotkeyKeyValue:X2}");
        return string.Join(" + ", parts);
    }

