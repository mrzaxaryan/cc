@inherits EventSubscriber
@inject DownloadStore Downloads
@inject DownloadService DownloadSvc
@inject AgentStore AgentDb
@inject RelayConnectionService RelaySvc
@inject ServiceStateStore SvcState
@inject MessageService Msg

<PanelLayout Title="File Uploads">
    <HeaderLeft>
        @if (IsGlobalServicePaused)
        {
            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs">Service Paused</C2Badge>
        }
        else if (IsGloballyRunning)
        {
            <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs">
                <C2Icon Name="sync" Size="Size.Xs" CssClass="panel-spinning" /> Running
            </C2Badge>
        }
        else if (SyncPaused > 0 || SyncQueued > 0)
        {
            <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">Paused</C2Badge>
        }
        else
        {
            <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">Idle</C2Badge>
        }
    </HeaderLeft>
    <HeaderRight>
        @if (IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeService" Title="Resume upload service for all agents">RESUME SERVICE</C2Btn>
        }
        else
        {
            <C2Btn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="PauseService" Title="Pause upload service for all agents">PAUSE SERVICE</C2Btn>
        }
        @if ((SyncDownloading > 0 || SyncQueued > 0) && !IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Warning" Size="Size.Xs" OnClick="StopAll" Title="Stop all active uploads">STOP ALL</C2Btn>
        }
        @if (SyncPaused > 0 && !IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeAll" Title="Resume all paused">RESUME ALL</C2Btn>
        }
    </HeaderRight>
    <Toolbar>
        <div class="panel-stats">
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-active">@SyncDownloading</span>
                <span class="panel-stat-label">Uploading</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@SyncQueued</span>
                <span class="panel-stat-label">Queued</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@SyncPaused</span>
                <span class="panel-stat-label">Paused</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-done">@SyncCompleted</span>
                <span class="panel-stat-label">Done</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-fail">@SyncFailed</span>
                <span class="panel-stat-label">Failed</span>
            </div>
        </div>
    </Toolbar>
    <Body>
        <div class="panel-card-list">
            @foreach (var group in GetAgentGroups())
            {
                var isProcessing = DownloadSvc.ProcessingAgents.Contains(group.Uuid);
                var isOnline = RelaySvc.GetAllAgents().Any(a => AgentDb.GetUuidByAgentId(a.Agent.Id) == group.Uuid);
                var isAgentPaused = SvcState.IsPaused(ServiceName.Upload, group.Uuid);
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="status-dot @(isOnline ? "dot-on" : "dot-off")"></span>
                        <span class="panel-card-name">@group.Name</span>
                        @if (isAgentPaused)
                        {
                            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs">Paused</C2Badge>
                        }
                        else if (isProcessing)
                        {
                            <C2Badge Variant="BadgeVariant.Info" Size="Size.Xs">
                                <C2Icon Name="sync" Size="Size.Xs" CssClass="panel-spinning" /> Uploading
                            </C2Badge>
                        }
                        else if (group.Queued > 0 && !isOnline)
                        {
                            <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">Offline</C2Badge>
                        }
                        <span class="panel-card-summary">
                            @if (group.Downloading > 0) { <span class="panel-count-active">@group.Downloading<C2Icon Name="dot" Size="Size.Xs" /></span> }
                            @if (group.Queued > 0) { <span class="panel-count-queued">@group.Queued<C2Icon Name="dot-outline" Size="Size.Xs" /></span> }
                            @if (group.Paused > 0) { <span class="panel-count-paused">@group.Paused<C2Icon Name="stop" Size="Size.Xs" /></span> }
                            <span class="panel-count-done">@group.Completed<C2Icon Name="check" Size="Size.Xs" /></span>
                            @if (group.Failed > 0) { <span class="panel-count-fail">@group.Failed<C2Icon Name="x" Size="Size.Xs" /></span> }
                        </span>
                        @if (isAgentPaused)
                        {
                            <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeAgentService(group.Uuid)" Title="Resume upload service for this agent"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                        }
                        else
                        {
                            <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseAgentService(group.Uuid)" Title="Pause upload service for this agent"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                        }
                    </div>

                    @* Active downloads for this agent *@
                    @foreach (var dl in GetAgentDownloads(group.Uuid, DownloadStatus.Downloading))
                    {
                        var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon active"><C2Icon Name="dot" Size="Size.Xs" /></span>
                                <span class="panel-row-name" title="@dl.RemotePath">@dl.FileName</span>
                                <span class="panel-row-status">
                                    <span class="sp-pct">@pct%</span>
                                    @if (dl.SpeedBytesPerSec > 0)
                                    {
                                        <span class="sp-speed">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                                    }
                                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseDownload(dl)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                            <C2Progress Size="Size.Xs" Variant="ProgressVariant.Info" Percent="@pct" />
                        </div>
                    }

                    @* Queued *@
                    @foreach (var dl in GetAgentDownloads(group.Uuid, DownloadStatus.Queued))
                    {
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon"><C2Icon Name="dot-outline" Size="Size.Xs" /></span>
                                <span class="panel-row-name" title="@dl.RemotePath">@dl.FileName</span>
                                <span class="panel-row-status">
                                    <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">QUEUED</C2Badge>
                                    <span class="panel-row-meta">@Formatters.FormatSize((ulong)dl.TotalSize)</span>
                                </span>
                            </div>
                        </div>
                    }

                    @* Paused *@
                    @foreach (var dl in GetAgentDownloads(group.Uuid, DownloadStatus.Paused))
                    {
                        var pctP = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon"><C2Icon Name="stop" Size="Size.Xs" /></span>
                                <span class="panel-row-name" title="@dl.RemotePath">@dl.FileName</span>
                                <span class="panel-row-status">
                                    <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">@pctP%</C2Badge>
                                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeDownload(dl)" Title="Resume"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Failed *@
                    @foreach (var dl in GetAgentDownloads(group.Uuid, DownloadStatus.Failed))
                    {
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon fail"><C2Icon Name="x" Size="Size.Xs" /></span>
                                <span class="panel-row-name" title="@dl.RemotePath">@dl.FileName</span>
                                <span class="panel-row-status">
                                    <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@dl.Error">FAILED</C2Badge>
                                    <C2Btn Size="Size.Xs" OnClick="() => ResumeDownload(dl)" Title="Retry"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Completed (collapsed summary) *@
                    @if (group.Completed > 0)
                    {
                        <div class="panel-row-item panel-done-summary" @onclick="() => ToggleCompleted(group.Uuid)">
                            <div class="panel-row">
                                <span class="panel-row-icon done"><C2Icon Name="check" Size="Size.Xs" /></span>
                                <span class="panel-row-name">@group.Completed completed files (@Formatters.FormatSize((ulong)group.CompletedSize))</span>
                                <span class="panel-row-status">
                                    <span class="panel-expand"><C2Icon Name="@(expandedAgents.Contains(group.Uuid) ? "chevron-up" : "chevron-down")" Size="Size.Xs" /></span>
                                </span>
                            </div>
                        </div>
                        @if (expandedAgents.Contains(group.Uuid))
                        {
                            @foreach (var dl in GetAgentDownloads(group.Uuid, DownloadStatus.Completed))
                            {
                                <div class="panel-row-item panel-done-item">
                                    <div class="panel-row">
                                        <span class="panel-row-icon done"><C2Icon Name="check" Size="Size.Xs" /></span>
                                        <span class="panel-row-name" title="@dl.RemotePath">@dl.FileName</span>
                                        <span class="panel-row-status">
                                            <span class="panel-row-meta">@Formatters.FormatSize((ulong)dl.TotalSize)</span>
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            }

            @if (Downloads.Downloads.Count == 0)
            {
                <div class="panel-empty">No upload activity. Add files from the File Manager to start uploading.</div>
            }
        </div>
    </Body>
</PanelLayout>

@code {
    private readonly HashSet<string> expandedAgents = new();

    private int SyncDownloading => Downloads.Downloads.Count(r => r.Status == DownloadStatus.Downloading);
    private int SyncQueued => Downloads.Downloads.Count(r => r.Status == DownloadStatus.Queued);
    private int SyncPaused => Downloads.Downloads.Count(r => r.Status == DownloadStatus.Paused);
    private int SyncCompleted => Downloads.Downloads.Count(r => r.Status == DownloadStatus.Completed);
    private int SyncFailed => Downloads.Downloads.Count(r => r.Status == DownloadStatus.Failed);
    private bool IsGloballyRunning => DownloadSvc.ProcessingAgents.Count > 0 || SyncDownloading > 0;
    private bool IsGlobalServicePaused => SvcState.IsPaused(ServiceName.Upload, "global");

    protected override async Task OnInitializedAsync()
    {
        On<DownloadStoreChangedEvent>();
        On<RelayAgentsChangedEvent>();
        On<RelayConnectionChangedEvent>();
        On<ServiceStateChangedEvent>();
        await AgentDb.LoadAsync();
        await Downloads.LoadAsync();
        await SvcState.LoadAsync();
    }

    private record AgentGroup(string Uuid, string Name, int Downloading, int Queued, int Paused, int Completed, int Failed, long CompletedSize);

    private List<AgentGroup> GetAgentGroups()
    {
        return Downloads.Downloads
            .GroupBy(r => r.AgentUuid)
            .Select(g =>
            {
                var uuid = g.Key;
                return new AgentGroup(
                    uuid, AgentDb.GetDisplayName(uuid),
                    g.Count(r => r.Status == DownloadStatus.Downloading),
                    g.Count(r => r.Status == DownloadStatus.Queued),
                    g.Count(r => r.Status == DownloadStatus.Paused),
                    g.Count(r => r.Status == DownloadStatus.Completed),
                    g.Count(r => r.Status == DownloadStatus.Failed),
                    g.Where(r => r.Status == DownloadStatus.Completed).Sum(r => r.TotalSize)
                );
            })
            .OrderByDescending(g => g.Downloading)
            .ThenByDescending(g => g.Queued)
            .ThenByDescending(g => g.Paused)
            .ThenBy(g => g.Name)
            .ToList();
    }

    private List<DownloadRecord> GetAgentDownloads(string uuid, string status)
    {
        return Downloads.Downloads
            .Where(r => r.AgentUuid == uuid && r.Status == status)
            .OrderBy(r => r.Priority)
            .ThenBy(r => r.CreatedAt)
            .ToList();
    }

    private void ToggleCompleted(string uuid)
    {
        if (!expandedAgents.Remove(uuid))
            expandedAgents.Add(uuid);
    }

    // --- Service-level controls ---

    private async Task PauseService()
    {
        await SvcState.PauseAsync(ServiceName.Upload, "global");
        Downloads.Cts.CancelAll();
        var queued = Downloads.Downloads.Where(r => r.Status == DownloadStatus.Queued).ToList();
        foreach (var dl in queued)
            await Downloads.PauseAsync(dl.Id);
    }

    private async Task ResumeService()
    {
        await SvcState.ResumeAsync(ServiceName.Upload, "global");
    }

    private async Task PauseAgentService(string uuid)
    {
        await SvcState.PauseAsync(ServiceName.Upload, uuid);
        var active = Downloads.Downloads.Where(r => r.AgentUuid == uuid && r.Status == DownloadStatus.Downloading).ToList();
        foreach (var dl in active)
            Downloads.Cts.Cancel(dl.Id);
        var queued = Downloads.Downloads.Where(r => r.AgentUuid == uuid && r.Status == DownloadStatus.Queued).ToList();
        foreach (var dl in queued)
            await Downloads.PauseAsync(dl.Id);
    }

    private async Task ResumeAgentService(string uuid)
    {
        await SvcState.ResumeAsync(ServiceName.Upload, uuid);
    }

    // --- Item-level controls ---

    private void PauseDownload(DownloadRecord dl) => Downloads.Cts.Cancel(dl.Id);

    private async Task ResumeDownload(DownloadRecord dl)
    {
        if (Downloads.Cts.HasActive(dl.Id)) return;
        await Downloads.QueueAsync(dl.Id);
    }

    private async Task StopAll()
    {
        Downloads.Cts.CancelAll();
        var queued = Downloads.Downloads.Where(r => r.Status == DownloadStatus.Queued).ToList();
        foreach (var dl in queued)
            await Downloads.PauseAsync(dl.Id);
    }

    private async Task ResumeAll()
    {
        var paused = Downloads.Downloads.Where(r => r.Status == DownloadStatus.Paused).ToList();
        foreach (var dl in paused)
            await Downloads.QueueAsync(dl.Id);
    }

    public override void Dispose() => base.Dispose();
}
