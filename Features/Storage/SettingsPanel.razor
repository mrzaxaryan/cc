@inherits EventSubscriber
@inject CacheManager Cache
@inject VfsStore Vfs
@inject AgentStore AgentDb
@inject TransferStore Downloads
@inject MessageService Msg
@inject ThemeService Theme
@inject IJSRuntime Js

<PanelLayout Title="Settings">
    <Toolbar>
        <div class="panel-tabs">
            <button class="panel-tab @(tab == Tab.Appearance ? "active" : "")" @onclick="() => tab = Tab.Appearance">Appearance</button>
            <button class="panel-tab @(tab == Tab.Storage ? "active" : "")" @onclick="() => tab = Tab.Storage">Storage</button>
            <button class="panel-tab @(tab == Tab.IndexedDB ? "active" : "")" @onclick="() => { tab = Tab.IndexedDB; _ = LoadDbStats(); }">IndexedDB</button>
            <button class="panel-tab @(tab == Tab.About ? "active" : "")" @onclick="() => tab = Tab.About">About</button>
        </div>
    </Toolbar>
    <Body>
        @if (tab == Tab.Appearance)
        {
            <div class="sp-section">
                <div class="sp-section-title">Theme</div>
                <div class="sp-row">
                    <span class="sp-row-label">Color Theme</span>
                    <div class="sp-theme-btns">
                        <button class="sp-theme-btn @(Theme.Current == C2.Infrastructure.Theme.Dark ? "active" : "")"
                                @onclick="() => SetTheme(C2.Infrastructure.Theme.Dark)">
                            <C2Icon Name="moon" Size="Size.Xs" /> Dark
                        </button>
                        <button class="sp-theme-btn @(Theme.Current == C2.Infrastructure.Theme.Light ? "active" : "")"
                                @onclick="() => SetTheme(C2.Infrastructure.Theme.Light)">
                            <C2Icon Name="sun" Size="Size.Xs" /> Light
                        </button>
                    </div>
                </div>
            </div>

            <div class="sp-section sp-danger-zone">
                <div class="sp-section-title">Danger Zone</div>
                <div class="sp-row">
                    <div class="sp-row-info">
                        <span class="sp-row-label">Reset Application</span>
                        <span class="sp-row-desc">Deletes all settings, cached files, and application data.</span>
                    </div>
                    @if (confirmReset)
                    {
                        <div class="sp-confirm">
                            <span class="sp-confirm-text">Are you sure?</span>
                            <C2Btn Variant="BtnVariant.DangerSolid" OnClick="ResetApplication" Disabled="@resetting" Loading="@resetting">YES, RESET</C2Btn>
                            <C2Btn OnClick="() => confirmReset = false">CANCEL</C2Btn>
                        </div>
                    }
                    else
                    {
                        <C2Btn Variant="BtnVariant.Danger" OnClick="() => confirmReset = true">RESET</C2Btn>
                    }
                </div>
            </div>
        }
        else if (tab == Tab.Storage)
        {
            @* Toolbar *@
            <div class="cm-toolbar">
                <C2Badge Variant="BadgeVariant.Info">@(Cache.DirectoryName ?? "No folder")</C2Badge>
                <div class="cm-toolbar-actions">
                    <C2Btn OnClick="Refresh" Disabled="@loading" Title="Refresh"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
                    <C2Btn Variant="BtnVariant.Warning" OnClick="ChangeFolder" Title="Change folder"><C2Icon Name="folder" Size="Size.Xs" /></C2Btn>
                </div>
            </div>

            @* Stats *@
            <C2Card Compact CssClass="cm-stats-card">
                <div class="cm-stats">
                    <div class="cm-stat">
                        <span class="cm-stat-value">@stats.agentCount</span>
                        <span class="cm-stat-label">Agents</span>
                    </div>
                    <div class="cm-stat">
                        <span class="cm-stat-value">@stats.dirCount</span>
                        <span class="cm-stat-label">Directories</span>
                    </div>
                    <div class="cm-stat">
                        <span class="cm-stat-value">@stats.fileCount</span>
                        <span class="cm-stat-label">Files</span>
                    </div>
                    <div class="cm-stat">
                        <span class="cm-stat-value">@Formatters.FormatSize((ulong)stats.totalSize)</span>
                        <span class="cm-stat-label">Metadata</span>
                    </div>
                    <div class="cm-stat">
                        <span class="cm-stat-value">@Formatters.FormatSize((ulong)blobSize)</span>
                        <span class="cm-stat-label">On Disk</span>
                    </div>
                </div>
            </C2Card>

            @* Agent list *@
            <div class="cm-list">
                @if (loading)
                {
                    <div class="cm-list-loading"><C2Spinner /></div>
                }
                else if (agentStats.Count == 0)
                {
                    <div class="panel-empty"><em>No cached data</em></div>
                }
                else
                {
                    @foreach (var agent in agentStats)
                    {
                        <div class="cm-item">
                            <span class="cm-item-name">@agent.name</span>
                            <span class="cm-item-meta">@agent.dirs dir / @agent.files files</span>
                            <span class="cm-item-meta">@Formatters.FormatSize((ulong)agent.size) cached</span>
                            <C2ConfirmBtn OnConfirm="() => DeleteAgentCache(agent.uuid)" Title="Delete agent cache"><C2Icon Name="trash" Size="Size.Xs" /></C2ConfirmBtn>
                        </div>
                    }
                }
            </div>
        }
        else if (tab == Tab.IndexedDB)
        {
            <div class="cm-db-section">
                <div class="cm-toolbar">
                    <C2Badge Variant="BadgeVariant.Dark">c2-agents</C2Badge>
                    <span class="cm-db-version">v4</span>
                    <div class="cm-toolbar-actions">
                        <C2Btn OnClick="LoadDbStats" Disabled="@dbLoading" Title="Refresh"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
                        <C2Btn Variant="BtnVariant.Primary" OnClick="BackupDatabase" Disabled="@dbBacking" Loading="@dbBacking" Title="Export .bak"><C2Icon Name="download" Size="Size.Xs" /></C2Btn>
                        <C2Btn Variant="BtnVariant.Warning" OnClick="RestoreDatabase" Disabled="@dbRestoring" Loading="@dbRestoring" Title="Import .bak"><C2Icon Name="upload" Size="Size.Xs" /></C2Btn>
                    </div>
                </div>
                @if (dbLoading)
                {
                    <div class="cm-list-loading"><C2Spinner /></div>
                }
                else
                {
                    <C2Table Hover>
                        <thead>
                            <tr>
                                <th>Object Store</th>
                                <th>Key</th>
                                <th style="text-align:right">Records</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in dbTables)
                            {
                                <tr>
                                    <td><code>@t.Name</code></td>
                                    <td><code class="cm-db-key">@GetKeyPath(t.Name)</code></td>
                                    <td style="text-align:right;font-weight:600">@t.Count</td>
                                </tr>
                            }
                        </tbody>
                    </C2Table>
                    @if (dbTables.Count > 0)
                    {
                        <div class="cm-db-total">
                            Total: @dbTables.Sum(t => t.Count) records across @dbTables.Count stores
                        </div>
                    }
                }
            </div>
        }
        else if (tab == Tab.About)
        {
            <div class="cm-about">
                <div class="cm-about-hero">
                    <img class="cm-about-icon" src="icon-192.png" alt="C2" />
                    <div class="cm-about-brand">C2</div>
                    <div class="cm-about-tagline">Command &amp; Control</div>
                </div>

                <div class="cm-about-cards">
                    <C2Card Compact>
                        <div class="cm-about-card-title">Build</div>
                        <div class="cm-about-rows">
                            <div class="cm-about-row">
                                <span class="cm-about-label">Version</span>
                                <code class="cm-about-value">@BuildMeta.Version</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Built</span>
                                <code class="cm-about-value">@BuildMeta.Date</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Commit</span>
                                <code class="cm-about-value">@BuildMeta.Hash</code>
                            </div>
                        </div>
                    </C2Card>

                    <C2Card Compact>
                        <div class="cm-about-card-title">Runtime</div>
                        <div class="cm-about-rows">
                            <div class="cm-about-row">
                                <span class="cm-about-label">Framework</span>
                                <code class="cm-about-value">@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">OS</span>
                                <code class="cm-about-value">@System.Runtime.InteropServices.RuntimeInformation.OSDescription</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Architecture</span>
                                <code class="cm-about-value">@System.Runtime.InteropServices.RuntimeInformation.OSArchitecture</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Processors</span>
                                <code class="cm-about-value">@System.Environment.ProcessorCount</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Culture</span>
                                <code class="cm-about-value">@System.Globalization.CultureInfo.CurrentCulture</code>
                            </div>
                        </div>
                    </C2Card>

                    <C2Card Compact>
                        <div class="cm-about-card-title">Browser</div>
                        <div class="cm-about-rows">
                            <div class="cm-about-row">
                                <span class="cm-about-label">User Agent</span>
                                <code class="cm-about-value cm-about-value--ua">@(browserInfo.UserAgent ?? "—")</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Language</span>
                                <code class="cm-about-value">@(browserInfo.Language ?? "—")</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Screen</span>
                                <code class="cm-about-value">@(browserInfo.Screen ?? "—")</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Threads</span>
                                <code class="cm-about-value">@(browserInfo.Threads > 0 ? browserInfo.Threads.ToString() : "—")</code>
                            </div>
                            <div class="cm-about-row">
                                <span class="cm-about-label">Online</span>
                                <code class="cm-about-value">@(browserInfo.Online ? "Yes" : "No")</code>
                            </div>
                        </div>
                    </C2Card>
                </div>
            </div>
        }
    </Body>
</PanelLayout>

@code {
    private enum Tab { Appearance, Storage, IndexedDB, About }
    private Tab tab = Tab.Appearance;

    private List<(string uuid, string name, int dirs, int files, long size)> agentStats = new();
    private (int agentCount, int dirCount, int fileCount, long totalSize) stats;
    private long blobSize;
    private bool loading;
    private bool confirmReset;
    private bool resetting;

    // IndexedDB tab
    private record DbTable(string Name, int Count);
    private List<DbTable> dbTables = new();
    private bool dbLoading;
    private bool dbBacking;
    private bool dbRestoring;

    // Browser info (About tab)
    private record BrowserInfo(string? UserAgent, string? Language, string? Screen, int Threads, bool Online);
    private BrowserInfo browserInfo = new(null, null, null, 0, true);

    // Debounce
    private Timer? _debounceTimer;
    private bool _refreshing;

    protected override async Task OnInitializedAsync()
    {
        On<CacheChangedEvent>(e => OnDataChanged());
        On<VfsChangedEvent>(e => OnDataChanged());
        On<ThemeChangedEvent>();
        await Refresh();
        await LoadBrowserInfo();
    }

    private async Task LoadBrowserInfo()
    {
        try
        {
            var ua = await Js.InvokeAsync<string?>("eval", "navigator.userAgent");
            var lang = await Js.InvokeAsync<string?>("eval", "navigator.language");
            var screen = await Js.InvokeAsync<string?>("eval", "`${screen.width}×${screen.height} (${window.devicePixelRatio}x)`");
            var threads = await Js.InvokeAsync<int>("eval", "navigator.hardwareConcurrency || 0");
            var online = await Js.InvokeAsync<bool>("eval", "navigator.onLine");
            browserInfo = new(ua, lang, screen, threads, online);
        }
        catch { }
    }

    private void OnDataChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            if (_refreshing) return;
            await InvokeAsync(Refresh);
        }, null, 300, Timeout.Infinite);
    }

    private async Task Refresh()
    {
        if (!Cache.HasDirectory || _refreshing) return;
        _refreshing = true;
        loading = true;
        StateHasChanged();

        try
        {
            blobSize = await Cache.GetCacheSizeAsync();
            var uuids = AgentDb.Agents.Values.Select(a => a.Uuid).ToList();
            stats = await Vfs.GetGlobalStatsAsync(uuids);

            agentStats = new();
            foreach (var agent in AgentDb.Agents.Values)
            {
                var (d, f, _) = await Vfs.GetAgentStatsAsync(agent.Uuid);
                var cachedSize = Downloads.GetByAgent(agent.Uuid)
                    .Where(r => r.Status == TransferStatus.Completed)
                    .Sum(r => r.TotalSize);
                if (d > 0 || f > 0 || cachedSize > 0)
                    agentStats.Add((agent.Uuid, agent.Name, d, f, cachedSize));
            }
        }
        catch (Exception ex)
        {
            Msg.Error("Load Failed", $"Could not load storage data: {ex.Message}", "Settings");
        }
        finally
        {
            loading = false;
            _refreshing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAgentCache(string agentUuid)
    {
        try
        {
            loading = true;
            StateHasChanged();
            await Vfs.ClearAgentAsync(agentUuid);
            foreach (var dl in Downloads.GetByAgent(agentUuid))
                await Downloads.RemoveAsync(dl.Id);
            await Refresh();
        }
        catch (Exception ex) { Msg.Error("Cache Clear Failed", $"Could not clear agent cache: {ex.Message}", "Settings"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task ResetApplication()
    {
        confirmReset = false;
        resetting = true;
        StateHasChanged();
        try
        {
            await Cache.ClearAllDataAsync();
            await Js.InvokeVoidAsync("eval", "location.reload()");
        }
        catch (Exception ex) { Msg.Error("Reset Failed", $"Could not fully reset application: {ex.Message}", "Settings"); }
        finally { resetting = false; StateHasChanged(); }
    }

    private async Task ChangeFolder()
    {
        try
        {
            await Cache.PickDirectoryAsync();
            await Refresh();
        }
        catch (Exception ex) { Msg.Error("Folder Change Failed", $"Could not select folder: {ex.Message}", "Settings"); }
    }

    private async Task SetTheme(C2.Infrastructure.Theme theme)
    {
        if (Theme.Current == theme) return;
        await Theme.Toggle();
    }

    // IndexedDB

    private async Task RestoreDatabase()
    {
        dbRestoring = true;
        StateHasChanged();
        try
        {
            var applied = await Js.InvokeAsync<bool>("c2DbInfo.importBackup");
            if (applied)
            {
                await LoadDbStats();
                Msg.Success("Backup Restored", "Database restored — reload to apply changes.", "Settings");
            }
        }
        catch (Exception ex) { Msg.Error("Restore Failed", ex.Message, "Settings"); }
        finally { dbRestoring = false; StateHasChanged(); }
    }

    private async Task BackupDatabase()
    {
        dbBacking = true;
        StateHasChanged();
        try
        {
            await Js.InvokeVoidAsync("c2DbInfo.exportBackup");
        }
        catch (Exception ex) { Msg.Error("Backup Failed", $"Could not export database: {ex.Message}", "Settings"); }
        finally { dbBacking = false; StateHasChanged(); }
    }

    private async Task LoadDbStats()
    {
        dbLoading = true;
        StateHasChanged();
        try
        {
            var results = await Js.InvokeAsync<DbTableResult[]>("c2DbInfo.getTableStats");
            dbTables = results.Select(r => new DbTable(r.Name, r.Count)).ToList();
        }
        catch (Exception ex) { Msg.Error("IndexedDB Error", $"Failed to read database stats: {ex.Message}", "Settings"); }
        finally { dbLoading = false; StateHasChanged(); }
    }

    private record DbTableResult(string Name, int Count);

    private static string GetKeyPath(string store) => store switch
    {
        "agents" => "uuid",
        "relays" => "url",
        "downloads" => "id (auto)",
        "directories" => "id",
        "files" => "id",
        _ => "—"
    };

    public override void Dispose()
    {
        _debounceTimer?.Dispose();
        base.Dispose();
    }
}
