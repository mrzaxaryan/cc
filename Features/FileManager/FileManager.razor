@using System.Net.WebSockets
@implements IDisposable
@inject CacheManager Cache
@inject RelayConnectionService RelaySvc
@inject AgentStore AgentDb
@inject DownloadStore Downloads
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js
@inject IEventBus Bus
@inject VfsStore Vfs

<div class="fm">
    @* Navigation toolbar *@
    <div class="fm-toolbar">
        <C2Btn OnClick="NavigateUp" Disabled="@(loading || (!IsConnected && entries is null))" Title="Up" Size="Size.Xs">
            <C2Icon Name="arrow-up" Size="Size.Xs" />
        </C2Btn>
        <C2Btn OnClick="Refresh" Disabled="@(loading || !IsConnected)" Title="Refresh" Size="Size.Xs">
            <C2Icon Name="refresh" Size="Size.Xs" />
        </C2Btn>
        <div class="fm-path-bar">
            <C2Input @bind-Value="currentPath" OnKeyDown="OnPathKeyDown" Monospace />
        </div>
        @if (!IsConnected || _agentOffline)
        {
            <div class="fm-offline-badge">
                <span class="fm-offline-dot"></span>
                @(_usingCachedData ? "Cached" : "Offline")
            </div>
        }
    </div>

    @* Breadcrumb *@
    @if (pathSegments.Length > 0)
    {
        <div class="fm-breadcrumb">
            <a href="javascript:void(0)" class="fm-crumb" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
            @for (int i = 0; i < pathSegments.Length; i++)
            {
                var idx = i;
                <span class="fm-crumb-sep">/</span>
                @if (idx == pathSegments.Length - 1)
                {
                    <span class="fm-crumb-active">@pathSegments[idx]</span>
                }
                else
                {
                    <a href="javascript:void(0)" class="fm-crumb" @onclick="() => NavigateToBreadcrumb(idx)" @onclick:preventDefault>@pathSegments[idx]</a>
                }
            }
        </div>
    }

    @* Action bar *@
    <div class="fm-actions">
        <C2Btn Size="Size.Xs" OnClick="OpenFullSearchWindow" Disabled="@(!IsConnected)" Title="Search agent filesystem">
            <C2Icon Name="search" Size="Size.Xs" /> Search
        </C2Btn>
        <C2Btn Size="Size.Xs" OnClick="ToggleUploads" Title="File transfers"
               CssClass="@(_uploadsOpen ? "fm-filter-btn-active" : "")">
            <C2Icon Name="arrow-up-down" Size="Size.Xs" /> Uploads
        </C2Btn>
        <div class="fm-actions-spacer"></div>
        <C2Btn Size="Size.Xs" OnClick="ToggleFilter" Title="Filter by name"
               CssClass="@(filterActive ? "fm-filter-btn-active" : "")">
            <C2Icon Name="filter" Size="Size.Xs" />
        </C2Btn>
    </div>
    @if (filterActive)
    {
        <div class="fm-filter-bar">
            <C2Icon Name="search" Size="Size.Xs" CssClass="fm-filter-icon" />
            <C2Input @bind-Value="filterText" @bind-Value:after="OnFilterTextChanged" BindOnInput
                     Placeholder="Filter by name..." Size="Size.Xs" Monospace
                     CssClass="fm-filter-input" OnKeyDown="OnFilterKeyDown" />
            @if (!string.IsNullOrEmpty(filterText))
            {
                <span class="fm-filter-count">@(FilteredEntries?.Count ?? 0) / @(entries?.Count ?? 0)</span>
                <C2Btn Size="Size.Xs" OnClick="ClearFilter" Title="Clear filter">
                    <C2Icon Name="x" Size="Size.Xs" />
                </C2Btn>
            }
        </div>
    }

    @* Uploads panel *@
    @if (_uploadsOpen)
    {
        <div class="fm-uploads">
            @* Filter bar *@
            <div class="fm-ul-filters">
                <div class="fm-ul-tabs">
                    @foreach (var f in Enum.GetValues<UlFilter>())
                    {
                        var fv = f;
                        <button class="fm-ul-tab @(_ulFilter == fv ? "fm-ul-tab-active" : "")" @onclick="() => SetUlFilter(fv)">
                            @fv <span class="fm-ul-tab-count">@UlCount(fv)</span>
                        </button>
                    }
                </div>
                <div class="fm-ul-date-filter">
                    <C2Icon Name="calendar" Size="Size.Xs" CssClass="fm-ul-cal-icon" />
                    <select class="fm-ul-date-select" value="@_ulDateFilter" @onchange="OnUlDateChanged">
                        <option value="All">All time</option>
                        <option value="Today">Today</option>
                        <option value="Week">Last 7 days</option>
                        <option value="Month">Last 30 days</option>
                    </select>
                </div>
            </div>

            @* Column headers *@
            <div class="fm-ul-head">
                <span class="fm-ul-th-icon"></span>
                <span class="fm-ul-th-name">Name</span>
                <span class="fm-ul-th-size">Size</span>
                <span class="fm-ul-th-status">Status</span>
                <span class="fm-ul-th-date">Date</span>
                <span class="fm-ul-th-acts"></span>
            </div>

            @* File rows *@
            <div class="fm-ul-list">
                @if (_ulFiltered.Count == 0)
                {
                    <div class="fm-ul-empty">No transfers.</div>
                }
                else
                {
                    <Virtualize Items="_ulFiltered" Context="rec" ItemSize="30" OverscanCount="5">
                        @{ var r = rec; var pct = rec.TotalSize > 0 ? (int)(rec.DownloadedSize * 100 / rec.TotalSize) : 0; }
                        <div class="fm-ul-row fm-ul-@rec.Status" @onclick="() => UlNavigate(r)" title="Go to file location">
                            <span class="fm-ul-icon"><C2Icon Name="@UlIcon(rec.Status)" Size="Size.Xs" /></span>
                            <span class="fm-ul-name" title="@rec.RemotePath">@rec.FileName</span>
                            <span class="fm-ul-size">
                                @if (rec.Status == DownloadStatus.Downloading)
                                { @Formatters.FormatSize((ulong)rec.DownloadedSize)<text> / </text> }
                                @Formatters.FormatSize((ulong)rec.TotalSize)
                            </span>
                            <span class="fm-ul-status">
                                @switch (rec.Status)
                                {
                                    case DownloadStatus.Downloading:
                                        <span class="fm-ul-pct">@pct%</span>
                                        @if (rec.SpeedBytesPerSec > 0) { <span class="fm-ul-speed">@Formatters.FormatSpeed(rec.SpeedBytesPerSec)</span> }
                                        break;
                                    case DownloadStatus.Queued:
                                        <span class="fm-ul-badge fm-ul-badge-queued">QUEUED</span>
                                        break;
                                    case DownloadStatus.Paused:
                                        <span class="fm-ul-badge fm-ul-badge-paused">PAUSED @pct%</span>
                                        break;
                                    case DownloadStatus.Completed:
                                        <span class="fm-ul-badge fm-ul-badge-done">DONE</span>
                                        break;
                                    case DownloadStatus.Failed:
                                        <span class="fm-ul-badge fm-ul-badge-error" title="@rec.Error">FAILED</span>
                                        break;
                                }
                            </span>
                            <span class="fm-ul-date">@Formatters.FormatTimestamp(rec.CreatedAt)</span>
                            <span class="fm-ul-acts" @onclick:stopPropagation>
                                @if (rec.Status == DownloadStatus.Downloading)
                                { <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => UlPause(r)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn> }
                                @if (rec.Status == DownloadStatus.Paused)
                                { <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => UlResume(r)" Title="Resume"><C2Icon Name="play" Size="Size.Xs" /></C2Btn> }
                            </span>
                            @if (rec.Status is DownloadStatus.Downloading or DownloadStatus.Paused)
                            {
                                <div class="fm-ul-bar" style="width:@pct%"></div>
                            }
                        </div>
                    </Virtualize>
                }
            </div>
        </div>
    }

    @* Dual pane area *@
    @if (!_uploadsOpen)
    {
        <div class="fm-panels @(viewingFile ? "fm-panels-with-viewer" : "")">
        <div class="fm-pane fm-pane-left">
            <FilePanel @ref="localPanel"
                       Mode="FilePanel.PanelMode.Local"
                       AgentUuid="@AgentUuid"
                       CurrentPath="@currentPath"
                       Entries="@FilteredEntries"
                       Loading="@loading"
                       IsActive="@(activePanel == ActivePanel.Local)"
                       OnActivate="() => SetActive(ActivePanel.Local)"
                       OnAction="OnLocalAction"
                       SortColumn="@sortColumn"
                       SortAscending="@sortAscending"
                       OnSortChanged="OnSortChanged"
                       OnSelectionChanged="sel => remotePanel?.SyncSelection(sel)" />
        </div>
        <div class="fm-pane fm-pane-right">
            <FilePanel @ref="remotePanel"
                       Mode="FilePanel.PanelMode.Remote"
                       AgentUuid="@AgentUuid"
                       CurrentPath="@currentPath"
                       Entries="@(IsConnected && !_agentOffline ? FilteredEntries : null)"
                       Loading="@loading"
                       IsActive="@(activePanel == ActivePanel.Remote)"
                       OnActivate="() => SetActive(ActivePanel.Remote)"
                       OnAction="OnRemoteAction"
                       SortColumn="@sortColumn"
                       SortAscending="@sortAscending"
                       OnSortChanged="OnSortChanged"
                       OnSelectionChanged="sel => localPanel?.SyncSelection(sel)" />
            @if (_inlineView && _inlineViewUrl is not null)
            {
                <div class="fm-inline-viewer">
                    <div class="fm-inline-viewer-bar">
                        <span class="fm-inline-viewer-name">@_inlineViewName</span>
                        <C2Btn Size="Size.Xs" OnClick="CloseInlineView" Title="Close"><C2Icon Name="x" Size="Size.Xs" /></C2Btn>
                    </div>
                    <iframe src="@_inlineViewUrl" class="fm-inline-viewer-frame"></iframe>
                </div>
            }
        </div>
    </div>
    }

    @* File viewer *@
    @if (viewingFile)
    {
        <div class="fm-viewer-container">
            <FileViewer FilePath="@viewingFilePath" FileName="@viewingFileName"
                        IsConnected="@IsConnected" Relay="@Relay" OnClose="CloseFileViewer" />
        </div>
    }

    @* Status bar *@
    @{ var sel = ActiveSelection; var selSize = sel.Where(e => !e.IsDirectory && !e.IsDrive).Sum(e => (long)e.Size); var filtered = FilteredEntries; }
    <div class="fm-status">
        @if (filtered is not null)
        {
            <span class="fm-status-count">@(string.IsNullOrWhiteSpace(filterText) ? $"{filtered.Count} items" : $"{filtered.Count} / {entries?.Count ?? 0} items")</span>
        }
        @if (sel.Count > 0)
        {
            <span class="fm-status-sel">@sel.Count sel</span>
            @if (selSize > 0)
            {
                <span class="fm-status-size">@Formatters.FormatSize((ulong)selSize)</span>
            }
        }
    </div>
</div>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private enum ActivePanel { Local, Remote }

    private bool IsConnected => Relay is not null && Relay.IsConnected;
private HashSet<DirEntry> ActiveSelection =>
        (activePanel == ActivePanel.Local ? localPanel : remotePanel)?.SelectedEntries ?? new();

    private FilePanel? localPanel;
    private FilePanel? remotePanel;
    private ActivePanel activePanel = ActivePanel.Remote;

    // Shared state (both panels)
    private string currentPath = "";
    private string[] pathSegments = [];
    private List<DirEntry>? entries;
    private bool loading;
    private string sortColumn = "name";
    private bool sortAscending = true;
    private bool _usingCachedData;

    // Filter state
    private bool filterActive;
    private string? filterText;

    // Uploads panel
    private bool _uploadsOpen;
    private List<DownloadRecord> _uploads = [];
    private List<DownloadRecord> _ulFiltered = [];
    private enum UlFilter { All, Current, Pending, Error, Done }
    private UlFilter _ulFilter = UlFilter.All;
    private string _ulDateFilter = "All";

    // Cached filtered entries — avoids creating a new list on every render
    private List<DirEntry>? _filteredCache;
    private List<DirEntry>? _filteredSrc;
    private string? _filteredText;

    private List<DirEntry>? FilteredEntries
    {
        get
        {
            if (_filteredSrc == entries && _filteredText == filterText && _filteredCache is not null)
                return _filteredCache;
            _filteredSrc = entries;
            _filteredText = filterText;
            _filteredCache = entries is null ? null
                : string.IsNullOrWhiteSpace(filterText) ? entries
                : entries.Where(e => e.Name.Contains(filterText.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();
            return _filteredCache;
        }
    }

    // Agent OS detection
    private string AgentOs
    {
        get
        {
            var os = RelaySvc.GetAllAgents()
                .Where(a => a.Agent.Id == AgentId)
                .Select(a => a.Agent.Os)
                .FirstOrDefault();
            if (string.IsNullOrEmpty(os) && !string.IsNullOrEmpty(AgentUuid))
                os = AgentDb.GetByUuid(AgentUuid)?.Os;
            return os ?? "";
        }
    }
    private bool IsWindowsAgent => string.Equals(AgentOs, "Windows", StringComparison.OrdinalIgnoreCase);
    private bool IsAndroidAgent => string.Equals(AgentOs, "Android", StringComparison.OrdinalIgnoreCase);
    private bool IsUnixAgent => !IsWindowsAgent;
    private string PathSep => IsUnixAgent ? "/" : @"\";
    private string RootPath => IsWindowsAgent ? "" : IsAndroidAgent ? "/storage/emulated/0/" : "/";

    // File viewer
    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";

    // Inline viewer (shown in remote pane)
    private bool _inlineView;
    private string? _inlineViewUrl;
    private string? _inlineViewName;

    private RelaySocket? _prevRelay;
    private bool _prevIsConnected;

    protected override async Task OnParametersSetAsync()
    {
        var wasConnected = _prevIsConnected;
        _prevIsConnected = IsConnected;
        var relayChanged = Relay != _prevRelay;
        _prevRelay = Relay;

        // Agent just came online — refresh both panels regardless of relay object identity
        if (IsConnected && (!wasConnected || relayChanged))
        {
            await NavigateTo(currentPath.Length > 0 ? currentPath : RootPath);
            return;
        }

        if (entries is not null) return;

        await Downloads.LoadAsync();
        if (string.IsNullOrEmpty(currentPath)) currentPath = RootPath;
        if (IsConnected) await NavigateTo(currentPath);
        else if (!string.IsNullOrEmpty(AgentUuid)) await NavigateToCached(currentPath);
    }

    private IDisposable? _dlSub;
    private IDisposable? _disconnectSub;
    private bool _agentOffline;
    private bool _scrollSyncSetup;

    protected override void OnInitialized()
    {
        _dlSub = Bus.Subscribe<DownloadStoreChangedEvent>(_ => RefreshDownloadBadges());
        _disconnectSub = Bus.Subscribe<AgentDisconnectedEvent>(e =>
        {
            if (e.Uuid != AgentUuid && e.AgentId != AgentId) return;
            _agentOffline = true;
            _ = InvokeAsync(StateHasChanged);
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Set up scroll sync once both panels have their vlist elements rendered (entries loaded)
        if (!_scrollSyncSetup && entries is not null && localPanel is not null && remotePanel is not null)
        {
            _scrollSyncSetup = true;
            try
            {
                await Js.InvokeVoidAsync("c2SyncScroll", localPanel.VlistElement, remotePanel.VlistElement);
                await Js.InvokeVoidAsync("c2SyncScroll", remotePanel.VlistElement, localPanel.VlistElement);
            }
            catch { _scrollSyncSetup = false; }
        }
    }

    public void Dispose() { _dlSub?.Dispose(); _disconnectSub?.Dispose(); _pendingRefresh?.Cancel(); }

    private void OnSortChanged((string column, bool ascending) sort)
    {
        sortColumn = sort.column;
        sortAscending = sort.ascending;
    }

    private DateTime _lastBadgeRefresh;
    private CancellationTokenSource? _pendingRefresh;

    private void RefreshDownloadBadges()
    {
        // Throttle to max once per second, but always schedule a trailing refresh
        // so final state changes (e.g. completed) are never lost
        var now = DateTime.UtcNow;
        if ((now - _lastBadgeRefresh).TotalMilliseconds >= 1000)
        {
            _lastBadgeRefresh = now;
            _pendingRefresh?.Cancel();
            _pendingRefresh = null;
            DoRefreshBadges();
            return;
        }

        // Schedule a trailing refresh if not already pending
        if (_pendingRefresh is not null) return;
        _pendingRefresh = new CancellationTokenSource();
        var ct = _pendingRefresh.Token;
        var delay = 1000 - (int)(now - _lastBadgeRefresh).TotalMilliseconds;
        _ = Task.Delay(delay, ct).ContinueWith(_ =>
        {
            if (ct.IsCancellationRequested) return;
            _pendingRefresh = null;
            _lastBadgeRefresh = DateTime.UtcNow;
            InvokeAsync(DoRefreshBadges);
        }, ct);
    }

    private void DoRefreshBadges()
    {
        localPanel?.RebuildDownloadLookup();
        remotePanel?.RebuildDownloadLookup();
        localPanel?.NotifyStateChanged();
        remotePanel?.NotifyStateChanged();
        if (_uploadsOpen) RefreshUploads();
    }

    // --- Uploads panel ---

    private void ToggleUploads()
    {
        _uploadsOpen = !_uploadsOpen;
        if (_uploadsOpen) RefreshUploads();
    }

    private void SetUlFilter(UlFilter f) { _ulFilter = f; ApplyUlFilter(); }

    private void OnUlDateChanged(ChangeEventArgs e) { _ulDateFilter = e.Value?.ToString() ?? "All"; ApplyUlFilter(); }

    private void RefreshUploads()
    {
        var cutoff = _ulDateFilter switch
        {
            "Today" => DateTimeOffset.UtcNow.Date,
            "Week"  => DateTimeOffset.UtcNow.AddDays(-7),
            "Month" => DateTimeOffset.UtcNow.AddDays(-30),
            _       => (DateTimeOffset?)null
        };

        _uploads = (string.IsNullOrEmpty(AgentUuid) ? Downloads.Downloads : Downloads.GetByAgent(AgentUuid))
            .Where(r => r.Status is not DownloadStatus.Pending)
            .Where(r => cutoff is null || DateTimeOffset.FromUnixTimeMilliseconds((long)r.CreatedAt) >= cutoff)
            .OrderBy(r => r.Status == DownloadStatus.Downloading ? 0 : r.Status == DownloadStatus.Queued ? 1 : r.Status == DownloadStatus.Paused ? 2 : r.Status == DownloadStatus.Failed ? 3 : 4)
            .ThenBy(r => r.Priority).ThenBy(r => r.CreatedAt)
            .ToList();

        ApplyUlFilter();
    }

    private void ApplyUlFilter()
    {
        var src = _ulFilter switch
        {
            UlFilter.Current => _uploads.Where(r => r.Status == DownloadStatus.Downloading),
            UlFilter.Pending => _uploads.Where(r => r.Status is DownloadStatus.Queued or DownloadStatus.Paused),
            UlFilter.Error   => _uploads.Where(r => r.Status == DownloadStatus.Failed),
            UlFilter.Done    => _uploads.Where(r => r.Status == DownloadStatus.Completed),
            _                => _uploads.AsEnumerable()
        };
        if (!string.IsNullOrWhiteSpace(filterText))
            src = src.Where(r => r.FileName.Contains(filterText.Trim(), StringComparison.OrdinalIgnoreCase)
                               || r.RemotePath.Contains(filterText.Trim(), StringComparison.OrdinalIgnoreCase));
        _ulFiltered = src.ToList();
        StateHasChanged();
    }

    private int UlCount(UlFilter f) => f switch
    {
        UlFilter.Current => _uploads.Count(r => r.Status == DownloadStatus.Downloading),
        UlFilter.Pending => _uploads.Count(r => r.Status is DownloadStatus.Queued or DownloadStatus.Paused),
        UlFilter.Error   => _uploads.Count(r => r.Status == DownloadStatus.Failed),
        UlFilter.Done    => _uploads.Count(r => r.Status == DownloadStatus.Completed),
        _                => _uploads.Count
    };

    private async Task UlNavigate(DownloadRecord rec)
    {
        var path = rec.RemotePath;
        var lastSep = Math.Max(path.LastIndexOf('\\'), path.LastIndexOf('/'));
        var dir = lastSep > 0 ? path[..(lastSep + 1)] : path;
        _uploadsOpen = false;
        await Navigate(dir);
        filterActive = true;
        filterText = rec.FileName;
    }

    private void UlPause(DownloadRecord r) => Downloads.Cts.Cancel(r.Id);
    private async Task UlResume(DownloadRecord r) { if (!Downloads.Cts.HasActive(r.Id)) await Downloads.QueueAsync(r.Id); }

    private static string UlIcon(string status) => status switch
    {
        DownloadStatus.Downloading => "dot",
        DownloadStatus.Queued     => "dot-outline",
        DownloadStatus.Paused     => "stop",
        DownloadStatus.Completed  => "check",
        DownloadStatus.Failed     => "x",
        _                         => "dot-outline"
    };

    public void Reset()
    {
        currentPath = RootPath;
        pathSegments = [];
        entries = null;
        viewingFile = false;
        _usingCachedData = false;
    }

    private void ToggleFilter()
    {
        filterActive = !filterActive;
        if (!filterActive) filterText = null;
    }

    private void ClearFilter() { filterText = null; if (_uploadsOpen) ApplyUlFilter(); }

    private void OnFilterTextChanged() { if (_uploadsOpen) ApplyUlFilter(); }

    private void OnFilterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { filterActive = false; filterText = null; if (_uploadsOpen) ApplyUlFilter(); }
    }

    private void SetActive(ActivePanel panel) => activePanel = panel;

    // --- Navigation (single source of truth) ---

    // Routes to live fetch or cached browse depending on connection state.
    private Task Navigate(string path) =>
        IsConnected ? NavigateTo(path) : NavigateToCached(path);

    private async Task NavigateTo(string path)
    {
        if (loading || !IsConnected) return;

        currentPath = FileManagerPath.Normalize(path, IsUnixAgent);
        pathSegments = FileManagerPath.GetSegments(currentPath);
        filterText = null;
        _inlineView = false; if (_inlineViewUrl is not null) { _ = Js.InvokeVoidAsync("c2RevokeObjectUrl", _inlineViewUrl).AsTask(); _inlineViewUrl = null; _inlineViewName = null; }
        loading = true; entries = null; _scrollSyncSetup = false; StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildPathCommand(AgentCommands.ListDirectory, currentPath);
            var response = await SendCommand(payload);
            if (response is null) return;
            var (parsed, parseError) = DirEntry.ParseDirectoryResponse(response);
            if (parseError is not null) { Msg.Show(parseError, MessageType.Error, source: "File Manager"); return; }
            entries = parsed;
            _usingCachedData = false;
            _agentOffline = false;
        }
        catch (Exception ex) { Msg.Error("Browse Failed", $"Could not list directory: {ex.Message}", "File Manager"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task NavigateToCached(string path)
    {
        if (loading || string.IsNullOrEmpty(AgentUuid)) return;

        currentPath = FileManagerPath.Normalize(path, IsUnixAgent);
        pathSegments = FileManagerPath.GetSegments(currentPath);
        filterText = null;
        _inlineView = false; if (_inlineViewUrl is not null) { _ = Js.InvokeVoidAsync("c2RevokeObjectUrl", _inlineViewUrl).AsTask(); _inlineViewUrl = null; _inlineViewName = null; }
        loading = true; entries = null; _scrollSyncSetup = false; StateHasChanged();

        try
        {
            var dirId = await Vfs.FindDirectoryIdAsync(AgentUuid, currentPath);
            if (dirId is null) return; // no cache for this path

            var dirs = await Vfs.GetChildDirectoriesAsync(AgentUuid, dirId);

            var downloads = Downloads.GetByAgent(AgentUuid)
                .Where(r => r.Status is DownloadStatus.Queued or DownloadStatus.Downloading or DownloadStatus.Paused or DownloadStatus.Completed
                         && r.RemotePath.StartsWith(currentPath, StringComparison.OrdinalIgnoreCase)
                         && r.RemotePath.Length > currentPath.Length)
                .Where(r => { var tail = r.RemotePath[currentPath.Length..]; return !tail.Contains('\\') && !tail.Contains('/'); })
                .ToList();

            var result = new List<DirEntry>(dirs.Count + downloads.Count);
            foreach (var d in dirs)
                result.Add(new DirEntry(d.Name, d.CreationTime, d.LastModifiedTime, 0, 0, !d.IsDrive, d.IsDrive, false, false, false));
            foreach (var f in downloads)
                result.Add(new DirEntry(f.FileName, 0, 0, (ulong)Math.Max(0, f.TotalSize), 0, false, false, false, false, false));

            entries = result;
            _usingCachedData = true;
        }
        catch { }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task SaveToVfsCacheAsync(string agentUuid, string path, List<DirEntry> dirEntries)
    {
        try
        {
            var parentId = await Vfs.ResolveOrCreatePathAsync(agentUuid, path);
            foreach (var e in dirEntries.Where(e => e.IsDirectory || e.IsDrive))
                await Vfs.PutDirectoryAsync(agentUuid, parentId, e.Name, path + e.Name, e.IsDrive, e.CreationTime, e.LastModifiedTime);
        }
        catch { }
    }

    private async Task NavigateUp()
    {
        var parent = FileManagerPath.GetParent(pathSegments, PathSep, IsUnixAgent, RootPath);
        await Navigate(parent);
    }

    private async Task NavigateToRoot() => await Navigate(RootPath);

    private async Task NavigateToBreadcrumb(int index)
    {
        var path = FileManagerPath.BuildBreadcrumbPath(pathSegments, index, PathSep, IsUnixAgent);
        await Navigate(path);
    }

    private async Task OnPathKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await Navigate(currentPath); }
    private async Task Refresh() => await NavigateTo(currentPath);

    // --- Panel action handlers ---

    private async Task OnRemoteAction((DirEntry entry, FilePanel.PanelAction action) args)
    {
        var (entry, action) = args;
        switch (action)
        {
            case FilePanel.PanelAction.Open:
                if (entry is null) await NavigateUp();
                else if (entry.IsDirectory || entry.IsDrive) await Navigate(currentPath + entry.Name);
                break;
            case FilePanel.PanelAction.View:
                ViewFile(entry);
                break;
            case FilePanel.PanelAction.Download:
                await EnqueueFileSync(entry);
                break;
            case FilePanel.PanelAction.Hash:
                await HashFile(entry);
                break;
            case FilePanel.PanelAction.SaveToBrowser:
                await SaveToBrowser(entry);
                break;
            case FilePanel.PanelAction.Search:
                if (entry is not null && (entry.IsDirectory || entry.IsDrive))
                    OpenSearchWindow(currentPath + entry.Name);
                else
                    OpenSearchWindow(FileManagerPath.TrimTrailing(currentPath));
                break;
        }
    }

    private async Task OnLocalAction((DirEntry entry, FilePanel.PanelAction action) args)
    {
        var (entry, action) = args;
        switch (action)
        {
            case FilePanel.PanelAction.Open:
                if (entry is null) await NavigateUp();
                else if (entry.IsDirectory || entry.IsDrive) await Navigate(currentPath + entry.Name);
                break;
            case FilePanel.PanelAction.View:
                await ShowInRemotePanel(entry);
                break;
            case FilePanel.PanelAction.SaveToBrowser:
                await SaveToBrowser(entry);
                break;
        }
    }

    // --- File operations ---

    private void ViewFile(DirEntry entry)
    {
        if (entry is null || string.IsNullOrEmpty(AgentUuid)) return;
        if (Downloads.Find(AgentUuid, currentPath + entry.Name)?.Status != DownloadStatus.Completed) return;
        viewingFileName = entry.Name;
        viewingFilePath = currentPath + entry.Name;
        viewingFile = true;
        StateHasChanged();
    }

    private async Task EnqueueFileSync(DirEntry entry)
    {
        if (!Cache.HasDirectory || string.IsNullOrEmpty(AgentUuid)) return;
        if (entry.IsDirectory || entry.IsDrive || entry.Size == 0) return;
        var remotePath = currentPath + entry.Name;
        var totalSize = (long)entry.Size;
        var record = Downloads.Find(AgentUuid, remotePath);
        if (record is null)
        {
            var fileId = Guid.NewGuid().ToString("N");
            await Downloads.AddAsync(AgentUuid, AgentName ?? "", remotePath, entry.Name, fileId, totalSize);
            if (entries is not null)
                _ = SaveToVfsCacheAsync(AgentUuid, currentPath, entries);
        }
        else if (record.Status is DownloadStatus.Completed or DownloadStatus.Failed)
            await Downloads.RequeueAsync(record.Id, record.CacheSubPath, totalSize);
        else if (record.Status == DownloadStatus.Paused)
            await Downloads.QueueAsync(record.Id);
    }

    private async Task HashFile(DirEntry entry)
    {
        if (!IsConnected) return;
        var path = currentPath + entry.Name;
        var payload = RelaySocket.BuildFileCommand(AgentCommands.HashFile, path, 0, 0);
        var response = await SendCommand(payload);
        if (response is null || response.Length < 36) return;
        var status = RelaySocket.ReadStatus(response);
        if (status != 0) { Msg.Error("Hash Error", $"Agent returned status {status}", "File Manager"); return; }
        var hash = RelaySocket.ReadHash(response);
        Msg.Show($"SHA-256: {hash}", MessageType.Success, source: "File Manager");
    }

    private async Task ShowInRemotePanel(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var dl = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (dl is null || dl.Status != DownloadStatus.Completed) return;
        try
        {
            if (!await Cache.BlobExistsAsync(dl.CacheSubPath)) { Msg.Error("Open Failed", "File not found in local cache", "File Manager"); return; }
            if (_inlineViewUrl is not null) await Js.InvokeVoidAsync("c2RevokeObjectUrl", _inlineViewUrl);
            _inlineViewUrl = await Js.InvokeAsync<string>("c2GetObjectUrl", dl.FileName, dl.CacheSubPath);
            _inlineViewName = dl.FileName;
            _inlineView = true;
            StateHasChanged();
        }
        catch (Exception ex) { Msg.Error("Open Failed", $"Could not open {dl.FileName}: {ex.Message}", "File Manager"); }
    }

    private async Task CloseInlineView()
    {
        _inlineView = false;
        _inlineViewName = null;
        if (_inlineViewUrl is not null)
        {
            await Js.InvokeVoidAsync("c2RevokeObjectUrl", _inlineViewUrl);
            _inlineViewUrl = null;
        }
    }

    private async Task SaveToBrowser(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var dl = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (dl is null || dl.Status != DownloadStatus.Completed) return;
        try
        {
            if (!await Cache.BlobExistsAsync(dl.CacheSubPath)) { Msg.Error("Save Failed", "File not found in local cache", "File Manager"); return; }
            await Js.InvokeVoidAsync("c2SaveFile", dl.FileName, dl.CacheSubPath);
        }
        catch (Exception ex) { Msg.Error("Save Failed", $"Could not save {dl.FileName}: {ex.Message}", "File Manager"); }
    }

    private void CloseFileViewer()
    {
        viewingFile = false;
        viewingFileName = "";
        viewingFilePath = "";
    }

    // --- Windows ---

    private void OpenSearchWindow(string path)
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid, searchPath: path);
    }

    private void OpenFullSearchWindow()
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid);
    }

    // --- Agent communication ---

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected) { Msg.Error("Not Connected", "No active connection to agent", "File Manager"); return null; }
        try { return await Relay.SendAndReceive(payload); }
        catch (Exception ex) { Msg.Error("Command Failed", $"Agent command error: {ex.Message}", "File Manager"); return null; }
    }
}
