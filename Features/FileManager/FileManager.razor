@using System.Net.WebSockets
@inherits EventSubscriber
@inject CacheManager Cache
@inject DownloadStore Downloads
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js

<div class="fm">
    @* Top toolbar *@
    <div class="fm-toolbar">
        <div class="fm-toolbar-left">
            <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs"
                   OnClick="DownloadSelected"
                   Disabled="@(!IsConnected || !Cache.HasDirectory || !HasRemoteFileSelection)"
                   Title="Download selected files from remote to local cache (F5)">
                <C2Icon Name="arrow-left" Size="Size.Xs" /> F5 Copy
            </C2Btn>
            <C2Btn Size="Size.Xs" OnClick="OpenFullSearchWindow" Disabled="@(!IsConnected)" Title="Search agent filesystem">
                <C2Icon Name="search" Size="Size.Xs" /> Search
            </C2Btn>
            <C2Btn Size="Size.Xs" OnClick="OpenDownloadsWindow" Title="Download queue">
                <C2Icon Name="arrow-up-down" Size="Size.Xs" /> Transfers
            </C2Btn>
        </div>
        @if (!IsConnected)
        {
            <div class="fm-offline-badge">
                <span class="fm-offline-dot"></span>
                Agent offline
            </div>
        }
    </div>

    @* Dual pane area *@
    <div class="fm-panels @(viewingFile ? "fm-panels-with-viewer" : "")">
        <div class="fm-pane fm-pane-left">
            <FilePanel @ref="localPanel"
                       Mode="FilePanel.PanelMode.Local"
                       Relay="Relay"
                       AgentId="@AgentId"
                       AgentName="@AgentName"
                       AgentUuid="@AgentUuid"
                       IsActive="@(activePanel == ActivePanel.Local)"
                       OnActivate="() => SetActive(ActivePanel.Local)"
                       OnViewFile="OnLocalViewFile"
                       OnSearchPath="OnSearchPath"
                       OnNavigated="OnLocalNavigated" />
        </div>
        <div class="fm-pane fm-pane-right">
            <FilePanel @ref="remotePanel"
                       Mode="FilePanel.PanelMode.Remote"
                       Relay="Relay"
                       AgentId="@AgentId"
                       AgentName="@AgentName"
                       AgentUuid="@AgentUuid"
                       IsActive="@(activePanel == ActivePanel.Remote)"
                       OnActivate="() => SetActive(ActivePanel.Remote)"
                       OnViewFile="OnRemoteViewFile"
                       OnSearchPath="OnSearchPath"
                       OnNavigated="OnRemoteNavigated" />
        </div>
    </div>

    @* File viewer (slides in from bottom when active) *@
    @if (viewingFile)
    {
        <div class="fm-viewer-container">
            <FileViewer FilePath="@viewingFilePath" FileName="@viewingFileName"
                        IsConnected="@IsConnected" Relay="@Relay" OnClose="CloseFileViewer" />
        </div>
    }

    @* Function key bar — classic Total Commander style *@
    <div class="fm-fnkeys">
        <button class="fm-fnkey" @onclick="ViewSelected" disabled="@(!HasAnySelection)"><span class="fm-fnkey-num">F3</span> View</button>
        <button class="fm-fnkey" @onclick="DownloadSelected" disabled="@(!IsConnected || !Cache.HasDirectory || !HasRemoteFileSelection)"><span class="fm-fnkey-num">F5</span> Copy</button>
        <button class="fm-fnkey" @onclick="OpenDownloadsWindow"><span class="fm-fnkey-num">F6</span> Queue</button>
        <button class="fm-fnkey" @onclick="OpenFullSearchWindow" disabled="@(!IsConnected)"><span class="fm-fnkey-num">F7</span> Search</button>
    </div>
</div>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private enum ActivePanel { Local, Remote }

    private bool IsConnected => Relay is not null && Relay.IsConnected;
    private bool HasRemoteFileSelection => remotePanel?.SelectedEntries.Any(e => !e.IsDirectory && !e.IsDrive) == true;
    private bool HasAnySelection
    {
        get
        {
            var panel = activePanel == ActivePanel.Local ? localPanel : remotePanel;
            return panel?.SelectedEntries.Count > 0;
        }
    }

    private FilePanel? localPanel;
    private FilePanel? remotePanel;
    private ActivePanel activePanel = ActivePanel.Remote;

    // File viewer
    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";

    protected override void OnInitialized()
    {
        On<DownloadStoreChangedEvent>();
    }

    public override void Dispose() => base.Dispose();

    public void Reset()
    {
        viewingFile = false;
        viewingFileName = "";
        viewingFilePath = "";
    }

    private bool _syncing;

    private void SetActive(ActivePanel panel)
    {
        activePanel = panel;
    }

    private async Task OnLocalNavigated(string path)
    {
        if (_syncing || remotePanel is null) return;
        _syncing = true;
        try { await remotePanel.NavigateToPath(path); } finally { _syncing = false; }
    }

    private async Task OnRemoteNavigated(string path)
    {
        if (_syncing || localPanel is null) return;
        _syncing = true;
        try { await localPanel.NavigateToPath(path); } finally { _syncing = false; }
    }

    // --- File operations ---

    private async Task DownloadSelected()
    {
        if (remotePanel is null) return;
        await remotePanel.EnqueueSelectedFiles();
        Msg.Show("Files queued for download", MessageType.Info, source: "File Manager");
    }

    private async Task ViewSelected()
    {
        var panel = activePanel == ActivePanel.Local ? localPanel : remotePanel;
        if (panel is null) return;
        var file = panel.SelectedEntries.FirstOrDefault(e => !e.IsDirectory && !e.IsDrive);
        if (file is null) return;
        if (activePanel == ActivePanel.Local)
            await OnLocalViewFile(file);
        else
            await OnRemoteViewFile(file);
    }

    // --- View file ---

    private Task OnRemoteViewFile(DirEntry entry)
    {
        if (remotePanel is null) return Task.CompletedTask;
        if (!string.IsNullOrEmpty(AgentUuid) && Downloads.Find(AgentUuid, remotePanel.CurrentPath + entry.Name)?.Status == DownloadStatus.Completed)
        {
            viewingFileName = entry.Name;
            viewingFilePath = remotePanel.CurrentPath + entry.Name;
            viewingFile = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task OnLocalViewFile(DirEntry entry)
    {
        if (localPanel is null) return Task.CompletedTask;
        if (!string.IsNullOrEmpty(AgentUuid) && Downloads.Find(AgentUuid, localPanel.CurrentPath + entry.Name)?.Status == DownloadStatus.Completed)
        {
            viewingFileName = entry.Name;
            viewingFilePath = localPanel.CurrentPath + entry.Name;
            viewingFile = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private void CloseFileViewer()
    {
        viewingFile = false;
        viewingFileName = "";
        viewingFilePath = "";
    }

    // --- Search / Downloads windows ---

    private void OnSearchPath(string path)
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid, searchPath: path);
    }

    private void OpenFullSearchWindow()
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid);
    }

    private void OpenDownloadsWindow()
    {
        if (!string.IsNullOrEmpty(AgentId)) Wm.OpenAgentWindow("Downloads", AgentId, agentName: AgentName, agentUuid: AgentUuid);
        else Wm.OpenWindow("Downloads");
    }
}
