@using System.Net.WebSockets
@inherits EventSubscriber
@inject CacheManager Cache
@inject VfsStore Vfs
@inject RelayConnectionService RelaySvc
@inject AgentStore AgentDb
@inject DownloadStore Downloads
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js

<div class="fm">
    @if (!IsConnected)
    {
        <div class="fm-offline">
            <span class="fm-offline-dot"></span>
            Agent disconnected — browsing cached data only.
        </div>
    }

    @* Toolbar *@
    <div class="fm-toolbar">
        <C2Btn OnClick="NavigateUp" Disabled="@(loading || (!IsConnected && !HasCache))" Title="Up">
            <C2Icon Name="arrow-up" Size="Size.Xs" />
        </C2Btn>
        <C2Btn OnClick="() => NavigateTo(currentPath)" Disabled="@(loading || (!IsConnected && !HasCache))" Title="Refresh"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
        <div class="fm-path-bar">
            <C2Input @bind-Value="currentPath" OnKeyDown="OnPathKeyDown" Monospace />
        </div>
        @if (selectedEntries.Count > 1)
        {
            <C2Badge Variant="BadgeVariant.Info" Size="Size.Xs">@selectedEntries.Count selected</C2Badge>
        }
        <C2Btn Variant="BtnVariant.Primary" OnClick="OpenFullSearchWindow" Disabled="@(!IsConnected)" Title="Search entire filesystem">
            <C2Icon Name="search" Size="Size.Xs" /> SEARCH
        </C2Btn>
        <C2Btn Variant="BtnVariant.Primary" OnClick="OpenDownloadsWindow" Title="Upload Manager">
            <C2Icon Name="arrow-up-down" Size="Size.Xs" /> UPLOADS
        </C2Btn>
    </div>

    @* Breadcrumb *@
    @if (pathSegments.Length > 0)
    {
        <div class="fm-breadcrumb">
            <a href="javascript:void(0)" class="fm-crumb" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
            @for (int i = 0; i < pathSegments.Length; i++)
            {
                var idx = i;
                <span class="fm-crumb-sep">/</span>
                @if (idx == pathSegments.Length - 1)
                {
                    <span class="fm-crumb-active">@pathSegments[idx]</span>
                }
                else
                {
                    <a href="javascript:void(0)" class="fm-crumb" @onclick="() => NavigateToBreadcrumb(idx)" @onclick:preventDefault>@pathSegments[idx]</a>
                }
            }
        </div>
    }

    <div class="fm-content @(viewingFile ? "fm-split" : "")">
        @* Directory listing *@
        <div class="fm-listing">
            <div class="fm-listing-header">
                @if (loading)
                {
                    <C2Spinner Size="Size.Xs" />
                }
                <span class="fm-listing-title">@(currentPath == RootPath ? (IsWindowsAgent ? "Drives" : "/") : currentPath)</span>
                @if (entries is not null)
                {
                    <span class="fm-count">@entries.Count items</span>
                }
            </div>
            <div class="fm-entries" @onkeydown="OnKeyDown" @onkeydown:preventDefault="@ShouldPreventKeyDefault" tabindex="0" @ref="entriesRef">
                @if (entries is not null)
                {
                    <C2Table Hover Compact Fixed CssClass="fm-table">
                        <thead>
                            <tr>
                                <th class="fm-col-check">
                                    <input type="checkbox" class="fm-check-all"
                                           checked="@(entries.Count > 0 && selectedEntries.Count == entries.Count)"
                                           @onchange="ToggleSelectAll" title="Select all" />
                                </th>
                                <th class="fm-col-icon"></th>
                                <th class="fm-col-name @SortClass("name")" @onclick='() => ToggleSort("name")'>
                                    Name @SortArrow("name")
                                </th>
                                <th class="fm-col-size @SortClass("size")" @onclick='() => ToggleSort("size")'>
                                    Size @SortArrow("size")
                                </th>
                                <th class="fm-col-modified @SortClass("modified")" @onclick='() => ToggleSort("modified")'>
                                    Modified @SortArrow("modified")
                                </th>
                                <th class="fm-col-type @SortClass("type")" @onclick='() => ToggleSort("type")'>
                                    Type @SortArrow("type")
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pathSegments.Length > 0)
                            {
                                <tr class="fm-row-parent" @onclick="NavigateUp">
                                    <td class="fm-col-check"></td>
                                    <td class="fm-col-icon"><C2Icon Name="arrow-up" Size="Size.Xs" /></td>
                                    <td colspan="4" class="fm-parent-label">..</td>
                                </tr>
                            }
                            @{ var sorted = SortedEntries; var rowIdx = 0; }
                            @foreach (var entry in sorted)
                            {
                                var e = entry;
                                var idx = rowIdx++;
                                var isDir = e.IsDirectory || e.IsDrive;
                                var isSelected = selectedEntries.Contains(e);
                                var isFocused = idx == focusIndex;
                                <C2Tr Active="@isSelected"
                                      Dim="@(e.IsHidden || e.IsSystem)"
                                      CssClass="@($"fm-row{(isFocused ? " fm-row-focused" : "")}")"
                                      OnClick="(ev) => OnRowClick(ev, e)"
                                      OnContextMenu="(ev) => ShowContextMenu(ev, e)"
                                      PreventDefault>
                                    <td class="fm-col-check" @onclick:stopPropagation="true">
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="() => ToggleCheckbox(e)" />
                                    </td>
                                    <td class="fm-col-icon" @ondblclick="() => OnEntryDoubleClick(e)" @ondblclick:stopPropagation="true"><C2Icon Name="@GetIcon(e)" Size="Size.Xs" CssClass="@IconClass(e)" /></td>
                                    <td class="fm-col-name" @ondblclick="() => OnEntryDoubleClick(e)" @ondblclick:stopPropagation="true">
                                        <span class="fm-name-text">@e.Name</span>
                                        @if (!isDir && Cache.HasDirectory)
                                        {
                                            <FileActions Entry="e" CurrentPath="@currentPath" AgentUuid="@AgentUuid" />
                                        }
                                    </td>
                                    <td class="fm-col-size">@(isDir ? "" : Formatters.FormatSize(e.Size))</td>
                                    <td class="fm-col-modified fm-hide-mobile">@Formatters.FormatFileTime(e.LastModifiedTime)</td>
                                    <td class="fm-col-type fm-hide-mobile">@Formatters.GetFileTypeLabel(e.Name, e.IsDirectory, e.IsDrive)</td>
                                </C2Tr>
                            }
                        </tbody>
                    </C2Table>

                    @if (entries.Count == 0 && !IsConnected)
                    {
                        <div class="fm-empty">No cached data for this path. Browse directories while the agent is online to cache them.</div>
                    }
                }
                else if (!loading)
                {
                    <div class="fm-empty">Enter a path and press Enter or click a drive.</div>
                }
            </div>

            @* Bulk action bar *@
            @if (selectedEntries.Count > 1)
            {
                <div class="fm-bulk-bar">
                    <span class="fm-bulk-count">@selectedEntries.Count selected</span>
                    @if (selectedEntries.Any(e => !e.IsDirectory && !e.IsDrive))
                    {
                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Primary"
                               OnClick="BulkUpload" Disabled="@(!IsConnected || !Cache.HasDirectory)">Upload All</C2Btn>
                    }
                    <C2Btn Size="Size.Xs" OnClick="ClearSelection">Deselect</C2Btn>
                </div>
            }
        </div>

        @* File viewer *@
        @if (viewingFile)
        {
            <FileViewer FilePath="@viewingFilePath" FileName="@viewingFileName"
                        IsConnected="@IsConnected" Relay="@Relay" OnClose="CloseFileViewer" />
        }
    </div>
</div>

@* Context menu *@
<C2Dropdown Visible="@ctxVisible" X="@ctxX" Y="@ctxY" OnClose="HideContextMenu">
    @if (ctxEntry is not null)
    {
        var isDir = ctxEntry.IsDirectory || ctxEntry.IsDrive;
        @if (isDir)
        {
            <C2DropdownItem OnClick="CtxOpen">Open</C2DropdownItem>
            <C2DropdownItem OnClick="CtxSearch" Disabled="@(!IsConnected)">Search</C2DropdownItem>
            <div class="fm-ctx-sep"></div>
            <C2DropdownItem OnClick="CtxCopyPath">Copy Path</C2DropdownItem>
        }
        else
        {
            @if (IsFileSynced(ctxEntry.Name))
            {
                <C2DropdownItem OnClick="CtxView">View</C2DropdownItem>
                <C2DropdownItem OnClick="CtxSaveToBrowser">Save to Browser</C2DropdownItem>
                <div class="fm-ctx-sep"></div>
            }
            else
            {
                <C2DropdownItem OnClick="CtxUpload" Disabled="@(!IsConnected || !Cache.HasDirectory)">Upload to Cache</C2DropdownItem>
                <div class="fm-ctx-sep"></div>
            }
            <C2DropdownItem OnClick="CtxHash" Disabled="@(!IsConnected)">SHA-256 Hash</C2DropdownItem>
            <C2DropdownItem OnClick="CtxCopyPath">Copy Path</C2DropdownItem>
            <C2DropdownItem OnClick="CtxSearchDir" Disabled="@(!IsConnected)">Search in Directory</C2DropdownItem>
        }
    }
</C2Dropdown>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private bool IsConnected => Relay is not null && Relay.IsConnected;
    private bool IsAgentOnline => AgentId is not null && RelaySvc.GetAllAgents().Any(a => a.Agent.Id == AgentId);
    private bool HasCache => Cache.HasDirectory && !string.IsNullOrEmpty(AgentUuid);

    private bool IsWindowsAgent
    {
        get
        {
            var os = RelaySvc.GetAllAgents()
                .Where(a => a.Agent.Id == AgentId)
                .Select(a => a.Agent.Os)
                .FirstOrDefault();
            if (string.IsNullOrEmpty(os) && !string.IsNullOrEmpty(AgentUuid))
                os = AgentDb.GetByUuid(AgentUuid)?.Os;
            return string.Equals(os, "Windows", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsUnixAgent => !IsWindowsAgent;
    private string PathSep => IsUnixAgent ? "/" : @"\";
    private string RootPath => IsWindowsAgent ? "" : "/";

    // Core state
    private string currentPath = "";
    private string[] pathSegments = [];
    private List<DirEntry>? entries;
    private bool loading;
    private bool _syncing;

    // File viewer
    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";

    // Selection state
    private HashSet<DirEntry> selectedEntries = new();
    private DirEntry? lastClickedEntry;
    private int focusIndex = -1;

    // Sort state
    private string sortColumn = "name";
    private bool sortAscending = true;

    // Context menu state
    private bool ctxVisible;
    private double ctxX, ctxY;
    private DirEntry? ctxEntry;

    // Element reference for keyboard focus
    private ElementReference entriesRef;

    // Cached sorted list
    private List<DirEntry>? _sortedCache;
    private string? _sortedCacheKey;

    private List<DirEntry> SortedEntries
    {
        get
        {
            var key = $"{sortColumn}:{sortAscending}:{entries?.Count}";
            if (_sortedCache is not null && _sortedCacheKey == key)
                return _sortedCache;
            _sortedCache = ApplySort(entries ?? new());
            _sortedCacheKey = key;
            return _sortedCache;
        }
    }

    private bool ShouldPreventKeyDefault => true;

    private RelaySocket? _prevRelay;

    protected override async Task OnParametersSetAsync()
    {
        // Detect relay reconnection: if we had no connected relay before
        // but now we do, refresh the current directory
        var relayChanged = Relay != _prevRelay && IsConnected;
        _prevRelay = Relay;

        if (relayChanged && entries is not null)
        {
            await NavigateTo(currentPath ?? RootPath);
            return;
        }

        if (entries is not null) return;
        await Downloads.LoadAsync();

        if (string.IsNullOrEmpty(currentPath))
            currentPath = RootPath;

        if (IsConnected)
            await NavigateTo(currentPath);
        else if (HasCache)
            await NavigateFromCache(currentPath);
    }

    protected override void OnInitialized()
    {
        On<CacheChangedEvent>(e =>
        {
            if (!_syncing && Cache.HasDirectory && entries is not null)
                _ = SyncCacheAsync();
        });
        On<DownloadStoreChangedEvent>();
    }

    public override void Dispose() => base.Dispose();

    public void Reset()
    {
        currentPath = RootPath;
        pathSegments = [];
        entries = null;
        selectedEntries.Clear();
        lastClickedEntry = null;
        focusIndex = -1;
        viewingFile = false;
        InvalidateSortCache();
    }

    // --- Sorting ---

    private void ToggleSort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        InvalidateSortCache();
    }

    private void InvalidateSortCache()
    {
        _sortedCache = null;
        _sortedCacheKey = null;
    }

    private List<DirEntry> ApplySort(List<DirEntry> source)
    {
        var dirs = source.Where(e => e.IsDirectory || e.IsDrive);
        var files = source.Where(e => !e.IsDirectory && !e.IsDrive);
        return SortGroup(dirs).Concat(SortGroup(files)).ToList();
    }

    private IEnumerable<DirEntry> SortGroup(IEnumerable<DirEntry> group)
    {
        return sortColumn switch
        {
            "name" => sortAscending
                ? group.OrderBy(e => e.Name, StringComparer.OrdinalIgnoreCase)
                : group.OrderByDescending(e => e.Name, StringComparer.OrdinalIgnoreCase),
            "size" => sortAscending
                ? group.OrderBy(e => e.Size)
                : group.OrderByDescending(e => e.Size),
            "modified" => sortAscending
                ? group.OrderBy(e => e.LastModifiedTime)
                : group.OrderByDescending(e => e.LastModifiedTime),
            "type" => sortAscending
                ? group.OrderBy(e => System.IO.Path.GetExtension(e.Name), StringComparer.OrdinalIgnoreCase)
                : group.OrderByDescending(e => System.IO.Path.GetExtension(e.Name), StringComparer.OrdinalIgnoreCase),
            _ => group.OrderBy(e => e.Name, StringComparer.OrdinalIgnoreCase)
        };
    }

    private string SortClass(string column) =>
        sortColumn == column ? "fm-col-sortable fm-sort-active" : "fm-col-sortable";

    private MarkupString SortArrow(string column)
    {
        if (sortColumn != column) return new MarkupString("");
        var arrow = sortAscending ? "&#x25B2;" : "&#x25BC;";
        return new MarkupString($"<span class=\"fm-sort-arrow\">{arrow}</span>");
    }

    // --- Selection ---

    private void OnRowClick(MouseEventArgs e, DirEntry entry)
    {
        if (e.CtrlKey || e.MetaKey)
        {
            if (!selectedEntries.Remove(entry))
                selectedEntries.Add(entry);
            lastClickedEntry = entry;
        }
        else if (e.ShiftKey && lastClickedEntry is not null)
        {
            var sorted = SortedEntries;
            var startIdx = sorted.IndexOf(lastClickedEntry);
            var endIdx = sorted.IndexOf(entry);
            if (startIdx < 0) startIdx = 0;
            if (startIdx > endIdx) (startIdx, endIdx) = (endIdx, startIdx);
            selectedEntries.Clear();
            for (int i = startIdx; i <= endIdx; i++)
                selectedEntries.Add(sorted[i]);
        }
        else
        {
            selectedEntries.Clear();
            selectedEntries.Add(entry);
            lastClickedEntry = entry;
        }
        focusIndex = SortedEntries.IndexOf(entry);
    }

    private void ToggleCheckbox(DirEntry entry)
    {
        if (!selectedEntries.Remove(entry))
            selectedEntries.Add(entry);
        lastClickedEntry = entry;
    }

    private void ToggleSelectAll()
    {
        if (entries is null) return;
        if (selectedEntries.Count == entries.Count)
            selectedEntries.Clear();
        else
            selectedEntries = new HashSet<DirEntry>(entries);
    }

    private void ClearSelection()
    {
        selectedEntries.Clear();
        focusIndex = -1;
    }

    // --- Keyboard Navigation ---

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        var sorted = SortedEntries;
        if (sorted.Count == 0) return;

        switch (e.Key)
        {
            case "ArrowDown":
                focusIndex = Math.Min(focusIndex + 1, sorted.Count - 1);
                if (!e.ShiftKey) SelectSingle(sorted[focusIndex]);
                else AddToSelection(sorted[focusIndex]);
                break;
            case "ArrowUp":
                focusIndex = Math.Max(focusIndex - 1, 0);
                if (!e.ShiftKey) SelectSingle(sorted[focusIndex]);
                else AddToSelection(sorted[focusIndex]);
                break;
            case "Enter":
                if (focusIndex >= 0 && focusIndex < sorted.Count)
                    await OnEntryDoubleClick(sorted[focusIndex]);
                break;
            case "Backspace":
                await NavigateUp();
                break;
            case "Escape":
                if (ctxVisible) HideContextMenu();
                else ClearSelection();
                break;
            case "a" when e.CtrlKey:
                selectedEntries = new HashSet<DirEntry>(sorted);
                break;
        }
    }

    private void SelectSingle(DirEntry entry)
    {
        selectedEntries.Clear();
        selectedEntries.Add(entry);
        lastClickedEntry = entry;
    }

    private void AddToSelection(DirEntry entry)
    {
        selectedEntries.Add(entry);
        lastClickedEntry = entry;
    }

    // --- Context Menu ---

    private void ShowContextMenu(MouseEventArgs e, DirEntry entry)
    {
        if (!selectedEntries.Contains(entry))
        {
            selectedEntries.Clear();
            selectedEntries.Add(entry);
            lastClickedEntry = entry;
        }
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxEntry = entry;
        ctxVisible = true;
    }

    private void HideContextMenu() { ctxVisible = false; ctxEntry = null; }

    private async Task CtxOpen()
    {
        HideContextMenu();
        if (ctxEntry is null) return;
        await OpenAsDirectory(ctxEntry.Name);
    }

    private void CtxSearch()
    {
        var name = ctxEntry?.Name;
        HideContextMenu();
        if (name is null || string.IsNullOrEmpty(AgentId)) return;
        var searchPath = currentPath + name;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid, searchPath: searchPath);
    }

    private async Task CtxCopyPath()
    {
        var name = ctxEntry?.Name;
        HideContextMenu();
        if (name is null) return;
        var fullPath = currentPath + name;
        try { await Js.InvokeVoidAsync("navigator.clipboard.writeText", fullPath); }
        catch { }
        Msg.Show($"Copied: {fullPath}", MessageType.Info, source: "File Manager");
    }

    private async Task CtxUpload()
    {
        var entry = ctxEntry;
        HideContextMenu();
        if (entry is null) return;
        await EnqueueFileSync(entry);
    }

    private async Task CtxView()
    {
        var name = ctxEntry?.Name;
        HideContextMenu();
        if (name is null) return;
        await ViewFile(name);
    }

    private async Task CtxSaveToBrowser()
    {
        var entry = ctxEntry;
        HideContextMenu();
        if (entry is null || string.IsNullOrEmpty(AgentUuid)) return;
        var dl = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (dl is null || dl.Status != DownloadStatus.Completed) return;
        try
        {
            if (!await Cache.BlobExistsAsync(dl.CacheSubPath)) { Msg.Error("Save Failed", "File not found in local cache", "File Manager"); return; }
            await Js.InvokeVoidAsync("c2SaveFile", dl.FileName, dl.CacheSubPath);
        }
        catch (Exception ex) { Msg.Error("Save Failed", $"Could not save {dl.FileName}: {ex.Message}", "File Manager"); }
    }

    private async Task CtxHash()
    {
        var entry = ctxEntry;
        HideContextMenu();
        if (entry is null || !IsConnected) return;
        var path = currentPath + entry.Name;
        var payload = RelaySocket.BuildFileCommand(AgentCommands.HashFile, path, 0, 0);
        var response = await SendCommand(payload);
        if (response is null || response.Length < 36) return;
        var status = RelaySocket.ReadStatus(response);
        if (status != 0) { Msg.Error("Hash Error", $"Agent returned status {status}", "File Manager"); return; }
        var hash = RelaySocket.ReadHash(response);
        Msg.Show($"SHA-256: {hash}", MessageType.Success, source: "File Manager");
    }

    private void CtxSearchDir()
    {
        HideContextMenu();
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid, searchPath: FileManagerPath.TrimTrailing(currentPath));
    }

    // --- Bulk Operations ---

    private async Task BulkUpload()
    {
        var files = selectedEntries.Where(e => !e.IsDirectory && !e.IsDrive).ToList();
        foreach (var entry in files)
            await EnqueueFileSync(entry);
    }

    // --- Download Integration (moved from FileActions) ---

    private async Task EnqueueFileSync(DirEntry entry)
    {
        if (!Cache.HasDirectory || string.IsNullOrEmpty(AgentUuid)) return;
        var remotePath = currentPath + entry.Name;
        var parentRemotePath = FileManagerPath.TrimTrailing(currentPath);
        var totalSize = (long)entry.Size;
        var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, parentRemotePath);
        var vfsFile = await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, remotePath.Replace('\\', '/'), totalSize);
        var record = Downloads.Find(AgentUuid, remotePath);
        if (record is null)
            await Downloads.AddAsync(AgentUuid, AgentName ?? "", remotePath, entry.Name, vfsFile.Id, totalSize);
        else if (record.Status is DownloadStatus.Completed or DownloadStatus.Failed)
            await Downloads.RequeueAsync(record.Id, vfsFile.Id, totalSize);
        else if (record.Status == DownloadStatus.Paused)
            await Downloads.QueueAsync(record.Id);
    }

    private bool IsFileSynced(string fileName)
        => !string.IsNullOrEmpty(AgentUuid) && Downloads.Find(AgentUuid, currentPath + fileName)?.Status == DownloadStatus.Completed;

    // --- Icons ---

    private static string GetIcon(DirEntry e)
    {
        if (e.IsDrive) return "hard-drive";
        if (e.IsDirectory) return "folder";
        var ext = System.IO.Path.GetExtension(e.Name).ToLowerInvariant();
        return ext switch
        {
            ".exe" or ".dll" or ".sys" => "file-code",
            ".txt" or ".log" or ".cfg" or ".ini" or ".conf" or ".yaml" or ".yml" or ".json" or ".xml" or ".csv" => "file-text",
            ".zip" or ".rar" or ".7z" or ".tar" or ".gz" or ".bz2" => "package",
            ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".ico" or ".svg" or ".webp" => "image",
            ".pdf" => "bookmark",
            ".mp3" or ".wav" or ".flac" or ".ogg" or ".aac" => "music",
            ".mp4" or ".mkv" or ".avi" or ".mov" or ".wmv" => "film",
            _ => "file"
        };
    }

    private static string IconClass(DirEntry e)
    {
        if (e.IsDrive) return "fm-icon-drive";
        if (e.IsDirectory) return "fm-icon-dir";
        return "fm-icon-file";
    }

    // --- Navigation ---

    private async Task NavigateTo(string path)
    {
        if (loading) return;
        if (!IsConnected) { if (HasCache) await NavigateFromCache(path); return; }

        currentPath = FileManagerPath.Normalize(path, IsUnixAgent);
        pathSegments = FileManagerPath.GetSegments(currentPath);
        loading = true; entries = null; ClearSelection(); InvalidateSortCache(); StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildPathCommand(AgentCommands.ListDirectory, currentPath);
            var response = await SendCommand(payload);
            if (response is null) return;

            var (parsed, parseError) = DirEntry.ParseDirectoryResponse(response);
            if (parseError is not null) { Msg.Show(parseError, MessageType.Error, source: "File Manager"); return; }
            entries = parsed;
            InvalidateSortCache();

            _ = SyncCacheAsync();
        }
        catch (Exception ex) { Msg.Error("Browse Failed", $"Could not list directory: {ex.Message}", "File Manager"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task NavigateFromCache(string path)
    {
        if (loading) return;

        currentPath = FileManagerPath.Normalize(path, IsUnixAgent);
        pathSegments = FileManagerPath.GetSegments(currentPath);
        loading = true; entries = null; ClearSelection(); InvalidateSortCache(); StateHasChanged();

        try
        {
            var remotePath = FileManagerPath.TrimTrailing(currentPath);
            var parentId = await ResolveDirectoryId(remotePath);
            var dirs = await Vfs.GetChildDirectoriesAsync(AgentUuid!, parentId);
            var files = await Vfs.GetFilesInDirectoryAsync(AgentUuid!, parentId);

            entries = new List<DirEntry>();
            foreach (var d in dirs)
                entries.Add(new DirEntry(Name: d.Name, CreationTime: 0, LastModifiedTime: 0, Size: 0, Type: 0, IsDirectory: true, IsDrive: d.IsDrive, IsHidden: false, IsSystem: false, IsReadOnly: false));
            foreach (var f in files)
                entries.Add(new DirEntry(Name: f.Name, CreationTime: 0, LastModifiedTime: 0, Size: (ulong)f.Size, Type: 0, IsDirectory: false, IsDrive: false, IsHidden: false, IsSystem: false, IsReadOnly: false));
            InvalidateSortCache();
        }
        catch (Exception ex) { Msg.Error("Cache Read Failed", $"Could not load cached entries: {ex.Message}", "File Manager"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task<string> ResolveDirectoryId(string remotePath)
    {
        if (string.IsNullOrEmpty(remotePath)) return VfsStore.RootParentId;
        return await Vfs.ResolveOrCreatePathAsync(AgentUuid!, remotePath);
    }

    private async Task NavigateUp()
    {
        var parent = FileManagerPath.GetParent(pathSegments, PathSep, IsUnixAgent, RootPath);
        await NavigateTo(parent);
    }

    private async Task NavigateToRoot() => await NavigateTo(RootPath);

    private async Task NavigateToBreadcrumb(int index)
    {
        var path = FileManagerPath.BuildBreadcrumbPath(pathSegments, index, PathSep, IsUnixAgent);
        await NavigateTo(path);
    }

    private async Task OnPathKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await NavigateTo(currentPath); }
    private async Task OpenAsDirectory(string name) => await NavigateTo(currentPath + name);

    // --- File viewer ---

    private Task ViewFile(string name)
    {
        viewingFileName = name;
        viewingFilePath = currentPath + name;
        viewingFile = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void CloseFileViewer()
    {
        viewingFile = false;
        viewingFileName = "";
        viewingFilePath = "";
    }

    private async Task OnEntryDoubleClick(DirEntry entry)
    {
        if (entry.IsDirectory || entry.IsDrive) await OpenAsDirectory(entry.Name);
        else if (IsFileSynced(entry.Name)) await ViewFile(entry.Name);
    }

    // --- Cache sync ---

    private async Task SyncCacheAsync()
    {
        if (_syncing) return;
        if (!Cache.HasDirectory || entries is null || string.IsNullOrEmpty(AgentUuid)) return;
        var snapshot = entries.ToList();
        var remotePath = FileManagerPath.TrimTrailing(currentPath);
        _syncing = true;
        try
        {
            var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, remotePath);
            foreach (var entry in snapshot)
            {
                try
                {
                    var entryRemotePath = string.IsNullOrEmpty(remotePath) ? entry.Name : $"{remotePath}/{entry.Name}";
                    if (entry.IsDirectory || entry.IsDrive) await Vfs.PutDirectoryAsync(AgentUuid, parentId, entry.Name, entryRemotePath, entry.IsDrive);
                    else await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, entryRemotePath, (long)entry.Size);
                }
                catch (Exception ex) { Msg.Show($"Cache sync: {ex.Message}", MessageType.Warning, source: "File Manager"); }
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) { Msg.Show($"Cache sync failed: {ex.Message}", MessageType.Warning, source: "File Manager"); }
        finally { _syncing = false; }
    }

    // --- Windows ---

    private void OpenDownloadsWindow()
    {
        if (!string.IsNullOrEmpty(AgentId)) Wm.OpenAgentWindow("Downloads", AgentId, agentName: AgentName, agentUuid: AgentUuid);
        else Wm.OpenWindow("Downloads");
    }

    private void OpenFullSearchWindow()
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid);
    }

    // --- Agent communication ---

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected) { Msg.Error("Not Connected", "No active connection to agent", "File Manager"); return null; }
        try { return await Relay.SendAndReceive(payload); }
        catch (Exception ex) { Msg.Error("Command Failed", $"Agent command error: {ex.Message}", "File Manager"); return null; }
    }
}
