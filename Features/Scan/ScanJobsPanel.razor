@inherits EventSubscriber
@inject ScanStore Scans
@inject TransferStore Downloads
@inject AgentStore AgentDb
@inject RelayConnectionService RelaySvc
@inject ServiceStateStore SvcState
@inject MessageService Msg

<PanelLayout Title="File Search">
    <HeaderLeft>
        @if (IsGlobalServicePaused)
        {
            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs">Service Paused</C2Badge>
        }
        else if (IsGloballyRunning)
        {
            <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs">
                <C2Icon Name="search" Size="Size.Xs" CssClass="panel-spinning" /> Searching
            </C2Badge>
        }
        else if (TotalPaused > 0)
        {
            <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">Paused</C2Badge>
        }
        else
        {
            <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">Idle</C2Badge>
        }
    </HeaderLeft>
    <HeaderRight>
        @if (IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeService" Title="Resume search service for all agents">RESUME SERVICE</C2Btn>
        }
        else
        {
            <C2Btn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="PauseService" Title="Pause search service for all agents">PAUSE SERVICE</C2Btn>
        }
        @if (TotalScanning > 0 && !IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Warning" Size="Size.Xs" OnClick="StopAll" Title="Pause all active searches">PAUSE ALL</C2Btn>
        }
        @if (TotalPaused > 0 && !IsGlobalServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeAll" Title="Resume all paused searches">RESUME ALL</C2Btn>
        }
    </HeaderRight>
    <Toolbar>
        <div class="panel-stats">
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-active">@TotalScanning</span>
                <span class="panel-stat-label">Searching</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@TotalPaused</span>
                <span class="panel-stat-label">Paused</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-done">@TotalCompleted</span>
                <span class="panel-stat-label">Done</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-fail">@TotalFailed</span>
                <span class="panel-stat-label">Failed</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@TotalFilesFound</span>
                <span class="panel-stat-label">Files</span>
            </div>
        </div>
    </Toolbar>
    <Body>
        <div class="panel-card-list">
            @foreach (var group in GetAgentGroups())
            {
                var isOnline = RelaySvc.GetAllAgents().Any(a => AgentDb.GetUuidByAgentId(a.Agent.Id) == group.Uuid);
                var isAgentPaused = SvcState.IsPaused(ServiceName.Scan, group.Uuid);
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="status-dot @(isOnline ? "dot-on" : "dot-off")"></span>
                        <span class="panel-card-name">@group.Name</span>
                        @if (isAgentPaused)
                        {
                            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs">Paused</C2Badge>
                        }
                        <span class="panel-card-summary">
                            @if (group.Scanning > 0) { <span class="panel-count-active">@group.Scanning<C2Icon Name="dot" Size="Size.Xs" /></span> }
                            @if (group.Paused > 0) { <span class="panel-count-paused">@group.Paused<C2Icon Name="stop" Size="Size.Xs" /></span> }
                            <span class="panel-count-done">@group.Completed<C2Icon Name="check" Size="Size.Xs" /></span>
                            @if (group.Failed > 0) { <span class="panel-count-fail">@group.Failed<C2Icon Name="x" Size="Size.Xs" /></span> }
                        </span>
                        @if (isAgentPaused)
                        {
                            <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeAgentService(group.Uuid)" Title="Resume search service for this agent"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                        }
                        else
                        {
                            <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseAgentService(group.Uuid)" Title="Pause search service for this agent"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                        }
                    </div>

                    @* Active scans *@
                    @foreach (var scan in GetAgentScans(group.Uuid, ScanStatus.Scanning))
                    {
                        var pct = scan.DirsTotal > 0 ? (int)(scan.DirsScanned * 100 / scan.DirsTotal) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon active"><C2Icon Name="dot" Size="Size.Xs" /></span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions</span>
                                </div>
                                <span class="panel-row-status">
                                    <span class="panel-row-meta">@scan.DirsScanned/@scan.DirsTotal dirs &middot; @scan.FilesFound files</span>
                                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseScan(scan)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                            <C2Progress Size="Size.Xs" Variant="ProgressVariant.Info" Percent="@pct" />
                        </div>
                    }

                    @* Paused *@
                    @foreach (var scan in GetAgentScans(group.Uuid, ScanStatus.Paused))
                    {
                        var pctP = scan.DirsTotal > 0 ? (int)(scan.DirsScanned * 100 / scan.DirsTotal) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon"><C2Icon Name="stop" Size="Size.Xs" /></span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions &middot; @scan.FilesFound files found</span>
                                </div>
                                <span class="panel-row-status">
                                    <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">@pctP%</C2Badge>
                                    <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeScan(scan)" Title="Resume"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Failed *@
                    @foreach (var scan in GetAgentScans(group.Uuid, ScanStatus.Failed))
                    {
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon fail"><C2Icon Name="x" Size="Size.Xs" /></span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions &middot; @scan.FilesFound files found</span>
                                </div>
                                <span class="panel-row-status">
                                    <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@scan.Error">FAILED</C2Badge>
                                    <C2Btn Size="Size.Xs" OnClick="() => ResumeScan(scan)" Title="Retry"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Completed (collapsed summary) *@
                    @if (group.Completed > 0)
                    {
                        <div class="panel-row-item panel-done-summary" @onclick="() => ToggleCompleted(group.Uuid)">
                            <div class="panel-row">
                                <span class="panel-row-icon done"><C2Icon Name="check" Size="Size.Xs" /></span>
                                <span class="panel-row-name">@group.Completed completed searches (@group.TotalFiles files found)</span>
                                <span class="panel-row-status">
                                    <span class="panel-expand"><C2Icon Name="@(expandedAgents.Contains(group.Uuid) ? "chevron-up" : "chevron-down")" Size="Size.Xs" /></span>
                                </span>
                            </div>
                        </div>
                        @if (expandedAgents.Contains(group.Uuid))
                        {
                            @foreach (var scan in GetAgentScans(group.Uuid, ScanStatus.Completed))
                            {
                                <div class="panel-row-item panel-done-item">
                                    <div class="panel-row">
                                        <span class="panel-row-icon done"><C2Icon Name="check" Size="Size.Xs" /></span>
                                        <div class="panel-row-info">
                                            <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                            <span class="panel-row-meta">@scan.Extensions &middot; @scan.DirsScanned dirs &middot; @scan.FilesFound files</span>
                                        </div>
                                        <span class="panel-row-status">
                                            <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => RemoveScan(scan)" Title="Remove"><C2Icon Name="x" Size="Size.Xs" /></C2Btn>
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            }

            @if (Scans.Searches.Count == 0)
            {
                <div class="panel-empty">No search activity. Use the SEARCH button on directories in the File Manager.</div>
            }
        </div>
    </Body>
</PanelLayout>

@code {
    private readonly HashSet<string> expandedAgents = new();

    private int TotalScanning => Scans.Searches.Count(r => r.Status == ScanStatus.Scanning);
    private int TotalPaused => Scans.Searches.Count(r => r.Status == ScanStatus.Paused);
    private int TotalCompleted => Scans.Searches.Count(r => r.Status == ScanStatus.Completed);
    private int TotalFailed => Scans.Searches.Count(r => r.Status == ScanStatus.Failed);
    private int TotalFilesFound => Scans.Searches.Sum(r => r.FilesFound);
    private bool IsGloballyRunning => TotalScanning > 0;
    private bool IsGlobalServicePaused => SvcState.IsPaused(ServiceName.Scan, "global");

    protected override async Task OnInitializedAsync()
    {
        On<ScanStoreChangedEvent>();
        On<RelayAgentsChangedEvent>();
        On<RelayConnectionChangedEvent>();
        On<ServiceStateChangedEvent>();
        await AgentDb.LoadAsync();
        await Scans.LoadAsync();
        await SvcState.LoadAsync();
    }

    private record AgentGroup(string Uuid, string Name, int Scanning, int Paused, int Completed, int Failed, int TotalFiles);

    private List<AgentGroup> GetAgentGroups()
    {
        return Scans.Searches
            .GroupBy(r => r.AgentUuid)
            .Select(g =>
            {
                var uuid = g.Key;
                return new AgentGroup(
                    uuid, AgentDb.GetDisplayName(uuid),
                    g.Count(r => r.Status == ScanStatus.Scanning),
                    g.Count(r => r.Status == ScanStatus.Paused),
                    g.Count(r => r.Status == ScanStatus.Completed),
                    g.Count(r => r.Status == ScanStatus.Failed),
                    g.Sum(r => r.FilesFound)
                );
            })
            .OrderByDescending(g => g.Scanning)
            .ThenByDescending(g => g.Paused)
            .ThenBy(g => g.Name)
            .ToList();
    }

    private List<ScanRecord> GetAgentScans(string uuid, string status)
    {
        return Scans.Searches
            .Where(r => r.AgentUuid == uuid && r.Status == status)
            .OrderByDescending(r => r.CreatedAt)
            .ToList();
    }

    private void ToggleCompleted(string uuid)
    {
        if (!expandedAgents.Remove(uuid))
            expandedAgents.Add(uuid);
    }

    // --- Service-level controls ---

    private async Task PauseService()
    {
        await SvcState.PauseAsync(ServiceName.Scan, "global");
        Scans.Cts.CancelAll();
    }

    private async Task ResumeService()
    {
        await SvcState.ResumeAsync(ServiceName.Scan, "global");
        // Individual items remain paused — user can resume them manually or they auto-resume on next agent connect
    }

    private async Task PauseAgentService(string uuid)
    {
        await SvcState.PauseAsync(ServiceName.Scan, uuid);
        var scanning = Scans.Searches.Where(r => r.AgentUuid == uuid && r.Status == ScanStatus.Scanning).ToList();
        foreach (var s in scanning)
            Scans.Cts.Cancel(s.Id);
    }

    private async Task ResumeAgentService(string uuid)
    {
        await SvcState.ResumeAsync(ServiceName.Scan, uuid);
    }

    // --- Item-level controls ---

    private void PauseScan(ScanRecord scan) => Scans.Cts.Cancel(scan.Id);

    private async Task ResumeScan(ScanRecord scan)
    {
        if (Scans.Cts.HasActive(scan.Id)) return;
        await Scans.ResumeAsync(scan.Id);
    }

    private async Task RemoveScan(ScanRecord scan) => await Scans.RemoveAsync(scan.Id);

    private async Task StopAll()
    {
        Scans.Cts.CancelAll();
        var scanning = Scans.Searches.Where(r => r.Status == ScanStatus.Scanning).ToList();
        foreach (var s in scanning)
            await Scans.PauseAsync(s.Id);
    }

    private async Task ResumeAll()
    {
        var paused = Scans.Searches.Where(r => r.Status == ScanStatus.Paused).ToList();
        foreach (var s in paused)
            await Scans.ResumeAsync(s.Id);
    }

    public override void Dispose() => base.Dispose();
}
