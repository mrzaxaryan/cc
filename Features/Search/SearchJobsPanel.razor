@inject SearchStore Scans
@inject DownloadStore Downloads
@inject AgentStore AgentDb
@inject RelayConnectionService RelaySvc
@inject ServiceStateStore SvcState
@inject MessageService Msg
@implements IDisposable

<PanelLayout Title="File Search">
    <HeaderLeft>
        @if (IsGlobalServicePaused)
        {
            <CcBadge Variant="BadgeVariant.Danger" Size="Size.Xs">Service Paused</CcBadge>
        }
        else if (IsGloballyRunning)
        {
            <CcBadge Variant="BadgeVariant.Success" Size="Size.Xs">
                <CcIcon Name="search" Size="Size.Xs" CssClass="panel-spinning" /> Searching
            </CcBadge>
        }
        else if (TotalPaused > 0)
        {
            <CcBadge Variant="BadgeVariant.Warning" Size="Size.Xs">Paused</CcBadge>
        }
        else
        {
            <CcBadge Variant="BadgeVariant.Muted" Size="Size.Xs">Idle</CcBadge>
        }
    </HeaderLeft>
    <HeaderRight>
        @if (IsGlobalServicePaused)
        {
            <CcBtn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeService" Title="Resume search service for all agents">RESUME SERVICE</CcBtn>
        }
        else
        {
            <CcBtn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="PauseService" Title="Pause search service for all agents">PAUSE SERVICE</CcBtn>
        }
        @if (TotalScanning > 0 && !IsGlobalServicePaused)
        {
            <CcBtn Variant="BtnVariant.Warning" Size="Size.Xs" OnClick="StopAll" Title="Pause all active searches">PAUSE ALL</CcBtn>
        }
        @if (TotalPaused > 0 && !IsGlobalServicePaused)
        {
            <CcBtn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeAll" Title="Resume all paused searches">RESUME ALL</CcBtn>
        }
    </HeaderRight>
    <Toolbar>
        <div class="panel-stats">
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-active">@TotalScanning</span>
                <span class="panel-stat-label">Searching</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@TotalPaused</span>
                <span class="panel-stat-label">Paused</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-done">@TotalCompleted</span>
                <span class="panel-stat-label">Done</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value panel-stat-fail">@TotalFailed</span>
                <span class="panel-stat-label">Failed</span>
            </div>
            <div class="panel-stat">
                <span class="panel-stat-value">@TotalFilesFound</span>
                <span class="panel-stat-label">Files</span>
            </div>
        </div>
    </Toolbar>
    <Body>
        <div class="panel-card-list">
            @foreach (var group in GetAgentGroups())
            {
                var isOnline = RelaySvc.GetAllAgents().Any(a => AgentDb.GetUuidByAgentId(a.Agent.Id) == group.Uuid);
                var isAgentPaused = SvcState.IsPaused(ServiceName.Search, group.Uuid);
                <div class="panel-card">
                    <div class="panel-card-header">
                        <span class="status-dot @(isOnline ? "dot-on" : "dot-off")"></span>
                        <span class="panel-card-name">@group.Name</span>
                        @if (isAgentPaused)
                        {
                            <CcBadge Variant="BadgeVariant.Danger" Size="Size.Xs">Paused</CcBadge>
                        }
                        <span class="panel-card-summary">
                            @if (group.Scanning > 0) { <span class="panel-count-active">@group.Scanning&#x25CF;</span> }
                            @if (group.Paused > 0) { <span class="panel-count-paused">@group.Paused&#x25A0;</span> }
                            <span class="panel-count-done">@group.Completed&#x2713;</span>
                            @if (group.Failed > 0) { <span class="panel-count-fail">@group.Failed&#x2717;</span> }
                        </span>
                        @if (isAgentPaused)
                        {
                            <CcBtn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeAgentService(group.Uuid)" Title="Resume search service for this agent">&#x25B6;</CcBtn>
                        }
                        else
                        {
                            <CcBtn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseAgentService(group.Uuid)" Title="Pause search service for this agent">&#x23F8;</CcBtn>
                        }
                    </div>

                    @* Active scans *@
                    @foreach (var scan in GetAgentScans(group.Uuid, SearchStatus.Scanning))
                    {
                        var pct = scan.DirsTotal > 0 ? (int)(scan.DirsScanned * 100 / scan.DirsTotal) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon active">&#x25CF;</span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions</span>
                                </div>
                                <span class="panel-row-status">
                                    <span class="panel-row-meta">@scan.DirsScanned/@scan.DirsTotal dirs &middot; @scan.FilesFound files</span>
                                    <CcBtn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseScan(scan)" Title="Pause">&#x23F8;</CcBtn>
                                </span>
                            </div>
                            <CcProgress Size="Size.Xs" Variant="ProgressVariant.Info" Percent="@pct" />
                        </div>
                    }

                    @* Paused *@
                    @foreach (var scan in GetAgentScans(group.Uuid, SearchStatus.Paused))
                    {
                        var pctP = scan.DirsTotal > 0 ? (int)(scan.DirsScanned * 100 / scan.DirsTotal) : 0;
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon">&#x25A0;</span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions &middot; @scan.FilesFound files found</span>
                                </div>
                                <span class="panel-row-status">
                                    <CcBadge Variant="BadgeVariant.Warning" Size="Size.Xs">@pctP%</CcBadge>
                                    <CcBtn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeScan(scan)" Title="Resume">&#x25B6;</CcBtn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Failed *@
                    @foreach (var scan in GetAgentScans(group.Uuid, SearchStatus.Failed))
                    {
                        <div class="panel-row-item">
                            <div class="panel-row">
                                <span class="panel-row-icon fail">&#x2717;</span>
                                <div class="panel-row-info">
                                    <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                    <span class="panel-row-meta">@scan.Extensions &middot; @scan.FilesFound files found</span>
                                </div>
                                <span class="panel-row-status">
                                    <CcBadge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@scan.Error">FAILED</CcBadge>
                                    <CcBtn Size="Size.Xs" OnClick="() => ResumeScan(scan)" Title="Retry">&#x21bb;</CcBtn>
                                </span>
                            </div>
                        </div>
                    }

                    @* Completed (collapsed summary) *@
                    @if (group.Completed > 0)
                    {
                        <div class="panel-row-item panel-done-summary" @onclick="() => ToggleCompleted(group.Uuid)">
                            <div class="panel-row">
                                <span class="panel-row-icon done">&#x2713;</span>
                                <span class="panel-row-name">@group.Completed completed searches (@group.TotalFiles files found)</span>
                                <span class="panel-row-status">
                                    <span class="panel-expand">@(expandedAgents.Contains(group.Uuid) ? "&#x25B2;" : "&#x25BC;")</span>
                                </span>
                            </div>
                        </div>
                        @if (expandedAgents.Contains(group.Uuid))
                        {
                            @foreach (var scan in GetAgentScans(group.Uuid, SearchStatus.Completed))
                            {
                                <div class="panel-row-item panel-done-item">
                                    <div class="panel-row">
                                        <span class="panel-row-icon done">&#x2713;</span>
                                        <div class="panel-row-info">
                                            <span class="panel-row-name" title="@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)">@(string.IsNullOrEmpty(scan.RootPath) ? "Full filesystem" : scan.RootPath)</span>
                                            <span class="panel-row-meta">@scan.Extensions &middot; @scan.DirsScanned dirs &middot; @scan.FilesFound files</span>
                                        </div>
                                        <span class="panel-row-status">
                                            <CcBtn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => RemoveScan(scan)" Title="Remove">&#x2715;</CcBtn>
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            }

            @if (Scans.Searches.Count == 0)
            {
                <div class="panel-empty">No search activity. Use the SEARCH button on directories in the File Manager.</div>
            }
        </div>
    </Body>
</PanelLayout>

@code {
    private readonly HashSet<string> expandedAgents = new();

    private int TotalScanning => Scans.Searches.Count(r => r.Status == SearchStatus.Scanning);
    private int TotalPaused => Scans.Searches.Count(r => r.Status == SearchStatus.Paused);
    private int TotalCompleted => Scans.Searches.Count(r => r.Status == SearchStatus.Completed);
    private int TotalFailed => Scans.Searches.Count(r => r.Status == SearchStatus.Failed);
    private int TotalFilesFound => Scans.Searches.Sum(r => r.FilesFound);
    private bool IsGloballyRunning => TotalScanning > 0;
    private bool IsGlobalServicePaused => SvcState.IsPaused(ServiceName.Search, "global");

    protected override async Task OnInitializedAsync()
    {
        Scans.OnChanged += OnChanged;
        RelaySvc.OnChanged += OnChanged;
        SvcState.OnChanged += OnChanged;
        await AgentDb.LoadAsync();
        await Scans.LoadAsync();
        await SvcState.LoadAsync();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private record AgentGroup(string Uuid, string Name, int Scanning, int Paused, int Completed, int Failed, int TotalFiles);

    private List<AgentGroup> GetAgentGroups()
    {
        return Scans.Searches
            .GroupBy(r => r.AgentUuid)
            .Select(g =>
            {
                var uuid = g.Key;
                return new AgentGroup(
                    uuid, AgentDb.GetDisplayName(uuid),
                    g.Count(r => r.Status == SearchStatus.Scanning),
                    g.Count(r => r.Status == SearchStatus.Paused),
                    g.Count(r => r.Status == SearchStatus.Completed),
                    g.Count(r => r.Status == SearchStatus.Failed),
                    g.Sum(r => r.FilesFound)
                );
            })
            .OrderByDescending(g => g.Scanning)
            .ThenByDescending(g => g.Paused)
            .ThenBy(g => g.Name)
            .ToList();
    }

    private List<SearchRecord> GetAgentScans(string uuid, string status)
    {
        return Scans.Searches
            .Where(r => r.AgentUuid == uuid && r.Status == status)
            .OrderByDescending(r => r.CreatedAt)
            .ToList();
    }

    private void ToggleCompleted(string uuid)
    {
        if (!expandedAgents.Remove(uuid))
            expandedAgents.Add(uuid);
    }

    // --- Service-level controls ---

    private async Task PauseService()
    {
        await SvcState.PauseAsync(ServiceName.Search, "global");
        Scans.Cts.CancelAll();
    }

    private async Task ResumeService()
    {
        await SvcState.ResumeAsync(ServiceName.Search, "global");
        // Individual items remain paused — user can resume them manually or they auto-resume on next agent connect
    }

    private async Task PauseAgentService(string uuid)
    {
        await SvcState.PauseAsync(ServiceName.Search, uuid);
        var scanning = Scans.Searches.Where(r => r.AgentUuid == uuid && r.Status == SearchStatus.Scanning).ToList();
        foreach (var s in scanning)
            Scans.Cts.Cancel(s.Id);
    }

    private async Task ResumeAgentService(string uuid)
    {
        await SvcState.ResumeAsync(ServiceName.Search, uuid);
    }

    // --- Item-level controls ---

    private void PauseScan(SearchRecord scan) => Scans.Cts.Cancel(scan.Id);

    private async Task ResumeScan(SearchRecord scan)
    {
        if (Scans.Cts.HasActive(scan.Id)) return;
        await Scans.ResumeAsync(scan.Id);
    }

    private async Task RemoveScan(SearchRecord scan) => await Scans.RemoveAsync(scan.Id);

    private async Task StopAll()
    {
        Scans.Cts.CancelAll();
        var scanning = Scans.Searches.Where(r => r.Status == SearchStatus.Scanning).ToList();
        foreach (var s in scanning)
            await Scans.PauseAsync(s.Id);
    }

    private async Task ResumeAll()
    {
        var paused = Scans.Searches.Where(r => r.Status == SearchStatus.Paused).ToList();
        foreach (var s in paused)
            await Scans.ResumeAsync(s.Id);
    }

    public void Dispose()
    {
        Scans.OnChanged -= OnChanged;
        RelaySvc.OnChanged -= OnChanged;
        SvcState.OnChanged -= OnChanged;
    }
}
