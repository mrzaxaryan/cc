@inherits EventSubscriber
@inject SearchStore Scans
@inject DownloadStore Downloads
@inject VfsStore Vfs
@inject AgentStore AgentDb
@inject ExtensionGroupStore ExtGroupStore
@inject ServiceStateStore SvcState
@inject MessageService Msg

<PanelLayout Title="File Search">
    <HeaderLeft>
        @if (!string.IsNullOrEmpty(AgentName))
        {
            <span class="panel-agent-label">@AgentName</span>
        }
        @if (IsAgentServicePaused)
        {
            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs">Service Paused</C2Badge>
        }
    </HeaderLeft>
    <HeaderRight>
        @if (IsAgentServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeAgentService" Title="Resume search service for this agent">RESUME SERVICE</C2Btn>
        }
        else
        {
            <C2Btn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="PauseAgentService" Title="Pause search service for this agent">PAUSE SERVICE</C2Btn>
        }
        @if (AgentScanning > 0 && !IsAgentServicePaused)
        {
            <C2Btn Variant="BtnVariant.Warning" Size="Size.Xs" OnClick="PauseAllAgent" Title="Pause all searches for this agent">PAUSE ALL</C2Btn>
        }
        @if (AgentPaused > 0 && !IsAgentServicePaused)
        {
            <C2Btn Variant="BtnVariant.Success" Size="Size.Xs" OnClick="ResumeAllAgent" Title="Resume all searches for this agent">RESUME ALL</C2Btn>
        }
        <C2Btn Size="Size.Xs" OnClick="Refresh" Title="Refresh"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
    </HeaderRight>
    <Toolbar>
        @* New search form *@
        @if (showNewScan)
        {
            <div class="scan-form">
                @if (!fullScanMode)
                {
                    <div class="scan-form-row">
                        <label class="scan-label">Directory</label>
                        <C2Input @bind-Value="newScanPath" Placeholder="C:\Users" Monospace />
                    </div>
                }
                <div class="scan-form-row">
                    <label class="scan-label">Extension groups</label>
                    <div class="scan-ext-groups">
                        @foreach (var group in ExtGroupStore.Groups)
                        {
                            var g = group;
                            var isActive = activeGroups.Contains(g.Name);
                            <button class="scan-ext-group @(isActive ? "active" : "") @(!g.Enabled ? "disabled" : "")" @onclick="() => ToggleGroup(g.Name)" title="@g.Extensions" disabled="@(!g.Enabled)">
                                @g.Name
                            </button>
                        }
                    </div>
                </div>
                <div class="scan-form-row">
                    <label class="scan-label">Extensions (comma-separated)</label>
                    <C2Input @bind-Value="newScanExtensions" Placeholder=".txt,.pdf,.doc,.xls" Monospace />
                </div>
                @if (!string.IsNullOrEmpty(extensionError))
                {
                    <div class="scan-form-row scan-ext-error">@extensionError</div>
                }
                <div class="scan-form-row scan-form-check">
                    <label>
                        <input type="checkbox" @bind="newScanAutoDownload" />
                        Auto-download matching files
                    </label>
                </div>
                <div class="scan-form-actions">
                    @if (fullScanMode)
                    {
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="StartFullScan" Disabled="@(string.IsNullOrWhiteSpace(newScanExtensions))">START FULL SEARCH</C2Btn>
                    }
                    else
                    {
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="StartScan" Disabled="@(string.IsNullOrWhiteSpace(newScanPath) || string.IsNullOrWhiteSpace(newScanExtensions))">START SEARCH</C2Btn>
                    }
                    <C2Btn Size="Size.Xs" OnClick="CancelForm">CANCEL</C2Btn>
                </div>
            </div>
        }
        else
        {
            <div class="scan-new-btn">
                <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="ShowNewScan">NEW SEARCH</C2Btn>
                <C2Btn Size="Size.Xs" OnClick="ShowFullScan">FULL SEARCH</C2Btn>
            </div>
        }

        @* Active scans *@
        <div class="panel-tabs">
            <button class="panel-tab @(filter == Filter.All ? "active" : "")" @onclick="() => SetFilter(Filter.All)">
                All <span class="panel-tab-count">@allRecords.Count</span>
            </button>
            <button class="panel-tab @(filter == Filter.Active ? "active" : "")" @onclick="() => SetFilter(Filter.Active)">
                Active <span class="panel-tab-count">@CountByFilter(Filter.Active)</span>
            </button>
            <button class="panel-tab @(filter == Filter.Done ? "active" : "")" @onclick="() => SetFilter(Filter.Done)">
                Done <span class="panel-tab-count">@CountByFilter(Filter.Done)</span>
            </button>
        </div>
    </Toolbar>
    <Body>
        @if (filteredRecords.Count == 0)
        {
            <div class="panel-empty">
                @if (allRecords.Count == 0)
                {
                    <span>No searches yet. Click NEW SEARCH to start.</span>
                }
                else
                {
                    <span>No @filter.ToString().ToLower() searches</span>
                }
            </div>
        }
        else
        {
            <div class="scan-list">
                @foreach (var scan in filteredRecords)
                {
                    var s = scan;
                    var pct = s.DirsTotal > 0 ? (int)(s.DirsScanned * 100 / s.DirsTotal) : 0;
                    <div class="scan-item @StatusClass(s.Status)">
                        <div class="scan-item-row">
                            <span class="scan-item-icon" title="@StatusLabel(s.Status)"><C2Icon Name="@StatusIcon(s.Status)" Size="Size.Xs" /></span>
                            <div class="scan-item-info">
                                <span class="scan-item-path" title="@(string.IsNullOrEmpty(s.RootPath) ? "Full filesystem" : s.RootPath)">@(string.IsNullOrEmpty(s.RootPath) ? "Full filesystem" : s.RootPath)</span>
                                <span class="scan-item-meta">
                                    @s.Extensions
                                    @if (!string.IsNullOrEmpty(s.AgentName) && string.IsNullOrEmpty(AgentUuid))
                                    {
                                        <span class="scan-item-agent">@s.AgentName</span>
                                    }
                                </span>
                            </div>
                            <div class="scan-item-status">
                                @switch (s.Status)
                                {
                                    case SearchStatus.Scanning:
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseScan(s)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                        break;
                                    case SearchStatus.Paused:
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeScan(s)" Title="Resume"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                                        break;
                                    case SearchStatus.Completed:
                                        <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs">DONE</C2Badge>
                                        break;
                                    case SearchStatus.Failed:
                                        <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@s.Error">FAILED</C2Badge>
                                        break;
                                }
                                <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => RemoveScan(s)" Title="Remove" CssClass="panel-remove-btn"><C2Icon Name="x" Size="Size.Xs" /></C2Btn>
                            </div>
                        </div>
                        <div class="scan-item-stats">
                            <span>Dirs: @s.DirsScanned / @s.DirsTotal</span>
                            <span>Files found: @s.FilesFound</span>
                            @if (s.AutoDownload)
                            {
                                <span>Queued: @s.FilesQueued</span>
                            }
                        </div>
                        @if (s.Status is SearchStatus.Scanning or SearchStatus.Paused)
                        {
                            <C2Progress Size="Size.Xs" Variant="@ProgressVariant(s.Status)" Percent="@pct" />
                        }
                    </div>
                }
            </div>
        }
    </Body>
</PanelLayout>

@code {
    [Parameter] public string? AgentUuid { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? InitialPath { get; set; }

    private enum Filter { All, Active, Done }

    private List<SearchRecord> allRecords = new();
    private List<SearchRecord> filteredRecords = new();
    private Filter filter = Filter.All;

    private bool showNewScan;
    private bool fullScanMode;
    private string newScanPath = "";
    private string newScanExtensions = "";
    private bool newScanAutoDownload = true;
    private HashSet<string> activeGroups = new();
    private string extensionError = "";

    private bool IsAgentServicePaused => !string.IsNullOrEmpty(AgentUuid) && SvcState.IsEffectivelyPaused(ServiceName.Search, AgentUuid);

    protected override async Task OnInitializedAsync()
    {
        On<SearchStoreChangedEvent>();
        On<ServiceStateChangedEvent>();
        await Scans.LoadAsync();
        await Downloads.LoadAsync();
        await ExtGroupStore.LoadAsync();
        await SvcState.LoadAsync();

        if (!string.IsNullOrEmpty(InitialPath))
        {
            newScanPath = InitialPath;
            showNewScan = true;
        }

        Refresh();
    }

    private void OnScansChanged()
    {
        _ = InvokeAsync(() =>
        {
            Refresh();
            StateHasChanged();
        });
    }

    private void SetFilter(Filter f) { filter = f; ApplyFilter(); }

    private void ApplyFilter()
    {
        filteredRecords = filter switch
        {
            Filter.Active => allRecords.Where(r => r.Status is SearchStatus.Scanning or SearchStatus.Paused).ToList(),
            Filter.Done => allRecords.Where(r => r.Status is SearchStatus.Completed or SearchStatus.Failed).ToList(),
            _ => allRecords.ToList()
        };
    }

    private int CountByFilter(Filter f) => f switch
    {
        Filter.Active => allRecords.Count(r => r.Status is SearchStatus.Scanning or SearchStatus.Paused),
        Filter.Done => allRecords.Count(r => r.Status is SearchStatus.Completed or SearchStatus.Failed),
        _ => allRecords.Count
    };

    private void Refresh()
    {
        allRecords = string.IsNullOrEmpty(AgentUuid)
            ? Scans.Searches.ToList()
            : Scans.GetByAgent(AgentUuid);
        allRecords = allRecords
            .OrderBy(r => r.Status == SearchStatus.Scanning ? 0 : r.Status == SearchStatus.Paused ? 1 : 2)
            .ThenByDescending(r => r.CreatedAt)
            .ToList();
        ApplyFilter();
    }

    private async Task StartScan()
    {
        if (string.IsNullOrEmpty(AgentUuid) || string.IsNullOrWhiteSpace(newScanPath) || string.IsNullOrWhiteSpace(newScanExtensions))
            return;

        if (!ValidateExtensions()) return;

        var extensions = ExtensionGroupStore.NormalizeExtensions(newScanExtensions);

        var path = newScanPath.TrimEnd('\\', '/');
        if (!string.IsNullOrEmpty(path) && !path.EndsWith(@"\"))
            path += @"\";

        await Scans.AddAsync(AgentUuid, AgentName ?? "", path, extensions, newScanAutoDownload);
        showNewScan = false;
        activeGroups.Clear();
        extensionError = "";
        Refresh();
    }

    private async Task StartFullScan()
    {
        if (string.IsNullOrEmpty(AgentUuid) || string.IsNullOrWhiteSpace(newScanExtensions))
            return;

        if (!ValidateExtensions()) return;

        var extensions = ExtensionGroupStore.NormalizeExtensions(newScanExtensions);
        await Scans.AddAsync(AgentUuid, AgentName ?? "", "", extensions, newScanAutoDownload);
        showNewScan = false;
        fullScanMode = false;
        activeGroups.Clear();
        extensionError = "";
        Refresh();
    }

    private void ShowNewScan() { fullScanMode = false; showNewScan = true; }
    private void ShowFullScan() { fullScanMode = true; showNewScan = true; }
    private void CancelForm() { showNewScan = false; fullScanMode = false; }

    private void ToggleGroup(string groupName)
    {
        if (!activeGroups.Remove(groupName))
            activeGroups.Add(groupName);
        RebuildExtensions();
    }

    private void RebuildExtensions()
    {
        var current = newScanExtensions
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(e => e.StartsWith(".") ? e.ToLowerInvariant() : $".{e.ToLowerInvariant()}")
            .ToHashSet();

        var allGroupExts = new HashSet<string>();
        foreach (var g in ExtGroupStore.Groups)
            foreach (var e in g.Extensions.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                allGroupExts.Add(e);

        // keep manually added extensions (not in any group)
        var manual = current.Where(e => !allGroupExts.Contains(e)).ToList();

        // add extensions from active groups
        var result = new List<string>(manual);
        foreach (var groupName in activeGroups)
        {
            var group = ExtGroupStore.Groups.FirstOrDefault(g => g.Name == groupName);
            if (group is not null)
                result.AddRange(group.Extensions.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        }

        newScanExtensions = string.Join(",", result.Distinct());
        extensionError = "";
    }

    private bool ValidateExtensions()
    {
        if (string.IsNullOrWhiteSpace(newScanExtensions))
        {
            extensionError = "At least one extension is required.";
            return false;
        }

        var normalized = ExtensionGroupStore.NormalizeExtensions(newScanExtensions);
        var invalid = ExtensionGroupStore.GetInvalidExtensions(normalized);

        if (invalid.Count > 0)
        {
            extensionError = $"Invalid extension(s): {string.Join(", ", invalid)} — must be a dot followed by 1-15 alphanumeric characters.";
            return false;
        }

        extensionError = "";
        return true;
    }

    private int AgentScanning => allRecords.Count(r => r.Status == SearchStatus.Scanning);
    private int AgentPaused => allRecords.Count(r => r.Status == SearchStatus.Paused);

    private async Task PauseAgentService()
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        await SvcState.PauseAsync(ServiceName.Search, AgentUuid);
        var scanning = allRecords.Where(r => r.Status == SearchStatus.Scanning).ToList();
        foreach (var s in scanning)
            Scans.Cts.Cancel(s.Id);
    }

    private async Task ResumeAgentService()
    {
        if (string.IsNullOrEmpty(AgentUuid)) return;
        await SvcState.ResumeAsync(ServiceName.Search, AgentUuid);
    }

    private void PauseAllAgent()
    {
        foreach (var s in allRecords.Where(r => r.Status == SearchStatus.Scanning))
            Scans.Cts.Cancel(s.Id);
    }

    private async Task ResumeAllAgent()
    {
        var paused = allRecords.Where(r => r.Status == SearchStatus.Paused).ToList();
        foreach (var s in paused)
        {
            if (!Scans.Cts.HasActive(s.Id))
                await Scans.ResumeAsync(s.Id);
        }
    }

    private void PauseScan(SearchRecord scan) => Scans.Cts.Cancel(scan.Id);

    private async Task ResumeScan(SearchRecord scan)
    {
        if (Scans.Cts.HasActive(scan.Id)) return;
        await Scans.ResumeAsync(scan.Id);
    }

    private async Task RemoveScan(SearchRecord scan)
    {
        Scans.Cts.Cancel(scan.Id);
        await Scans.RemoveAsync(scan.Id);
    }

    private static string StatusIcon(string s) => s switch
    {
        SearchStatus.Scanning => "dot",
        SearchStatus.Paused => "stop",
        SearchStatus.Completed => "check",
        SearchStatus.Failed => "x",
        _ => "dot-outline"
    };

    private static string StatusLabel(string s) => s switch
    {
        SearchStatus.Scanning => "Scanning",
        SearchStatus.Paused => "Paused",
        SearchStatus.Completed => "Completed",
        SearchStatus.Failed => "Failed",
        _ => ""
    };

    private static string StatusClass(string s) => s switch
    {
        SearchStatus.Scanning => "scan-item-active",
        SearchStatus.Completed => "scan-item-done",
        SearchStatus.Failed => "scan-item-failed",
        _ => ""
    };

    private static ProgressVariant ProgressVariant(string s) => s switch
    {
        SearchStatus.Scanning => C2.Shared.ProgressVariant.Info,
        SearchStatus.Paused => C2.Shared.ProgressVariant.Warning,
        _ => C2.Shared.ProgressVariant.Muted
    };

    public override void Dispose() => base.Dispose();
}
