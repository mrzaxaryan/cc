@inherits EventSubscriber
@inject TransferStore Downloads

@{
    var dl = GetTransferRecord();
    if (dl is null || dl.Status == TransferStatus.Pending)
        return;

    switch (dl.Status)
    {
        case TransferStatus.Downloading:
            var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
            <span class="fm-dl-badge">
                <C2Spinner Size="Size.Xs" />
                <C2Badge Variant="BadgeVariant.Info" Size="Size.Xs">@pct%</C2Badge>
            </span>
            break;

        case TransferStatus.Queued:
            <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">QUEUED</C2Badge>
            break;

        case TransferStatus.Completed:
            <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs"><C2Icon Name="check" Size="Size.Xs" /></C2Badge>
            break;

        case TransferStatus.Paused:
            var pctP = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
            <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs"><C2Icon Name="pause" Size="Size.Xs" /> @pctP%</C2Badge>
            break;

        case TransferStatus.Failed:
            <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@dl.Error"><C2Icon Name="x" Size="Size.Xs" /></C2Badge>
            break;
    }
}

@code {
    [Parameter] public DirEntry Entry { get; set; } = default!;
    [Parameter] public string CurrentPath { get; set; } = "";
    [Parameter] public string? AgentUuid { get; set; }

    protected override void OnInitialized()
    {
        On<TransferStoreChangedEvent>();
    }

    private TransferRecord? GetTransferRecord()
        => string.IsNullOrEmpty(AgentUuid) ? null : Downloads.Find(AgentUuid, CurrentPath + Entry.Name);

    public override void Dispose() => base.Dispose();
}
