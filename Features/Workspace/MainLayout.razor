@inherits EventSubscriber
@inject CacheManager Cache
@inject RelayStore Relay
@inject RelayConnectionService RelaySvc
@inject TransferService TransferSvc
@inject ScanService ScanSvc
@inject WindowManager Wm
@inject ThemeService Theme
@inject MessageService Msg
@inject NotificationStore Notif
@inject ExtensionGroupStore ExtGroups
@inject TransferStore TransferStore
@inject ScanStore ScanStore
@inject IJSRuntime JS

@if (!initialized)
{
    <div class="c2-loading">
        <span class="c2-loading-brand">C2</span>
        <div class="c2-loading-spinner"></div>
        <div class="c2-loading-text"></div>
    </div>
}
else if (showSetup)
{
    <SetupWizard OnComplete="OnSetupComplete" />
}
else
{
    <div class="mdi-menubar">
        <div class="brand-menu" @onfocusout="OnBrandFocusOut" tabindex="-1">
            <button class="mdi-brand" @onclick="ToggleBrandMenu">
                C2 <C2Icon Name="chevron-down" Size="Size.Xs" CssClass="brand-chevron" />
            </button>
            @if (brandMenuOpen)
            {
                <div class="brand-popup">
                    <button class="brand-popup-item" @onclick='() => BrandAction("Settings")'>
                        <C2Icon Name="settings" Size="Size.Xs" /> Settings
                    </button>
                    <button class="brand-popup-item" @onclick="BrandToggleTheme">
                        <C2Icon Name="@(Theme.Current == C2.Infrastructure.Theme.Dark ? "sun" : "moon")" Size="Size.Xs" />
                        @(Theme.Current == C2.Infrastructure.Theme.Dark ? "Light Theme" : "Dark Theme")
                    </button>
                    <button class="brand-popup-item" @onclick="BrandReload">
                        <C2Icon Name="refresh" Size="Size.Xs" /> Reload App
                    </button>
                    <div class="brand-popup-divider"></div>
                    <button class="brand-popup-item shutdown" @onclick="ShutdownAsync">
                        <C2Icon Name="power" Size="Size.Xs" /> Shut Down
                    </button>
                </div>
            }
        </div>
        <span class="mdi-sep"></span>

        @foreach (var item in MenuItems)
        {
            var panel = item.Panel;
            <button class="mdi-menu-item" @onclick="() => Wm.OpenWindow(panel)">
                <C2Icon Name="@item.Icon" Size="Size.Xs" /> @item.Label
            </button>
        }

        <div class="tools-menu" @onfocusout="OnToolsFocusOut" tabindex="-1">
            <button class="mdi-menu-item" @onclick="ToggleToolsMenu">
                <C2Icon Name="tool" Size="Size.Xs" /> Tools <C2Icon Name="chevron-down" Size="Size.Xs" CssClass="brand-chevron" />
            </button>
            @if (toolsMenuOpen)
            {
                <div class="tools-popup">
                    @foreach (var tool in ToolItems)
                    {
                        var panel = tool.Panel;
                        <button class="brand-popup-item" @onclick="() => OpenTool(panel)">
                            <C2Icon Name="@tool.Icon" Size="Size.Xs" /> @tool.Label
                        </button>
                    }
                </div>
            }
        </div>

        <div class="mdi-spacer"></div>

        @* Notifications *@
        <div class="notif-wrapper" @onfocusout="OnFocusOut" tabindex="-1">
            <button class="mdi-icon-btn" @onclick="ToggleDropdown" title="Notifications">
                <C2Icon Name="bell" Size="Size.Sm" />
                @if (updateAvailable || Notif.UnreadCount > 0)
                {
                    <span class="notif-badge">@BadgeText()</span>
                }
            </button>

            @if (dropdownOpen)
            {
                <div class="notif-dropdown">
                    <div class="notif-header">
                        <span>Notifications</span>
                        @if (Notif.Items.Count > 0)
                        {
                            <button class="notif-clear-all" @onclick="ClearAll">Clear all</button>
                        }
                    </div>
                    @if (updateAvailable)
                    {
                        <div class="notif-update">
                            <span>Update available — current build <code>@BuildMeta.Hash</code></span>
                            <button class="notif-reload" @onclick="ReloadApp">Reload</button>
                        </div>
                    }
                    <div class="notif-list">
                        @if (!updateAvailable && Notif.Items.Count == 0)
                        {
                            <div class="notif-empty">No notifications</div>
                        }
                        else
                        {
                            @foreach (var n in Notif.Items)
                            {
                                <div class="notif-item notif-@n.Type" @key="n.Id">
                                    <div class="notif-body">
                                        <div class="notif-row">
                                            @if (!string.IsNullOrEmpty(n.Source))
                                            {
                                                <span class="notif-source">@n.Source</span>
                                            }
                                            @if (!string.IsNullOrEmpty(n.Title))
                                            {
                                                <span class="notif-title">@n.Title</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(n.Detail))
                                        {
                                            <span class="notif-detail">@n.Detail</span>
                                        }
                                        else if (string.IsNullOrEmpty(n.Title))
                                        {
                                            <span class="notif-text">@n.Text</span>
                                        }
                                    </div>
                                    <span class="notif-time">@FormatTime(n.Created)</span>
                                    @if (n.Type == "error")
                                    {
                                        <button class="notif-copy" @onclick="() => CopyText(n.Detail ?? n.Text)" title="Copy">
                                            <C2Icon Name="copy" Size="Size.Xs" />
                                        </button>
                                    }
                                    <button class="notif-remove" @onclick="() => RemoveOne(n.Id)" title="Dismiss">&times;</button>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>

    </div>

    <div class="mdi-workspace"></div>

    <FloatingWindows />

    @if (isShutdown)
    {
        <div class="shutdown-overlay">
            <div class="shutdown-card">
                <C2Icon Name="power" Size="Size.Lg" CssClass="shutdown-icon" />
                <h2 class="shutdown-title">All services stopped</h2>
                <p class="shutdown-text">Close this window or restart the app.</p>
                <div class="shutdown-actions">
                    <button class="shutdown-btn close" @onclick="CloseWindow">
                        <C2Icon Name="x" Size="Size.Xs" /> Close Window
                    </button>
                    <button class="shutdown-btn restart" @onclick="RestartApp">
                        <C2Icon Name="refresh" Size="Size.Xs" /> Restart
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private record MenuItem(string Panel, string Icon, string Label);
    private static readonly MenuItem[] MenuItems =
    [
        new("Agents", "agents", "Agents"),
        new("Relay", "server", "Relay"),
        new("ExtensionGroups", "layers", "Extensions"),
    ];

    private static readonly MenuItem[] ToolItems =
    [
        new("PeParser", "file-code", "PE Parser"),
        new("Base64", "code", "Base64"),
        new("LnkTool", "link", "LNK Tool"),
    ];

    private bool showSetup;
    private bool initialized;
    private bool dropdownOpen;
    private bool updateAvailable;
    private bool brandMenuOpen;
    private bool toolsMenuOpen;
    private bool isShutdown;
    private Timer? _updateTimer;

    protected override void OnInitialized()
    {
        On<WindowChangedEvent>();
        On<ThemeChangedEvent>();
        On<NotificationStoreChangedEvent>();
        OnAsync<NotificationEvent>(async e =>
        {
            await Notif.AddAsync(e.Text, e.Type, e.Title, e.Detail, e.Source);
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync();
            await Cache.InitializeAsync();
            await Relay.LoadAsync();
            await Notif.LoadAsync();
            await ExtGroups.LoadAsync();
            await RelaySvc.StartAsync();
            await TransferSvc.StartAsync();
            await ScanSvc.StartAsync();
            showSetup = Cache.SetupRequired || Cache.NeedsPermission || Relay.SetupRequired || ExtGroups.SetupRequired;
            initialized = true;
            StateHasChanged();

            _updateTimer = new Timer(async _ =>
            {
                try
                {
                    var available = await JS.InvokeAsync<bool>("eval", "!!window._c2UpdateAvailable");
                    if (available && !updateAvailable)
                    {
                        updateAvailable = true;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch { }
            }, null, 3000, 5000);
        }
    }

    private void ToggleDropdown()
    {
        dropdownOpen = !dropdownOpen;
        if (dropdownOpen) Notif.MarkAllRead();
    }

    private async void OnFocusOut()
    {
        await Task.Delay(200);
        await InvokeAsync(() =>
        {
            dropdownOpen = false;
            StateHasChanged();
        });
    }
    private async Task RemoveOne(int id) => await Notif.RemoveAsync(id);
    private async Task CopyText(string text) => await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);

    private async Task ClearAll()
    {
        await Notif.ClearAsync();
        dropdownOpen = false;
    }

    private string BadgeText()
    {
        var count = Notif.UnreadCount + (updateAvailable ? 1 : 0);
        return count > 99 ? "99+" : count.ToString();
    }

    private void ReloadApp() => _ = JS.InvokeVoidAsync("eval", "location.reload()");

    private static string FormatTime(double epochMs)
    {
        var dt = DateTimeOffset.FromUnixTimeMilliseconds((long)epochMs).LocalDateTime;
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d");
    }

    private void ToggleToolsMenu() => toolsMenuOpen = !toolsMenuOpen;

    private void OpenTool(string panel)
    {
        toolsMenuOpen = false;
        Wm.OpenWindow(panel);
    }

    private async void OnToolsFocusOut()
    {
        await Task.Delay(200);
        await InvokeAsync(() =>
        {
            toolsMenuOpen = false;
            StateHasChanged();
        });
    }

    private void ToggleBrandMenu() => brandMenuOpen = !brandMenuOpen;

    private void BrandAction(string panel)
    {
        brandMenuOpen = false;
        Wm.OpenWindow(panel);
    }

    private async Task BrandToggleTheme()
    {
        brandMenuOpen = false;
        await Theme.Toggle();
    }

    private void BrandReload()
    {
        brandMenuOpen = false;
        _ = JS.InvokeVoidAsync("eval", "location.reload()");
    }

    private async void OnBrandFocusOut()
    {
        await Task.Delay(200);
        await InvokeAsync(() =>
        {
            brandMenuOpen = false;
            StateHasChanged();
        });
    }

    private async Task ShutdownAsync()
    {
        brandMenuOpen = false;

        // Cancel all in-flight downloads, uploads, and searches
        TransferStore.Cts.CancelAll();
        ScanStore.Cts.CancelAll();

        // Dispose services (closes WebSockets, stops background loops)
        await RelaySvc.DisposeAsync();
        TransferSvc.Dispose();
        ScanSvc.Dispose();
        _updateTimer?.Dispose();

        isShutdown = true;
    }

    private void CloseWindow() => _ = JS.InvokeVoidAsync("eval", "window.close()");

    private void RestartApp() => _ = JS.InvokeVoidAsync("eval", "location.reload()");

    private void OnSetupComplete()
    {
        showSetup = false;
        StateHasChanged();
    }

    public override void Dispose()
    {
        _updateTimer?.Dispose();
        base.Dispose();
    }
}