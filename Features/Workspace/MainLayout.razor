
@inherits EventSubscriber
@inject CacheManager Cache
@inject RelayStore Relay
@inject RelayConnectionService RelaySvc
@inject DownloadService DownloadSvc
@inject SearchService SearchSvc
@inject WindowManager Wm
@inject ThemeService Theme
@inject MessageService Msg
@inject NotificationStore Notif
@inject ExtensionGroupStore ExtGroups
@inject IJSRuntime JS

@if (!initialized)
{
    <div class="cc-loading">
        <span class="cc-loading-brand">cc</span>
        <div class="cc-loading-spinner"></div>
        <div class="cc-loading-text"></div>
    </div>
}
else if (showSetup)
{
    <SetupWizard OnComplete="OnSetupComplete" />
}
else
{
    <div class="mdi-menubar">
        <span class="mdi-brand">cc</span>
        <span class="mdi-sep"></span>

        @foreach (var item in MenuItems)
        {
            var panel = item.Panel;
            <button class="mdi-menu-item" @onclick="() => Wm.OpenWindow(panel)">
                <CcIcon Name="@item.Icon" Size="Size.Xs" /> @item.Label
            </button>
        }

        <div class="mdi-spacer"></div>

        @* Notifications *@
        <div class="notif-wrapper" @onfocusout="OnFocusOut" tabindex="-1">
            <button class="mdi-icon-btn" @onclick="ToggleDropdown" title="Notifications">
                <CcIcon Name="bell" Size="Size.Sm" />
                @if (updateAvailable || Notif.UnreadCount > 0)
                {
                    <span class="notif-badge">@BadgeText()</span>
                }
            </button>

            @if (dropdownOpen)
            {
                <div class="notif-dropdown">
                    <div class="notif-header">
                        <span>Notifications</span>
                        @if (Notif.Items.Count > 0)
                        {
                            <button class="notif-clear-all" @onclick="ClearAll">Clear all</button>
                        }
                    </div>
                    @if (updateAvailable)
                    {
                        <div class="notif-update">
                            <span>Update available — current build <code>@BuildMeta.Hash</code></span>
                            <button class="notif-reload" @onclick="ReloadApp">Reload</button>
                        </div>
                    }
                    <div class="notif-list">
                        @if (!updateAvailable && Notif.Items.Count == 0)
                        {
                            <div class="notif-empty">No notifications</div>
                        }
                        else
                        {
                            @foreach (var n in Notif.Items)
                            {
                                <div class="notif-item notif-@n.Type" @key="n.Id">
                                    <span class="notif-text">@n.Text</span>
                                    <span class="notif-time">@FormatTime(n.Created)</span>
                                    @if (n.Type == "error")
                                    {
                                        <button class="notif-copy" @onclick="() => CopyText(n.Text)" title="Copy">
                                            <CcIcon Name="copy" Size="Size.Xs" />
                                        </button>
                                    }
                                    <button class="notif-remove" @onclick="() => RemoveOne(n.Id)" title="Dismiss">&times;</button>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        @* Theme toggle *@
        <button class="mdi-icon-btn" @onclick="ToggleTheme" title="Toggle theme">
            @if (Theme.Current == cc.Infrastructure.Theme.Dark)
            {
                <CcIcon Name="sun" Size="Size.Sm" />
            }
            else
            {
                <CcIcon Name="moon" Size="Size.Sm" />
            }
        </button>
    </div>

    <div class="mdi-workspace"></div>

    <FloatingWindows />
}

@code {
    private record MenuItem(string Panel, string Icon, string Label);
    private static readonly MenuItem[] MenuItems =
    [
        new("Agents", "agents", "Agents"),
        new("Relay", "server", "Relay"),
        new("Settings", "database", "Settings"),
        new("Uploads", "sync", "Uploads"),
        new("SearchJobs", "search", "Search"),
        new("ExtensionGroups", "database", "Extensions"),
    ];

    private bool showSetup;
    private bool initialized;
    private bool dropdownOpen;
    private bool updateAvailable;
    private Timer? _updateTimer;

    protected override void OnInitialized()
    {
        On<WindowChangedEvent>();
        On<ThemeChangedEvent>();
        On<NotificationStoreChangedEvent>();
        OnAsync<NotificationEvent>(async e =>
        {
            await Notif.AddAsync(e.Text, e.Type);
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync();
            await Cache.InitializeAsync();
            await Relay.LoadAsync();
            await Notif.LoadAsync();
            await ExtGroups.LoadAsync();
            await RelaySvc.StartAsync();
            await DownloadSvc.StartAsync();
            await SearchSvc.StartAsync();
            showSetup = Cache.SetupRequired || Cache.NeedsPermission || Relay.SetupRequired || ExtGroups.SetupRequired;
            initialized = true;
            StateHasChanged();

            _updateTimer = new Timer(async _ =>
            {
                try
                {
                    var available = await JS.InvokeAsync<bool>("eval", "!!window._ccUpdateAvailable");
                    if (available && !updateAvailable)
                    {
                        updateAvailable = true;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch { }
            }, null, 3000, 5000);
        }
    }

    private void ToggleDropdown()
    {
        dropdownOpen = !dropdownOpen;
        if (dropdownOpen) Notif.MarkAllRead();
    }

    private async void OnFocusOut()
    {
        await Task.Delay(200);
        await InvokeAsync(() =>
        {
            dropdownOpen = false;
            StateHasChanged();
        });
    }
    private async Task RemoveOne(int id) => await Notif.RemoveAsync(id);
    private async Task CopyText(string text) => await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);

    private async Task ClearAll()
    {
        await Notif.ClearAsync();
        dropdownOpen = false;
    }

    private string BadgeText()
    {
        var count = Notif.UnreadCount + (updateAvailable ? 1 : 0);
        return count > 99 ? "99+" : count.ToString();
    }

    private void ReloadApp() => _ = JS.InvokeVoidAsync("eval", "location.reload()");

    private static string FormatTime(double epochMs)
    {
        var dt = DateTimeOffset.FromUnixTimeMilliseconds((long)epochMs).LocalDateTime;
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d");
    }

    private async Task ToggleTheme() => await Theme.Toggle();

    private void OnSetupComplete()
    {
        showSetup = false;
        StateHasChanged();
    }

    public override void Dispose()
    {
        _updateTimer?.Dispose();
        base.Dispose();
    }
}
