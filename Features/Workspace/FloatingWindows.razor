
@inherits EventSubscriber
@inject WindowManager Wm
@inject IJSRuntime Js

@* Snap preview — positioned and shown/hidden by JS *@
<div id="c2-snap-preview"></div>

@* Floating windows *@
@foreach (var win in Wm.Windows)
{
    if (win.Minimized) continue;
    var w = win;
    var isFocused = IsTopWindow(w);
    <div @key="win.Id"
         data-win-id="@win.Id"
         data-panel="@win.Panel"
         data-agent-uuid="@win.AgentUuid"
         @(win.IsSnapped ? $"data-snap-zone={win.SnapZone}" : null)
         class="app-window @(win.Maximized ? "maximized" : "") @(isFocused ? "focused" : "unfocused")"
         style="@WindowStyle(win)">
        <div class="app-window-titlebar" style="touch-action:none;">
            <span class="app-window-icon"><C2Icon Name="@PanelIcon(win.Panel)" Size="Size.Xs" /></span>
            <span class="app-window-title">@win.Title</span>
            <div class="app-window-controls">
                <button class="app-window-btn minimize-btn" @onclick="() => OnMinimize(win)" @onpointerdown:stopPropagation="true" title="Minimize">
                    <svg width="10" height="10" viewBox="0 0 10 10"><line x1="2" y1="5" x2="8" y2="5" stroke="currentColor" stroke-width="1.5"/></svg>
                </button>
                <button class="app-window-btn maximize-btn" @onclick="() => OnMaximize(win)" @onpointerdown:stopPropagation="true" title="@(win.Maximized ? "Restore" : "Maximize")">
                    @if (win.Maximized)
                    {
                        <svg width="10" height="10" viewBox="0 0 10 10"><rect x="1.5" y="3" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M3.5 3V2.5a1 1 0 0 1 1-1H8a1 1 0 0 1 1 1V6a1 1 0 0 1-1 1h-.5" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                    }
                    else
                    {
                        <svg width="10" height="10" viewBox="0 0 10 10"><rect x="1.5" y="1.5" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                    }
                </button>
                <button class="app-window-btn close-btn" @onclick="async () => await OnClose(win)" @onpointerdown:stopPropagation="true" title="Close">
                    <svg width="10" height="10" viewBox="0 0 10 10"><line x1="2" y1="2" x2="8" y2="8" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="2" x2="2" y2="8" stroke="currentColor" stroke-width="1.5"/></svg>
                </button>
            </div>
        </div>
        <div class="app-window-body">
            @switch (win.Panel)
            {
                case "FileManager":       <FileManager Relay="win.Relay" AgentId="@win.AgentId" AgentName="@win.AgentName" AgentUuid="@win.AgentUuid" /> break;
                case "Settings":          <SettingsPanel /> break;
                case "Relay":             <RelayPanel /> break;
                case "Agents":            <AgentsPanel /> break;
                case "Downloads":         <DownloadsPanel AgentUuid="@win.AgentUuid" AgentName="@win.AgentName" /> break;
                case "FileSearch":        <FileSearchPanel AgentUuid="@win.AgentUuid" AgentName="@win.AgentName" InitialPath="@win.SearchPath" /> break;
                case "SearchJobs":        <SearchJobsPanel /> break;
                case "ExtensionGroups":   <ExtensionGroupsPanel /> break;
                case "AgentInfo":         <AgentInfoPanel AgentId="@win.AgentId" AgentUuid="@win.AgentUuid" /> break;
                case "Shell":            <ShellPanel Relay="win.Relay" AgentId="@win.AgentId" AgentName="@win.AgentName" AgentUuid="@win.AgentUuid" /> break;
                case "Vnc":              <VncPanel Relay="win.Relay" AgentId="@win.AgentId" AgentName="@win.AgentName" AgentUuid="@win.AgentUuid" /> break;
                case "PeParser":         <PeParserPanel /> break;
                case "Base64":           <Base64Panel /> break;
                case "LnkTool":          <LnkToolPanel /> break;
            }
        </div>
        @if (!win.Maximized)
        {
            @foreach (var edge in Edges)
            {
                <div class="app-window-resize-@edge.ToLower()" style="touch-action:none;"></div>
            }
        }
    </div>
}

@* Taskbar — always visible *@
<div class="mdi-taskbar">
    @foreach (var win in Wm.Windows)
    {
        var w = win;
        <button @key="win.Id"
                class="mdi-taskbar-item @(IsTopWindow(w) ? "active" : "") @(w.Minimized ? "minimized" : "")"
                @onclick="() => OnTaskbarClick(w)"
                @ondblclick:preventDefault="true"
                @ondblclick:stopPropagation="true">
            <C2Icon Name="@PanelIcon(win.Panel)" Size="Size.Xs" />
            <span class="mdi-taskbar-label">@win.Title</span>
        </button>
    }

    <div class="mdi-taskbar-spacer"></div>

    @* Window management dropdown *@
    <div class="taskbar-menu-wrapper" @onfocusout="OnTaskbarMenuFocusOut" tabindex="-1">
        <button class="mdi-taskbar-menu-btn" @onclick="ToggleTaskbarMenu" title="Window management">
            <C2Icon Name="grid" Size="Size.Xs" />
            <C2Icon Name="chevron-up" Size="Size.Xs" />
        </button>

        @if (_taskbarMenuOpen)
        {
            <div class="taskbar-dropdown">
                <div class="taskbar-dropdown-section">
                    <span class="taskbar-dropdown-label">Tile</span>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("grid-2x2")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="grid" Size="Size.Xs" /> 2 x 2
                    </button>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("grid-3x3")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="grid" Size="Size.Xs" /> 3 x 3
                    </button>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("grid-4x4")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="grid" Size="Size.Xs" /> 4 x 4
                    </button>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("side-by-side")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="columns" Size="Size.Xs" /> Side by Side
                    </button>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("stack")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="rows" Size="Size.Xs" /> Stack
                    </button>
                    <button class="taskbar-dropdown-item" @onclick='() => TileWindows("cascade")' disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="layers" Size="Size.Xs" /> Cascade
                    </button>
                </div>
                <div class="taskbar-dropdown-divider"></div>
                <div class="taskbar-dropdown-section">
                    <button class="taskbar-dropdown-item" @onclick="MinimizeAll" disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="minimize" Size="Size.Xs" /> Minimize All
                    </button>
                    <button class="taskbar-dropdown-item" @onclick="RestoreAll" disabled="@(Wm.Windows.Count == 0)">
                        <C2Icon Name="maximize" Size="Size.Xs" /> Restore All
                    </button>
                </div>
                <div class="taskbar-dropdown-divider"></div>
                <button class="taskbar-dropdown-item taskbar-dropdown-danger" @onclick="CloseAll" disabled="@(Wm.Windows.Count == 0)">
                    <C2Icon Name="x" Size="Size.Xs" /> Close All
                </button>
            </div>
        }
    </div>
</div>

@code {
    private double _vpWidth;
    private double _vpHeight;
    private DotNetObjectReference<FloatingWindows>? _dotnetRef;
    private HashSet<int> _registeredIds = new();

    private static readonly string[] Edges = ["n", "s", "e", "w", "nw", "ne", "sw", "se"];

    protected override void OnInitialized() => On<WindowChangedEvent>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("c2Windows.init", _dotnetRef);
        }

        // Sync window registry with JS
        var currentIds = new HashSet<int>(Wm.Windows.Select(w => w.Id));

        // Unregister removed windows
        foreach (var id in _registeredIds.Except(currentIds).ToList())
        {
            await Js.InvokeVoidAsync("c2Windows.unregisterWindow", id);
            _registeredIds.Remove(id);
        }

        // Register new windows
        foreach (var id in currentIds.Except(_registeredIds).ToList())
        {
            await Js.InvokeVoidAsync("c2Windows.registerWindow", id);
            _registeredIds.Add(id);
        }
    }

    // --- Window style (skipped during JS drag/resize — JS owns the DOM) ---

    private static string WindowStyle(WindowState win)
    {
        if (win.Maximized)
            return $"z-index:{win.ZIndex};";
        return $"left:{win.X}px;top:{win.Y}px;width:{win.Width}px;height:{win.Height}px;z-index:{win.ZIndex};";
    }

    // --- JSInvokable callbacks from windowManager.js ---

    [JSInvokable]
    public void OnViewportResize(double width, double height)
    {
        _vpWidth = width;
        _vpHeight = height;
        Wm.SetViewportSize(width, height);
    }

    [JSInvokable]
    public void OnDragEnd(int id, double x, double y)
    {
        Wm.UpdatePositionSilent(id, x, y);
    }

    [JSInvokable]
    public void OnResizeEnd(int id, double x, double y, double w, double h)
    {
        Wm.UpdateGeometrySilent(id, x, y, w, h);
    }

    [JSInvokable]
    public void OnSnapApplied(int id, double x, double y, double w, double h, string zone)
    {
        Wm.ApplySnap(id, x, y, w, h, zone);
    }

    [JSInvokable]
    public void OnBringToFront(int id)
    {
        var win = Wm.Windows.FirstOrDefault(w => w.Id == id);
        if (win is not null) Wm.BringToFront(win);
    }

    [JSInvokable]
    public void OnWindowAction(int id, string action)
    {
        var win = Wm.Windows.FirstOrDefault(w => w.Id == id);
        if (win is null) return;

        switch (action)
        {
            case "toggle-maximize":
                Wm.ToggleMaximize(win);
                _ = Js.InvokeVoidAsync("c2Windows.setMaximized", id, win.Maximized);
                if (!win.Maximized)
                    _ = Js.InvokeVoidAsync("c2Windows.applyPosition", id, win.X, win.Y, win.Width, win.Height, true);
                break;
            case "maximize":
                if (!win.Maximized) Wm.ToggleMaximize(win);
                _ = Js.InvokeVoidAsync("c2Windows.setMaximized", id, true);
                break;
            case "restore":
                if (win.IsSnapped) Wm.ClearSnap(id);
                else if (win.Maximized) Wm.ToggleMaximize(win);
                _ = Js.InvokeVoidAsync("c2Windows.setMaximized", id, false);
                if (!win.IsSnapped && !win.Maximized)
                    _ = Js.InvokeVoidAsync("c2Windows.applyPosition", id, win.X, win.Y, win.Width, win.Height, true);
                break;
        }
    }

    [JSInvokable]
    public void OnTileApplied(string layout, int[] ids, double[] xs, double[] ys, double[] ws, double[] hs)
    {
        Wm.ApplyTilePositions(ids, xs, ys, ws, hs);
    }

    // --- UI event handlers (discrete clicks — fine for Blazor) ---

    private bool IsTopWindow(WindowState win)
    {
        if (win.Minimized) return false;
        var visible = Wm.Windows.Where(w => !w.Minimized).ToList();
        return visible.Count > 0 && visible.MaxBy(w => w.ZIndex) == win;
    }

    private static string PanelIcon(string panel) => panel switch
    {
        "Agents" => "agents",
        "Relay" => "server",
        "Settings" => "settings",
        "FileManager" => "folder",
        "Downloads" => "download",
        "FileSearch" => "search",
        "SearchJobs" => "search",
        "ExtensionGroups" => "layers",
        "Shell" => "terminal",
        "Vnc" => "monitor",
        "PeParser" => "file-code",
        "Base64" => "code",
        "LnkTool" => "link",
        _ => "monitor"
    };

    private void OnTaskbarClick(WindowState win)
    {
        if (win.Minimized)
        {
            win.Minimized = false;
            Wm.BringToFront(win);
            _ = Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, false);
        }
        else if (IsTopWindow(win))
        {
            Wm.ToggleMinimize(win);
            _ = Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, true);
        }
        else
        {
            Wm.BringToFront(win);
        }
    }

    private void OnMinimize(WindowState win)
    {
        Wm.ToggleMinimize(win);
        _ = Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, win.Minimized);
    }

    private void OnMaximize(WindowState win)
    {
        Wm.ToggleMaximize(win);
        _ = Js.InvokeVoidAsync("c2Windows.setMaximized", win.Id, win.Maximized);
        if (!win.Maximized)
            _ = Js.InvokeVoidAsync("c2Windows.applyPosition", win.Id, win.X, win.Y, win.Width, win.Height, true);
    }

    // --- Taskbar menu ---
    private bool _taskbarMenuOpen;

    private void ToggleTaskbarMenu() => _taskbarMenuOpen = !_taskbarMenuOpen;

    private async void OnTaskbarMenuFocusOut()
    {
        await Task.Delay(200);
        await InvokeAsync(() => { _taskbarMenuOpen = false; StateHasChanged(); });
    }

    private async Task TileWindows(string layout)
    {
        _taskbarMenuOpen = false;
        // Restore minimized windows first so they participate in tiling
        foreach (var win in Wm.Windows.Where(w => w.Minimized))
        {
            win.Minimized = false;
            await Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, false);
        }
        var ids = Wm.Windows.Select(w => w.Id).ToArray();
        var tiles = await Js.InvokeAsync<TilePosition[]>("c2Windows.tileWindows", layout, ids);
        // Update model synchronously before Blazor re-renders
        if (tiles is { Length: > 0 })
            Wm.ApplyTilePositions(
                tiles.Select(t => t.Id).ToArray(),
                tiles.Select(t => t.X).ToArray(),
                tiles.Select(t => t.Y).ToArray(),
                tiles.Select(t => t.W).ToArray(),
                tiles.Select(t => t.H).ToArray());
    }

    private record TilePosition(int Id, double X, double Y, double W, double H);

    private void MinimizeAll()
    {
        _taskbarMenuOpen = false;
        foreach (var win in Wm.Windows.Where(w => !w.Minimized))
        {
            Wm.ToggleMinimize(win);
            _ = Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, true);
        }
    }

    private void RestoreAll()
    {
        _taskbarMenuOpen = false;
        foreach (var win in Wm.Windows.Where(w => w.Minimized).ToList())
        {
            Wm.ToggleMinimize(win);
            _ = Js.InvokeVoidAsync("c2Windows.setMinimized", win.Id, false);
        }
    }

    private async Task CloseAll()
    {
        _taskbarMenuOpen = false;
        foreach (var win in Wm.Windows.ToList())
        {
            await Js.InvokeVoidAsync("c2Windows.animateClose", win.Id);
            _registeredIds.Remove(win.Id);
        }
        await Wm.CloseAllWindows();
    }

    private async Task OnClose(WindowState win)
    {
        await Js.InvokeVoidAsync("c2Windows.animateClose", win.Id);
        _registeredIds.Remove(win.Id);
        await Wm.CloseWindow(win);
    }

    public override void Dispose()
    {
        _dotnetRef?.Dispose();
        _ = Js.InvokeVoidAsync("c2Windows.dispose");
        base.Dispose();
    }
}
