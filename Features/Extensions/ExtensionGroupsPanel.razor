@inherits EventSubscriber
@inject ExtensionGroupStore Store
@inject MessageService Msg

<PanelLayout Title="Extension Groups">
    <HeaderRight>
        <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="ShowAddForm">ADD GROUP</C2Btn>
    </HeaderRight>
    <Body>
        @if (showForm)
        {
            <div class="eg-form">
                <div class="eg-form-row">
                    <label class="eg-label">Group Name</label>
                    <C2Input @bind-Value="formName" Placeholder="e.g. Audio" />
                </div>
                <div class="eg-form-row">
                    <label class="eg-label">Extensions (comma-separated)</label>
                    <C2Input @bind-Value="formExtensions" Placeholder=".mp3,.wav,.flac,.ogg" Monospace />
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="eg-form-error">@formError</div>
                }
                <div class="eg-form-actions">
                    <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="SaveGroup" Disabled="@saving" Loading="@saving">
                        @(editingGroup is not null ? "UPDATE" : "ADD")
                    </C2Btn>
                    <C2Btn Size="Size.Xs" OnClick="CancelForm">CANCEL</C2Btn>
                </div>
            </div>
        }

        @if (Store.Groups.Count == 0)
        {
            <div class="panel-empty">
                No extension groups configured.
                <C2Btn Variant="BtnVariant.Primary" Size="Size.Xs" OnClick="SeedDefaults" Disabled="@saving">LOAD DEFAULTS</C2Btn>
            </div>
        }
        else
        {
            <div class="eg-table-wrap">
                <table class="eg-table">
                    <thead>
                        <tr>
                            <th class="eg-col-toggle"></th>
                            <th class="eg-col-name">Name</th>
                            <th class="eg-col-exts">Extensions</th>
                            <th class="eg-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in Store.Groups)
                        {
                            var g = group;
                            <tr class="@(!g.Enabled ? "eg-row-disabled" : "")">
                                <td class="eg-col-toggle">
                                    <input type="checkbox" checked="@g.Enabled" @onchange="() => ToggleEnabled(g)" />
                                </td>
                                <td class="eg-col-name">@g.Name</td>
                                <td class="eg-col-exts"><span class="eg-exts-text">@g.Extensions</span></td>
                                <td class="eg-col-actions">
                                    <div class="eg-actions">
                                        <C2Btn Size="Size.Xs" OnClick="() => EditGroup(g)" Title="Edit">EDIT</C2Btn>
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Danger" OnClick="() => RemoveGroup(g)" Title="Remove">&#x2715;</C2Btn>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Body>
</PanelLayout>

@code {
    private bool showForm;
    private bool saving;
    private string formName = "";
    private string formExtensions = "";
    private string formError = "";
    private ExtensionGroup? editingGroup;

    protected override async Task OnInitializedAsync()
    {
        On<ExtensionGroupStoreChangedEvent>();
        await Store.LoadAsync();
    }

    private void ShowAddForm()
    {
        editingGroup = null;
        formName = "";
        formExtensions = "";
        formError = "";
        showForm = true;
    }

    private void EditGroup(ExtensionGroup group)
    {
        editingGroup = group;
        formName = group.Name;
        formExtensions = group.Extensions;
        formError = "";
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingGroup = null;
        formError = "";
    }

    private async Task SaveGroup()
    {
        var name = formName.Trim();
        if (string.IsNullOrEmpty(name))
        {
            formError = "Group name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formExtensions))
        {
            formError = "At least one extension is required.";
            return;
        }

        var normalized = ExtensionGroupStore.NormalizeExtensions(formExtensions);
        var invalid = ExtensionGroupStore.GetInvalidExtensions(normalized);
        if (invalid.Count > 0)
        {
            formError = $"Invalid: {string.Join(", ", invalid)} — must be a dot followed by 1-15 alphanumeric characters.";
            return;
        }

        // Check duplicate name when adding new
        if (editingGroup is null && Store.Groups.Any(g => g.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            formError = $"A group named '{name}' already exists.";
            return;
        }

        saving = true;
        StateHasChanged();
        try
        {
            if (editingGroup is not null && editingGroup.Name != name)
            {
                // Name changed — remove old, add new
                await Store.RemoveAsync(editingGroup.Name);
            }
            await Store.AddAsync(name, normalized, editingGroup?.Enabled ?? true);
            showForm = false;
            editingGroup = null;
            formError = "";
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { saving = false; }
    }

    private async Task ToggleEnabled(ExtensionGroup group)
    {
        group.Enabled = !group.Enabled;
        await Store.UpdateAsync(group);
    }

    private async Task RemoveGroup(ExtensionGroup group)
    {
        await Store.RemoveAsync(group.Name);
    }

    private async Task SeedDefaults()
    {
        saving = true;
        StateHasChanged();
        try
        {
            await Store.SeedDefaultsAsync();
        }
        catch (Exception ex) { Msg.Error(ex.Message); }
        finally { saving = false; }
    }

    public override void Dispose() => base.Dispose();
}
