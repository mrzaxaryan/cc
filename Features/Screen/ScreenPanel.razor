@using C2.Features.Relay
@inherits EventSubscriber
@inject MessageService Msg
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="screen-root" @ref="_rootEl">
    @if (!_screen.IsConnected)
    {
        <div class="screen-overlay">
            <span class="status-dot dot-off"></span>
            <span>Agent disconnected</span>
        </div>
    }
    else if (_screen.IsLoadingDisplays)
    {
        <div class="screen-overlay">
            <C2Spinner Size="Size.Sm" />
            <span>Enumerating displays…</span>
        </div>
    }
    else if (_screen.Displays.Length == 0)
    {
        <div class="screen-overlay">
            <span>No displays detected</span>
        </div>
    }

    <div class="screen-canvas-wrap" @onclick="FocusCanvas">
        <canvas @ref="_canvasEl"></canvas>
    </div>

    <div class="screen-toolbar">
        @* Drag handle *@
        <div class="screen-drag-handle" title="Drag to move">
            <svg width="6" height="10" viewBox="0 0 6 10"><circle cx="1" cy="1" r="1" fill="currentColor"/><circle cx="5" cy="1" r="1" fill="currentColor"/><circle cx="1" cy="5" r="1" fill="currentColor"/><circle cx="5" cy="5" r="1" fill="currentColor"/><circle cx="1" cy="9" r="1" fill="currentColor"/><circle cx="5" cy="9" r="1" fill="currentColor"/></svg>
        </div>

        <div class="screen-toolbar-group">
            <span class="screen-dot @(_screen.IsConnected ? "screen-dot--on" : "screen-dot--off")"></span>
            @if (SelectedDisplay is not null)
            {
                <span class="screen-info">@(SelectedDisplay.Width)x@(SelectedDisplay.Height)</span>
            }
            @if (_screen.IsStreaming)
            {
                <span class="screen-info screen-info--accent">@(_screen.Fps) fps</span>
            }
            <select class="screen-select" @onchange="OnDisplayChanged" disabled="@(_screen.Displays.Length == 0)" title="Display">
                @if (_screen.Displays.Length == 0)
                {
                    <option>No displays</option>
                }
                else
                {
                    @foreach (var d in _screen.Displays)
                    {
                        <option value="@d.Index" selected="@(d.Index == _screen.SelectedDisplay)">@d.Label</option>
                    }
                }
            </select>
            <select class="screen-select" @onchange="OnQualityChanged" title="Quality">
                @foreach (var q in QualityPresets)
                {
                    <option value="@q.Value" selected="@(_screen.Quality == q.Value)">@q.Label</option>
                }
            </select>
            <select class="screen-select" @onchange="OnScaleModeChanged" title="Scaling">
                @foreach (var m in ScaleModes)
                {
                    <option value="@m.Value" selected="@(_scaleMode == m.Value)">@m.Label</option>
                }
            </select>
        </div>

        <div class="screen-toolbar-group">
            @if (!_screen.IsStreaming)
            {
                <button class="screen-btn" @onclick="CaptureOnce" disabled="@(!_screen.IsConnected || _screen.IsCapturing || _screen.Displays.Length == 0)" title="Capture single frame">
                    @if (_screen.IsCapturing)
                    {
                        <C2Spinner Size="Size.Xs" />
                    }
                    else
                    {
                        <C2Icon Name="camera" Size="Size.Xs" />
                    }
                </button>
                <button class="screen-btn screen-btn--stream" @onclick="StartStreaming" disabled="@(!_screen.IsConnected || _screen.Displays.Length == 0)" title="Start streaming">
                    <C2Icon Name="play" Size="Size.Xs" />
                </button>
            }
            else
            {
                <button class="screen-btn screen-btn--stop" @onclick="StopStreaming" title="Stop streaming">
                    <C2Icon Name="square" Size="Size.Xs" />
                </button>
            }
            <button class="screen-btn" @onclick="RefreshDisplays" disabled="@(!_screen.IsConnected || _screen.IsLoadingDisplays)" title="Refresh displays">
                <C2Icon Name="refresh" Size="Size.Xs" />
            </button>
            <button class="screen-btn" @onclick="ToggleFullscreen" title="Toggle fullscreen">
                <C2Icon Name="@(_isFullscreen ? "exit-fullscreen" : "fullscreen")" Size="Size.Xs" />
            </button>
        </div>

    </div>
</div>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private ScreenService _screen = null!;
    private ElementReference _canvasEl;
    private ElementReference _rootEl;
    private DotNetObjectReference<ScreenPanel>? _dotnetRef;
    private readonly string _sessionId = Guid.NewGuid().ToString("N")[..8];
    private bool _jsInitialized;
    private bool _isFullscreen;
    private string _scaleMode = "stretch";
    private RelaySocket? _prevRelay;

    private static readonly (string Label, uint Value)[] QualityPresets =
    [
        ("Low", 25),
        ("Medium", 50),
        ("High", 75),
        ("Max", 95)
    ];

    private static readonly (string Label, string Value)[] ScaleModes =
    [
        ("Stretch", "stretch"),
        ("Fit", "fit"),
        ("Fill", "fill")
    ];

    private DisplayInfo? SelectedDisplay =>
        _screen.Displays.Length > 0 && _screen.SelectedDisplay < _screen.Displays.Length
            ? _screen.Displays[_screen.SelectedDisplay]
            : null;

    protected override void OnInitialized()
    {
        InitScreenService();

        On<AgentOnlineEvent>(e =>
        {
            if (e.Uuid != AgentUuid) return;
            if (_screen.IsConnected)
                _ = InvokeAsync(async () => await _screen.FetchDisplaysAsync());
        });

        // Relay may have been reconnected — re-render to pick up new connection state
        On<WindowChangedEvent>();
    }

    protected override async Task OnInitializedAsync()
    {
        if (_screen.IsConnected)
            await _screen.FetchDisplaysAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Relay != _prevRelay && Relay is { IsConnected: true })
        {
            // Relay changed (agent reconnected) — recreate service with new relay
            ReplaceScreenService();
            await _screen.FetchDisplaysAsync();
        }
        _prevRelay = Relay;
    }

    private void InitScreenService()
    {
        if (Relay is null) return;
        _screen = new ScreenService(Relay, Msg);
        _screen.StateChanged += OnScreenStateChanged;
        _screen.FrameReady += OnFrame;
        _screen.StreamingChanged += OnStreamingChanged;
        _prevRelay = Relay;
    }

    private void ReplaceScreenService()
    {
        _screen.StateChanged -= OnScreenStateChanged;
        _screen.FrameReady -= OnFrame;
        _screen.StreamingChanged -= OnStreamingChanged;
        _screen.Dispose();
        InitScreenService();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("c2Screen.init", _sessionId, _rootEl, _canvasEl, _dotnetRef);
            _jsInitialized = true;
        }
    }

    // --- Frame rendering via JS interop (single call per frame) ---

    private async Task OnFrame(bool isFullFrame, ScreenSection[] sections)
    {
        if (!_jsInitialized) return;

        // Build a flat array of section descriptors for JS: [{x, y, data}, ...]
        var jsSections = new object[sections.Length];
        for (var i = 0; i < sections.Length; i++)
            jsSections[i] = new { x = sections[i].X, y = sections[i].Y, data = sections[i].JpegData };

        await Js.InvokeVoidAsync("c2Screen.renderFrame", _sessionId, isFullFrame, jsSections);
    }

    private void OnStreamingChanged(bool streaming)
    {
        if (_jsInitialized)
            _ = Js.InvokeVoidAsync("c2Screen.setStreaming", _sessionId, streaming);
    }

    // --- UI event handlers ---

    private async Task CaptureOnce() => await _screen.CaptureOnceAsync();

    private async Task StartStreaming() => await _screen.StartStreamingAsync();

    private void StopStreaming() => _screen.StopStreaming();

    private async Task RefreshDisplays()
    {
        _screen.ResetFrame();
        await _screen.FetchDisplaysAsync();
    }

    private async Task ToggleFullscreen()
    {
        if (!_jsInitialized) return;
        await Js.InvokeVoidAsync("c2Screen.toggleFullscreen", _sessionId);
        _isFullscreen = !_isFullscreen;
    }

    private async Task FocusCanvas()
    {
        if (_jsInitialized)
            await Js.InvokeVoidAsync("c2Screen.focus", _sessionId);
    }

    private void OnDisplayChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _screen.Displays.Length)
        {
            _screen.SelectedDisplay = idx;
            _screen.ResetFrame();
        }
    }

    private void OnQualityChanged(ChangeEventArgs e)
    {
        if (uint.TryParse(e.Value?.ToString(), out var q))
        {
            _screen.Quality = q;
            _screen.ResetFrame();
        }
    }

    private void OnScaleModeChanged(ChangeEventArgs e)
    {
        var mode = e.Value?.ToString();
        if (mode is "stretch" or "fit" or "fill")
        {
            _scaleMode = mode;
            if (_jsInitialized)
                _ = Js.InvokeVoidAsync("c2Screen.setScaleMode", _sessionId, mode);
        }
    }

    private async void OnScreenStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    // --- Mouse/keyboard events from JS ---

    [JSInvokable]
    public void OnMouseEvent(string action, int x, int y, int button)
    {
    }

    [JSInvokable]
    public void OnWheelEvent(int x, int y, int delta)
    {
    }

    [JSInvokable]
    public void OnKeyEvent(string action, string key, string code,
        bool ctrl, bool shift, bool alt, bool meta)
    {
    }

    // --- Cleanup ---

    public new void Dispose()
    {
        _screen.StateChanged -= OnScreenStateChanged;
        _screen.FrameReady -= OnFrame;
        _screen.StreamingChanged -= OnStreamingChanged;
        _screen.Dispose();
        base.Dispose();
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (_jsInitialized)
            try { await Js.InvokeVoidAsync("c2Screen.dispose", _sessionId); } catch { }
        _dotnetRef?.Dispose();
    }
}
