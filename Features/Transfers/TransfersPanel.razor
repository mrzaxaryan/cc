@inherits EventSubscriber
@inject TransferStore Transfers
@inject AgentStore AgentDb
@inject MessageService Msg
@inject WindowManager Wm
@inject IJSRuntime Js

<PanelLayout Title="Upload Manager">
    <HeaderLeft>
        @if (!string.IsNullOrEmpty(AgentName))
        {
            <span class="panel-agent-label">@AgentName</span>
        }
    </HeaderLeft>
    <HeaderRight>
        @if (HasActiveSyncs)
        {
            <C2Btn Variant="BtnVariant.Warning" Size="Size.Xs" OnClick="StopAllSyncs" Title="Pause all">STOP ALL</C2Btn>
        }
        @if (activeRecords.Count > 0)
        {
            @if (confirmClear)
            {
                <C2Btn Variant="BtnVariant.DangerSolid" Size="Size.Xs" OnClick="ClearPaused">YES</C2Btn>
                <C2Btn Size="Size.Xs" OnClick="() => confirmClear = false">NO</C2Btn>
            }
            else
            {
                <C2Btn Variant="BtnVariant.Danger" Size="Size.Xs" OnClick="() => confirmClear = true" Title="Clear paused/failed">CLEAR</C2Btn>
            }
        }
        <C2Btn Size="Size.Xs" OnClick="Refresh" Title="Refresh"><C2Icon Name="refresh" Size="Size.Xs" /></C2Btn>
    </HeaderRight>
    <Toolbar>
        <div class="panel-tabs">
            <button class="panel-tab @(filter == Filter.All ? "active" : "")" @onclick="() => SetFilter(Filter.All)">
                All <span class="panel-tab-count">@activeRecords.Count</span>
            </button>
            <button class="panel-tab @(filter == Filter.Active ? "active" : "")" @onclick="() => SetFilter(Filter.Active)">
                Active <span class="panel-tab-count">@CountByFilter(Filter.Active)</span>
            </button>
            <button class="panel-tab @(filter == Filter.Paused ? "active" : "")" @onclick="() => SetFilter(Filter.Paused)">
                Paused <span class="panel-tab-count">@CountByFilter(Filter.Paused)</span>
            </button>
            <button class="panel-tab @(filter == Filter.Done ? "active" : "")" @onclick="() => SetFilter(Filter.Done)">
                Done <span class="panel-tab-count">@CountByFilter(Filter.Done)</span>
            </button>
        </div>
    </Toolbar>
    <Body>
        @if (filteredRecords.Count == 0)
        {
            <div class="panel-empty">
                @if (activeRecords.Count == 0)
                {
                    <span>No active syncs</span>
                }
                else
                {
                    <span>No @filter.ToString().ToLower() items</span>
                }
            </div>
        }
        else
        {
            <div class="sm-list">
                @foreach (var dl in filteredRecords)
                {
                    var rec = dl;
                    var pct = dl.TotalSize > 0 ? (int)(dl.DownloadedSize * 100 / dl.TotalSize) : 0;
                    <div class="sm-item @StatusClass(dl.Status)"
                         @oncontextmenu="(ev) => ShowContextMenu(ev, rec)"
                         @oncontextmenu:preventDefault>
                        <div class="sm-item-row">
                            <span class="sm-item-icon" title="@StatusLabel(dl.Status)"><C2Icon Name="@StatusIcon(dl.Status)" Size="Size.Xs" /></span>
                            <div class="sm-item-info">
                                <span class="sm-item-name" title="@dl.RemotePath">@dl.FileName</span>
                                <span class="sm-item-meta">
                                    @Formatters.FormatSize((ulong)dl.DownloadedSize) / @Formatters.FormatSize((ulong)dl.TotalSize)
                                    @if (!string.IsNullOrEmpty(dl.AgentName) && string.IsNullOrEmpty(AgentUuid))
                                    {
                                        <span class="sm-item-agent">@dl.AgentName</span>
                                    }
                                </span>
                            </div>
                            <div class="sm-item-status">
                                @switch (dl.Status)
                                {
                                    case TransferStatus.Downloading:
                                        <span class="sm-pct">@pct%</span>
                                        @if (dl.SpeedBytesPerSec > 0)
                                        {
                                            <span class="sm-speed">@Formatters.FormatSpeed(dl.SpeedBytesPerSec)</span>
                                        }
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseDownload(rec)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                        break;

                                    case TransferStatus.Pending:
                                        <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">PENDING</C2Badge>
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseQueued(rec)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                        break;

                                    case TransferStatus.Queued:
                                        <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">QUEUED</C2Badge>
                                        <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => BumpPriority(rec, -1)" Title="Higher priority"><C2Icon Name="chevron-up" Size="Size.Xs" /></C2Btn>
                                        <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => BumpPriority(rec, 1)" Title="Lower priority"><C2Icon Name="chevron-down" Size="Size.Xs" /></C2Btn>
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Warning" OnClick="() => PauseQueued(rec)" Title="Pause"><C2Icon Name="pause" Size="Size.Xs" /></C2Btn>
                                        break;

                                    case TransferStatus.Paused:
                                        <C2Badge Variant="BadgeVariant.Warning" Size="Size.Xs">PAUSED @pct%</C2Badge>
                                        <C2Btn Size="Size.Xs" Variant="BtnVariant.Success" OnClick="() => ResumeDownload(rec)" Disabled="@(Transfers.Cts.HasActive(rec.Id))" Title="Resume"><C2Icon Name="play" Size="Size.Xs" /></C2Btn>
                                        break;

                                    case TransferStatus.Completed:
                                        <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs">DONE</C2Badge>
                                        break;

                                    case TransferStatus.Failed:
                                        <C2Badge Variant="BadgeVariant.Danger" Size="Size.Xs" Title="@dl.Error">FAILED</C2Badge>
                                        break;
                                }
                                <C2Btn Size="Size.Icon" Variant="BtnVariant.Ghost" OnClick="() => RemoveDownload(rec)" Title="Remove" CssClass="panel-remove-btn"><C2Icon Name="x" Size="Size.Xs" /></C2Btn>
                            </div>
                        </div>
                        @if (dl.Status is TransferStatus.Downloading or TransferStatus.Queued or TransferStatus.Pending or TransferStatus.Paused)
                        {
                            <C2Progress Size="Size.Xs" Variant="@ProgressVariant(dl.Status)" Percent="@pct" />
                        }
                    </div>
                }
            </div>
        }
    </Body>
</PanelLayout>

<C2Dropdown Visible="@ctxVisible" X="@ctxX" Y="@ctxY" OnClose="HideContextMenu">
    <C2DropdownItem OnClick="CtxOpenFileSystem"><C2Icon Name="folder" Size="Size.Xs" /> Open in File System</C2DropdownItem>
    @if (ctxRec is not null)
    {
        <div class="ap-ctx-submenu-wrap">
            <button class="ap-ctx-sub-trigger" type="button">
                <span class="ap-ctx-sub-label"><C2Icon Name="copy" Size="Size.Xs" /> Copy</span>
                <span class="ap-ctx-arrow"><C2Icon Name="chevron-right" Size="Size.Xs" /></span>
            </button>
            <div class="ap-ctx-submenu">
                <C2DropdownItem OnClick="() => CtxCopy(ctxRec.FileName)" CssClass="ap-ctx-copy-item">File Name</C2DropdownItem>
                <C2DropdownItem OnClick="() => CtxCopy(ctxRec.RemotePath)" CssClass="ap-ctx-copy-item">Remote Path</C2DropdownItem>
                @if (!string.IsNullOrEmpty(ctxRec.AgentName))
                {
                    <C2DropdownItem OnClick="() => CtxCopy(ctxRec.AgentName)" CssClass="ap-ctx-copy-item">Agent Name</C2DropdownItem>
                }
            </div>
        </div>
    }
</C2Dropdown>

@code {
    [Parameter] public string? AgentUuid { get; set; }
    [Parameter] public string? AgentName { get; set; }

    private enum Filter { All, Active, Paused, Done }

    private List<TransferRecord> activeRecords = new();
    private List<TransferRecord> filteredRecords = new();
    private Filter filter = Filter.All;
    private bool confirmClear;

    private bool ctxVisible;
    private double ctxX;
    private double ctxY;
    private TransferRecord? ctxRec;

    protected override async Task OnInitializedAsync()
    {
        On<TransferStoreChangedEvent>(e => Refresh());
        await AgentDb.LoadAsync();
        await Transfers.LoadAsync();
        Refresh();
    }

    private bool HasActiveSyncs =>
        activeRecords.Any(r => r.Status is TransferStatus.Downloading or TransferStatus.Queued or TransferStatus.Pending);

    private void SetFilter(Filter f) { filter = f; ApplyFilter(); }

    private void ApplyFilter()
    {
        filteredRecords = filter switch
        {
            Filter.Active => activeRecords.Where(r => r.Status is TransferStatus.Downloading or TransferStatus.Queued or TransferStatus.Pending).ToList(),
            Filter.Paused => activeRecords.Where(r => r.Status is TransferStatus.Paused or TransferStatus.Failed).ToList(),
            Filter.Done => activeRecords.Where(r => r.Status == TransferStatus.Completed).ToList(),
            _ => activeRecords.ToList()
        };
    }

    private int CountByFilter(Filter f) => f switch
    {
        Filter.Active => activeRecords.Count(r => r.Status is TransferStatus.Downloading or TransferStatus.Queued or TransferStatus.Pending),
        Filter.Paused => activeRecords.Count(r => r.Status is TransferStatus.Paused or TransferStatus.Failed),
        Filter.Done => activeRecords.Count(r => r.Status == TransferStatus.Completed),
        _ => activeRecords.Count
    };

    private static string StatusIcon(string s) => s switch
    {
        TransferStatus.Downloading => "dot",
        TransferStatus.Pending => "dot-outline",
        TransferStatus.Queued => "dot-outline",
        TransferStatus.Paused => "stop",
        TransferStatus.Completed => "check",
        TransferStatus.Failed => "x",
        _ => "dot-outline"
    };

    private static string StatusLabel(string s) => s switch
    {
        TransferStatus.Downloading => "Downloading",
        TransferStatus.Pending => "Pending",
        TransferStatus.Queued => "Queued",
        TransferStatus.Paused => "Paused",
        TransferStatus.Completed => "Completed",
        TransferStatus.Failed => "Failed",
        _ => ""
    };

    private static string StatusClass(string s) => s switch
    {
        TransferStatus.Downloading => "sm-item-active",
        TransferStatus.Completed => "sm-item-done",
        TransferStatus.Failed => "sm-item-failed",
        _ => ""
    };

    private static ProgressVariant ProgressVariant(string s) => s switch
    {
        TransferStatus.Downloading => C2.Shared.ProgressVariant.Info,
        TransferStatus.Paused => C2.Shared.ProgressVariant.Warning,
        _ => C2.Shared.ProgressVariant.Muted
    };

    private async Task StopAllSyncs()
    {
        var active = activeRecords.FirstOrDefault(r => r.Status == TransferStatus.Downloading);
        if (active is not null) Transfers.Cts.Cancel(active.Id);
        var queued = activeRecords.Where(r => r.Status is TransferStatus.Queued or TransferStatus.Pending).ToList();
        foreach (var dl in queued) await Transfers.PauseAsync(dl.Id);
    }

    private void Refresh()
    {
        var all = Transfers.GetActive();
        activeRecords = string.IsNullOrEmpty(AgentUuid) ? all : all.Where(r => r.AgentUuid == AgentUuid).ToList();
        activeRecords = activeRecords
            .OrderBy(r => r.Status == TransferStatus.Downloading ? 0 : r.Status == TransferStatus.Queued ? 1 : r.Status == TransferStatus.Pending ? 1 : r.Status == TransferStatus.Paused ? 2 : r.Status == TransferStatus.Failed ? 3 : 4)
            .ThenBy(r => r.Priority)
            .ThenBy(r => r.CreatedAt)
            .ToList();
        ApplyFilter();
    }

    private async Task BumpPriority(TransferRecord dl, int delta) => await Transfers.SetPriorityAsync(dl.Id, dl.Priority + delta);
    private void PauseDownload(TransferRecord dl) => Transfers.Cts.Cancel(dl.Id);
    private async Task PauseQueued(TransferRecord dl) => await Transfers.PauseAsync(dl.Id);

    private async Task ResumeDownload(TransferRecord dl)
    {
        if (Transfers.Cts.HasActive(dl.Id)) return;
        await Transfers.QueueAsync(dl.Id);
    }

    private async Task RemoveDownload(TransferRecord dl) { Transfers.Cts.Cancel(dl.Id); await Transfers.RemoveAsync(dl.Id); }

    private async Task ClearPaused()
    {
        confirmClear = false;
        var toRemove = activeRecords.Where(r => r.Status is TransferStatus.Paused or TransferStatus.Failed).ToList();
        foreach (var dl in toRemove) await Transfers.RemoveAsync(dl.Id);
    }

    private void ShowContextMenu(MouseEventArgs e, TransferRecord rec)
    {
        ctxX = e.ClientX;
        ctxY = e.ClientY;
        ctxRec = rec;
        ctxVisible = true;
    }

    private void HideContextMenu() => ctxVisible = false;

    private async Task CtxCopy(string value)
    {
        HideContextMenu();
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", value);
    }

    private void CtxOpenFileSystem()
    {
        HideContextMenu();
        if (ctxRec is null) return;
        var agentId = ctxRec.AgentUuid;
        var dir = GetDirectory(ctxRec.RemotePath);
        Wm.OpenAgentWindow("FileSystem", agentId, agentName: ctxRec.AgentName, agentUuid: ctxRec.AgentUuid, searchPath: dir);
    }

    private static string? GetDirectory(string? path)
    {
        if (string.IsNullOrEmpty(path)) return null;
        var sep = path.Contains('\\') ? '\\' : '/';
        var idx = path.LastIndexOf(sep);
        return idx > 0 ? path[..idx] + sep : null;
    }

    public override void Dispose() => base.Dispose();
}
