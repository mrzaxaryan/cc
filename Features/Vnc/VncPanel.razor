@using C2.Features.Relay
@inherits EventSubscriber
@inject MessageService Msg
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="vnc-root" @ref="_rootEl">
    @if (!_vnc.IsConnected)
    {
        <div class="vnc-overlay">
            <span class="status-dot dot-off"></span>
            <span>Agent disconnected</span>
        </div>
    }
    else if (_vnc.IsLoadingDisplays)
    {
        <div class="vnc-overlay">
            <C2Spinner Size="Size.Sm" />
            <span>Enumerating displays…</span>
        </div>
    }
    else if (_vnc.Displays.Length == 0)
    {
        <div class="vnc-overlay">
            <span>No displays detected</span>
        </div>
    }

    <div class="vnc-canvas-wrap" @onclick="FocusCanvas">
        <canvas @ref="_canvasEl"></canvas>
    </div>

    <div class="vnc-toolbar">
        @* Drag handle *@
        <div class="vnc-drag-handle" title="Drag to move">
            <svg width="6" height="10" viewBox="0 0 6 10"><circle cx="1" cy="1" r="1" fill="currentColor"/><circle cx="5" cy="1" r="1" fill="currentColor"/><circle cx="1" cy="5" r="1" fill="currentColor"/><circle cx="5" cy="5" r="1" fill="currentColor"/><circle cx="1" cy="9" r="1" fill="currentColor"/><circle cx="5" cy="9" r="1" fill="currentColor"/></svg>
        </div>

        <div class="vnc-toolbar-group">
            <span class="vnc-dot @(_vnc.IsConnected ? "vnc-dot--on" : "vnc-dot--off")"></span>
            @if (SelectedDisplay is not null)
            {
                <span class="vnc-info">@(SelectedDisplay.Width)x@(SelectedDisplay.Height)</span>
            }
            @if (_vnc.IsStreaming)
            {
                <span class="vnc-info vnc-info--accent">@(_vnc.Fps) fps</span>
            }
        </div>

        <div class="vnc-toolbar-group">
            @if (!_vnc.IsStreaming)
            {
                <button class="vnc-btn" @onclick="CaptureOnce" disabled="@(!_vnc.IsConnected || _vnc.IsCapturing || _vnc.Displays.Length == 0)" title="Capture single frame">
                    @if (_vnc.IsCapturing)
                    {
                        <C2Spinner Size="Size.Xs" />
                    }
                    else
                    {
                        <C2Icon Name="camera" Size="Size.Xs" />
                    }
                </button>
                <button class="vnc-btn vnc-btn--stream" @onclick="StartStreaming" disabled="@(!_vnc.IsConnected || _vnc.Displays.Length == 0)" title="Start streaming">
                    <C2Icon Name="play" Size="Size.Xs" />
                </button>
            }
            else
            {
                <button class="vnc-btn vnc-btn--stop" @onclick="StopStreaming" title="Stop streaming">
                    <C2Icon Name="square" Size="Size.Xs" />
                </button>
            }
            <button class="vnc-btn" @onclick="RefreshDisplays" disabled="@(!_vnc.IsConnected || _vnc.IsLoadingDisplays)" title="Refresh displays">
                <C2Icon Name="refresh" Size="Size.Xs" />
            </button>
            <button class="vnc-btn" @onclick="ToggleFullscreen" title="Toggle fullscreen">
                <C2Icon Name="maximize" Size="Size.Xs" />
            </button>
        </div>

        @* Settings popover *@
        <div class="vnc-toolbar-group">
            <button class="vnc-btn @(_settingsOpen ? "vnc-btn--active" : "")" @onclick="ToggleSettings" @onclick:stopPropagation="true" title="Settings">
                <C2Icon Name="settings" Size="Size.Xs" />
            </button>
        </div>

        @if (_settingsOpen)
        {
            <div class="vnc-settings" @onclick:stopPropagation="true">
                <div class="vnc-settings-row">
                    <label class="vnc-settings-label">Display</label>
                    <select class="vnc-select vnc-select--wide" @onchange="OnDisplayChanged" disabled="@(_vnc.Displays.Length == 0)">
                        @if (_vnc.Displays.Length == 0)
                        {
                            <option>No displays</option>
                        }
                        else
                        {
                            @foreach (var d in _vnc.Displays)
                            {
                                <option value="@d.Index" selected="@(d.Index == _vnc.SelectedDisplay)">@d.Label</option>
                            }
                        }
                    </select>
                </div>
                <div class="vnc-settings-row">
                    <label class="vnc-settings-label">Quality</label>
                    <select class="vnc-select vnc-select--wide" @onchange="OnQualityChanged">
                        @foreach (var q in QualityPresets)
                        {
                            <option value="@q.Value" selected="@(_vnc.Quality == q.Value)">@q.Label</option>
                        }
                    </select>
                </div>
                <div class="vnc-settings-row">
                    <label class="vnc-settings-label">Scaling</label>
                    <select class="vnc-select vnc-select--wide" @onchange="OnScaleModeChanged">
                        @foreach (var m in ScaleModes)
                        {
                            <option value="@m.Value" selected="@(_scaleMode == m.Value)">@m.Label</option>
                        }
                    </select>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private VncService _vnc = null!;
    private ElementReference _canvasEl;
    private ElementReference _rootEl;
    private DotNetObjectReference<VncPanel>? _dotnetRef;
    private readonly string _sessionId = Guid.NewGuid().ToString("N")[..8];
    private bool _jsInitialized;
    private bool _settingsOpen;
    private string _scaleMode = "stretch";

    private static readonly (string Label, uint Value)[] QualityPresets =
    [
        ("Low", 25),
        ("Medium", 50),
        ("High", 75),
        ("Max", 95)
    ];

    private static readonly (string Label, string Value)[] ScaleModes =
    [
        ("Stretch", "stretch"),
        ("Fit", "fit"),
        ("Fill", "fill")
    ];

    private DisplayInfo? SelectedDisplay =>
        _vnc.Displays.Length > 0 && _vnc.SelectedDisplay < _vnc.Displays.Length
            ? _vnc.Displays[_vnc.SelectedDisplay]
            : null;

    protected override void OnInitialized()
    {
        _vnc = new VncService(Relay!, Msg);
        _vnc.StateChanged += OnVncStateChanged;
        _vnc.FrameReady += OnFrame;
        _vnc.StreamingChanged += OnStreamingChanged;

        On<AgentOnlineEvent>(e =>
        {
            if (e.AgentId == AgentId && _vnc.IsConnected)
                _ = InvokeAsync(async () => await _vnc.FetchDisplaysAsync());
        });
    }

    protected override async Task OnInitializedAsync()
    {
        if (_vnc.IsConnected)
            await _vnc.FetchDisplaysAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("c2Vnc.init", _sessionId, _rootEl, _canvasEl, _dotnetRef);
            _jsInitialized = true;
        }
    }

    // --- Frame rendering via JS interop (single call per frame) ---

    private async Task OnFrame(bool isFullFrame, ScreenSection[] sections)
    {
        if (!_jsInitialized) return;

        // Build a flat array of section descriptors for JS: [{x, y, data}, ...]
        var jsSections = new object[sections.Length];
        for (var i = 0; i < sections.Length; i++)
            jsSections[i] = new { x = sections[i].X, y = sections[i].Y, data = sections[i].JpegData };

        await Js.InvokeVoidAsync("c2Vnc.renderFrame", _sessionId, isFullFrame, jsSections);
    }

    private void OnStreamingChanged(bool streaming)
    {
        if (_jsInitialized)
            _ = Js.InvokeVoidAsync("c2Vnc.setStreaming", _sessionId, streaming);
    }

    // --- UI event handlers ---

    private async Task CaptureOnce() => await _vnc.CaptureOnceAsync();

    private async Task StartStreaming() => await _vnc.StartStreamingAsync();

    private void StopStreaming() => _vnc.StopStreaming();

    private async Task RefreshDisplays()
    {
        _vnc.ResetFrame();
        await _vnc.FetchDisplaysAsync();
    }

    private async Task ToggleFullscreen()
    {
        if (_jsInitialized)
            await Js.InvokeVoidAsync("c2Vnc.toggleFullscreen", _sessionId);
    }

    private async Task FocusCanvas()
    {
        if (_jsInitialized)
            await Js.InvokeVoidAsync("c2Vnc.focus", _sessionId);
    }

    private void ToggleSettings() => _settingsOpen = !_settingsOpen;

    private void OnDisplayChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _vnc.Displays.Length)
        {
            _vnc.SelectedDisplay = idx;
            _vnc.ResetFrame();
        }
    }

    private void OnQualityChanged(ChangeEventArgs e)
    {
        if (uint.TryParse(e.Value?.ToString(), out var q))
        {
            _vnc.Quality = q;
            _vnc.ResetFrame();
        }
    }

    private void OnScaleModeChanged(ChangeEventArgs e)
    {
        var mode = e.Value?.ToString();
        if (mode is "stretch" or "fit" or "fill")
        {
            _scaleMode = mode;
            if (_jsInitialized)
                _ = Js.InvokeVoidAsync("c2Vnc.setScaleMode", _sessionId, mode);
        }
    }

    private async void OnVncStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    // --- Mouse/keyboard events from JS ---

    [JSInvokable]
    public void OnMouseEvent(string action, int x, int y, int button)
    {
    }

    [JSInvokable]
    public void OnWheelEvent(int x, int y, int delta)
    {
    }

    [JSInvokable]
    public void OnKeyEvent(string action, string key, string code,
        bool ctrl, bool shift, bool alt, bool meta)
    {
    }

    // --- Cleanup ---

    public new void Dispose()
    {
        _vnc.StateChanged -= OnVncStateChanged;
        _vnc.FrameReady -= OnFrame;
        _vnc.StreamingChanged -= OnStreamingChanged;
        _vnc.Dispose();
        base.Dispose();
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (_jsInitialized)
            try { await Js.InvokeVoidAsync("c2Vnc.dispose", _sessionId); } catch { }
        _dotnetRef?.Dispose();
    }
}
