@using cc.Features.Relay
@inject MessageService Msg
@inject IJSRuntime Js
@implements IDisposable

<PanelLayout Title="Shell">
    <HeaderLeft>
        @if (IsConnected)
        {
            <CcBadge Variant="BadgeVariant.Success" Size="Size.Xs">Connected</CcBadge>
        }
        else
        {
            <CcBadge Variant="BadgeVariant.Muted" Size="Size.Xs">Disconnected</CcBadge>
        }
    </HeaderLeft>
    <HeaderRight>
        <CcBtn OnClick="ClearOutput" Title="Clear terminal" Size="Size.Xs" Variant="BtnVariant.Ghost">Clear</CcBtn>
        <CcBtn OnClick="PollOutput" Disabled="@(!IsConnected || _polling)" Loading="@_polling" Title="Read output" Size="Size.Xs">Read</CcBtn>
        <CcBtn OnClick="ToggleAutoRead" Title="@(_autoRead ? "Stop auto-read" : "Start auto-read")" Size="Size.Xs"
               Variant="@(_autoRead ? BtnVariant.Success : BtnVariant.Default)">
            @(_autoRead ? "Auto: ON" : "Auto: OFF")
        </CcBtn>
    </HeaderRight>
    <Body>
        <div class="sh">
            @if (!IsConnected)
            {
                <div class="sh-banner sh-banner--warn">
                    <span class="status-dot dot-off"></span>
                    Agent disconnected — shell unavailable.
                </div>
            }

            <div class="sh-terminal" @ref="_terminalEl">
                @if (_lines.Count == 0 && string.IsNullOrEmpty(_pendingOutput))
                {
                    <div class="sh-empty">No output yet. Type a command below.</div>
                }
                else
                {
                    @foreach (var line in _lines)
                    {
                        <div class="sh-line @(line.IsCommand ? "sh-line--cmd" : line.IsError ? "sh-line--err" : "")">@line.Text</div>
                    }
                    @if (!string.IsNullOrEmpty(_pendingOutput))
                    {
                        <div class="sh-line">@_pendingOutput</div>
                    }
                }
            </div>

            <div class="sh-input-bar">
                <span class="sh-prompt">$</span>
                <input class="sh-input" @bind="_inputValue" @bind:event="oninput"
                       @ref="_inputEl"
                       @onkeydown="OnKeyDown" placeholder="@(IsConnected ? "Type command..." : "Disconnected")"
                       disabled="@(!IsConnected)" autocomplete="off" spellcheck="false" />
                <CcBtn OnClick="SendCommand" Disabled="@(!IsConnected || string.IsNullOrWhiteSpace(_inputValue))"
                       Size="Size.Xs" Variant="BtnVariant.Primary" Title="Send command">
                    &#x23CE;
                </CcBtn>
            </div>
        </div>
    </Body>
</PanelLayout>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private record ShellLine(string Text, bool IsCommand = false, bool IsError = false);

    private readonly List<ShellLine> _lines = new();
    private string _pendingOutput = "";
    private string _inputValue = "";
    private bool _polling;
    private bool _autoRead;
    private Timer? _autoReadTimer;
    private ElementReference _terminalEl;
    private ElementReference _inputEl;
    private readonly List<string> _history = new();
    private int _historyIndex = -1;
    private const int MaxLines = 2000;

    private bool IsConnected => Relay is { IsConnected: true };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await FocusInput();
    }

    private async Task FocusInput()
    {
        try { await _inputEl.FocusAsync(); } catch { }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Js.InvokeVoidAsync("eval", $"document.querySelector('[_bl_{_terminalEl.Id}]')?.scrollTo(0, 999999)");
        }
        catch { }
    }

    private void AppendOutput(string text)
    {
        // Split into lines, handling partial lines
        var combined = _pendingOutput + text;
        var parts = combined.Split('\n');

        // All but last are complete lines
        for (var i = 0; i < parts.Length - 1; i++)
            _lines.Add(new ShellLine(parts[i]));

        // Last part may be partial (no trailing newline)
        _pendingOutput = parts[^1];

        TrimLines();
    }

    private void AppendCommand(string cmd)
    {
        FlushPending();
        _lines.Add(new ShellLine($"$ {cmd}", IsCommand: true));
        TrimLines();
    }

    private void AppendError(string msg)
    {
        FlushPending();
        _lines.Add(new ShellLine(msg, IsError: true));
        TrimLines();
    }

    private void FlushPending()
    {
        if (!string.IsNullOrEmpty(_pendingOutput))
        {
            _lines.Add(new ShellLine(_pendingOutput));
            _pendingOutput = "";
        }
    }

    private void TrimLines()
    {
        if (_lines.Count > MaxLines)
            _lines.RemoveRange(0, _lines.Count - MaxLines);
    }

    private async Task SendCommand()
    {
        if (!IsConnected || string.IsNullOrWhiteSpace(_inputValue)) return;

        var cmd = _inputValue;
        _inputValue = "";
        _history.Add(cmd);
        _historyIndex = _history.Count;

        AppendCommand(cmd);
        StateHasChanged();
        await ScrollToBottom();

        var payload = RelaySocket.BuildWriteShell(cmd + "\n");
        try
        {
            var response = await Relay!.SendAndReceive(payload);
            if (response is not null && response.Length >= 4)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status != 0)
                    AppendError($"[WriteShell error: status {status}]");
            }
        }
        catch (Exception ex)
        {
            AppendError($"[Send error: {ex.Message}]");
        }

        // Brief delay then read output
        await Task.Delay(150);
        await PollOutput();
        await FocusInput();
    }

    private async Task PollOutput()
    {
        if (!IsConnected || _polling) return;
        _polling = true;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildReadShell();
            var response = await Relay!.SendAndReceive(payload);
            if (response is not null && response.Length >= 4)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status == 0 && response.Length >= 12)
                {
                    var (_, text) = RelaySocket.ReadShellOutput(response);
                    if (!string.IsNullOrEmpty(text))
                    {
                        AppendOutput(text);
                        await ScrollToBottom();
                    }
                }
                else if (status != 0)
                {
                    AppendError($"[ReadShell error: status {status}]");
                }
            }
        }
        catch (Exception ex)
        {
            AppendError($"[Read error: {ex.Message}]");
        }
        finally
        {
            _polling = false;
            StateHasChanged();
        }
    }

    private void ToggleAutoRead()
    {
        _autoRead = !_autoRead;
        if (_autoRead)
        {
            _autoReadTimer = new Timer(async _ =>
            {
                if (!IsConnected || _polling) return;
                await InvokeAsync(async () =>
                {
                    await PollOutput();
                });
            }, null, 500, 500);
        }
        else
        {
            _autoReadTimer?.Dispose();
            _autoReadTimer = null;
        }
    }

    private void ClearOutput()
    {
        _lines.Clear();
        _pendingOutput = "";
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
                await SendCommand();
                break;
            case "ArrowUp" when _history.Count > 0:
                _historyIndex = Math.Max(0, _historyIndex - 1);
                _inputValue = _history[_historyIndex];
                break;
            case "ArrowDown" when _history.Count > 0:
                _historyIndex = Math.Min(_history.Count, _historyIndex + 1);
                _inputValue = _historyIndex < _history.Count ? _history[_historyIndex] : "";
                break;
            case "l" when e.CtrlKey:
                ClearOutput();
                break;
        }
    }

    public void Dispose()
    {
        _autoReadTimer?.Dispose();
    }
}
