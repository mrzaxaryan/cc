@using C2.Features.Relay
@inject MessageService Msg
@inject IJSRuntime Js
@implements IDisposable

<PanelLayout Title="Shell">
    <HeaderLeft>
        @if (IsConnected)
        {
            <C2Badge Variant="BadgeVariant.Success" Size="Size.Xs">Connected</C2Badge>
        }
        else
        {
            <C2Badge Variant="BadgeVariant.Muted" Size="Size.Xs">Disconnected</C2Badge>
        }
    </HeaderLeft>
    <HeaderRight>
        <C2Btn OnClick="SendBreak" Disabled="@(!IsConnected)" Title="Send Ctrl+C (break)" Size="Size.Xs" Variant="BtnVariant.Danger">Ctrl+C</C2Btn>
        <C2Btn OnClick="SaveLog" Disabled="@(_lines.Count == 0)" Title="Save shell log" Size="Size.Xs" Variant="BtnVariant.Ghost">Save Log</C2Btn>
        <C2Btn OnClick="ClearOutput" Title="Clear terminal" Size="Size.Xs" Variant="BtnVariant.Ghost">Clear</C2Btn>
        <C2Btn OnClick="PollOutput" Disabled="@(!IsConnected || _polling)" Loading="@_polling" Title="Read output" Size="Size.Xs">Read</C2Btn>
        <C2Btn OnClick="ToggleAutoRead" Title="@(_autoRead ? "Stop auto-read" : "Start auto-read")" Size="Size.Xs"
               Variant="@(_autoRead ? BtnVariant.Success : BtnVariant.Default)">
            @(_autoRead ? "Auto: ON" : "Auto: OFF")
        </C2Btn>
    </HeaderRight>
    <Body>
        <div class="sh" @onclick="FocusInput">
            @if (!IsConnected)
            {
                <div class="sh-banner sh-banner--warn">
                    <span class="status-dot dot-off"></span>
                    Agent disconnected — shell unavailable.
                </div>
            }

            <div class="sh-terminal" @ref="_terminalEl">
                @foreach (var line in _lines)
                {
                    <div class="sh-line @(line.IsCommand ? "sh-line--cmd" : line.IsError ? "sh-line--err" : "")">@line.Text</div>
                }

                @* Active input line — pending output + typed text + cursor on ONE line *@
                @if (IsConnected)
                {
                    <div class="sh-line sh-line--active">@_pendingOutput@_inputValue<span class="sh-cursor @(_focused ? "" : "sh-cursor--hidden")"></span></div>
                }
                else if (!string.IsNullOrEmpty(_pendingOutput))
                {
                    <div class="sh-line">@_pendingOutput</div>
                }
                else if (_lines.Count == 0)
                {
                    <div class="sh-empty">No output yet.</div>
                }

                @* Hidden input captures keystrokes *@
                <input class="sh-hidden-input" @ref="_inputEl"
                       @bind="_inputValue" @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       @onfocus="() => { _focused = true; }"
                       @onblur="() => { _focused = false; }"
                       disabled="@(!IsConnected)"
                       autocomplete="off" spellcheck="false" autocorrect="off" autocapitalize="off" />
            </div>
        </div>
    </Body>
</PanelLayout>

@code {
    [Parameter] public RelaySocket? Relay { get; set; }
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? AgentName { get; set; }
    [Parameter] public string? AgentUuid { get; set; }

    private record ShellLine(string Text, bool IsCommand = false, bool IsError = false);

    private readonly List<ShellLine> _lines = new();
    private string _pendingOutput = "";
    private string _inputValue = "";
    private bool _polling;
    private bool _autoRead;
    private bool _focused;
    private bool _needsScroll;
    private Timer? _autoReadTimer;
    private ElementReference _terminalEl;
    private ElementReference _inputEl;
    private readonly List<string> _history = new();
    private int _historyIndex = -1;
    private const int MaxLines = 2000;

    private bool IsConnected => Relay is { IsConnected: true };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Always re-focus the hidden input after every render so keystrokes
        // keep flowing — the input loses focus on each StateHasChanged cycle.
        if (IsConnected)
            await FocusInput();

        if (_needsScroll)
        {
            _needsScroll = false;
            await ScrollToBottom();
        }
    }

    private async Task FocusInput()
    {
        try { await _inputEl.FocusAsync(); } catch { }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Js.InvokeVoidAsync("eval", $"document.querySelector('[_bl_{_terminalEl.Id}]')?.scrollTo(0, 999999)");
        }
        catch { }
    }

    private void AppendOutput(string text)
    {
        var combined = _pendingOutput + text.Replace("\r\n", "\n").Replace("\r", "");
        var parts = combined.Split('\n');

        for (var i = 0; i < parts.Length - 1; i++)
            _lines.Add(new ShellLine(parts[i]));

        _pendingOutput = parts[^1];
        TrimLines();
    }

    private void AppendCommand(string cmd)
    {
        // Commit the pending output (remote prompt) + typed command as one line
        _lines.Add(new ShellLine(_pendingOutput + cmd, IsCommand: true));
        _pendingOutput = "";
        TrimLines();
    }

    private void AppendError(string msg)
    {
        FlushPending();
        _lines.Add(new ShellLine(msg, IsError: true));
        TrimLines();
    }

    private void FlushPending()
    {
        if (!string.IsNullOrEmpty(_pendingOutput))
        {
            _lines.Add(new ShellLine(_pendingOutput));
            _pendingOutput = "";
        }
    }

    private void TrimLines()
    {
        if (_lines.Count > MaxLines)
            _lines.RemoveRange(0, _lines.Count - MaxLines);
    }

    private async Task SendBreak()
    {
        if (!IsConnected) return;

        FlushPending();
        _lines.Add(new ShellLine("^C", IsCommand: true));
        _needsScroll = true;
        StateHasChanged();

        var payload = RelaySocket.BuildWriteShell("\x03");
        try
        {
            var response = await Relay!.SendAndReceive(payload);
            if (response is not null && response.Length >= 4)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status != 0)
                    AppendError($"[Break error: status {status}]");
            }
        }
        catch (Exception ex)
        {
            AppendError($"[Break error: {ex.Message}]");
        }

        await Task.Delay(150);
        await PollOutput();
    }

    private async Task SendCommand()
    {
        if (!IsConnected || string.IsNullOrWhiteSpace(_inputValue)) return;

        var cmd = _inputValue;
        _inputValue = "";
        _history.Add(cmd);
        _historyIndex = _history.Count;

        AppendCommand(cmd);
        _needsScroll = true;
        StateHasChanged();

        var payload = RelaySocket.BuildWriteShell(cmd + "\n");
        try
        {
            var response = await Relay!.SendAndReceive(payload);
            if (response is not null && response.Length >= 4)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status != 0)
                    AppendError($"[WriteShell error: status {status}]");
            }
        }
        catch (Exception ex)
        {
            AppendError($"[Send error: {ex.Message}]");
        }

        await Task.Delay(150);
        await PollOutput();
    }

    private async Task PollOutput()
    {
        if (!IsConnected || _polling) return;
        _polling = true;
        StateHasChanged();

        try
        {
            var payload = RelaySocket.BuildReadShell();
            var response = await Relay!.SendAndReceive(payload);
            if (response is not null && response.Length >= 4)
            {
                var status = RelaySocket.ReadStatus(response);
                if (status == 0 && response.Length >= 12)
                {
                    var (_, text) = RelaySocket.ReadShellOutput(response);
                    if (!string.IsNullOrEmpty(text))
                    {
                        AppendOutput(text);
                        _needsScroll = true;
                    }
                }
                else if (status != 0)
                {
                    AppendError($"[ReadShell error: status {status}]");
                }
            }
        }
        catch (Exception ex)
        {
            AppendError($"[Read error: {ex.Message}]");
        }
        finally
        {
            _polling = false;
            StateHasChanged();
        }
    }

    private void ToggleAutoRead()
    {
        _autoRead = !_autoRead;
        if (_autoRead)
        {
            _autoReadTimer = new Timer(async _ =>
            {
                if (!IsConnected || _polling) return;
                await InvokeAsync(async () =>
                {
                    await PollOutput();
                });
            }, null, 500, 500);
        }
        else
        {
            _autoReadTimer?.Dispose();
            _autoReadTimer = null;
        }
    }

    private async Task SaveLog()
    {
        if (_lines.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        foreach (var line in _lines)
            sb.AppendLine(line.Text);
        if (!string.IsNullOrEmpty(_pendingOutput))
            sb.Append(_pendingOutput);

        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
        var fileName = $"shell_{AgentName ?? AgentId ?? "log"}_{timestamp}.txt";

        await Js.InvokeVoidAsync("downloadFile", fileName, base64);
        Msg.Info($"Shell log saved as {fileName}");
    }

    private void ClearOutput()
    {
        _lines.Clear();
        _pendingOutput = "";
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
                await SendCommand();
                break;
            case "ArrowUp" when _history.Count > 0:
                _historyIndex = Math.Max(0, _historyIndex - 1);
                _inputValue = _history[_historyIndex];
                break;
            case "ArrowDown" when _history.Count > 0:
                _historyIndex = Math.Min(_history.Count, _historyIndex + 1);
                _inputValue = _historyIndex < _history.Count ? _history[_historyIndex] : "";
                break;
            case "c" when e.CtrlKey && string.IsNullOrEmpty(_inputValue):
                await SendBreak();
                break;
            case "l" when e.CtrlKey:
                ClearOutput();
                break;
        }
    }

    public void Dispose()
    {
        _autoReadTimer?.Dispose();
    }
}
