@page "/relay"
@inject HttpClient Http

<PageTitle>Relay</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h1 class="mb-0">Relay</h1>
    <button class="btn btn-outline-primary btn-sm" @onclick="LoadStatus" disabled="@loading">
        @(loading ? "Refreshing..." : "Refresh")
    </button>
</div>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (status is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Agents</h5>
                    <p class="card-text display-6">@status.Agents.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Relays</h5>
                    <p class="card-text display-6">@status.Relays.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Event Listeners</h5>
                    <p class="card-text display-6">@status.EventListeners.Count</p>
                </div>
            </div>
        </div>
    </div>

    <h3>Agents</h3>
    @if (status.Agents.Connections.Length == 0)
    {
        <p><em>No agents connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Network</th>
                        <th>TLS</th>
                        <th>Connected At</th>
                        <th>Last Active</th>
                        <th>Messages</th>
                        <th>Relayed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in status.Agents.Connections)
                    {
                        <tr>
                            <td><code>@agent.Id</code></td>
                            <td><code>@agent.Ip</code></td>
                            <td title="@FormatCoords(agent)">@FormatLocation(agent)</td>
                            <td>@FormatNetwork(agent)</td>
                            <td><code>@agent.TlsVersion</code></td>
                            <td>@FormatTimestamp(agent.ConnectedAt)</td>
                            <td>@FormatTimestamp(agent.LastActiveAt)</td>
                            <td>@agent.MessageCount</td>
                            <td>
                                @if (agent.Relayed)
                                {
                                    <span class="badge bg-success" title="@agent.RelayId">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h3>Relays</h3>
    @if (status.Relays.Connections.Length == 0)
    {
        <p><em>No active relays.</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client ID</th>
                    <th>Connected At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var relay in status.Relays.Connections)
                {
                    <tr>
                        <td><code>@relay.Id</code></td>
                        <td><code>@relay.ClientId</code></td>
                        <td>@FormatTimestamp(relay.ConnectedAt)</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h3>Event Listeners</h3>
    @if (status.EventListeners.Connections.Length == 0)
    {
        <p><em>No event listeners connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>User Agent</th>
                        <th>Connected At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var listener in status.EventListeners.Connections)
                    {
                        <tr>
                            <td><code>@listener.Id</code></td>
                            <td><code>@listener.Ip</code></td>
                            <td>@FormatListenerLocation(listener)</td>
                            <td class="text-truncate" style="max-width:300px" title="@listener.UserAgent">@listener.UserAgent</td>
                            <td>@FormatTimestamp(listener.ConnectedAt)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private HealthStatus? status;
    private string? error;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatus();
    }

    private async Task LoadStatus()
    {
        loading = true;
        try
        {
            status = await Http.GetFromJsonAsync<HealthStatus>("https://relay.nostdlib.workers.dev/health");
            error = null;
        }
        catch (Exception ex)
        {
            error = $"Failed to load: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private static string FormatTimestamp(double ms)
    {
        if (ms <= 0) return "-";
        return DateTimeOffset.FromUnixTimeMilliseconds((long)ms).LocalDateTime.ToString("g");
    }

    private static string FormatLocation(AgentConnection c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(c.City)) parts.Add(c.City);
        if (!string.IsNullOrEmpty(c.Region) && c.Region != c.City) parts.Add(c.Region);
        if (!string.IsNullOrEmpty(c.Country)) parts.Add(c.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "-";
    }

    private static string FormatListenerLocation(EventListenerConnection c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(c.City)) parts.Add(c.City);
        if (!string.IsNullOrEmpty(c.Country)) parts.Add(c.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "-";
    }

    private static string FormatNetwork(AgentConnection c)
    {
        if (c.Asn > 0 && !string.IsNullOrEmpty(c.AsOrganization))
            return $"AS{c.Asn} ({c.AsOrganization})";
        if (c.Asn > 0)
            return $"AS{c.Asn}";
        return "-";
    }

    private static string FormatCoords(AgentConnection c)
    {
        if (!string.IsNullOrEmpty(c.Latitude) && !string.IsNullOrEmpty(c.Longitude))
            return $"{c.Latitude}, {c.Longitude}";
        return "";
    }

}
