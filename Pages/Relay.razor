@page "/relay"
@inject HttpClient Http
@inject RelayStore Store

<PageTitle>Relay</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h1 class="mb-0">Relay</h1>
    <button class="btn btn-outline-primary btn-sm" @onclick="LoadStatus" disabled="@loading">
        @(loading ? "Refreshing..." : "Refresh")
    </button>
</div>

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">Relay Servers</h5>
        <button class="btn btn-sm btn-outline-success" @onclick="() => showAdd = !showAdd">
            @(showAdd ? "Cancel" : "+ Add")
        </button>
    </div>
    <div class="card-body p-0">
        @if (showAdd)
        {
            <div class="p-3 border-bottom bg-light">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Name</label>
                        <input class="form-control form-control-sm" @bind="newName" placeholder="My Relay" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small mb-1">URL</label>
                        <input class="form-control form-control-sm" @bind="newUrl" placeholder="wss://relay.example.com" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-success btn-sm w-100" @onclick="AddRelay"
                                disabled="@(string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newUrl))">
                            Add
                        </button>
                    </div>
                </div>
            </div>
        }
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="width:30px"></th>
                    <th>Name</th>
                    <th>URL</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var relay in Store.Relays)
                {
                    var isActive = relay.Url == Store.ActiveUrl;
                    <tr class="@(isActive ? "table-active" : "")">
                        <td class="text-center">
                            @if (isActive)
                            {
                                <span class="text-success" title="Active">&#9679;</span>
                            }
                        </td>
                        <td>@relay.Name</td>
                        <td><code class="small">@relay.Url</code></td>
                        <td class="text-end">
                            @if (!isActive)
                            {
                                <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => SelectRelay(relay.Url)" title="Set as active">
                                    Use
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveRelay(relay.Url)" title="Remove">
                                    &times;
                                </button>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (status is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Agents</h5>
                    <p class="card-text display-6">@status.Agents.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Relays</h5>
                    <p class="card-text display-6">@status.Relays.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Event Listeners</h5>
                    <p class="card-text display-6">@status.EventListeners.Count</p>
                </div>
            </div>
        </div>
    </div>

    <h3>Agents</h3>
    @if (status.Agents.Connections.Length == 0)
    {
        <p><em>No agents connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Network</th>
                        <th>TLS</th>
                        <th>Connected At</th>
                        <th>Last Active</th>
                        <th>Messages</th>
                        <th>Relayed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in status.Agents.Connections)
                    {
                        <tr>
                            <td><code>@agent.Id</code></td>
                            <td><code>@agent.Ip</code></td>
                            <td title="@Formatters.FormatCoords(agent)">@Formatters.FormatLocation(agent)</td>
                            <td>@Formatters.FormatNetwork(agent)</td>
                            <td><code>@agent.TlsVersion</code></td>
                            <td>@Formatters.FormatTimestamp(agent.ConnectedAt)</td>
                            <td>@Formatters.FormatTimestamp(agent.LastActiveAt)</td>
                            <td>@agent.MessageCount</td>
                            <td>
                                @if (agent.Relayed)
                                {
                                    <span class="badge bg-success" title="@agent.RelayId">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h3>Relays</h3>
    @if (status.Relays.Connections.Length == 0)
    {
        <p><em>No active relays.</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client ID</th>
                    <th>Connected At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var relay in status.Relays.Connections)
                {
                    <tr>
                        <td><code>@relay.Id</code></td>
                        <td><code>@relay.ClientId</code></td>
                        <td>@Formatters.FormatTimestamp(relay.ConnectedAt)</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h3>Event Listeners</h3>
    @if (status.EventListeners.Connections.Length == 0)
    {
        <p><em>No event listeners connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>User Agent</th>
                        <th>Connected At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var listener in status.EventListeners.Connections)
                    {
                        <tr>
                            <td><code>@listener.Id</code></td>
                            <td><code>@listener.Ip</code></td>
                            <td>@Formatters.FormatListenerLocation(listener)</td>
                            <td class="text-truncate" style="max-width:300px" title="@listener.UserAgent">@listener.UserAgent</td>
                            <td>@Formatters.FormatTimestamp(listener.ConnectedAt)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private HealthStatus? status;
    private string? error;
    private bool loading;

    private bool showAdd;
    private string newName = "";
    private string newUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        await LoadStatus();
    }

    private async Task LoadStatus()
    {
        loading = true;
        try
        {
            status = await Http.GetFromJsonAsync<HealthStatus>($"{Store.HttpBaseUrl}/health");
            error = null;
        }
        catch (Exception ex)
        {
            error = $"Failed to load: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task AddRelay()
    {
        if (string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newUrl)) return;
        await Store.AddRelay(newName.Trim(), newUrl.Trim());
        newName = "";
        newUrl = "";
        showAdd = false;
    }

    private async Task RemoveRelay(string url)
    {
        await Store.RemoveRelay(url);
    }

    private async Task SelectRelay(string url)
    {
        await Store.SetActive(url);
        await LoadStatus();
    }
}
