@page "/agents"
@inject HttpClient Http
@using System.Timers
@implements IDisposable

<PageTitle>Agents</PageTitle>

<h1>Agents</h1>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (agents is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Connected</h5>
            <p class="card-text display-6">@agents.Count</p>
        </div>
    </div>

    @if (agents.Connections.Length == 0)
    {
        <p><em>No agents connected.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>IP</th>
                        <th>Location</th>
                        <th>Connected At</th>
                        <th>Messages</th>
                        <th>Relayed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in agents.Connections)
                    {
                        <tr>
                            <td><code>@agent.Id</code></td>
                            <td><code>@agent.Ip</code></td>
                            <td>@FormatLocation(agent)</td>
                            <td>@FormatTimestamp(agent.ConnectedAt)</td>
                            <td>@agent.MessageCount</td>
                            <td>
                                @if (agent.Relayed)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private GroupInfo<AgentConnection>? agents;
    private string? error;
    private Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatus();

        timer = new Timer(5000);
        timer.Elapsed += async (_, _) =>
        {
            await LoadStatus();
            await InvokeAsync(StateHasChanged);
        };
        timer.Start();
    }

    private async Task LoadStatus()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<RelayStatus>("https://relay.nostdlib.workers.dev/");
            agents = status?.Agents;
            error = null;
        }
        catch (Exception ex)
        {
            error = $"Failed to load: {ex.Message}";
        }
    }

    private static string FormatTimestamp(double ms)
    {
        return DateTimeOffset.FromUnixTimeMilliseconds((long)ms).LocalDateTime.ToString("g");
    }

    private static string FormatLocation(AgentConnection c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(c.City)) parts.Add(c.City);
        if (!string.IsNullOrEmpty(c.Country)) parts.Add(c.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "-";
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
    }
}
